---
interface ListItem {
  text: string;
}

interface ImageDef {
  src: string;
  alt: string;
}

interface Props {
  id?: string;
  eyebrow: string;
  title: string;
  text: string;
  images: [ImageDef, ImageDef];
  list?: ListItem[];
  cta?: { label: string; href?: string; booking?: boolean; };
  reverse?: boolean;
  surface?: boolean;
}

const {
  id,
  eyebrow,
  title,
  text,
  images,
  list,
  cta,
  reverse = false,
  surface = false,
} = Astro.props;

const sectionId = id || eyebrow.toLowerCase().replace(/\s+/g, '-');
const titleId = `${sectionId}-title`;
---

<section
  class:list={['section', { 'section--surface': surface }]}
  aria-labelledby={titleId}
>
  <div class="container s2">
    <div class:list={['s2__layout', { 's2__layout--reverse': reverse }]}>
      <div class="s2__copy reveal">
        <span class="section__eyebrow">{eyebrow}</span>
        <h2 id={titleId} set:html={title} />
        <p class="s2__desc">{text}</p>

        {list && list.length > 0 && (
          <ul class="s2__list" role="list">
            {list.map((item) => <li>{item.text}</li>)}
          </ul>
        )}

        {cta && (
          cta.booking
            ? <button type="button" class="btn btn--primary" data-booking>{cta.label}</button>
            : <a href={cta.href} class="btn btn--primary">{cta.label}</a>
        )}
      </div>

      <div class="s2__photos reveal reveal-d1">
        <div class="s2__photo s2__photo--main">
          <img
            src={images[0].src}
            alt={images[0].alt}
            width="480"
            height="320"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="s2__photo s2__photo--small">
          <img
            src={images[1].src}
            alt={images[1].alt}
            width="200"
            height="260"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .s2__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-10);
  }

  .s2__copy {
    max-width: 440px;
  }

  .s2__desc {
    font-size: 0.9rem;
    color: var(--c-text-secondary);
    line-height: 1.75;
    max-width: 36ch;
    margin-top: var(--s-5);
  }

  .s2__list {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    margin-top: var(--s-8);
    margin-bottom: var(--s-8);
  }

  .s2__list li {
    font-size: 0.82rem;
    color: var(--c-text-secondary);
    line-height: 1.5;
    padding-left: var(--s-5);
    position: relative;
  }

  .s2__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 2px;
    background: var(--c-orange);
    border-radius: 1px;
  }

  /* ── Photos cluster ── */

  .s2__photos {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--s-3);
    align-items: end;
    max-width: 520px;
  }

  .s2__photo {
    overflow: hidden;
    border-radius: var(--r-lg);
  }

  .s2__photo img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }

  .s2__photo:hover img { transform: scale(1.03); }

  .s2__photo--main {
    aspect-ratio: 3 / 2;
  }

  .s2__photo--small {
    width: clamp(100px, 22vw, 160px);
    aspect-ratio: 3 / 4;
    align-self: end;
    margin-bottom: var(--s-4);
    border: 3px solid var(--c-bg);
    box-shadow: 0 4px 20px rgb(0 0 0 / 0.1);
  }

  [data-theme='dark'] .s2__photo--small {
    border-color: var(--c-surface);
    box-shadow: 0 4px 20px rgb(0 0 0 / 0.4);
  }

  /* ── Desktop ── */

  @media (min-width: 900px) {
    .s2__layout {
      grid-template-columns: 1fr 1.1fr;
      gap: var(--s-16);
      align-items: center;
    }

    .s2__layout--reverse {
      grid-template-columns: 1.1fr 1fr;
    }

    .s2__layout--reverse .s2__photos {
      order: -1;
    }

    .s2__photos {
      max-width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .s2__photo img { transition: none; }
  }
</style>
