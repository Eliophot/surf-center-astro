<section class="cform section" aria-labelledby="cform-title">
  <div class="container">
    <header class="section__header reveal">
      <span class="section__eyebrow">Contact</span>
      <h2 id="cform-title">Demande de réservation</h2>
      <p class="section__lead">Décrivez votre projet, nous vous répondons sous 24h avec une proposition personnalisée.</p>
    </header>

    <form class="cform__form reveal" action="#" method="POST" data-event-form>
      <div class="cform__grid">
        <div class="cform__field">
          <label for="cf-name" class="cform__label">Nom complet *</label>
          <input type="text" id="cf-name" name="name" required aria-required="true" autocomplete="name" class="cform__input" />
        </div>

        <div class="cform__field">
          <label for="cf-email" class="cform__label">Email *</label>
          <input type="email" id="cf-email" name="email" required aria-required="true" autocomplete="email" class="cform__input" />
        </div>

        <div class="cform__field">
          <label for="cf-phone" class="cform__label">Téléphone</label>
          <input type="tel" id="cf-phone" name="phone" autocomplete="tel" class="cform__input" />
        </div>

        <div class="cform__field">
          <label for="cf-type" class="cform__label">Type d'événement *</label>
          <select id="cf-type" name="type" required aria-required="true" class="cform__input">
            <option value="">Sélectionner...</option>
            <option value="team-building">Team Building</option>
            <option value="seminaire">Séminaire & Incentive</option>
            <option value="soiree-entreprise">Soirée d'entreprise</option>
            <option value="evjf-evg">EVJF / EVG</option>
            <option value="anniversaire">Anniversaire & Fête</option>
            <option value="concert-prive">Concert & Soirée privée</option>
            <option value="autre">Autre</option>
          </select>
        </div>

        <div class="cform__field">
          <label for="cf-date" class="cform__label">Date souhaitée</label>
          <input type="date" id="cf-date" name="date" class="cform__input" />
        </div>

        <div class="cform__field">
          <label for="cf-guests" class="cform__label">Nombre de personnes</label>
          <input type="number" id="cf-guests" name="guests" min="1" max="500" placeholder="ex: 30" class="cform__input" />
        </div>

        <div class="cform__field cform__field--full">
          <label for="cf-message" class="cform__label">Votre projet *</label>
          <textarea id="cf-message" name="message" rows="5" required aria-required="true" class="cform__input cform__textarea" placeholder="Décrivez votre événement, vos besoins, vos envies..."></textarea>
        </div>
      </div>

      <div class="cform__actions">
        <button type="submit" class="btn btn--primary btn--lg">Envoyer la demande</button>
        <p class="cform__note" id="cform-note">Nous vous répondons sous 24h. Aucun engagement.</p>
      </div>
    </form>
  </div>
</section>

<style>
  .cform__form {
    max-width: 720px;
    margin-inline: auto;
  }

  .cform__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-5);
    margin-bottom: var(--s-8);
  }

  .cform__field--full { grid-column: 1 / -1; }

  .cform__label {
    display: block;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    margin-bottom: var(--s-2);
  }

  .cform__input {
    width: 100%;
    padding: var(--s-4) var(--s-5);
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--r-sm);
    font-family: inherit;
    font-size: 0.88rem;
    color: var(--c-text);
    transition: border-color var(--t-fast);
    -webkit-appearance: none;
  }

  .cform__input:focus {
    outline: none;
    border-color: var(--c-orange);
    box-shadow: 0 0 0 3px rgb(247 123 70 / 0.1);
  }

  .cform__input::placeholder {
    color: var(--c-text-muted);
  }

  .cform__textarea {
    resize: vertical;
    min-height: 120px;
  }

  select.cform__input {
    cursor: pointer;
  }

  .cform__actions {
    text-align: center;
  }

  .cform__note {
    font-size: 0.72rem;
    color: var(--c-text-muted);
    margin-top: var(--s-4);
  }

  @media (min-width: 600px) {
    .cform__grid { grid-template-columns: 1fr 1fr; }
  }
</style>
