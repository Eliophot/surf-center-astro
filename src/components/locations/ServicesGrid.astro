            </div>
          </div>
          <span class="svcgrid__label">{svc.label}</span>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .svcgrid {
    background: linear-gradient(180deg, rgba(237, 103, 118, 0.10) 0%, rgba(255, 255, 255, 0.10) 100%);
  }

  /* ── Theme tokens ────────────────────────────────── */
  .svcgrid__grid {
    --svc-card-bg: var(--c-bg);
    --svc-card-border: rgb(250 128 61 / 0.18);
    --svc-card-border-hover: rgb(237 102 122 / 0.45);
    --svc-card-glow: 0 0 0 rgb(0 0 0 / 0);
    --svc-card-glow-hover:
      0 12px 30px rgb(250 128 61 / 0.10),
      0 0 0 1px rgb(237 102 122 / 0.06);
    --svc-shimmer-c1: rgb(250 128 61 / 0.22);
    --svc-shimmer-c2: rgb(237 102 122 / 0.18);
    --svc-shimmer-blend: multiply;

    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-6);
    max-width: 1200px;
    margin-inline: auto;
  }

  [data-theme='dark'] .svcgrid__grid {
    --svc-card-bg: var(--c-surface);
    --svc-card-border: rgb(250 128 61 / 0.18);
    --svc-card-border-hover: rgb(237 102 122 / 0.50);
    --svc-card-glow: inset 0 0 0 1px rgb(255 255 255 / 0.02);
    --svc-card-glow-hover:
      0 0 24px rgb(250 128 61 / 0.16),
      0 0 60px rgb(237 102 122 / 0.10),
      inset 0 0 24px rgb(250 128 61 / 0.05);
    --svc-shimmer-c1: rgb(250 128 61 / 0.30);
    --svc-shimmer-c2: rgb(237 102 122 / 0.24);
    --svc-shimmer-blend: screen;
  }

  /* ── Card ────────────────────────────────────────── */
  .svcgrid__item {
    --holo-x: 50%;
    --holo-y: 50%;
    --holo-angle: 180deg;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--s-5);
    padding: var(--s-8) var(--s-6);
    background: var(--svc-card-bg);
    border-radius: var(--r-xl);
    border: 1px solid var(--svc-card-border);
    overflow: hidden;
    box-shadow: var(--svc-card-glow);
    transition:
      border-color 0.4s var(--ease),
      box-shadow 0.4s var(--ease),
      transform 0.4s var(--ease);
  }

  .svcgrid__item:hover {
    border-color: var(--svc-card-border-hover);
    box-shadow: var(--svc-card-glow-hover);
    transform: translateY(-2px);
  }

  /* ── Shimmer overlay ─────────────────────────────── */
  .svcgrid__shimmer {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s var(--ease);
    background:
      radial-gradient(
        circle at var(--holo-x) var(--holo-y),
        var(--svc-shimmer-c1) 0%,
        transparent 55%
      ),
      conic-gradient(
        from var(--holo-angle) at var(--holo-x) var(--holo-y),
        var(--svc-shimmer-c1),
        var(--svc-shimmer-c2),
        var(--svc-shimmer-c1)
      );
    mix-blend-mode: var(--svc-shimmer-blend);
  }

  .svcgrid__item:hover .svcgrid__shimmer { opacity: 1; }

  /* ── Icon ────────────────────────────────────────── */
  .svcgrid__icon-wrap {
    position: relative;
    z-index: 2;
  }

  .svcgrid__icon-wrap::before {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: var(--r-full);
    background: linear-gradient(135deg, rgb(247 123 70 / 0.15), rgb(247 123 70 / 0.05));
    z-index: 0;
  }

  .svcgrid__icon {
    position: relative;
    z-index: 1;
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--r-full);
    background: linear-gradient(180deg, #ED6776 0%, #F47456 71.742%, #F77B46 100%);
    color: #fff;
    box-shadow: 
      0 4px 16px rgb(237 103 118 / 0.40),
      inset 0 1px 0 rgb(255 255 255 / 0.2);
  }

  .svcgrid__icon svg {
    filter: drop-shadow(0 1px 2px rgb(0 0 0 / 0.15));
  }

  .svcgrid__label {
    position: relative;
    z-index: 2;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--c-text);
    line-height: 1.3;
  }

  @media (min-width: 600px) {
    .svcgrid__grid { 
      grid-template-columns: repeat(3, 1fr); 
      gap: var(--s-8);
    }

    .svcgrid__item {
      padding: var(--s-10) var(--s-6);
    }

    .svcgrid__icon {
      width: 80px;
      height: 80px;
    }

    .svcgrid__icon svg {
      width: 40px;
      height: 40px;
    }

    .svcgrid__label {
      font-size: 1.05rem;
    }
  }

  @media (min-width: 900px) {
    .svcgrid__icon {
      width: 88px;
      height: 88px;
    }

    .svcgrid__icon svg {
      width: 44px;
      height: 44px;
    }

    .svcgrid__icon-wrap::before {
      inset: -8px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .svcgrid__item,
    .svcgrid__shimmer { transition: none; }
    .svcgrid__item:hover { transform: none; }
  }
</style>

<script>
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reducedMotion) {
    document.querySelectorAll<HTMLElement>('[data-svc-card]').forEach((card) => {
      let pending = 0;
      const onMove = (e: MouseEvent) => {
        if (pending) return;
        pending = requestAnimationFrame(() => {
          pending = 0;
          const rect = card.getBoundingClientRect();
          const x = ((e.clientX - rect.left) / rect.width) * 100;
          const y = ((e.clientY - rect.top) / rect.height) * 100;
          card.style.setProperty('--holo-x', `${x}%`);
          card.style.setProperty('--holo-y', `${y}%`);
          card.style.setProperty('--holo-angle', `${Math.round(x * 3.6)}deg`);
        });
      };
      const onLeave = () => {
        if (pending) { cancelAnimationFrame(pending); pending = 0; }
        card.style.setProperty('--holo-x', '50%');
        card.style.setProperty('--holo-y', '50%');
      };
      card.addEventListener('mousemove', onMove, { passive: true });
      card.addEventListener('mouseleave', onLeave);
    });
  }
</script>
