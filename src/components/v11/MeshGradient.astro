---
interface Props {
  class?: string;
}

const extraClass = Astro.props.class || '';
---

<div class={`mg11 ${extraClass}`.trim()} aria-hidden="true">
  <div class="mg11__layer mg11__layer--1"></div>
  <div class="mg11__layer mg11__layer--2"></div>
  <div class="mg11__layer mg11__layer--3"></div>
  <div class="mg11__layer mg11__layer--4"></div>
</div>

<style>
  .mg11 {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }

  .mg11__layer {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.5;
    will-change: transform;
  }

  .mg11__layer--1 {
    width: 60%;
    height: 60%;
    top: -10%;
    left: -10%;
    background: radial-gradient(circle, rgba(38, 207, 255, 0.4) 0%, transparent 70%);
    animation: mg11-float1 12s ease-in-out infinite;
  }

  .mg11__layer--2 {
    width: 50%;
    height: 50%;
    bottom: -15%;
    right: -10%;
    background: radial-gradient(circle, rgba(107, 33, 168, 0.35) 0%, transparent 70%);
    animation: mg11-float2 15s ease-in-out infinite;
  }

  .mg11__layer--3 {
    width: 40%;
    height: 40%;
    top: 30%;
    right: 20%;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.3) 0%, transparent 70%);
    animation: mg11-float3 18s ease-in-out infinite;
  }

  .mg11__layer--4 {
    width: 30%;
    height: 30%;
    bottom: 10%;
    left: 25%;
    background: radial-gradient(circle, rgba(247, 123, 70, 0.15) 0%, transparent 70%);
    animation: mg11-float4 20s ease-in-out infinite;
  }

  @keyframes mg11-float1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(10%, 15%) scale(1.1); }
    66% { transform: translate(-5%, 5%) scale(0.95); }
  }

  @keyframes mg11-float2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-12%, -8%) scale(1.05); }
    66% { transform: translate(8%, -12%) scale(1.1); }
  }

  @keyframes mg11-float3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(15%, -10%) scale(0.9); }
    66% { transform: translate(-10%, 8%) scale(1.15); }
  }

  @keyframes mg11-float4 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-8%, -15%) scale(1.2); }
  }

  @media (prefers-reduced-motion: reduce) {
    .mg11__layer {
      animation: none;
    }
  }
</style>
