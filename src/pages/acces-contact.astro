---
import Layout from '../layouts/Layout.astro';
import LocationHero from '../components/locations/LocationHero.astro';
import Maillage from '../components/Maillage.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AccessContactForm from '../components/contact/AccessContactForm.svelte';

import imgLac from '../assets/images/location-lac-sainte-croix-gorges-verdon.png';

const title = 'Accès & Contact — Surf Center | Les Salles-sur-Verdon, Gorges du Verdon';
const description = 'Comment venir au Surf Center : adresse, itinéraire, contact, horaires. Base nautique aux Salles-sur-Verdon, lac de Sainte-Croix, Gorges du Verdon. Formulaire de contact.';

const siteUrl = 'https://surfcenter-verdon.fr';

const routes = [
  { city: 'Aix-en-Provence', time: '1h15', distance: '95 km', via: 'A51 puis D952' },
  { city: 'Marseille', time: '1h30', distance: '115 km', via: 'A51 puis D952' },
  { city: 'Nice', time: '2h00', distance: '160 km', via: 'A8 puis D6085' },
  { city: 'Toulon', time: '1h30', distance: '120 km', via: 'A8/A57 puis D560' },
  { city: 'Avignon', time: '1h45', distance: '145 km', via: 'A7 puis D952' },
  { city: 'Gap', time: '1h30', distance: '110 km', via: 'N85 puis D952' },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Accès & Contact — Surf Center',
    description,
    url: `${siteUrl}/acces-contact`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Accès & Contact', item: `${siteUrl}/acces-contact` },
    ],
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <LocationHero
    title="Accès & Contact"
    subtitle="Les Salles-sur-Verdon · Provence"
    image={imgLac}
    alt="Vue aérienne du lac de Sainte-Croix — Les Salles-sur-Verdon"
  />
  <Breadcrumbs items={[
    { label: 'Accueil', href: '/' },
    { label: 'Accès & Contact' },
  ]} />

  <!-- Adresse + Formulaire contact -->
  <section class="section" aria-labelledby="contact-title">
    <div class="container ctpage__layout">

      <!-- Colonne gauche : infos -->
      <div class="ctpage__info reveal">
        <span class="section__eyebrow">Nous trouver</span>
        <h2 id="contact-title">Surf Center</h2>

        <address class="ctpage__address">
          <div class="ctpage__addr-line">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <div>
              <strong>Plage des Salles-sur-Verdon</strong>
              <span>83630 Les Salles-sur-Verdon</span>
              <span>Gorges du Verdon, Provence</span>
            </div>
          </div>
          <div class="ctpage__addr-line">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            <div>
              <a class="ctpage__link" href="tel:+33492771450"><strong>04 92 77 14 50</strong></a>
              <span>Tous les jours en saison</span>
            </div>
          </div>
          <div class="ctpage__addr-line">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <div>
              <a class="ctpage__link" href="mailto:contact@surfcenter-verdon.fr"><strong>contact@surfcenter-verdon.fr</strong></a>
              <span>Réponse sous 24h</span>
            </div>
          </div>
        </address>

        <div class="ctpage__hours">
          <h3 class="ctpage__hours-title">Horaires</h3>
          <div class="ctpage__hours-row">
            <span>Avril — Juin</span>
            <span>10h — 18h</span>
          </div>
          <div class="ctpage__hours-row ctpage__hours-row--active">
            <span>Juillet — Août</span>
            <span>9h — 19h</span>
          </div>
          <div class="ctpage__hours-row">
            <span>Septembre — Octobre</span>
            <span>10h — 18h</span>
          </div>
        </div>
      </div>

      <!-- Colonne droite : formulaire -->
      <div class="ctpage__form-wrap reveal reveal-d1">
        <div class="ctpage__form-card">
          <h3 class="ctpage__form-title">Écrivez-nous</h3>
          <p class="ctpage__form-sub">Un renseignement, une demande spéciale ? On vous répond sous 24h.</p>
          <AccessContactForm client:load />
        </div>
      </div>
    </div>
  </section>

  <!-- Comment venir -->
  <section class="section section--surface" aria-labelledby="routes-title">
    <div class="container">
      <header class="section__header reveal">
        <span class="section__eyebrow">Itinéraire</span>
        <h2 id="routes-title">Comment venir ?</h2>
        <p class="section__lead">Le Surf Center est situé directement sur la plage du lac de Sainte-Croix, aux Salles-sur-Verdon. Parking gratuit.</p>
      </header>

      <div class="ctroutes__grid">
        {routes.map((r, i) => (
          <div class={`ctroutes__card reveal reveal-d${Math.min(i + 1, 4)}`}>
            <span class="ctroutes__city">{r.city}</span>
            <span class="ctroutes__time">{r.time}</span>
            <div class="ctroutes__details">
              <span>{r.distance}</span>
              <span>{r.via}</span>
            </div>
          </div>
        ))}
      </div>

      <div class="ctroutes__tip reveal">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        <p>GPS : entrez <strong>"Plage des Salles-sur-Verdon"</strong> — le parking est à 50m de la base.</p>
      </div>

      <div class="ctmap reveal" aria-label="Carte Surf Center">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2880.5!2d6.21!3d43.7766!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDPCsDQ2JzM2LjAiTiA2wrAxMic0NS42IkU!5e0!3m2!1sfr!2sfr!4v1"
          width="100%"
          height="420"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Carte — Surf Center, Les Salles-sur-Verdon"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Météo -->
  <section class="section" aria-labelledby="meteo-title">
    <div class="container ctmeteo__inner">
      <div class="ctmeteo__content reveal">
        <span class="section__eyebrow">Météo</span>
        <h2 id="meteo-title">Le climat du Verdon</h2>
        <p class="ctmeteo__text">Le lac de Sainte-Croix bénéficie d'un climat méditerranéen avec plus de 300 jours de soleil par an. L'eau atteint 22-24°C en été — idéale pour la baignade et les activités nautiques.</p>
      </div>
      <div class="ctmeteo__cards reveal reveal-d1">
        <div class="ctmeteo__card">
          <span class="ctmeteo__card-icon" aria-hidden="true">☀️</span>
          <span class="ctmeteo__card-value">300+</span>
          <span class="ctmeteo__card-label">jours de soleil / an</span>
        </div>
        <div class="ctmeteo__card">
          <span class="ctmeteo__card-icon" aria-hidden="true">🌊</span>
          <span class="ctmeteo__card-value">22—24°C</span>
          <span class="ctmeteo__card-label">eau en été</span>
        </div>
        <div class="ctmeteo__card">
          <span class="ctmeteo__card-icon" aria-hidden="true">🌡️</span>
          <span class="ctmeteo__card-value">28—35°C</span>
          <span class="ctmeteo__card-label">air en été</span>
        </div>
      </div>
    </div>
  </section>

  <Maillage />
</Layout>

<style>
  /* ── Contact layout ── */
  .ctpage__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-12);
    align-items: start;
  }

  .ctpage__address {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
    margin-top: var(--s-8);
    margin-bottom: var(--s-10);
  }

  .ctpage__addr-line {
    display: flex;
    gap: var(--s-4);
    align-items: flex-start;
  }

  .ctpage__addr-line svg {
    flex-shrink: 0;
    color: var(--c-orange);
    margin-top: 2px;
  }

  .ctpage__addr-line div {
    display: flex;
    flex-direction: column;
  }

  .ctpage__addr-line strong {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--c-text);
  }

  .ctpage__addr-line span {
    font-size: 0.76rem;
    color: var(--c-text-muted);
  }

  .ctpage__hours {
    padding: var(--s-6);
    background: var(--c-surface);
    border-radius: var(--r-md);
    border: 1px solid var(--c-border-light);
  }

  .ctpage__hours-title {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    margin-bottom: var(--s-4);
  }

  .ctpage__hours-row {
    display: flex;
    justify-content: space-between;
    padding: var(--s-3) 0;
    font-size: 0.82rem;
    color: var(--c-text-secondary);
    border-bottom: 1px solid var(--c-border-light);
  }

  .ctpage__hours-row:last-child { border: none; }

  .ctpage__hours-row--active {
    color: var(--c-text);
    font-weight: 600;
  }

  .ctpage__hours-row--active span:last-child {
    color: var(--c-orange);
  }

  /* ── Form card ── */
  .ctpage__form-card {
    padding: var(--s-10);
    background: var(--c-surface);
    border-radius: var(--r-xl);
    border: 1px solid var(--c-border-light);
    box-shadow: var(--shadow-md);
  }

  .ctpage__form-title {
    font-size: 1.3rem;
    font-weight: 700;
    text-transform: none;
    letter-spacing: -0.01em;
    margin-bottom: var(--s-2);
  }

  .ctpage__form-sub {
    font-size: 0.82rem;
    color: var(--c-text-muted);
    margin-bottom: var(--s-8);
  }

  /* NB: le formulaire est stylé directement dans `AccessContactForm.svelte`
     pour être 1:1 avec le form de la page Groupes & Événements. */

  /* ── Routes ── */
  .ctroutes__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--s-4);
    margin-bottom: var(--s-10);
  }

  .ctroutes__card {
    padding: var(--s-5);
    background: var(--c-bg);
    border-radius: var(--r-md);
    border: 1px solid var(--c-border-light);
    display: flex;
    flex-direction: column;
    transition: border-color var(--t-fast);
  }

  .ctroutes__card:hover { border-color: var(--c-orange); }

  .ctroutes__city {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--c-text);
    margin-bottom: 4px;
  }

  .ctroutes__time {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--c-orange);
    letter-spacing: -0.02em;
    margin-bottom: var(--s-2);
  }

  .ctroutes__details {
    display: flex;
    flex-direction: column;
    font-size: 0.68rem;
    color: var(--c-text-muted);
  }

  .ctroutes__tip {
    display: flex;
    align-items: flex-start;
    gap: var(--s-3);
    padding: var(--s-5);
    background: var(--c-bg);
    border-radius: var(--r-md);
    border: 1px solid var(--c-border-light);
  }

  .ctroutes__tip svg {
    flex-shrink: 0;
    color: var(--c-orange);
    margin-top: 2px;
  }

  .ctroutes__tip p {
    font-size: 0.85rem;
    color: var(--c-text-secondary);
    line-height: 1.5;
  }

  /* ── Liens coordonnées ── */
  .ctpage__link {
    color: inherit;
    text-decoration: none;
  }

  .ctpage__link:hover {
    text-decoration: underline;
    text-decoration-color: rgb(247 123 70 / 0.55);
  }

  /* ── Carte ── */
  .ctmap {
    margin-top: var(--s-10);
    border-radius: var(--r-xl);
    overflow: hidden;
    border: 1px solid var(--c-border-light);
    background: var(--c-bg);
    box-shadow: var(--shadow-sm);
  }

  [data-theme='dark'] .ctmap {
    background: var(--c-surface);
    border-color: var(--c-border);
  }

  .ctmap iframe { display: block; }

  /* ── Météo ── */
  .ctmeteo__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-10);
    align-items: center;
  }

  .ctmeteo__text {
    font-size: 0.95rem;
    color: var(--c-text-secondary);
    line-height: 1.75;
    max-width: 42ch;
    margin-top: var(--s-5);
  }

  .ctmeteo__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-4);
  }

  .ctmeteo__card {
    padding: var(--s-6);
    background: var(--c-surface);
    border-radius: var(--r-md);
    border: 1px solid var(--c-border-light);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .ctmeteo__card-icon {
    font-size: 1.5rem;
    margin-bottom: var(--s-2);
  }

  .ctmeteo__card-value {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--c-text);
    letter-spacing: -0.02em;
  }

  .ctmeteo__card-label {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-text-muted);
  }

  /* ── Responsive ── */
  @media (min-width: 900px) {
    .ctpage__layout { grid-template-columns: 0.9fr 1.1fr; gap: var(--s-16); }
    .ctmeteo__inner { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 768px) {
    .ctroutes__grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 480px) {
    .ctmeteo__cards { grid-template-columns: 1fr; }
  }
</style>
