---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

import imgBateau from '../assets/images/location-bateau-electrique-lac-sainte-croix-surfcenter.jpeg';
import imgEsprit from '../assets/images/esprit.png';
import imgSnack from '../assets/images/drone-snack-pedalo-lac-sainte-croix-surfcenter-salades.jpeg';
import imgYoga from '../assets/images/sarah-cours-yoga-surfcenter-lac-sainte-croix.jpg';
import imgConcert from '../assets/images/concert-surfcenter-lac-sainte-croix.png';

const links: { title: string; href: string; image: ImageMetadata; alt: string }[] = [
  {
    title: 'Nos locations',
    href: '/nos-locations',
    image: imgBateau,
    alt: 'Location de bateaux — Surf Center',
  },
  {
    title: "L'esprit Surf Center",
    href: '/esprit-surf-center',
    image: imgEsprit,
    alt: "L'esprit Surf Center — lac de Sainte-Croix",
  },
  {
    title: 'Restauration',
    href: '/restauration',
    image: imgSnack,
    alt: 'Restaurant Surf Center',
  },
  {
    title: 'Animations',
    href: '/animations',
    image: imgYoga,
    alt: 'Yoga au Surf Center',
  },
  {
    title: 'Groupes & Événements',
    href: '/groupes-evenements',
    image: imgConcert,
    alt: 'Concert au Surf Center',
  },
];
---

<section class="mscards" aria-labelledby="maillage-title">
  <div class="mscards__header container reveal">
    <div class="mscards__title-wrap">
      <span class="mscards__icon" aria-hidden="true">
        <img src="/figma/locations-icon.svg" alt="" width="82" height="87" loading="lazy" decoding="async" />
      </span>
      <h2 id="maillage-title" class="home-h3 mscards__title">Tout Surf Center</h2>
    </div>
    <div class="mscards__nav">
      <button class="mscards__arrow" type="button" data-mscards-prev aria-label="Précédent">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M13 4l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="mscards__arrow" type="button" data-mscards-next aria-label="Suivant">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>

  <div class="mscards__track" data-mscards-track>
    {links.map((link) => (
      <a href={link.href} class="mscards__card" aria-label={link.title}>
        <div class="mscards__visual">
          <Image
            src={link.image}
            alt={link.alt}
            width={600}
            height={800}
            loading="lazy"
            decoding="async"
            format="webp"
            quality={75}
          />
        </div>
        <div class="mscards__info">
          <h3 class="mscards__name">{link.title}</h3>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .mscards {
    padding: var(--s-section) 0 var(--s-16);
    background: var(--c-bg);
    overflow: hidden;
  }

  .mscards__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-6);
    margin-bottom: var(--s-10);
  }

  .mscards__title-wrap {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    min-width: 0;
  }

  .mscards__icon {
    width: 60px;
    height: 64px;
    flex: 0 0 auto;
    display: inline-flex;
  }

  .mscards__icon img {
    width: 100%;
    height: 100%;
    display: block;
  }

  .mscards__title {
    margin: 0;
    text-align: left;
  }

  .mscards__nav {
    display: flex;
    gap: var(--s-2);
    flex: 0 0 auto;
  }

  .mscards__arrow {
    width: 44px;
    height: 44px;
    border-radius: var(--r-full);
    border: 1.5px solid var(--c-border);
    background: var(--c-bg);
    color: var(--c-text-secondary);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all var(--t-fast) var(--ease);
  }

  .mscards__arrow:hover {
    border-color: var(--c-orange);
    color: var(--c-orange);
    background: var(--c-surface);
  }

  .mscards__arrow:disabled {
    opacity: 0.3;
    pointer-events: none;
  }

  .mscards__track {
    display: flex;
    gap: var(--s-4);
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding: 0 var(--s-6);
    scroll-snap-type: x mandatory;
  }

  .mscards__track::-webkit-scrollbar { display: none; }

  .mscards__card {
    flex: 0 0 78%;
    scroll-snap-align: start;
    text-align: left;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-decoration: none;
    color: var(--c-text);
    -webkit-tap-highlight-color: transparent;
  }

  .mscards__visual {
    position: relative;
    overflow: hidden;
    border-radius: var(--r-md);
    margin-bottom: var(--s-4);
  }

  .mscards__visual :global(img) {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    transition: transform 0.8s var(--ease);
  }

  .mscards__card:hover .mscards__visual :global(img) { transform: scale(1.04); }

  .mscards__info {
    display: flex;
    padding: 0 var(--s-1);
  }

  .mscards__name {
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 0;
  }

  @media (max-width: 599px) {
    .mscards__icon { width: 44px; height: 47px; }
    .mscards__header { flex-wrap: wrap; }
  }

  @media (max-width: 480px) {
    .mscards__nav { display: none; }
  }

  @media (min-width: 600px) { .mscards__card { flex: 0 0 48%; } }
  @media (min-width: 900px) { .mscards__card { flex: 0 0 35%; } }
  @media (min-width: 1200px) { .mscards__card { flex: 0 0 28%; } }

  @media (prefers-reduced-motion: reduce) {
    .mscards__visual :global(img) { transition: none; }
  }
</style>

<script>
  document.querySelectorAll('[data-mscards-track]').forEach((track) => {
    const section = track.closest('.mscards');
    const prevBtn = section?.querySelector('[data-mscards-prev]') as HTMLButtonElement | null;
    const nextBtn = section?.querySelector('[data-mscards-next]') as HTMLButtonElement | null;
    if (!track || !prevBtn || !nextBtn) return;

    const el = track as HTMLElement;

    const getScrollAmount = () => {
      const card = el.querySelector('.mscards__card') as HTMLElement | null;
      if (!card) return 300;
      return card.offsetWidth + 16;
    };

    const updateArrows = () => {
      prevBtn.disabled = el.scrollLeft <= 2;
      nextBtn.disabled = el.scrollLeft + el.clientWidth >= el.scrollWidth - 2;
    };

    updateArrows();
    el.addEventListener('scroll', updateArrows, { passive: true });

    prevBtn.addEventListener('click', () => {
      el.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', () => {
      el.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    });
  });
</script>
