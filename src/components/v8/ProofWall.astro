---
const reviews = [
  { quote: "Un cadre magnifique, un accueil au top et des bateaux en très bon état. On a passé une journée incroyable sur le lac avec les enfants. On reviendra !", author: "Sophie L.", context: "Famille — Août 2025", rating: 5, activity: "Bateau électrique" },
  { quote: "La meilleure base nautique du Verdon. Le paddle au lever du soleil sur le lac de Sainte-Croix, c'est juste magique. Équipe pro et super sympa.", author: "Maxime R.", context: "Paddle — Juillet 2025", rating: 5, activity: "Paddle board" },
  { quote: "Super spot, super équipe. Les pizzas du snack sont excellentes. L'endroit idéal pour une journée complète au lac. Le must du Verdon.", author: "Camille & Julien", context: "Couple — Septembre 2025", rating: 5, activity: "Pédalo + Snack" },
  { quote: "Troisième été de suite qu'on vient et c'est toujours aussi bien. Les enfants adorent le pédalo, nous on préfère le bateau électrique. Parfait !", author: "Laurent D.", context: "Famille — Juillet 2025", rating: 5, activity: "Bateau électrique" },
  { quote: "Quel lac ! Et quel accueil. Paddle au coucher du soleil puis pizza au snack. La journée parfaite existe, elle est au Surf Center.", author: "Émilie P.", context: "Entre amis — Août 2025", rating: 5, activity: "Paddle + Restauration" },
  { quote: "Première fois en planche à voile et l'équipe a été top pour nous guider. Le cadre est incroyable, on a adoré. Merci !", author: "Thomas B.", context: "Windsurf — Juin 2025", rating: 5, activity: "Planche à voile" },
];
---

<section class="section" aria-labelledby="v8-reviews-title">
  <div class="container">
    <header class="section__header reveal">
      <span class="section__eyebrow">Avis clients</span>
      <h2 id="v8-reviews-title">Ils ont vécu<br/>l'expérience</h2>
      <p class="section__lead">4.8/5 sur Google — Plus de 320 avis vérifiés.</p>
    </header>

    <div class="pw__grid">
      {reviews.map((r, i) => (
        <blockquote class={`pw__card reveal reveal-d${Math.min(i + 1, 4)}`}>
          <div class="pw__stars" aria-label={`${r.rating} étoiles sur 5`}>★★★★★</div>
          <p class="pw__text">&ldquo;{r.quote}&rdquo;</p>
          <footer class="pw__footer">
            <div class="pw__author-info">
              <cite class="pw__author">{r.author}</cite>
              <span class="pw__context">{r.context}</span>
            </div>
            <span class="pw__activity">{r.activity}</span>
          </footer>
        </blockquote>
      ))}
    </div>

    <div class="pw__cta reveal">
      <div class="pw__google">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1Z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23Z" fill="#34A853"/><path d="M5.84 14.09A6.68 6.68 0 0 1 5.5 12c0-.72.12-1.42.35-2.09V7.07H2.18A10.96 10.96 0 0 0 1 12c0 1.77.42 3.45 1.18 4.93l3.66-2.84Z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53Z" fill="#EA4335"/></svg>
        <span class="pw__google-text">4.8/5 sur Google</span>
      </div>
      <button type="button" class="btn btn--primary" data-booking>
        <span class="btn-flip__inner"><span class="btn-flip__front">Réserver ma place</span><span class="btn-flip__back">Réserver ma place</span></span>
      </button>
    </div>
  </div>
</section>

<style>
  .pw__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-5);
  }

  .pw__card {
    padding: var(--s-6) var(--s-7);
    background: var(--c-surface);
    border-radius: var(--r-lg);
    border: 1px solid var(--c-border-light);
    margin: 0;
    display: flex;
    flex-direction: column;
    transition: border-color var(--t-fast);
  }
  .pw__card:hover { border-color: var(--c-border); }

  .pw__stars { font-size: 0.85rem; color: #fbbf24; letter-spacing: 2px; margin-bottom: var(--s-3); }

  .pw__text {
    font-size: 0.92rem;
    line-height: 1.7;
    color: var(--c-text);
    margin-bottom: auto;
    padding-bottom: var(--s-5);
    font-style: italic;
  }

  .pw__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    padding-top: var(--s-4);
    border-top: 1px solid var(--c-border-light);
  }
  .pw__author-info { display: flex; flex-direction: column; gap: 2px; }
  .pw__author { font-style: normal; font-weight: 700; font-size: 0.78rem; letter-spacing: 0.04em; text-transform: uppercase; color: var(--c-text); }
  .pw__context { font-size: 0.68rem; color: var(--c-text-muted); }
  .pw__activity {
    font-size: 0.62rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--c-orange);
    padding: 0.25rem 0.6rem;
    background: rgb(247 123 70 / 0.1);
    border-radius: var(--r-full);
    white-space: nowrap;
  }

  .pw__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--s-6);
    margin-top: var(--s-12);
    flex-wrap: wrap;
  }
  .pw__google { display: flex; align-items: center; gap: var(--s-2); }
  .pw__google-text { font-size: 0.78rem; font-weight: 600; color: var(--c-text-muted); }

  @media (min-width: 768px) { .pw__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1100px) { .pw__grid { grid-template-columns: repeat(3, 1fr); } }
</style>
