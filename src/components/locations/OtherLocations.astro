---
import { Image } from 'astro:assets';
import type { LocationDetail } from '../../data/locations';

import imgBateau from '../../assets/images/location-bateau-electrique-lac-sainte-croix-surfcenter.jpeg';
import imgPaddle from '../../assets/images/location-paddle-lac-sainte-croix-surfcenter.jpeg';
import imgPedalo from '../../assets/images/location-pedalo-lac-sainte-croix.jpeg';
import imgCanoe from '../../assets/images/canoe.jpeg';
import imgVoile from '../../assets/images/location-planche-a-voile-windsurf-lac-sainte-croix.png';
import imgCatamaran from '../../assets/images/catamaran-lac-sainte-croix-falaises.jpg';

const imageMap: Record<string, ImageMetadata> = {
  'bateau-electrique': imgBateau,
  'paddle': imgPaddle,
  'pedalo': imgPedalo,
  'canoe': imgCanoe,
  'planche-a-voile': imgVoile,
  'catamaran': imgCatamaran,
};

interface Props {
  locations: LocationDetail[];
}

const { locations } = Astro.props;
---

<section class="otherloc section section--surface" aria-labelledby="otherloc-title">
  <div class="container">
    <header class="section__header reveal">
      <span class="section__eyebrow">Découvrir aussi</span>
      <h2 id="otherloc-title">Les autres locations</h2>
    </header>

    <div class="otherloc__grid" role="list">
      {locations.map((loc, i) => (
        <a href={`/nos-locations/${loc.slug}`} class={`otherloc__card reveal reveal-d${Math.min(i + 1, 4)}`} role="listitem" aria-label={`${loc.title} — dès ${loc.price}€/${loc.priceUnit}`}>
          {imageMap[loc.slug] ? (
            <Image src={imageMap[loc.slug]} alt={loc.heroAlt} width={400} height={300} loading="lazy" decoding="async" format="webp" quality={75} />
          ) : (
            <img src={loc.detailImage} alt={loc.heroAlt} width="400" height="300" loading="lazy" decoding="async" />
          )}
          <div class="otherloc__overlay" aria-hidden="true"></div>
          <div class="otherloc__content">
            <h3 class="otherloc__name">{loc.title}</h3>
            <span class="otherloc__price">dès {loc.price}€/{loc.priceUnit}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .otherloc__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-4);
  }

  .otherloc__card {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--r-lg);
    color: #fff;
  }

  .otherloc__card img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease);
  }

  .otherloc__card:hover img { transform: scale(1.06); }

  .otherloc__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgb(0 0 0 / 0.65) 0%, rgb(0 0 0 / 0.05) 60%);
  }

  .otherloc__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--s-5);
    z-index: 1;
  }

  .otherloc__name {
    font-size: clamp(0.82rem, 1.5vw, 1rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #fff;
    margin-bottom: 2px;
  }

  .otherloc__price {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--c-orange);
  }

  @media (min-width: 768px) {
    .otherloc__grid { grid-template-columns: repeat(4, 1fr); }
  }

  @media (prefers-reduced-motion: reduce) {
    .otherloc__card img { transition: none; }
  }

  /* Mobile a11y — extra +1px on smallest type */
  @media (max-width: 768px) {
    .otherloc__price { font-size: calc(0.68rem + 1px); }
  }
</style>
