---
const phone = '04 92 77 14 50';
const phoneHref = 'tel:+33492771450';
---

<section class="cta-resa" aria-labelledby="cta-resa-title">
  <div class="container cta-resa__inner reveal">
    <p class="cta-resa__eyebrow">Prêt pour l'aventure ?</p>
    <h2 id="cta-resa-title" class="cta-resa__title">
      Réservez votre activité<br />sur le lac de Sainte-Croix
    </h2>
    <p class="cta-resa__desc">
      Places limitées en haute saison — réservez dès maintenant pour garantir votre créneau.
    </p>

    <div class="cta-resa__actions">
      <button type="button" class="cta-resa__btn" data-booking>
        <span class="btn-flip__inner">
          <span class="btn-flip__front">Réserver maintenant</span>
          <span class="btn-flip__back">Réserver maintenant</span>
        </span>
      </button>
      <a href={phoneHref} class="cta-resa__phone">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path
            d="M6.5 2.5H4a1.5 1.5 0 0 0-1.5 1.5A9.5 9.5 0 0 0 12 13.5a1.5 1.5 0 0 0 1.5-1.5v-2.5l-3-1.5-1.5 1.5a7.5 7.5 0 0 1-3.5-3.5L7 4.5l-.5-2Z"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linejoin="round"
          />
        </svg>
        <span>{phone}</span>
      </a>
    </div>
  </div>
</section>

<style>
  .cta-resa {
    background: linear-gradient(
      180deg,
      #ED6776 0%,
      #F47456 71.742%,
      #F77B46 100%
    );
    padding: clamp(3rem, 6vw, 5rem) 0;
    text-align: center;
    color: #fff;
  }

  .cta-resa__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta-resa__eyebrow {
    color: #fff;
    text-align: center;
    font-family: Montserrat, var(--font-sans);
    font-size: 11.2px;
    font-style: normal;
    font-weight: 700;
    line-height: 19.04px; /* 170% */
    letter-spacing: 2.24px;
    text-transform: uppercase;
    opacity: 0.85;
    margin: 0 0 var(--s-4);
  }

  .cta-resa__title {
    color: #fff;
    text-align: center;
    font-family: Montserrat, var(--font-sans);
    font-size: 38.4px;
    font-style: normal;
    font-weight: 800;
    line-height: 44.16px; /* 115% */
    letter-spacing: -0.768px;
    text-transform: uppercase;
    margin: 0 0 var(--s-5);
  }

  .cta-resa__desc {
    color: #fff;
    text-align: center;
    font-family: Montserrat, var(--font-sans);
    font-size: 14.1px;
    font-weight: 400;
    line-height: 22.53px; /* 160% */
    opacity: 0.9;
    max-width: 38ch;
    margin: 0 auto var(--s-8);
  }

  .cta-resa__actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--s-6);
    flex-wrap: wrap;
  }

  .cta-resa__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    color: #F77B46;
    border: 1px solid #fff;
    font-family: Montserrat, var(--font-sans);
    font-size: 13.1px;
    font-weight: 700;
    line-height: 13.12px; /* 100% */
    letter-spacing: 1.574px;
    text-transform: uppercase;
    padding: 17px 36px;
    border-radius: 9999px;
    cursor: pointer;
    overflow: hidden;
    transition:
      transform var(--t-fast) var(--ease),
      box-shadow var(--t-fast) var(--ease),
      background var(--t-fast),
      color var(--t-fast);
  }

  .cta-resa__btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.18);
    background: #fff;
    color: #ED6776;
  }

  .cta-resa__btn .btn-flip__inner {
    height: 1em;
  }

  .cta-resa__btn:active {
    transform: scale(0.98);
  }

  .cta-resa__phone {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: rgba(255, 255, 255, 0.85);
    font-family: Montserrat, var(--font-sans);
    font-size: 13.1px;
    font-weight: 600;
    line-height: 22.3px;
    text-decoration: none;
    transition: color var(--t-fast);
  }

  .cta-resa__phone:hover { color: #fff; }

  .cta-resa__phone svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  @media (max-width: 599px) {
    .cta-resa__title {
      font-size: clamp(1.6rem, 7vw, 2rem);
      line-height: 1.1;
      letter-spacing: -0.02em;
    }

    .cta-resa__desc { max-width: 32ch; }

    .cta-resa__actions {
      flex-direction: column;
      gap: var(--s-4);
    }

    .cta-resa__btn {
      width: min(320px, 100%);
      padding: 16px 28px;
    }
  }
</style>
