---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

import imgBateau from '../assets/images/location-bateau-electrique-lac-sainte-croix-surfcenter.jpeg';
import imgEsprit from '../assets/images/esprit.png';
import imgSnack from '../assets/images/drone-snack-pedalo-lac-sainte-croix-surfcenter-salades.jpeg';
import imgYoga from '../assets/images/sarah-cours-yoga-surfcenter-lac-sainte-croix.jpg';
import imgConcert from '../assets/images/concert-surfcenter-lac-sainte-croix.png';

const links: { title: string; description: string; href: string; image: ImageMetadata; alt: string }[] = [
  {
    title: "Nos locations",
    description: "Bateaux, paddle, pédalo, canoë",
    href: "/nos-locations",
    image: imgBateau,
    alt: "Location de bateaux — Surf Center",
  },
  {
    title: "L'esprit Surf Center",
    description: "Notre histoire & nos valeurs",
    href: "/esprit-surf-center",
    image: imgEsprit,
    alt: "L'esprit Surf Center — lac de Sainte-Croix",
  },
  {
    title: "Restauration",
    description: "Snack-pizzeria face au lac",
    href: "/restauration",
    image: imgSnack,
    alt: "Restaurant Surf Center",
  },
  {
    title: "Animations",
    description: "Yoga, cours & activités",
    href: "/animations",
    image: imgYoga,
    alt: "Yoga au Surf Center",
  },
  {
    title: "Groupes & Événements",
    description: "Concerts, soirées & privatisation",
    href: "/groupes-evenements",
    image: imgConcert,
    alt: "Concert au Surf Center",
  },
];
---

<section class="mscroll" aria-label="Tout Surf Center">
  <div class="mscroll__header container reveal">
    <div class="mscroll__title-wrap">
      <span class="mscroll__icon" aria-hidden="true">
        <img src="/figma/locations-icon.svg" alt="" width="82" height="87" loading="lazy" decoding="async" />
      </span>
      <h3 class="home-h3 mscroll__title">Tout Surf Center</h3>
    </div>
    <div class="mscroll__header-right">
      <p class="mscroll__count">{String(links.length).padStart(2, '0')} sections</p>
      <div class="mscroll__nav">
        <button class="mscroll__arrow" type="button" data-mscroll-prev aria-label="Précédent">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M13 4l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="mscroll__arrow" type="button" data-mscroll-next aria-label="Suivant">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div class="mscroll__track" data-mscroll-track>
    {links.map((link) => (
      <a href={link.href} class="mscroll__card" aria-label={link.title}>
        <div class="mscroll__visual">
          <Image
            src={link.image}
            alt={link.alt}
            width={600}
            height={800}
            loading="lazy"
            decoding="async"
            format="webp"
            quality={75}
          />
        </div>
        <div class="mscroll__info">
          <h4 class="mscroll__name">{link.title}</h4>
          <span class="mscroll__desc">{link.description}</span>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .mscroll {
    padding: var(--s-section) 0 var(--s-16);
    background: var(--c-bg);
    overflow: hidden;
  }

  .mscroll__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--s-6);
    margin-bottom: var(--s-10);
  }

  .mscroll__title-wrap {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .mscroll__icon {
    width: 60px;
    height: 64px;
    flex: 0 0 auto;
    display: inline-flex;
  }

  .mscroll__icon img {
    width: 100%;
    height: 100%;
    display: block;
  }

  .mscroll__title {
    text-align: left;
  }

  .mscroll__header-right {
    display: flex;
    align-items: center;
    gap: var(--s-6);
  }

  .mscroll__count {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--c-text-muted);
  }

  .mscroll__nav {
    display: flex;
    gap: var(--s-2);
  }

  .mscroll__arrow {
    width: 44px;
    height: 44px;
    border-radius: var(--r-full);
    border: 1.5px solid var(--c-border);
    background: var(--c-bg);
    color: var(--c-text-secondary);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all var(--t-fast) var(--ease);
  }

  .mscroll__arrow:hover {
    border-color: var(--c-orange);
    color: var(--c-orange);
    background: var(--c-surface);
  }

  .mscroll__arrow:disabled {
    opacity: 0.3;
    pointer-events: none;
  }

  .mscroll__track {
    display: flex;
    gap: var(--s-4);
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding: 0 var(--s-6);
    scroll-snap-type: x mandatory;
  }

  .mscroll__track::-webkit-scrollbar { display: none; }

  .mscroll__card {
    flex: 0 0 78%;
    scroll-snap-align: start;
    text-align: left;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-decoration: none;
    color: var(--c-text);
    -webkit-tap-highlight-color: transparent;
  }

  .mscroll__visual {
    position: relative;
    overflow: hidden;
    border-radius: var(--r-md);
    margin-bottom: var(--s-4);
  }

  .mscroll__visual :global(img) {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    transition: transform 0.8s var(--ease);
  }

  .mscroll__card:hover .mscroll__visual :global(img) { transform: scale(1.04); }

  .mscroll__info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0 var(--s-1);
  }

  .mscroll__name {
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 0;
  }

  .mscroll__desc {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--c-text-muted);
    letter-spacing: 0.02em;
  }

  @media (max-width: 599px) {
    .mscroll__icon { width: 44px; height: 47px; }
    .mscroll__header { flex-direction: column; align-items: flex-start; }
  }

  @media (min-width: 600px) { .mscroll__card { flex: 0 0 48%; } }
  @media (min-width: 900px) { .mscroll__card { flex: 0 0 35%; } }
  @media (min-width: 1200px) { .mscroll__card { flex: 0 0 28%; } }

  @media (prefers-reduced-motion: reduce) {
    .mscroll__visual :global(img) { transition: none; }
  }
</style>

<script>
  document.querySelectorAll('[data-mscroll-track]').forEach((track) => {
    const section = track.closest('.mscroll');
    const prevBtn = section?.querySelector('[data-mscroll-prev]') as HTMLButtonElement | null;
    const nextBtn = section?.querySelector('[data-mscroll-next]') as HTMLButtonElement | null;
    if (!track || !prevBtn || !nextBtn) return;

    const el = track as HTMLElement;

    const getScrollAmount = () => {
      const card = el.querySelector('.mscroll__card') as HTMLElement | null;
      if (!card) return 300;
      return card.offsetWidth + 16;
    };

    const updateArrows = () => {
      prevBtn.disabled = el.scrollLeft <= 2;
      nextBtn.disabled = el.scrollLeft + el.clientWidth >= el.scrollWidth - 2;
    };

    updateArrows();
    el.addEventListener('scroll', updateArrows, { passive: true });

    prevBtn.addEventListener('click', () => {
      el.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', () => {
      el.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    });
  });
</script>
