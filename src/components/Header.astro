---
import { Image } from 'astro:assets';
import logoImg from '../assets/images/logo-surf-center.png';

const navLinks = [
  { label: "Nos locations", href: "/nos-locations" },
  { label: "L'esprit Surf Center", href: "/esprit-surf-center" },
  { label: "Restauration", href: "/restauration" },
  { label: "Animations", href: "/animations" },
  { label: "Groupes & Événements", href: "/groupes-evenements" },
  { label: "Blog", href: "/blog" },
];
---

<a href="#main-content" class="skip-link">Aller au contenu principal</a>

<header class="header" data-header>
  <div class="header__inner container">
    <a href="/" class="header__logo" aria-label="Surf Center — Accueil">
      <Image
        class="header__logo-img header__logo-img--light"
        src={logoImg}
        alt=""
        width={60}
        height={56}
        loading="eager"
        format="webp"
        quality={85}
      />
      <Image
        class="header__logo-img header__logo-img--dark"
        src={logoImg}
        alt=""
        width={60}
        height={56}
        loading="eager"
        format="webp"
        quality={85}
      />
    </a>

    <nav class="header__nav" aria-label="Navigation principale">
      <ul role="list">
        {navLinks.map((link) => (
          <li>
            {link.modal
              ? <button type="button" class="header__nav-btn link-anim" data-shop>{link.label}</button>
              : <a href={link.href} class="link-anim">{link.label}</a>}
          </li>
        ))}
      </ul>
    </nav>

    <div class="header__end">
      <button
        class="header__theme"
        type="button"
        data-theme-toggle
        aria-label="Changer de thème"
      >
        <svg class="header__theme-icon header__theme-icon--sun" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <circle cx="9" cy="9" r="3.5" stroke="currentColor" stroke-width="1.2"/>
          <path d="M9 2v1.5M9 14.5V16M2 9h1.5M14.5 9H16M4.05 4.05l1.06 1.06M12.89 12.89l1.06 1.06M4.05 13.95l1.06-1.06M12.89 5.11l1.06-1.06" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        <svg class="header__theme-icon header__theme-icon--moon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M15.1 10.63A6.5 6.5 0 0 1 7.37 2.9 6.5 6.5 0 1 0 15.1 10.63Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
        </svg>
      </button>

      <button type="button" class="btn btn--primary btn--sm header__cta" data-booking><span class="btn-flip__inner"><span class="btn-flip__front">Réserver</span><span class="btn-flip__back">Réserver</span></span></button>

      <button
        class="header__burger"
        type="button"
        data-menu-toggle
        aria-expanded="false"
        aria-label="Menu de navigation"
      >
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
      </button>
    </div>
  </div>

  <div class="mmenu" id="mobile-menu" hidden>
    <div class="mmenu__inner">
      <nav class="mmenu__nav" aria-label="Navigation mobile">
        <ul role="list">
          {navLinks.map((link, i) => (
            <li class="mmenu__item" style={`--delay: ${i * 60}ms`}>
              {link.modal
                ? <button type="button" class="mmenu__link" data-shop>
                    <span class="mmenu__link-label">{link.label}</span>
                    <svg class="mmenu__link-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                      <path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                : <a href={link.href} class="mmenu__link">
                    <span class="mmenu__link-label">{link.label}</span>
                    <svg class="mmenu__link-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                      <path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>}
            </li>
          ))}
        </ul>
      </nav>

      <div class="mmenu__actions" style="--delay: 300ms">
        <button type="button" class="btn btn--primary mmenu__book" data-booking>Réserver une activité</button>
        <button type="button" class="btn btn--outline mmenu__cart" data-cart>Mon panier</button>
      </div>

      <div class="mmenu__footer" style="--delay: 400ms">
        <a href="tel:+33492771450" class="mmenu__contact">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M6.5 2.5H4a1.5 1.5 0 0 0-1.5 1.5A9.5 9.5 0 0 0 12 13.5a1.5 1.5 0 0 0 1.5-1.5v-2.5l-3-1.5-1.5 1.5a7.5 7.5 0 0 1-3.5-3.5L7 4.5l-.5-2Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
          </svg>
          04 92 77 14 50
        </a>
        <p class="mmenu__address">Les Salles-sur-Verdon · Gorges du Verdon</p>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector('[data-header]') as HTMLElement;
  const hero = document.querySelector('[data-hero]') as HTMLElement;

  if (header && hero) {
    const obs = new IntersectionObserver(
      ([entry]) => header.classList.toggle('is-scrolled', !entry.isIntersecting),
      { threshold: 0 },
    );
    obs.observe(hero);
  }

  const toggle = document.querySelector('[data-menu-toggle]') as HTMLButtonElement;
  const mobileMenu = document.getElementById('mobile-menu');

  if (toggle && mobileMenu) {
    const set = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      mobileMenu.hidden = !open;
      document.body.style.overflow = open ? 'hidden' : '';
      if (open) {
        mobileMenu.classList.add('is-open');
      } else {
        mobileMenu.classList.remove('is-open');
      }
    };

    toggle.addEventListener('click', () => {
      set(toggle.getAttribute('aria-expanded') !== 'true');
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
        set(false);
        toggle.focus();
      }
    });

    mobileMenu.querySelectorAll('a, button').forEach((el) =>
      el.addEventListener('click', () => set(false)),
    );
  }

  const themeToggle = document.querySelector('[data-theme-toggle]') as HTMLButtonElement;

  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);

      const meta = document.getElementById('meta-theme-color');
      if (meta) meta.setAttribute('content', next === 'dark' ? '#0a0a0a' : '#ffffff');
    });
  }
</script>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: var(--s-4);
    z-index: 200;
    padding: var(--s-2) var(--s-6);
    background: var(--c-orange);
    color: #fff;
    font-weight: 700;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .skip-link:focus { top: var(--s-2); }

  .header {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 100;
    height: var(--header-h);
    transition: all var(--t-normal) var(--ease-smooth);
  }

  .header.is-scrolled {
    background: var(--c-header-bg);
    backdrop-filter: blur(20px) saturate(1.4);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
    border-bottom: 1px solid var(--c-header-border);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    gap: var(--s-10);
  }

  .header__logo {
    z-index: 101;
    display: flex;
    align-items: center;
  }

  .header__logo-img {
    height: 28px;
    width: auto;
    object-fit: contain;
  }

  /* Over hero: show colored logo (visible on dark overlay) */
  .header__logo-img--light { display: block; }
  .header__logo-img--dark { display: none; }

  /* Scrolled light mode: show dark logo */
  .header.is-scrolled .header__logo-img--light { display: none; }
  .header.is-scrolled .header__logo-img--dark { display: block; }

  /* Scrolled dark mode: keep the light logo */
  :global([data-theme='dark']) .header.is-scrolled .header__logo-img--light {
    display: block;
  }
  :global([data-theme='dark']) .header.is-scrolled .header__logo-img--dark {
    display: none;
  }

  .header__nav { display: none; }
  .header__nav ul {
    display: flex;
    align-items: center;
    gap: var(--s-8);
    flex-wrap: nowrap;
  }
  .header__nav a,
  .header__nav-btn {
    font-size: 0.68rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgb(255 255 255 / 0.7);
    transition: color var(--t-fast);
    background: none;
    border: none;
    padding: var(--s-2) 0;
    cursor: pointer;
    font-family: inherit;
    white-space: nowrap;
  }
  .header__nav a:hover,
  .header__nav-btn:hover { color: #fff; }

  .header.is-scrolled .header__nav a,
  .header.is-scrolled .header__nav-btn { color: var(--c-header-text); }
  .header.is-scrolled .header__nav a:hover,
  .header.is-scrolled .header__nav-btn:hover { color: var(--c-header-text-hover); }

  .header__end {
    display: flex;
    align-items: center;
    gap: var(--s-3);
    z-index: 101;
  }

  .header__theme {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    color: rgb(255 255 255 / 0.7);
    transition: color var(--t-fast);
  }
  .header__theme:hover { color: #fff; }
  .header.is-scrolled .header__theme { color: var(--c-header-text); }
  .header.is-scrolled .header__theme:hover { color: var(--c-header-text-hover); }

  .header__theme-icon--sun { display: none; }
  .header__theme-icon--moon { display: block; }
  :global([data-theme='dark']) .header__theme-icon--sun { display: block; }
  :global([data-theme='dark']) .header__theme-icon--moon { display: none; }

  .header__burger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 2rem;
    height: 2rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .header__burger span {
    display: block;
    width: 1.4rem;
    height: 1px;
    background: #fff;
    transition: all var(--t-normal) var(--ease);
    transform-origin: center;
  }
  .header.is-scrolled .header__burger span { background: var(--c-header-burger); }
  .header__burger[aria-expanded='true'] span { background: var(--c-text) !important; }
  .header__burger[aria-expanded='true'] span:first-child {
    transform: translateY(3.5px) rotate(45deg);
  }
  .header__burger[aria-expanded='true'] span:last-child {
    transform: translateY(-3.5px) rotate(-45deg);
  }

  /* =============================================
     Mobile menu — Full screen overlay
     ============================================= */

  .mmenu {
    position: fixed;
    inset: 0;
    z-index: 99;
    background: var(--c-bg);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .mmenu[hidden] { display: none; }

  .mmenu__inner {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: calc(var(--header-h) + var(--s-8)) var(--s-6) var(--s-8);
  }

  .mmenu__nav { flex: 1; }

  .mmenu__nav ul {
    display: flex;
    flex-direction: column;
  }

  .mmenu__item {
    border-bottom: 1px solid var(--c-border-light);
    opacity: 0;
    transform: translateX(20px);
    transition:
      opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--delay);
  }

  .mmenu.is-open .mmenu__item {
    opacity: 1;
    transform: translateX(0);
  }

  .mmenu__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--s-5) 0;
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--c-text);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    transition: color var(--t-fast);
    -webkit-tap-highlight-color: transparent;
  }

  .mmenu__link:hover,
  .mmenu__link:active {
    color: var(--c-orange);
  }

  .mmenu__link-label {
    flex: 1;
    text-align: left;
  }

  .mmenu__link-arrow {
    flex-shrink: 0;
    color: var(--c-text-muted);
    transition: transform var(--t-fast) var(--ease), color var(--t-fast);
  }

  .mmenu__link:hover .mmenu__link-arrow,
  .mmenu__link:active .mmenu__link-arrow {
    color: var(--c-orange);
    transform: translateX(4px);
  }

  .mmenu__actions {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    margin-top: var(--s-8);
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--delay);
  }

  .mmenu.is-open .mmenu__actions {
    opacity: 1;
    transform: translateY(0);
  }

  .mmenu__book {
    width: 100%;
    justify-content: center;
    padding: 1rem;
    font-size: 0.85rem;
  }

  .mmenu__cart {
    width: 100%;
    justify-content: center;
    padding: 1rem;
    font-size: 0.85rem;
  }

  .mmenu__footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-2);
    margin-top: var(--s-10);
    padding-top: var(--s-6);
    border-top: 1px solid var(--c-border-light);
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--delay);
  }

  .mmenu.is-open .mmenu__footer {
    opacity: 1;
    transform: translateY(0);
  }

  .mmenu__contact {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--c-text);
    text-decoration: none;
    transition: color var(--t-fast);
  }

  .mmenu__contact:hover { color: var(--c-orange); }

  .mmenu__address {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-text-muted);
  }

  .header__cta { display: none; }

  @media (min-width: 960px) {
    .header__nav { display: block; }
    .header__cta { display: inline-flex; }
    .header__burger { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .mmenu__item,
    .mmenu__actions,
    .mmenu__footer {
      transition: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
