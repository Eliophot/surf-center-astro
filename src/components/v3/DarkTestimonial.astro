---
import { reviews } from '../../data/home';
const totalDuration = reviews.length * 6;
---

<section class="dtesti" aria-labelledby="v3-reviews-title">
  <img
    class="dtesti__bg"
    src="/lac-sainte-croix-gorges-verdon-location-bateaux-electriques.jpg"
    alt="" aria-hidden="true"
    width="1920" height="1080" loading="lazy" decoding="async"
  />

  <div class="container dtesti__inner">
    <h2 id="v3-reviews-title" class="sr-only">Témoignages</h2>

    <div class="dtesti__stars" aria-label="5 étoiles sur 5">
      {[...Array(5)].map(() => (
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M10 1.5l2.47 5.01 5.53.8-4 3.9.94 5.49L10 14.01l-4.94 2.69.94-5.49-4-3.9 5.53-.8L10 1.5z" fill="#f5a623" stroke="#f5a623" stroke-width="0.5"/>
        </svg>
      ))}
    </div>

    <div class="dtesti__carousel" style={`--total-duration: ${totalDuration}s`}>
      {reviews.map((r, i) => (
        <blockquote class="dtesti__slide" style={`--i: ${i}; --count: ${reviews.length}`}>
          <p class="dtesti__quote">&ldquo;{r.quote}&rdquo;</p>
          <footer class="dtesti__meta">
            <cite class="dtesti__author">{r.author}</cite>
            <span class="dtesti__context">{r.context}</span>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>

<style>
  .dtesti {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #050505;
  }

  .dtesti__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.12;
  }

  .dtesti__inner {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--s-16) var(--s-6);
    max-width: 700px;
    margin-inline: auto;
  }

  .dtesti__stars {
    display: flex;
    justify-content: center;
    gap: var(--s-1);
    margin-bottom: var(--s-8);
  }

  .dtesti__carousel {
    position: relative;
    min-height: 180px;
  }

  .dtesti__slide {
    position: absolute;
    inset: 0;
    margin: 0;
    border: none;
    padding: 0;
    opacity: 0;
    animation: dtesti-fade var(--total-duration) ease-in-out infinite;
    animation-delay: calc(var(--i) * (var(--total-duration) / var(--count)));
  }

  @keyframes dtesti-fade {
    0%, 5% { opacity: 0; }
    8%, 28% { opacity: 1; }
    33%, 100% { opacity: 0; }
  }

  .dtesti__quote {
    font-size: clamp(1.05rem, 2.2vw, 1.5rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.7;
    color: #fff;
    margin-bottom: var(--s-8);
  }

  .dtesti__meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .dtesti__author {
    font-style: normal;
    font-weight: 700;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
  }

  .dtesti__context {
    font-size: 0.7rem;
    color: rgb(255 255 255 / 0.4);
  }

  @media (prefers-reduced-motion: reduce) {
    .dtesti__slide { animation: none; opacity: 0; }
    .dtesti__slide:first-child { opacity: 1; }
  }
</style>
