---
import LayoutKinetic from '../../layouts/LayoutKinetic.astro';
import { locationDetails } from '../../data/locations';
import imgEsprit from '../../assets/images/esprit.png';
import imgLac from '../../assets/images/location-lac-sainte-croix-gorges-verdon.png';
import imgPaddle from '../../assets/images/location-paddle-bateaux-electriques-lac-sainte-croix-gorges-verdon.jpeg';
import imgBateau from '../../assets/images/location-bateau-electrique-lac-sainte-croix-surfcenter.jpeg';

const cadreCards = [
  { title: 'Le lac', text: 'Les eaux turquoise du lac de Sainte-Croix, à la porte des Gorges du Verdon. Un des plus beaux lacs d\'Europe.', stat: '2 200 ha' },
  { title: 'La plage', text: 'Base nautique installée sur la plage des Salles-sur-Verdon, accès direct à l\'eau, parking gratuit.', stat: '300 m' },
  { title: 'Le Verdon', text: 'Au cœur du Parc Naturel Régional du Verdon, entre lavande et falaises, un cadre naturel exceptionnel.', stat: '700 m' },
];
---

<LayoutKinetic
  title="L'esprit Surf Center — Notre histoire · Lac de Sainte-Croix"
  description="Découvrez l'esprit Surf Center : plus de 10 ans au bord du lac de Sainte-Croix, une équipe passionnée, des activités nautiques et un cadre exceptionnel dans les Gorges du Verdon."
>

  <!-- MOTION HERO -->
  <section class="k7es__hero">
    <div class="k7es__hero-bg">
      <img src={imgPaddle.src} alt="Paddle et bateaux sur le lac de Sainte-Croix — Gorges du Verdon" width="1920" height="1080" loading="eager" fetchpriority="high" decoding="async" />
      <div class="k7es__hero-dim" aria-hidden="true"></div>
    </div>
    <div class="k7es__hero-bars" aria-hidden="true">
      <span></span><span></span><span></span>
    </div>
    <div class="container k7es__hero-inner">
      <div class="k7es__hero-content">
        <h1 class="k7es__hero-title">
          <span class="k7es__t-bold">L'esprit</span>
          <span class="k7es__t-light">Surf Center</span>
        </h1>
        <p class="k7es__hero-sub">Depuis plus de 10 ans, un rendez-vous au bord du lac pour celles et ceux qui aiment l'eau, le soleil et les grands espaces.</p>
      </div>
    </div>
    <div class="k7es__hero-skew" aria-hidden="true"></div>
  </section>

  <!-- ANGLE SPLIT — HISTORY -->
  <section class="k7es__history" aria-labelledby="k7es-history-title">
    <div class="k7es__split-wrap">
      <div class="k7es__split-media">
        <img src={imgEsprit.src} alt="L'équipe Surf Center au lac de Sainte-Croix" width="960" height="640" loading="lazy" decoding="async" />
        <div class="k7es__split-angle" aria-hidden="true"></div>
      </div>
      <div class="k7es__split-body">
        <div class="container k7es__split-content reveal">
          <div class="k7es__stripe" aria-hidden="true"></div>
          <span class="k7es__split-label">Notre histoire</span>
          <h2 id="k7es-history-title" class="k7es__split-title">Nés au<br/>bord de l'eau</h2>
          <p class="k7es__split-desc">Le Surf Center est né de la passion d'une équipe pour le lac de Sainte-Croix. Ce qui a commencé comme une petite base de planche à voile est devenu, au fil des années, un lieu de vie complet : location nautique, snack-pizzeria, bar, animations, concerts.</p>
          <p class="k7es__split-desc">Notre philosophie est simple : offrir à chacun — familles, sportifs, groupes d'amis — le meilleur du lac dans un cadre authentique et convivial.</p>

          <div class="k7es__stats">
            <div class="k7es__stat">
              <span class="k7es__stat-num">10+</span>
              <span class="k7es__stat-unit">années</span>
            </div>
            <div class="k7es__stat">
              <span class="k7es__stat-num">5</span>
              <span class="k7es__stat-unit">activités</span>
            </div>
            <div class="k7es__stat">
              <span class="k7es__stat-num">1</span>
              <span class="k7es__stat-unit">lac d'exception</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RACE GRID — LE CADRE -->
  <section class="k7es__cadre" aria-labelledby="k7es-cadre-title">
    <div class="container">
      <div class="k7es__head reveal">
        <div class="k7es__stripe" aria-hidden="true"></div>
        <h2 id="k7es-cadre-title" class="k7es__section-title">Le cadre</h2>
      </div>

      <div class="k7es__cadre-grid">
        {cadreCards.map((card, i) => (
          <div class="k7es__cadre-card reveal" style={`--d:${i * 100}ms`}>
            <span class="k7es__cadre-num">{String(i + 1).padStart(2, '0')}</span>
            <div class="k7es__cadre-stat">{card.stat}</div>
            <h3 class="k7es__cadre-name">{card.title}</h3>
            <p class="k7es__cadre-text">{card.text}</p>
            <div class="k7es__cadre-bar" aria-hidden="true"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BRAND VALUES -->
  <section class="k7es__values" aria-labelledby="k7es-values-title">
    <div class="container">
      <div class="k7es__head reveal">
        <div class="k7es__stripe" aria-hidden="true"></div>
        <h2 id="k7es-values-title" class="k7es__section-title">Nos valeurs</h2>
      </div>

      <div class="k7es__manifesto reveal reveal-d1">
        <p>Un lieu où la nature impose le rythme. Où l'accueil est sincère. Où chacun trouve sa façon de profiter du lac.</p>
      </div>

      <div class="k7es__val-grid reveal reveal-d2">
        <div class="k7es__val">
          <strong>Nature</strong>
          <p>Un lac d'exception, des paysages préservés</p>
        </div>
        <div class="k7es__val">
          <strong>Simplicité</strong>
          <p>Du bon matériel, un bon accueil</p>
        </div>
        <div class="k7es__val">
          <strong>Convivialité</strong>
          <p>Chacun trouve ici sa façon de profiter</p>
        </div>
        <div class="k7es__val">
          <strong>Qualité</strong>
          <p>Bateaux récents, équipe passionnée</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MOTION GRID — ACTIVITIES -->
  <section class="k7es__activities" aria-labelledby="k7es-act-title">
    <div class="container">
      <div class="k7es__head reveal">
        <div class="k7es__stripe" aria-hidden="true"></div>
        <h2 id="k7es-act-title" class="k7es__section-title">Nos activités</h2>
      </div>

      <div class="k7es__act-grid">
        {locationDetails.map((loc, i) => (
          <a href={`/v7/nos-locations/${loc.slug}`} class="k7es__act-card reveal" style={`--d:${i * 80}ms`}>
            <img src={loc.heroImage} alt={loc.heroAlt} width="600" height="400" loading="lazy" decoding="async" />
            <div class="k7es__act-overlay">
              <span class="k7es__act-num">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="k7es__act-name">{loc.title}</h3>
              <span class="k7es__act-tag">{loc.tagline}</span>
              <span class="k7es__act-price">dès {loc.price}€/{loc.priceUnit}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="k7es__cta">
    <div class="container k7es__cta-inner reveal">
      <img src={imgLac.src} alt="Vue panoramique du lac de Sainte-Croix" width="1200" height="400" loading="lazy" decoding="async" class="k7es__cta-bg" />
      <div class="k7es__cta-dim" aria-hidden="true"></div>
      <div class="k7es__cta-content">
        <h2 class="k7es__cta-title">Prêt pour<br/>l'aventure ?</h2>
        <div class="k7es__cta-btns">
          <button type="button" class="btn btn--primary" data-booking>Réserver</button>
          <a href="/v7/acces-contact" class="btn btn--ghost">Nous trouver</a>
        </div>
      </div>
    </div>
  </section>

</LayoutKinetic>

<style>
  /* ====== HERO ====== */
  .k7es__hero {
    position: relative;
    min-height: 85svh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--c-dark);
  }

  .k7es__hero-bg {
    position: absolute;
    inset: 0;
  }

  .k7es__hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: k7es-zoom 22s ease-in-out alternate infinite;
  }

  @keyframes k7es-zoom {
    from { transform: scale(1); }
    to { transform: scale(1.08); }
  }

  .k7es__hero-dim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgb(0 0 0 / 0.3) 0%, rgb(0 0 0 / 0.7) 100%);
  }

  .k7es__hero-bars {
    position: absolute;
    right: 5%;
    top: 20%;
    display: flex;
    flex-direction: column;
    gap: 12px;
    z-index: 1;
  }

  .k7es__hero-bars span {
    width: 4px;
    background: var(--c-orange);
    border-radius: 2px;
  }

  .k7es__hero-bars span:nth-child(1) { height: 60px; opacity: 0.9; }
  .k7es__hero-bars span:nth-child(2) { height: 100px; opacity: 0.6; }
  .k7es__hero-bars span:nth-child(3) { height: 40px; opacity: 0.3; }

  .k7es__hero-inner {
    position: relative;
    z-index: 2;
    padding: calc(var(--header-h) + var(--s-16)) 0 var(--s-16);
  }

  .k7es__hero-content {
    max-width: 650px;
    animation: k7es-up 900ms var(--ease-smooth) both;
  }

  @keyframes k7es-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .k7es__hero-title {
    display: flex;
    flex-direction: column;
    margin-bottom: var(--s-6);
  }

  .k7es__t-bold {
    font-size: clamp(3.5rem, 12vw, 8rem);
    font-weight: bold;
    letter-spacing: -0.06em;
    line-height: 0.85;
    color: #fff;
    text-transform: uppercase;
  }

  .k7es__t-light {
    font-size: clamp(2.5rem, 8vw, 5.5rem);
    font-weight: 100;
    letter-spacing: -0.03em;
    line-height: 0.9;
    color: #fff;
    text-transform: uppercase;
    padding-left: clamp(1rem, 4vw, 3rem);
  }

  .k7es__hero-sub {
    font-size: 0.88rem;
    color: rgb(255 255 255 / 0.45);
    line-height: 1.7;
    max-width: 40ch;
  }

  .k7es__hero-skew {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 60px;
    background: var(--c-bg);
    clip-path: polygon(0 100%, 100% 30%, 100% 100%);
    z-index: 3;
  }

  /* ====== SHARED ====== */
  .k7es__stripe {
    width: 40px;
    height: 4px;
    background: var(--c-orange);
    flex-shrink: 0;
  }

  .k7es__section-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: bold;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    line-height: 1;
  }

  .k7es__head {
    display: flex;
    align-items: center;
    gap: var(--s-5);
    margin-bottom: var(--s-10);
  }

  /* ====== HISTORY SPLIT ====== */
  .k7es__history { overflow: hidden; }

  .k7es__split-wrap {
    display: grid;
    grid-template-columns: 1fr;
  }

  .k7es__split-media {
    position: relative;
    overflow: hidden;
  }

  .k7es__split-media img {
    width: 100%;
    display: block;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .k7es__split-angle {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 50px;
    background: var(--c-bg);
    clip-path: polygon(0 100%, 100% 0, 100% 100%);
  }

  .k7es__split-body {
    background: var(--c-bg);
    padding: var(--s-8) 0 var(--s-section);
  }

  .k7es__split-content { max-width: 520px; }

  .k7es__split-label {
    display: block;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    margin-bottom: var(--s-3);
  }

  .k7es__split-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: bold;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    line-height: 0.95;
    margin-bottom: var(--s-6);
  }

  .k7es__split-desc {
    font-size: 0.88rem;
    color: var(--c-text-secondary);
    line-height: 1.75;
    margin-bottom: var(--s-4);
  }

  .k7es__stats {
    display: flex;
    gap: var(--s-10);
    margin-top: var(--s-8);
    padding-top: var(--s-6);
    border-top: 1px solid var(--c-border-light);
  }

  .k7es__stat { display: flex; flex-direction: column; }

  .k7es__stat-num {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: bold;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .k7es__stat-unit {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    margin-top: 2px;
  }

  @media (min-width: 900px) {
    .k7es__split-wrap { grid-template-columns: 1.2fr 1fr; }
    .k7es__split-media img { aspect-ratio: auto; height: 100%; }
    .k7es__split-angle { display: none; }
    .k7es__split-body {
      display: flex;
      align-items: center;
      padding: var(--s-16);
    }
  }

  /* ====== CADRE RACE GRID ====== */
  .k7es__cadre {
    padding: var(--s-section) 0;
    background: var(--c-surface);
  }

  .k7es__cadre-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-4);
  }

  .k7es__cadre-card {
    position: relative;
    background: var(--c-bg);
    padding: var(--s-8);
    border: 2px solid var(--c-border);
    overflow: hidden;
    transition: border-color var(--t-fast), transform var(--t-fast);
  }

  .k7es__cadre-card:hover {
    border-color: var(--c-orange);
    transform: translateY(-3px);
  }

  .k7es__cadre-num {
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--c-orange);
  }

  .k7es__cadre-stat {
    font-size: clamp(2.5rem, 7vw, 4rem);
    font-weight: bold;
    letter-spacing: -0.05em;
    color: var(--c-text);
    line-height: 1;
    margin: var(--s-3) 0;
  }

  .k7es__cadre-name {
    font-size: 1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin-bottom: var(--s-3);
  }

  .k7es__cadre-text {
    font-size: 0.82rem;
    color: var(--c-text-secondary);
    line-height: 1.65;
  }

  .k7es__cadre-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: var(--c-orange);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--t-normal) var(--ease);
  }

  .k7es__cadre-card:hover .k7es__cadre-bar { transform: scaleX(1); }

  @media (min-width: 768px) {
    .k7es__cadre-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ====== VALUES ====== */
  .k7es__values {
    padding: var(--s-section) 0;
    background: var(--c-bg);
  }

  .k7es__manifesto {
    font-size: clamp(1.4rem, 3.5vw, 2.8rem);
    font-weight: 300;
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: var(--c-text);
    max-width: 700px;
    margin-bottom: var(--s-12);
  }

  .k7es__manifesto p { text-wrap: balance; }

  .k7es__val-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-8);
    padding-top: var(--s-8);
    border-top: 1px solid var(--c-border-light);
  }

  .k7es__val strong {
    display: block;
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--c-text);
    margin-bottom: 2px;
  }

  .k7es__val p {
    font-size: 0.78rem;
    color: var(--c-text-muted);
    line-height: 1.5;
  }

  @media (min-width: 768px) {
    .k7es__val-grid { grid-template-columns: repeat(4, 1fr); }
  }

  /* ====== ACTIVITIES MOTION GRID ====== */
  .k7es__activities {
    padding: var(--s-section) 0;
    background: var(--c-surface);
  }

  .k7es__act-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-auto-rows: 220px;
    gap: var(--s-3);
  }

  .k7es__act-card {
    position: relative;
    overflow: hidden;
    border-radius: var(--r-sm);
    background: #000;
  }

  .k7es__act-card:first-child { grid-column: 1 / -1; grid-row: span 1; }

  .k7es__act-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s var(--ease), opacity 0.3s;
  }

  .k7es__act-card:hover img { transform: scale(1.06); opacity: 0.8; }

  .k7es__act-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--s-5);
    background: linear-gradient(180deg, transparent 40%, rgb(0 0 0 / 0.7) 100%);
    pointer-events: none;
  }

  .k7es__act-num {
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--c-orange);
  }

  .k7es__act-name {
    font-size: 1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: #fff;
    line-height: 1.2;
  }

  .k7es__act-tag {
    font-size: 0.65rem;
    color: rgb(255 255 255 / 0.5);
    margin-top: 2px;
  }

  .k7es__act-price {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--c-orange);
    margin-top: 4px;
  }

  @media (min-width: 768px) {
    .k7es__act-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: 280px;
    }
    .k7es__act-card:first-child { grid-column: 1 / 3; }
    .k7es__act-name { font-size: 1.15rem; }
  }

  /* ====== CTA ====== */
  .k7es__cta {
    padding: var(--s-section) 0;
    background: var(--c-dark);
  }

  .k7es__cta-inner {
    position: relative;
    overflow: hidden;
    border-radius: var(--r-sm);
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .k7es__cta-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .k7es__cta-dim {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 0.6);
  }

  .k7es__cta-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--s-10);
  }

  .k7es__cta-title {
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: bold;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    line-height: 0.95;
    color: #fff;
    margin-bottom: var(--s-8);
  }

  .k7es__cta-btns {
    display: flex;
    gap: var(--s-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ====== REDUCED MOTION ====== */
  @media (prefers-reduced-motion: reduce) {
    .k7es__hero-bg img { animation: none; }
    .k7es__hero-content { animation: none; }
    .k7es__act-card img { transition: none; }
    .k7es__cadre-bar { transition: none; }
    .k7es__cadre-card { transition: none; }
  }
</style>
