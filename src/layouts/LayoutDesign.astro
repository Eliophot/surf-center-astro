---
import '../styles/global.css';
import HeaderDesign from '../components/v2/HeaderDesign.astro';
import FooterDesign from '../components/v2/FooterDesign.astro';
import UniversalModal from '../components/UniversalModal.astro';
import VersionSwitcher from '../components/VersionSwitcher.astro';
import StickyActions from '../components/StickyActions.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = '/og-default.jpg',
  jsonLd,
} = Astro.props;

const siteUrl = 'https://surfcenter-verdon.fr';
---

<!doctype html>
<html lang="fr" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#ffffff" id="meta-theme-color" />

    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = stored || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
        var meta = document.getElementById('meta-theme-color');
        if (meta) meta.setAttribute('content', theme === 'dark' ? '#0a0a0a' : '#ffffff');
      })();
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:site_name" content="Surf Center" />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Geo hints -->
    <meta name="geo.region" content="FR-83" />
    <meta name="geo.placename" content="Les Salles-sur-Verdon" />
    <meta name="geo.position" content="43.7766;6.2100" />
    <meta name="ICBM" content="43.7766, 6.2100" />

    {jsonLd && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])}
      />
    )}
  </head>
  <body>
    <HeaderDesign />
    <main id="main-content">
      <slot />
    </main>
    <FooterDesign />
    <UniversalModal />
    <VersionSwitcher />
    <StickyActions />

    <button class="spct" id="scrollPct" type="button" aria-label="Retour en haut">
      <span class="spct__left">
        <span class="spct__pct">
          <span class="spct__num" id="scrollValue">0</span><span class="spct__sign">%</span>
        </span>
        <span class="spct__arrow">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M8 13V3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M4 6.5L8 3l4 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </span>
      <span class="spct__sep"></span>
      <span class="spct__right">
        <span class="spct__label-scroll">SCROLL</span>
        <span class="spct__label-top">TOP</span>
      </span>
    </button>

    <style>
      .spct {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        z-index: 90;
        display: flex;
        align-items: center;
        gap: 0;
        height: 46px;
        padding: 0;
        border: 1px solid var(--c-border);
        border-radius: var(--r-full);
        background: var(--c-bg);
        box-shadow: 0 4px 24px rgb(0 0 0 / 0.08), 0 1px 3px rgb(0 0 0 / 0.04);
        cursor: pointer;
        opacity: 0;
        transform: translateY(16px);
        transition:
          opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1),
          transform 0.45s cubic-bezier(0.16, 1, 0.3, 1),
          box-shadow var(--t-fast),
          border-color var(--t-fast);
        pointer-events: none;
        user-select: none;
        font-family: var(--font-sans);
        outline: none;
      }

      [data-theme='dark'] .spct {
        background: var(--c-surface);
        border-color: var(--c-border);
        box-shadow: 0 4px 24px rgb(0 0 0 / 0.3), 0 1px 3px rgb(0 0 0 / 0.2);
      }

      .spct.is-active {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }

      .spct:hover {
        border-color: var(--c-text-muted);
        box-shadow: 0 6px 28px rgb(0 0 0 / 0.12), 0 2px 6px rgb(0 0 0 / 0.06);
      }

      [data-theme='dark'] .spct:hover {
        border-color: rgb(255 255 255 / 0.2);
        box-shadow: 0 6px 28px rgb(0 0 0 / 0.4);
      }

      .spct:active { transform: scale(0.96); }

      .spct__left {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 54px;
        height: 100%;
      }

      .spct__pct {
        display: flex;
        align-items: baseline;
        gap: 1px;
        transition: opacity 0.25s var(--ease), transform 0.25s var(--ease);
      }

      .spct__arrow {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--c-text);
        opacity: 0;
        transform: translateY(4px);
        transition: opacity 0.25s var(--ease), transform 0.25s var(--ease);
      }

      .spct:hover .spct__pct {
        opacity: 0;
        transform: translateY(-4px);
      }

      .spct:hover .spct__arrow {
        opacity: 1;
        transform: translateY(0);
      }

      .spct__num {
        font-size: 0.92rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1;
        color: var(--c-text);
        font-variant-numeric: tabular-nums;
      }

      .spct__sign {
        font-size: 0.52rem;
        font-weight: 600;
        color: var(--c-text-muted);
        line-height: 1;
        margin-left: 1px;
      }

      .spct__sep {
        width: 1px;
        height: 18px;
        background: var(--c-border);
        flex-shrink: 0;
      }

      .spct__right {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 1rem;
        height: 100%;
      }

      .spct__label-scroll,
      .spct__label-top {
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        line-height: 1;
        transition: opacity 0.25s var(--ease), transform 0.25s var(--ease);
      }

      .spct__label-scroll {
        color: var(--c-text-muted);
      }

      .spct__label-top {
        position: absolute;
        color: var(--c-text);
        opacity: 0;
        transform: translateY(4px);
      }

      .spct:hover .spct__label-scroll {
        opacity: 0;
        transform: translateY(-4px);
      }

      .spct:hover .spct__label-top {
        opacity: 1;
        transform: translateY(0);
      }

      @media (max-width: 480px) {
        .spct {
          bottom: 1.25rem;
          right: 1.25rem;
          height: 40px;
        }
        .spct__left { width: 46px; }
        .spct__num { font-size: 0.82rem; }
        .spct__right { padding: 0 0.8rem; }
        .spct__label-scroll, .spct__label-top { font-size: 0.56rem; }
      }

      @media (prefers-reduced-motion: reduce) {
        .spct,
        .spct__pct,
        .spct__arrow,
        .spct__label-scroll,
        .spct__label-top { transition: none; }
      }
    </style>

    <script is:inline>
      document.documentElement.classList.remove('no-js');
      if ('IntersectionObserver' in window) {
        var ro = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              ro.unobserve(e.target);
            }
          });
        }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll('.reveal').forEach(function (el) { ro.observe(el); });
      } else {
        document.querySelectorAll('.reveal').forEach(function (el) { el.classList.add('is-visible'); });
      }
    </script>

    <script is:inline>
      (function () {
        var el = document.getElementById('scrollPct');
        var val = document.getElementById('scrollValue');
        if (!el || !val) return;

        var ticking = false;
        var shown = false;
        var last = -1;

        function update() {
          ticking = false;
          var h = document.documentElement.scrollHeight - window.innerHeight;
          if (h <= 0) return;
          var pct = Math.round((window.scrollY / h) * 100);
          if (pct === last) return;
          last = pct;
          if (!shown && pct > 0) { shown = true; el.classList.add('is-active'); }
          if (shown && pct === 0) { shown = false; el.classList.remove('is-active'); }
          val.textContent = pct;
        }

        window.addEventListener('scroll', function () {
          if (!ticking) { ticking = true; requestAnimationFrame(update); }
        }, { passive: true });

        el.addEventListener('click', function () {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      })();
    </script>
  </body>
</html>
