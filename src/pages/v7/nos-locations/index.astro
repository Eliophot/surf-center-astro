---
import LayoutKinetic from '../../../layouts/LayoutKinetic.astro';
import { locationDetails } from '../../../data/locations';
---

<LayoutKinetic
  title="Nos Locations | Surf Center — Lac de Sainte-Croix"
  description="Location bateaux électriques, paddle, pédalo, canoë et planche à voile au lac de Sainte-Croix. Découvrez nos activités nautiques."
>
  <!-- KINETIC HERO -->
  <section class="k7loc__hero" aria-label="Nos locations">
    <div class="k7loc__hero-bg" aria-hidden="true">
      <div class="k7loc__hero-stripes"></div>
    </div>
    <div class="container k7loc__hero-inner">
      <span class="k7loc__hero-tag">5 activités · Dès 10€/h</span>
      <h1 class="k7loc__hero-title">
        <span class="k7loc__hero-t1">Nos</span>
        <span class="k7loc__hero-t2">Locations</span>
      </h1>
      <p class="k7loc__hero-sub">Bateaux électriques, paddle, pédalo, canoë, planche à voile — trouvez votre activité idéale sur le lac.</p>
    </div>
  </section>

  <!-- RACE CARDS -->
  <section class="k7loc__grid" aria-labelledby="k7loc-grid-title">
    <div class="container">
      <div class="k7loc__grid-head reveal">
        <div class="k7loc__grid-stripe" aria-hidden="true"></div>
        <h2 id="k7loc-grid-title" class="k7loc__grid-title">Activités nautiques</h2>
      </div>

      <div class="k7loc__mosaic">
        {locationDetails.map((loc, i) => (
          <a href={`/v7/nos-locations/${loc.slug}`} class:list={['k7loc__tile', `k7loc__tile--${i + 1}`, 'reveal']} style={`--d:${i * 100}ms`} aria-label={`Découvrir ${loc.title}`}>
            <img src={loc.heroImage} alt={loc.heroAlt} width="800" height="500" loading={i < 2 ? 'eager' : 'lazy'} decoding="async" />
            <div class="k7loc__overlay">
              <span class="k7loc__num">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="k7loc__name">{loc.title}</h3>
              <span class="k7loc__tag">{loc.tagline}</span>
              <span class="k7loc__price">dès {loc.price}€<small>/{loc.priceUnit}</small></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- MOTION STEPS — HOW IT WORKS -->
  <section class="k7loc__steps" aria-labelledby="k7loc-steps-title">
    <div class="container">
      <div class="k7loc__steps-head reveal">
        <div class="k7loc__steps-stripe" aria-hidden="true"></div>
        <h2 id="k7loc-steps-title" class="k7loc__steps-title">Comment ça marche</h2>
      </div>

      <div class="k7loc__steps-grid">
        <div class="k7loc__step reveal" style="--d:0ms">
          <span class="k7loc__step-num">01</span>
          <h3 class="k7loc__step-name">Choisissez</h3>
          <p class="k7loc__step-desc">Sélectionnez votre activité et la durée souhaitée. Réservation en ligne ou directement sur place.</p>
        </div>
        <div class="k7loc__step reveal" style="--d:120ms">
          <span class="k7loc__step-num">02</span>
          <h3 class="k7loc__step-name">Briefing</h3>
          <p class="k7loc__step-desc">Notre équipe vous accueille, vous équipe et vous donne un briefing sécurité personnalisé.</p>
        </div>
        <div class="k7loc__step reveal" style="--d:240ms">
          <span class="k7loc__step-num">03</span>
          <h3 class="k7loc__step-name">Naviguez</h3>
          <p class="k7loc__step-desc">Partez à la découverte du lac de Sainte-Croix et des Gorges du Verdon à votre rythme.</p>
        </div>
        <div class="k7loc__step reveal" style="--d:360ms">
          <span class="k7loc__step-num">04</span>
          <h3 class="k7loc__step-name">Profitez</h3>
          <p class="k7loc__step-desc">Prolongez au snack-pizzeria avec vue sur le lac. Pizzas, salades, glaces — tout est là.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SLANT GRID SERVICES -->
  <section class="k7loc__services" aria-labelledby="k7loc-svc-title">
    <div class="container">
      <div class="k7loc__svc-head reveal">
        <div class="k7loc__svc-stripe" aria-hidden="true"></div>
        <h2 id="k7loc-svc-title" class="k7loc__svc-title">Nos services</h2>
      </div>
      <div class="k7loc__svc-grid">
        <div class="k7loc__svc reveal" style="--d:0ms">
          <strong>Matériel récent</strong>
          <p>Flotte renouvelée chaque saison pour votre confort et votre sécurité.</p>
        </div>
        <div class="k7loc__svc reveal" style="--d:80ms">
          <strong>Sécurité</strong>
          <p>Gilets, leash, briefing — tout est inclus dans chaque location.</p>
        </div>
        <div class="k7loc__svc reveal" style="--d:160ms">
          <strong>Moniteurs diplômés</strong>
          <p>Cours et encadrement disponibles pour toutes les activités.</p>
        </div>
        <div class="k7loc__svc reveal" style="--d:240ms">
          <strong>Restauration</strong>
          <p>Snack-pizzeria sur place. Pizzas au feu de bois, terrasse vue lac.</p>
        </div>
        <div class="k7loc__svc reveal" style="--d:320ms">
          <strong>Parking gratuit</strong>
          <p>Grand parking accessible juste à côté de la base nautique.</p>
        </div>
        <div class="k7loc__svc reveal" style="--d:400ms">
          <strong>Réservation facile</strong>
          <p>Réservez en ligne ou sur place. Annulation flexible.</p>
        </div>
      </div>
    </div>
  </section>
</LayoutKinetic>

<style>
  /* ═══════════════ HERO ═══════════════ */
  .k7loc__hero {
    position: relative;
    min-height: 70svh;
    display: flex;
    align-items: flex-end;
    background: var(--c-dark);
    overflow: hidden;
  }

  .k7loc__hero-bg { position: absolute; inset: 0; }

  .k7loc__hero-stripes {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 40px,
      rgb(255 255 255 / 0.02) 40px,
      rgb(255 255 255 / 0.02) 42px
    );
  }

  .k7loc__hero-inner {
    position: relative;
    z-index: 1;
    padding: calc(var(--header-h) + var(--s-16)) 0 var(--s-16);
    animation: k7loc-up 800ms var(--ease-smooth) both;
  }

  @keyframes k7loc-up {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .k7loc__hero-tag {
    display: inline-block;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--c-orange);
    background: rgb(247 123 70 / 0.1);
    padding: 5px 16px;
    border-radius: var(--r-full);
    margin-bottom: var(--s-6);
  }

  .k7loc__hero-title {
    display: flex;
    flex-direction: column;
    margin-bottom: var(--s-6);
  }

  .k7loc__hero-t1 {
    font-size: clamp(3.5rem, 12vw, 8rem);
    font-weight: 900;
    letter-spacing: -0.06em;
    line-height: 0.85;
    color: #fff;
    text-transform: uppercase;
  }

  .k7loc__hero-t2 {
    font-size: clamp(3.5rem, 12vw, 8rem);
    font-weight: 100;
    letter-spacing: -0.04em;
    line-height: 0.85;
    color: #fff;
    text-transform: uppercase;
    padding-left: clamp(1.5rem, 5vw, 4rem);
  }

  .k7loc__hero-sub {
    font-size: 0.88rem;
    color: rgb(255 255 255 / 0.45);
    line-height: 1.7;
    max-width: 42ch;
  }

  /* ═══════════════ RACE GRID ═══════════════ */
  .k7loc__grid {
    padding: var(--s-section) 0;
    background: var(--c-bg);
  }

  .k7loc__grid-head {
    display: flex;
    align-items: center;
    gap: var(--s-5);
    margin-bottom: var(--s-10);
  }

  .k7loc__grid-stripe {
    width: 40px;
    height: 4px;
    background: var(--c-orange);
    flex-shrink: 0;
  }

  .k7loc__grid-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    line-height: 1;
  }

  .k7loc__mosaic {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-auto-rows: 240px;
    gap: var(--s-3);
  }

  .k7loc__tile {
    position: relative;
    overflow: hidden;
    border-radius: var(--r-sm);
    background: #000;
    display: block;
  }

  .k7loc__tile--1 { grid-column: 1 / -1; }
  .k7loc__tile--3 { grid-column: 1 / -1; }

  .k7loc__tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s var(--ease), opacity 0.3s;
  }

  .k7loc__tile:hover img { transform: scale(1.06); opacity: 0.8; }

  .k7loc__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--s-5);
    background: linear-gradient(180deg, transparent 30%, rgb(0 0 0 / 0.7) 100%);
    pointer-events: none;
  }

  .k7loc__num {
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--c-orange);
    margin-bottom: 2px;
  }

  .k7loc__name {
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: #fff;
    line-height: 1.2;
  }

  .k7loc__tag {
    font-size: 0.65rem;
    color: rgb(255 255 255 / 0.55);
    margin-top: 2px;
  }

  .k7loc__price {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--c-orange);
    margin-top: 4px;
  }

  .k7loc__price small {
    font-weight: 400;
    font-size: 0.65rem;
    color: rgb(255 255 255 / 0.5);
  }

  @media (min-width: 768px) {
    .k7loc__mosaic {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: 320px;
    }
    .k7loc__tile--1 { grid-column: 1 / 3; }
    .k7loc__tile--3 { grid-column: auto; }
    .k7loc__name { font-size: 1.3rem; }
  }

  /* ═══════════════ MOTION STEPS ═══════════════ */
  .k7loc__steps {
    padding: var(--s-section) 0;
    background: var(--c-surface);
  }

  .k7loc__steps-head {
    display: flex;
    align-items: center;
    gap: var(--s-5);
    margin-bottom: var(--s-10);
  }

  .k7loc__steps-stripe {
    width: 40px;
    height: 4px;
    background: var(--c-orange);
    flex-shrink: 0;
  }

  .k7loc__steps-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    line-height: 1;
  }

  .k7loc__steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-8);
  }

  .k7loc__step {
    position: relative;
    padding-left: var(--s-10);
    border-left: 2px solid var(--c-border-light);
  }

  .k7loc__step-num {
    position: absolute;
    left: calc(-1 * var(--s-1));
    top: 0;
    transform: translateX(-50%);
    font-size: 0.55rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: var(--c-orange);
    background: var(--c-surface);
    padding: 2px 0;
  }

  .k7loc__step-name {
    font-size: 1.15rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin-bottom: var(--s-2);
  }

  .k7loc__step-desc {
    font-size: 0.82rem;
    color: var(--c-text-secondary);
    line-height: 1.7;
  }

  @media (min-width: 768px) {
    .k7loc__steps-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
    }
    .k7loc__step { border-left: none; border-top: 2px solid var(--c-border-light); padding: var(--s-6) var(--s-5) 0 0; }
    .k7loc__step-num { left: 0; top: -1px; transform: translateY(-50%); padding: 0 8px 0 0; }
  }

  /* ═══════════════ SLANT SERVICES ═══════════════ */
  .k7loc__services {
    padding: var(--s-section) 0;
    background: var(--c-bg);
  }

  .k7loc__svc-head {
    display: flex;
    align-items: center;
    gap: var(--s-5);
    margin-bottom: var(--s-10);
  }

  .k7loc__svc-stripe {
    width: 40px;
    height: 4px;
    background: var(--c-orange);
    flex-shrink: 0;
  }

  .k7loc__svc-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    line-height: 1;
  }

  .k7loc__svc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-6);
    padding-top: var(--s-6);
    border-top: 1px solid var(--c-border-light);
  }

  .k7loc__svc {
    padding: var(--s-5);
    border-left: 3px solid var(--c-orange);
    background: var(--c-surface);
    border-radius: 0 var(--r-sm) var(--r-sm) 0;
  }

  .k7loc__svc strong {
    display: block;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .k7loc__svc p {
    font-size: 0.8rem;
    color: var(--c-text-secondary);
    line-height: 1.6;
  }

  @media (min-width: 600px) {
    .k7loc__svc-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 900px) {
    .k7loc__svc-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ═══════════════ MOTION ═══════════════ */
  @media (prefers-reduced-motion: reduce) {
    .k7loc__hero-inner { animation: none; }
    .k7loc__tile img { transition: none; }
  }
</style>
