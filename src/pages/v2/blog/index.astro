---
import LayoutDesign from '../../../layouts/LayoutDesign.astro';

const title = 'Blog — Actualités & conseils | Surf Center Verdon';
const description = 'Découvrez nos articles sur les activités nautiques, le lac de Sainte-Croix, les Gorges du Verdon et les coulisses du Surf Center.';

const blogPosts = [
  {
    slug: 'top-5-activites-lac-sainte-croix',
    title: 'Top 5 des activités incontournables au lac de Sainte-Croix',
    excerpt: 'Paddle, bateau électrique, canoë, pédalo ou planche à voile — découvrez les cinq activités qui font du lac de Sainte-Croix une destination nautique unique en Provence.',
    date: '2026-04-15',
    dateFormatted: '15 avril 2026',
    image: '/location-paddle-bateaux-electriques-lac-sainte-croix-gorges-verdon.jpeg',
    alt: 'Activités nautiques au lac de Sainte-Croix',
    category: 'Activités',
  },
  {
    slug: 'gorges-du-verdon-guide-complet',
    title: 'Gorges du Verdon : le guide complet pour votre séjour',
    excerpt: 'Itinéraires, bonnes adresses, saisons idéales — tout ce qu\'il faut savoir pour organiser un séjour inoubliable aux Gorges du Verdon et au lac de Sainte-Croix.',
    date: '2026-03-28',
    dateFormatted: '28 mars 2026',
    image: '/lac-sainte-croix-gorges-verdon-location-bateaux-electriques.jpg',
    alt: 'Gorges du Verdon et lac de Sainte-Croix',
    category: 'Découverte',
  },
  {
    slug: 'concerts-ete-2026-programme',
    title: 'Concerts été 2026 : la programmation du Surf Center',
    excerpt: 'Soirées acoustiques, DJ sets au coucher du soleil, soirées thématiques — découvrez le programme musical de l\'été 2026 au Surf Center.',
    date: '2026-03-10',
    dateFormatted: '10 mars 2026',
    image: '/concert-surfcenter-lac-sainte-croix.png',
    alt: 'Concert au coucher du soleil au Surf Center',
    category: 'Événements',
  },
  {
    slug: 'bateau-electrique-sans-permis-famille',
    title: 'Bateau électrique sans permis : l\'activité famille par excellence',
    excerpt: 'Silencieux, facile à piloter, écologique — le bateau électrique est l\'activité idéale pour explorer le lac en famille. On vous explique tout.',
    date: '2026-02-22',
    dateFormatted: '22 février 2026',
    image: '/location-bateau-electrique-lac-sainte-croix-surfcenter.jpeg',
    alt: 'Bateau électrique sur le lac de Sainte-Croix',
    category: 'Locations',
  },
];
---

<LayoutDesign title={title} description={description}>

  <!-- ═══ SPLIT HERO ═══ -->
  <section class="bloghub-hero" aria-label="Blog Surf Center">
    <div class="bloghub-hero__left">
      <div class="bloghub-hero__content">
        <span class="bloghub-hero__eyebrow">Actualités & Conseils</span>
        <h1 class="bloghub-hero__title">Blog</h1>
        <p class="bloghub-hero__baseline">Activités nautiques, vie du Surf Center<br/>& découverte du Verdon</p>
      </div>
      <p class="bloghub-hero__location">Surf Center · Les Salles-sur-Verdon</p>
    </div>
    <div class="bloghub-hero__right">
      <img
        class="bloghub-hero__img"
        src="/location-paddle-bateaux-electriques-lac-sainte-croix-gorges-verdon.jpeg"
        alt="Vue sur le lac de Sainte-Croix — Surf Center"
        width="960" height="1080"
        loading="eager" fetchpriority="high" decoding="async"
      />
    </div>
  </section>

  <!-- ═══ BENTO BLOG GRID ═══ -->
  <section class="section bloghub-grid" aria-labelledby="bloghub-grid-title">
    <div class="container">
      <header class="section__header reveal">
        <span class="section__eyebrow">Articles</span>
        <h2 id="bloghub-grid-title">Dernières publications</h2>
      </header>

      <div class="bloghub-bento">
        {blogPosts.map((post, i) => (
          <a href={`/v2/blog/${post.slug}`} class={`bloghub-card ${i === 0 ? 'bloghub-card--featured' : ''} reveal reveal-d${(i % 4) + 1}`}>
            <div class="bloghub-card__frame">
              <img class="bloghub-card__img" src={post.image} alt={post.alt} width="800" height="500" loading="lazy" decoding="async" />
              <div class="bloghub-card__glass-cat">
                <span>{post.category}</span>
              </div>
            </div>
            <div class="bloghub-card__body">
              <time class="bloghub-card__date" datetime={post.date}>{post.dateFormatted}</time>
              <h3 class="bloghub-card__title">{post.title}</h3>
              <p class="bloghub-card__excerpt">{post.excerpt}</p>
              <span class="bloghub-card__read">
                Lire l'article
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</LayoutDesign>

<style>
  /* ═══ SPLIT HERO ═══ */
  .bloghub-hero {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 70svh;
  }

  .bloghub-hero__left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: calc(var(--header-h) + var(--s-8)) var(--s-6) var(--s-8);
    background: var(--c-dark);
    color: #fff;
    position: relative;
  }

  .bloghub-hero__content { max-width: 540px; }

  .bloghub-hero__eyebrow {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--c-orange);
    margin-bottom: var(--s-6);
    display: block;
  }

  .bloghub-hero__title {
    font-size: clamp(5rem, 14vw, 12rem);
    font-weight: 800;
    line-height: 0.85;
    letter-spacing: -0.05em;
    text-transform: uppercase;
    color: #fff !important;
    margin-bottom: var(--s-6);
  }

  .bloghub-hero__baseline {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgb(255 255 255 / 0.45);
    line-height: 1.7;
  }

  .bloghub-hero__location {
    position: absolute;
    bottom: var(--s-6);
    left: var(--s-6);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.25);
  }

  .bloghub-hero__right {
    position: relative;
    min-height: 40vh;
  }

  .bloghub-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 900px) {
    .bloghub-hero { grid-template-columns: 1fr 1fr; min-height: 60svh; }
    .bloghub-hero__left { padding: var(--s-20) var(--s-16) var(--s-12); }
    .bloghub-hero__location { left: var(--s-16); }
    .bloghub-hero__right { min-height: 60svh; }
  }

  /* ═══ BENTO BLOG GRID ═══ */
  .bloghub-bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-6);
  }

  .bloghub-card {
    text-decoration: none;
    color: var(--c-text);
    border-radius: var(--r-xl);
    overflow: hidden;
    background: var(--c-surface);
    border: 1px solid var(--c-border-light);
    display: flex;
    flex-direction: column;
    transition: transform var(--t-normal) var(--ease), box-shadow var(--t-normal) var(--ease);
  }

  .bloghub-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .bloghub-card__frame {
    position: relative;
    overflow: hidden;
  }

  .bloghub-card__img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    transition: transform 0.8s var(--ease);
  }

  .bloghub-card:hover .bloghub-card__img {
    transform: scale(1.05);
  }

  .bloghub-card__glass-cat {
    position: absolute;
    top: var(--s-4);
    left: var(--s-4);
    background: rgb(0 0 0 / 0.5);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgb(255 255 255 / 0.12);
    border-radius: var(--r-full);
    padding: var(--s-1) var(--s-4);
  }

  .bloghub-card__glass-cat span {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fff;
  }

  .bloghub-card__body {
    padding: var(--s-6);
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    flex: 1;
  }

  .bloghub-card__date {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-orange);
  }

  .bloghub-card__title {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.3;
    text-transform: none;
    letter-spacing: normal;
  }

  .bloghub-card__excerpt {
    font-size: 0.85rem;
    color: var(--c-text-secondary);
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bloghub-card__read {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-orange);
    margin-top: auto;
    padding-top: var(--s-3);
    transition: gap var(--t-fast);
  }

  .bloghub-card:hover .bloghub-card__read { gap: var(--s-3); }

  @media (min-width: 768px) {
    .bloghub-bento {
      grid-template-columns: repeat(2, 1fr);
    }

    .bloghub-card--featured {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: 1.4fr 1fr;
    }

    .bloghub-card--featured .bloghub-card__img {
      aspect-ratio: auto;
      height: 100%;
    }

    .bloghub-card--featured .bloghub-card__body {
      padding: var(--s-8);
      justify-content: center;
    }

    .bloghub-card--featured .bloghub-card__title {
      font-size: 1.4rem;
    }
  }

  @media (min-width: 1024px) {
    .bloghub-bento {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
