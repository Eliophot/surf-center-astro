---
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const versionPrefixes = ['/', '/v2', '/v7', '/v8', '/v11'];

const versions = [
  { label: 'Standard', prefix: '/', icon: 'S' },
  { label: 'Design', prefix: '/v2', icon: 'D' },
  { label: 'Kinetic', prefix: '/v7', icon: 'K' },
  { label: 'Marketing', prefix: '/v8', icon: 'M' },
  { label: 'Hyper Design', prefix: '/v11', icon: 'H' },
];
const count = versions.length;

function getActivePrefix(): string {
  const clean = currentPath === '' ? '/' : currentPath;
  for (const p of versionPrefixes) {
    if (p !== '/' && clean.startsWith(p)) return p;
  }
  return '/';
}

function getPageSuffix(): string {
  const prefix = getActivePrefix();
  if (prefix === '/') return currentPath === '/' ? '' : currentPath;
  return currentPath.slice(prefix.length);
}

function buildHref(targetPrefix: string): string {
  const suffix = getPageSuffix();
  if (targetPrefix === '/') return suffix || '/';
  return suffix ? targetPrefix + suffix : targetPrefix;
}

function isActive(prefix: string): boolean {
  return getActivePrefix() === prefix;
}

const activeIdx = versions.findIndex((v) => isActive(v.prefix));
const activeVersion = versions[activeIdx];
---

<!-- ── Desktop version switcher ── -->
<nav class="vsw" aria-label="Changer de version">
  <button class="vsw__trigger" type="button" aria-expanded="false" aria-haspopup="true">
    <svg class="vsw__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="3" width="7" height="7" rx="1.5"/>
      <rect x="14" y="3" width="7" height="7" rx="1.5"/>
      <rect x="3" y="14" width="7" height="7" rx="1.5"/>
      <rect x="14" y="14" width="7" height="7" rx="1.5"/>
    </svg>
    <span class="vsw__hint">Versions</span>
  </button>

  <div class="vsw__dropdown">
    <div class="vsw__bar" style={`--active-idx: ${activeIdx}; --count: ${count}`}>
      <span class="vsw__indicator" aria-hidden="true"></span>
      {versions.map((v) => (
        <a
          href={buildHref(v.prefix)}
          class:list={['vsw__link', { 'is-active': isActive(v.prefix) }]}
          aria-current={isActive(v.prefix) ? 'page' : undefined}
        >
          {v.label}
        </a>
      ))}
    </div>
    <span class="vsw__badge">preprod</span>
  </div>
</nav>

<!-- ── Mobile version switcher (bottom sheet) ── -->
<div class="vsm" data-vsm>
  <button class="vsm__fab" type="button" aria-label="Changer de version" data-vsm-trigger>
    <span class="vsm__fab-icon">{activeVersion.icon}</span>
    <svg class="vsm__fab-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
      <path d="M2.5 6L5 3.5 7.5 6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div class="vsm__overlay" data-vsm-overlay></div>

  <div class="vsm__sheet" role="dialog" aria-label="Versions du site" data-vsm-sheet>
    <div class="vsm__handle" aria-hidden="true"><span></span></div>
    <div class="vsm__header">
      <span class="vsm__title">Version du site</span>
      <span class="vsm__preprod">preprod</span>
    </div>
    <div class="vsm__list">
      {versions.map((v, i) => (
        <a
          href={buildHref(v.prefix)}
          class:list={['vsm__item', { 'is-active': isActive(v.prefix) }]}
          aria-current={isActive(v.prefix) ? 'page' : undefined}
        >
          <span class="vsm__item-icon">{v.icon}</span>
          <span class="vsm__item-content">
            <span class="vsm__item-label">{v.label}</span>
            <span class="vsm__item-path">{v.prefix === '/' ? '/' : v.prefix}</span>
          </span>
          {isActive(v.prefix) && (
            <svg class="vsm__item-check" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3.5 8.5L6.5 11.5L12.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          )}
        </a>
      ))}
    </div>
  </div>
</div>

<script>
  // Desktop switcher
  const nav = document.querySelector('.vsw') as HTMLElement | null;
  const trigger = nav?.querySelector('.vsw__trigger') as HTMLButtonElement | null;
  if (nav && trigger) {
    trigger.addEventListener('click', () => {
      const isOpen = nav.classList.toggle('is-open');
      trigger.setAttribute('aria-expanded', String(isOpen));
    });

    document.addEventListener('click', (e) => {
      if (!nav.contains(e.target as Node)) {
        nav.classList.remove('is-open');
        trigger.setAttribute('aria-expanded', 'false');
      }
    });
  }

  // Mobile switcher
  const vsm = document.querySelector('[data-vsm]') as HTMLElement | null;
  const vsmTrigger = document.querySelector('[data-vsm-trigger]') as HTMLButtonElement | null;
  const vsmOverlay = document.querySelector('[data-vsm-overlay]') as HTMLElement | null;
  const vsmSheet = document.querySelector('[data-vsm-sheet]') as HTMLElement | null;

  if (vsm && vsmTrigger && vsmOverlay && vsmSheet) {
    function openSheet() {
      vsm!.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }

    function closeSheet() {
      vsm!.classList.remove('is-open');
      document.body.style.overflow = '';
    }

    vsmTrigger.addEventListener('click', openSheet);
    vsmOverlay.addEventListener('click', closeSheet);

    vsmSheet.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement).closest('.vsm__item');
      if (link) closeSheet();
    });

    // Swipe-down to close
    let startY = 0;
    vsmSheet.addEventListener('touchstart', (e) => {
      startY = e.touches[0].clientY;
    }, { passive: true });

    vsmSheet.addEventListener('touchend', (e) => {
      const dy = e.changedTouches[0].clientY - startY;
      if (dy > 60) closeSheet();
    }, { passive: true });
  }
</script>

<style>
  /* ══════════════════════════════════════
     DESKTOP — left sidebar trigger
     ══════════════════════════════════════ */

  .vsw {
    position: fixed;
    left: var(--s-5);
    top: 50%;
    transform: translateY(-50%);
    z-index: 900;
    animation: vsw-enter 600ms var(--ease-smooth) 800ms both;
  }

  @keyframes vsw-enter {
    from { opacity: 0; transform: translateY(-50%) translateX(-16px); }
    to { opacity: 1; transform: translateY(-50%) translateX(0); }
  }

  .vsw__trigger {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 9px;
    background: #111;
    border: 1px solid rgb(255 255 255 / 0.08);
    border-radius: 10px;
    color: rgb(255 255 255 / 0.4);
    cursor: pointer;
    box-shadow: 0 4px 20px rgb(0 0 0 / 0.3);
    transition: color 250ms, background 250ms, border-color 250ms, gap 300ms, padding 300ms;
    -webkit-tap-highlight-color: transparent;
    overflow: hidden;
  }

  .vsw__trigger:hover {
    color: #fff;
    background: #1a1a1a;
    border-color: rgb(255 255 255 / 0.15);
    gap: 8px;
    padding: 9px 12px 9px 9px;
  }

  .vsw__icon { flex-shrink: 0; }

  .vsw__hint {
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
    max-width: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-width 300ms var(--ease), opacity 250ms;
  }

  .vsw__trigger:hover .vsw__hint {
    max-width: 80px;
    opacity: 1;
  }

  .vsw__dropdown {
    position: absolute;
    left: 0;
    top: calc(100% + 8px);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    pointer-events: none;
    transition: opacity 200ms, transform 200ms, visibility 0ms 200ms;
  }

  .vsw.is-open .vsw__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
    transition: opacity 200ms, transform 200ms, visibility 0ms 0ms;
  }

  .vsw__bar {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 4px;
    background: #111;
    border-radius: 14px;
    border: 1px solid rgb(255 255 255 / 0.08);
    box-shadow: 0 10px 40px rgb(0 0 0 / 0.4);
  }

  .vsw__indicator {
    position: absolute;
    left: 4px;
    right: 4px;
    height: calc(100% / var(--count) - 4px * 2 / var(--count));
    top: calc(4px + var(--active-idx) * (100% / var(--count)));
    background: rgb(255 255 255 / 0.1);
    border-radius: 10px;
    transition: top 350ms var(--ease);
    pointer-events: none;
    border: 1px solid rgb(255 255 255 / 0.05);
  }

  .vsw__link {
    position: relative;
    z-index: 1;
    display: block;
    padding: 8px 16px;
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgb(255 255 255 / 0.28);
    white-space: nowrap;
    text-align: center;
    transition: color 200ms;
    -webkit-tap-highlight-color: transparent;
  }

  .vsw__link:hover { color: rgb(255 255 255 / 0.6); }
  .vsw__link.is-active { color: #fff; }

  .vsw__badge {
    align-self: center;
    font-size: 0.42rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--c-orange);
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .vsw { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .vsw { animation: none; }
    .vsw__indicator { transition: none; }
    .vsw__dropdown { transition: none; }
    .vsw__hint { transition: none; }
  }

  /* ══════════════════════════════════════
     MOBILE — bottom sheet switcher
     ══════════════════════════════════════ */

  .vsm {
    display: none;
  }

  @media (max-width: 768px) {
    .vsm {
      display: block;
      position: fixed;
      z-index: 950;
    }

    /* ── FAB trigger ── */

    .vsm__fab {
      position: fixed;
      left: var(--s-4);
      bottom: var(--s-5);
      z-index: 951;
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 10px 14px;
      background: #111;
      border: 1px solid rgb(255 255 255 / 0.1);
      border-radius: var(--r-full);
      color: rgb(255 255 255 / 0.6);
      cursor: pointer;
      box-shadow: 0 4px 24px rgb(0 0 0 / 0.35);
      font-family: inherit;
      -webkit-tap-highlight-color: transparent;
      animation: vsm-fab-in 500ms var(--ease-smooth) 800ms both;
    }

    @keyframes vsm-fab-in {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .vsm__fab:active {
      transform: scale(0.95);
    }

    .vsm__fab-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 22px;
      height: 22px;
      background: var(--c-orange);
      color: #fff;
      border-radius: 6px;
      font-size: 0.6rem;
      font-weight: 800;
      letter-spacing: 0.02em;
    }

    .vsm__fab-chevron {
      transition: transform 300ms var(--ease);
    }

    .vsm.is-open .vsm__fab-chevron {
      transform: rotate(180deg);
    }

    /* ── Overlay ── */

    .vsm__overlay {
      position: fixed;
      inset: 0;
      z-index: 949;
      background: rgb(0 0 0 / 0.5);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      opacity: 0;
      visibility: hidden;
      transition: opacity 300ms, visibility 0ms 300ms;
    }

    .vsm.is-open .vsm__overlay {
      opacity: 1;
      visibility: visible;
      transition: opacity 300ms, visibility 0ms 0ms;
    }

    /* ── Sheet ── */

    .vsm__sheet {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 952;
      background: #111;
      border-radius: 20px 20px 0 0;
      border-top: 1px solid rgb(255 255 255 / 0.08);
      padding: 0 var(--s-5) calc(env(safe-area-inset-bottom, 0px) + var(--s-6));
      transform: translateY(100%);
      transition: transform 350ms cubic-bezier(0.16, 1, 0.3, 1);
      max-height: 85vh;
      overflow-y: auto;
      overscroll-behavior: contain;
      box-shadow: 0 -8px 40px rgb(0 0 0 / 0.4);
    }

    .vsm.is-open .vsm__sheet {
      transform: translateY(0);
    }

    /* ── Handle ── */

    .vsm__handle {
      display: flex;
      justify-content: center;
      padding: 10px 0 6px;
    }

    .vsm__handle span {
      width: 36px;
      height: 4px;
      border-radius: 2px;
      background: rgb(255 255 255 / 0.15);
    }

    /* ── Header ── */

    .vsm__header {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: var(--s-3) 0 var(--s-4);
    }

    .vsm__title {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgb(255 255 255 / 0.4);
    }

    .vsm__preprod {
      font-size: 0.5rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--c-orange);
      opacity: 0.7;
      padding: 2px 8px;
      border: 1px solid rgb(255 255 255 / 0.06);
      border-radius: var(--r-full);
    }

    /* ── List ── */

    .vsm__list {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .vsm__item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 12px;
      border-radius: 12px;
      text-decoration: none;
      color: rgb(255 255 255 / 0.45);
      transition: background 200ms, color 200ms;
      -webkit-tap-highlight-color: transparent;
    }

    .vsm__item:active {
      background: rgb(255 255 255 / 0.04);
    }

    .vsm__item.is-active {
      background: rgb(255 255 255 / 0.06);
      color: #fff;
    }

    .vsm__item-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 34px;
      height: 34px;
      border-radius: 8px;
      background: rgb(255 255 255 / 0.05);
      border: 1px solid rgb(255 255 255 / 0.06);
      font-size: 0.7rem;
      font-weight: 800;
      color: rgb(255 255 255 / 0.4);
      flex-shrink: 0;
    }

    .vsm__item.is-active .vsm__item-icon {
      background: var(--c-orange);
      border-color: transparent;
      color: #fff;
    }

    .vsm__item-content {
      display: flex;
      flex-direction: column;
      gap: 2px;
      flex: 1;
      min-width: 0;
    }

    .vsm__item-label {
      font-size: 0.85rem;
      font-weight: 600;
      line-height: 1.2;
    }

    .vsm__item-path {
      font-size: 0.65rem;
      color: rgb(255 255 255 / 0.2);
      font-family: monospace;
    }

    .vsm__item.is-active .vsm__item-path {
      color: rgb(255 255 255 / 0.35);
    }

    .vsm__item-check {
      flex-shrink: 0;
      color: var(--c-orange);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .vsm__fab { animation: none; }
    .vsm__sheet { transition: none; }
    .vsm__overlay { transition: none; }
    .vsm__fab-chevron { transition: none; }
  }
</style>
