---
export type BookingButtonProps = {
  href?: string;
  label?: string;
  size?: 'md' | 'lg';
  desktopOnly?: boolean;
  pulse?: boolean;
  class?: string;
};

const {
  href = '/v8/nos-locations',
  label = 'Réserver maintenant',
  size = 'md',
  desktopOnly = false,
  pulse = false,
  class: className = '',
} = Astro.props as BookingButtonProps;

const classes = [
  'm8-booking',
  size === 'lg' ? 'm8-booking--lg' : '',
  desktopOnly ? 'm8-booking--desktop' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<a href={href} class={classes}>
  {pulse && <span class="m8-booking__pulse" aria-hidden="true"></span>}
  <span class="m8-booking__flip">
    <span class="m8-booking__front">{label}</span>
    <span class="m8-booking__back">{label}</span>
  </span>
</a>

<style>
  .m8-booking {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    padding: 0.9rem 2.2rem;
    background: var(--c-orange);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    border-radius: var(--r-full);
    white-space: nowrap;
    text-decoration: none;
    transition: background var(--t-fast), transform var(--t-fast), box-shadow var(--t-fast);
  }

  .m8-booking:hover {
    background: var(--c-orange-dark);
    transform: translateY(-1px);
    box-shadow: var(--shadow-glow);
    color: #fff;
  }

  .m8-booking:active { transform: scale(0.97); }

  .m8-booking__flip {
    display: grid;
    grid-template: 1fr / 1fr;
    overflow: hidden;
    height: 1.4em;
    line-height: 1.4;
    perspective: 200px;
  }

  .m8-booking__front,
  .m8-booking__back {
    grid-area: 1 / 1;
    backface-visibility: hidden;
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.45s ease;
  }

  .m8-booking__back {
    transform: rotateX(90deg) translateZ(0.55em);
    opacity: 0;
  }

  .m8-booking:hover .m8-booking__front {
    transform: rotateX(-90deg) translateZ(0.55em);
    opacity: 0;
  }

  .m8-booking:hover .m8-booking__back {
    transform: rotateX(0deg);
    opacity: 1;
  }

  .m8-booking__pulse {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    border-radius: inherit;
    transform: translate(-50%, -50%);
    border: 2px solid var(--c-orange);
    animation: m8-booking-pulse 2.5s ease-out infinite;
    pointer-events: none;
  }

  @keyframes m8-booking-pulse {
    0% { opacity: 0.6; transform: translate(-50%, -50%) scale(1); }
    100% { opacity: 0; transform: translate(-50%, -50%) scale(1.35); }
  }

  .m8-booking--lg {
    padding: 1rem 2.6rem;
    font-size: 0.82rem;
  }

  .m8-booking--desktop { display: none; }

  @media (min-width: 960px) {
    .m8-booking--desktop { display: inline-flex; }
  }

  @media (prefers-reduced-motion: reduce) {
    .m8-booking__pulse { animation: none; }
    .m8-booking__front,
    .m8-booking__back { transition: none; }
  }
</style>
