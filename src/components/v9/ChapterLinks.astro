---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import imgBateau from '../../assets/images/location-bateau-electrique-lac-sainte-croix-surfcenter.jpeg';
import imgEsprit from '../../assets/images/esprit.png';
import imgSnack from '../../assets/images/drone-snack-pedalo-lac-sainte-croix-surfcenter-salades.jpeg';
import imgYoga from '../../assets/images/sarah-cours-yoga-surfcenter-lac-sainte-croix.jpg';
import imgConcert from '../../assets/images/concert-surfcenter-lac-sainte-croix.png';

const links: { title: string; href: string; image: ImageMetadata; alt: string }[] = [
  { title: "Nos locations", href: "/nos-locations", image: imgBateau, alt: "Locations Surf Center" },
  { title: "L'esprit", href: "/esprit-surf-center", image: imgEsprit, alt: "L'esprit Surf Center" },
  { title: "Restauration", href: "/restauration", image: imgSnack, alt: "Snack Surf Center" },
  { title: "Animations", href: "/animations", image: imgYoga, alt: "Animations Surf Center" },
  { title: "Événements", href: "/groupes-evenements", image: imgConcert, alt: "Événements Surf Center" },
];
---

<section class="section clink section--surface" aria-labelledby="v9-links-title">
  <div class="container">
    <h2 id="v9-links-title" class="clink__title reveal">Tout le Surf Center</h2>
    <div class="clink__row">
      {links.map((l, i) => (
        <a href={l.href} class={`clink__item reveal reveal-d${Math.min(i + 1, 4)}`}>
          <Image class="clink__img" src={l.image} alt={l.alt} width={300} height={200} loading="lazy" decoding="async" format="webp" quality={70} />
          <div class="clink__overlay"></div>
          <span class="clink__label">{l.title}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .clink__title {
    font-size: clamp(1.2rem, 3vw, 1.6rem);
    font-weight: 300;
    text-transform: none;
    text-align: center;
    margin-bottom: var(--s-10);
  }

  .clink__row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--s-3);
  }

  .clink__item {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border-radius: var(--r-md);
    text-decoration: none;
    color: #fff;
  }

  .clink__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s var(--ease); }
  .clink__item:hover .clink__img { transform: scale(1.05); }

  .clink__overlay { position: absolute; inset: 0; background: rgb(0 0 0 / 0.5); transition: background var(--t-fast); }
  .clink__item:hover .clink__overlay { background: rgb(0 0 0 / 0.35); }

  .clink__label {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  @media (min-width: 768px) { .clink__row { grid-template-columns: repeat(5, 1fr); } }
</style>
