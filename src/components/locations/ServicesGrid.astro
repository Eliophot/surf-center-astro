---
interface ServiceItem {
  icon: string;
  label: string;
}

interface Props {
  services: ServiceItem[];
  title?: string;
}

const { services, title = 'Services inclus' } = Astro.props;

const iconMap: Record<string, string> = {
  anchor: 'M12 22V8M12 8a4 4 0 100-8 4 4 0 000 8zM5 12H2a10 10 0 0020 0h-3',
  users: 'M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zM22 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75',
  battery: 'M17 6H3a2 2 0 00-2 2v8a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2zM23 13v-2',
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  sun: 'M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41M16 12a4 4 0 11-8 0 4 4 0 018 0z',
  map: 'M1 6v16l7-4 8 4 7-4V2l-7 4-8-4-7 4zM8 2v16M16 6v16',
  zap: 'M13 2L3 14h9l-1 10 10-12h-9l1-10z',
};
---

<div class="svcgrid section" aria-labelledby="svc-title">
  <div class="container">
    <header class="section__header reveal">
      <span class="section__eyebrow">Prestations</span>
      <h2 id="svc-title">{title}</h2>
    </header>

    <div class="svcgrid__grid" role="list">
      {services.map((svc, i) => (
        <div class={`svcgrid__item reveal reveal-d${Math.min(i + 1, 4)}`} role="listitem">
          <div class="svcgrid__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d={iconMap[svc.icon] || iconMap.anchor} />
            </svg>
          </div>
          <span class="svcgrid__label">{svc.label}</span>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .svcgrid__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--s-6);
  }

  .svcgrid__item {
    display: flex;
    align-items: center;
    gap: var(--s-4);
    padding: var(--s-5);
    background: var(--c-surface);
    border-radius: var(--r-md);
    border: 1px solid var(--c-border-light);
  }

  .svcgrid__icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--r-sm);
    background: var(--c-bg);
    color: var(--c-orange);
    flex-shrink: 0;
  }

  .svcgrid__label {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--c-text-secondary);
    line-height: 1.4;
  }

  @media (min-width: 768px) {
    .svcgrid__grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
