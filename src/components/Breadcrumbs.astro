---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="crumbs" aria-label="Fil d'Ariane">
  <ol class="crumbs__list container">
    {items.map((item, i) => (
      <li class="crumbs__item">
        {i > 0 && (
          <svg class="crumbs__sep" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M4.5 2.5l3 3.5-3 3.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        )}
        {item.href
          ? <a href={item.href} class="crumbs__link">{item.label}</a>
          : <span class="crumbs__current" aria-current="page">{item.label}</span>
        }
      </li>
    ))}
  </ol>
</nav>

<style>
  .crumbs {
    padding-block: var(--s-4);
    padding-inline: var(--s-4);
    background: transparent;
  }

  .crumbs__list {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--s-1);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .crumbs__item {
    display: inline-flex;
    align-items: center;
    gap: var(--s-1);
  }

  .crumbs__sep {
    color: var(--c-text-muted);
    flex-shrink: 0;
    opacity: 0.5;
  }

  .crumbs__link {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--c-text-muted);
    text-decoration: none;
    transition: color var(--t-fast);
  }

  .crumbs__link:hover {
    color: var(--c-orange);
  }

  .crumbs__current {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--c-text-secondary);
  }
</style>
