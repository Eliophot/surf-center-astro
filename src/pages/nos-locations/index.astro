---
import Layout from '../../layouts/Layout.astro';
import LocationHero from '../../components/locations/LocationHero.astro';
import LocationCards from '../../components/locations/LocationCards.astro';
import HowItWorks from '../../components/locations/HowItWorks.astro';
import ServicesGrid from '../../components/locations/ServicesGrid.astro';
import Maillage from '../../components/Maillage.astro';
import BookingCTA from '../../components/locations/BookingCTA.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

import imgHeroLocations from '../../assets/images/location-paddle-bateaux-electriques-lac-sainte-croix-gorges-verdon.jpeg';

const title = 'Nos locations — Bateaux, paddle, pédalo, canoë, catamaran | Surf Center Verdon';
const description = 'Location de bateaux électriques sans permis, paddle, pédalo, canoë, planche à voile et catamaran au lac de Sainte-Croix. Tarifs, créneaux et réservation en ligne — Surf Center, Gorges du Verdon.';

const sharedServices = [
  { icon: 'pet', label: 'Animaux acceptés' },
  { icon: 'nopermit', label: 'Location sans permis' },
  { icon: 'calendar', label: 'Réservation en ligne' },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Locations nautiques — Surf Center',
    description: 'Bateaux électriques, paddle, pédalo, canoë, planche à voile et catamaran au lac de Sainte-Croix.',
    url: 'https://surfcenter-verdon.fr/nos-locations',
    numberOfItems: 6,
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Bateaux électriques', url: 'https://surfcenter-verdon.fr/nos-locations/bateau-electrique' },
      { '@type': 'ListItem', position: 2, name: 'Stand-up Paddle', url: 'https://surfcenter-verdon.fr/nos-locations/paddle' },
      { '@type': 'ListItem', position: 3, name: 'Pédalos', url: 'https://surfcenter-verdon.fr/nos-locations/pedalo' },
      { '@type': 'ListItem', position: 4, name: 'Canoë-Kayak', url: 'https://surfcenter-verdon.fr/nos-locations/canoe' },
      { '@type': 'ListItem', position: 5, name: 'Planche à voile', url: 'https://surfcenter-verdon.fr/nos-locations/planche-a-voile' },
      { '@type': 'ListItem', position: 6, name: 'Catamaran', url: 'https://surfcenter-verdon.fr/nos-locations/catamaran' },
    ],
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <LocationHero
    title="Nos locations"
    tagline="Lac de Sainte-Croix · Gorges du Verdon"
    image={imgHeroLocations}
    alt="Paddle et bateaux électriques sur le lac de Sainte-Croix — Surf Center"
  />
  <Breadcrumbs items={[
    { label: 'Accueil', href: '/' },
    { label: 'Nos locations' },
  ]} />
  <LocationCards />
  <HowItWorks />
  <ServicesGrid services={sharedServices} title="Inclus avec chaque location" />
  <Maillage />
  <BookingCTA />
</Layout>
