---
const currentYear = new Date().getFullYear();

const navColumns = [
  {
    title: "Nos locations",
    links: [
      { label: "Bateau électrique", href: "/v2/nos-locations" },
      { label: "Paddle board", href: "/v2/nos-locations" },
      { label: "Pédalo", href: "/v2/nos-locations" },
      { label: "Canoë", href: "/v2/nos-locations" },
      { label: "Planche à voile", href: "/v2/nos-locations" },
    ],
  },
  {
    title: "Surf Center",
    links: [
      { label: "L'esprit Surf Center", href: "/v2/esprit-surf-center" },
      { label: "Restauration", href: "/v2/restauration" },
      { label: "Animations", href: "/v2/animations" },
      { label: "Groupes & Événements", href: "/v2/groupes-evenements" },
      { label: "Blog", href: "/v2/blog" },
    ],
  },
  {
    title: "Légal",
    links: [
      { label: "Mentions légales", href: "/v2/mentions-legales" },
      { label: "Confidentialité", href: "/v2/confidentialite" },
      { label: "CGV", href: "/v2/cgv" },
    ],
  },
];
---

<footer class="fd2" role="contentinfo" aria-label="Pied de page">
  <div class="fd2__accent" aria-hidden="true"></div>

  <div class="fd2__top">
    <div class="container fd2__grid">
      <div class="fd2__brand">
        <a href="/v2" class="fd2__logo" aria-label="Surf Center — Accueil">
          <img
            class="fd2__logo-img"
            src="/logo-surf-center2.png"
            alt=""
            width="120"
            height="36"
            loading="lazy"
          />
        </a>
        <p class="fd2__tagline">
          Base nautique au lac de Sainte-Croix,<br />
          Les Salles-sur-Verdon · Gorges du Verdon.
        </p>
        <address class="fd2__address">
          <p><a href="tel:+33492771450">04 92 77 14 50</a></p>
          <p><a href="mailto:contact@surfcenter-verdon.fr">contact@surfcenter-verdon.fr</a></p>
        </address>
        <div class="fd2__social">
          <a href="https://www.instagram.com/surfcenterverdon/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="fd2__social-link">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <rect x="1.5" y="1.5" width="15" height="15" rx="4" stroke="currentColor" stroke-width="1.2"/>
              <circle cx="9" cy="9" r="3.5" stroke="currentColor" stroke-width="1.2"/>
              <circle cx="13.25" cy="4.75" r="0.75" fill="currentColor"/>
            </svg>
          </a>
          <a href="https://www.facebook.com/surfcenter.verdon" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="fd2__social-link">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M10.5 3H12V0.75h-2.25C8.1 0.75 7 1.95 7 3.75V5.5H5v2.25h2V16.5h2.75V7.75h2L12 5.5h-2.25V4c0-.55.2-1 .75-1Z" fill="currentColor" transform="translate(0 0.75)"/>
            </svg>
          </a>
        </div>
      </div>

      {navColumns.map((col) => (
        <nav class="fd2__col" aria-label={col.title}>
          <p class="fd2__col-title">{col.title}</p>
          <ul role="list">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="fd2__link">{link.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      ))}
    </div>
  </div>

  <div class="fd2__bottom">
    <div class="container fd2__bottom-inner">
      <p>© {currentYear} Surf Center · Les Salles-sur-Verdon</p>
      <p class="fd2__credit">Crafted with passion on the Verdon</p>
    </div>
  </div>
</footer>

<style>
  .fd2 {
    position: relative;
    background: #050505;
    color: rgb(255 255 255 / 0.55);
    overflow: hidden;
  }

  .fd2__accent {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--c-orange) 30%,
      var(--c-blue) 70%,
      transparent 100%
    );
    opacity: 0.5;
  }

  .fd2__top {
    padding-block: var(--s-20) var(--s-16);
  }

  .fd2__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-12);
  }

  .fd2__brand {
    max-width: 300px;
  }

  .fd2__logo {
    display: flex;
    align-items: center;
    margin-bottom: var(--s-5);
  }

  .fd2__logo-img {
    height: 24px;
    width: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.5;
    transition: opacity var(--t-fast);
  }

  .fd2__logo:hover .fd2__logo-img {
    opacity: 0.8;
  }

  .fd2__tagline {
    font-size: 0.8rem;
    line-height: 1.6;
    color: rgb(255 255 255 / 0.3);
    margin-bottom: var(--s-5);
  }

  .fd2__address {
    font-style: normal;
    font-size: 0.78rem;
    line-height: 1.8;
    color: rgb(255 255 255 / 0.35);
    margin-bottom: var(--s-5);
  }
  .fd2__address a {
    transition: color var(--t-fast);
  }
  .fd2__address a:hover { color: var(--c-orange); }

  .fd2__social {
    display: flex;
    gap: var(--s-3);
  }

  .fd2__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border: 1px solid rgb(255 255 255 / 0.08);
    border-radius: 50%;
    color: rgb(255 255 255 / 0.35);
    transition: color var(--t-fast), border-color var(--t-fast), background var(--t-fast);
  }

  .fd2__social-link:hover {
    color: var(--c-orange);
    border-color: rgb(247 123 70 / 0.3);
    background: rgb(247 123 70 / 0.06);
  }

  .fd2__col-title {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.25);
    margin-bottom: var(--s-5);
    padding-bottom: var(--s-3);
    border-bottom: 1px solid rgb(255 255 255 / 0.06);
  }

  .fd2__col ul {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }

  .fd2__link {
    position: relative;
    font-size: 0.8rem;
    color: rgb(255 255 255 / 0.45);
    transition: color var(--t-fast), padding-left var(--t-fast);
  }

  .fd2__link:hover {
    color: #fff;
    padding-left: 0.5rem;
  }

  .fd2__link::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 0;
    height: 1px;
    background: var(--c-orange);
    transition: width var(--t-fast);
    transform: translateY(-50%);
  }

  .fd2__link:hover::before {
    width: 0.3rem;
  }

  .fd2__bottom {
    padding-block: var(--s-6);
    border-top: 1px solid rgb(255 255 255 / 0.06);
  }

  .fd2__bottom-inner {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
    font-size: 0.68rem;
    color: rgb(255 255 255 / 0.2);
    letter-spacing: 0.04em;
  }

  .fd2__credit {
    font-style: italic;
    color: rgb(255 255 255 / 0.12);
  }

  /* ── Bento grid layout on larger screens ── */

  @media (min-width: 640px) {
    .fd2__grid {
      grid-template-columns: 1.5fr 1fr 1fr;
      gap: var(--s-10) var(--s-8);
    }
    .fd2__brand {
      grid-row: 1 / 3;
    }
  }

  @media (min-width: 960px) {
    .fd2__grid {
      grid-template-columns: 1.6fr repeat(3, 1fr);
      gap: var(--s-10) var(--s-12);
    }
    .fd2__brand {
      grid-row: auto;
    }
    .fd2__bottom-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fd2__link,
    .fd2__link::before,
    .fd2__social-link,
    .fd2__logo-img {
      transition: none;
    }
  }
</style>
