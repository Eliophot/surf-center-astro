---
interface ServiceItem {
  icon: string;
  label: string;
}

interface Props {
  services: ServiceItem[];
  title?: string;
}

const { services, title = 'Services inclus' } = Astro.props;
---

<div class="svcgrid section" aria-labelledby="svc-title">
  <div class="container">
    <header class="section__header reveal">
      <span class="section__eyebrow">Nos engagements</span>
      <h2 id="svc-title">{title}</h2>
    </header>

    <div class="svcgrid__grid" role="list">
      {services.map((svc, i) => (
        <div class={`svcgrid__item reveal reveal-d${i + 1}`} role="listitem" data-svc-card>
          <span class="svcgrid__shimmer" aria-hidden="true"></span>
          <div class="svcgrid__icon-wrap" aria-hidden="true">
            <div class="svcgrid__icon">
