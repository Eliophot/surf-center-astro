<dialog class="cart" id="cart-modal" aria-label="Panier">
  <div class="cart__header">
    <p class="cart__title">Panier</p>
    <button
      class="cart__close"
      type="button"
      data-cart-close
      aria-label="Fermer le panier"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>
  <div class="cart__body">
    <iframe
      id="cart-iframe"
      title="Panier Surf Center"
      width="100%"
      height="100%"
      frameborder="0"
      loading="lazy"
    ></iframe>
  </div>
</dialog>

<script>
  const CART_URL =
    'https://booking.yoplanning.pro/af0e7a3e-a541-40bf-b074-470572d4e762/cart/?bedisplay=embed';

  const modal = document.getElementById('cart-modal') as HTMLDialogElement;
  const iframe = document.getElementById('cart-iframe') as HTMLIFrameElement;
  const closeBtn = document.querySelector('[data-cart-close]') as HTMLButtonElement;

  let iframeLoaded = false;

  function openCart(e: Event) {
    e.preventDefault();
    if (!iframeLoaded) {
      iframe.src = CART_URL;
      iframeLoaded = true;
    }
    modal.showModal();
    document.body.style.overflow = 'hidden';
  }

  function closeCart() {
    modal.close();
    document.body.style.overflow = '';
  }

  document.querySelectorAll('[data-cart]').forEach((trigger) =>
    trigger.addEventListener('click', openCart),
  );

  closeBtn.addEventListener('click', closeCart);

  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeCart();
  });

  modal.addEventListener('close', () => {
    document.body.style.overflow = '';
  });
</script>

<style>
  .cart {
    position: fixed;
    inset: 0;
    z-index: 500;
    width: 100%;
    max-width: 100%;
    height: 100%;
    max-height: 100%;
    margin: 0;
    padding: 0;
    border: none;
    background: var(--c-bg);
    color: var(--c-text);
  }

  .cart:not([open]) { display: none; }

  .cart[open] {
    display: flex;
    flex-direction: column;
    opacity: 1;
    transform: translateX(0);
    transition:
      opacity var(--t-normal) var(--ease),
      transform var(--t-normal) var(--ease);
  }

  @starting-style {
    .cart[open] {
      opacity: 0;
      transform: translateX(2rem);
    }
  }

  .cart::backdrop {
    background: rgb(0 0 0 / 0);
    transition:
      background var(--t-normal) var(--ease),
      display var(--t-normal) var(--ease) allow-discrete,
      overlay var(--t-normal) var(--ease) allow-discrete;
  }

  .cart[open]::backdrop {
    background: rgb(0 0 0 / 0.5);
  }

  @starting-style {
    .cart[open]::backdrop {
      background: rgb(0 0 0 / 0);
    }
  }

  .cart__header {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--s-4) var(--s-6);
    border-bottom: 1px solid var(--c-border-light);
  }

  .cart__title {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--c-text-muted);
  }

  .cart__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: transparent;
    border: 1px solid var(--c-border);
    color: var(--c-text-muted);
    cursor: pointer;
    transition: all var(--t-fast);
  }

  .cart__close:hover {
    background: var(--c-surface);
    color: var(--c-text);
    border-color: var(--c-border);
  }

  .cart__body {
    flex: 1;
    overflow: hidden;
    padding: 0;
  }

  .cart__body iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  @media (min-width: 768px) {
    .cart {
      inset: 0 0 0 auto;
      width: 480px;
      max-width: 100%;
      height: 100%;
      max-height: 100%;
      margin: 0;
      border-radius: var(--r-xl) 0 0 var(--r-xl);
      box-shadow: var(--shadow-lg);
    }
  }
</style>
