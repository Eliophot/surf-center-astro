---
import { Image } from 'astro:assets';
import imgBateau from '../../assets/images/location-bateau-electrique.jpeg';
import imgPaddle from '../../assets/images/location-paddle.jpeg';
import imgPedalo from '../../assets/images/location-pedalo.jpg';
import imgCanoe from '../../assets/images/location-canoe.jpeg';
import imgPlanche from '../../assets/images/location-planche-a-voile.png';

const collection = [
  { title: "Bateau électrique", note: "Sans permis · 7 pers.", price: "55", image: imgBateau, alt: "Bateau électrique", tag: "62329049-d954-482c-82a1-faa16321e3bf" },
  { title: "Paddle board", note: "Rigide · Tous niveaux", price: "15", image: imgPaddle, alt: "Paddle board", tag: "52bf76b6-6f0a-43ff-b0a2-4c1332d5ede5" },
  { title: "Pédalo", note: "Famille · Toboggan", price: "15", image: imgPedalo, alt: "Pédalo", tag: "03a55e88-44ac-4161-ad03-aa857b1d0dc0" },
  { title: "Canoë", note: "Exploration · Criques", price: "10", image: imgCanoe, alt: "Canoë", tag: "e57bf5a3-2296-4226-94a8-06295b1415d8" },
  { title: "Planche à voile", note: "Vent du Verdon", price: "20", image: imgPlanche, alt: "Planche à voile", tag: "7a524907-97b7-42bd-bfdc-deb401767b21" },
];
---

<section class="section lc section--surface" aria-labelledby="v10-collection-title">
  <div class="container">
    <div class="lc__header reveal">
      <div class="lc__rule" aria-hidden="true"></div>
      <h2 id="v10-collection-title" class="lc__title">La collection</h2>
      <p class="lc__lead">Cinq façons de vivre le lac. Chacune unique.</p>
    </div>

    <div class="lc__grid">
      {collection.map((item, i) => (
        <button type="button" class={`lc__card reveal reveal-d${Math.min(i + 1, 4)}`} data-product-book data-tag={item.tag} aria-label={`${item.title} — dès ${item.price}€/h`}>
          <div class="lc__img-wrap">
            <Image class="lc__img" src={item.image} alt={item.alt} width={500} height={700} loading="lazy" decoding="async" format="webp" quality={75} />
          </div>
          <div class="lc__info">
            <h3 class="lc__name">{item.title}</h3>
            <p class="lc__note">{item.note}</p>
            <div class="lc__price-row">
              <span class="lc__price">dès {item.price}€<span class="lc__price-unit">/h</span></span>
              <span class="lc__book-link">Réserver →</span>
            </div>
          </div>
        </button>
      ))}
    </div>
  </div>
</section>

<style>
  .lc__header { margin-bottom: var(--s-12); }
  .lc__rule { width: 32px; height: 1px; background: var(--c-orange); margin-bottom: var(--s-5); }
  .lc__title {
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    font-weight: 200;
    text-transform: none;
    letter-spacing: 0.02em;
    margin-bottom: var(--s-3);
  }
  .lc__lead { font-size: 0.9rem; color: var(--c-text-muted); }

  .lc__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-6);
  }

  .lc__card {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: var(--s-5);
    align-items: center;
    text-align: left;
    border: none;
    background: var(--c-bg);
    border-radius: var(--r-lg);
    padding: var(--s-4);
    cursor: pointer;
    font-family: inherit;
    color: inherit;
    transition: box-shadow var(--t-fast), transform var(--t-fast);
    -webkit-tap-highlight-color: transparent;
  }
  .lc__card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }

  .lc__img-wrap { overflow: hidden; border-radius: var(--r-md); aspect-ratio: 3 / 4; }
  .lc__img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s var(--ease); }
  .lc__card:hover .lc__img { transform: scale(1.05); }

  .lc__name { font-size: 0.95rem; font-weight: 600; letter-spacing: 0.02em; margin-bottom: 2px; }
  .lc__note { font-size: 0.72rem; color: var(--c-text-muted); margin-bottom: var(--s-3); }

  .lc__price-row { display: flex; align-items: center; justify-content: space-between; gap: var(--s-4); }
  .lc__price { font-size: 1.1rem; font-weight: 700; color: var(--c-text); }
  .lc__price-unit { font-size: 0.65em; color: var(--c-text-muted); font-weight: 500; }
  .lc__book-link {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-orange);
    opacity: 0;
    transition: opacity var(--t-fast);
  }
  .lc__card:hover .lc__book-link { opacity: 1; }

  @media (min-width: 600px) { .lc__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1000px) {
    .lc__grid { grid-template-columns: 1fr; gap: var(--s-4); max-width: 640px; }
    .lc__card { grid-template-columns: 140px 1fr; }
  }
</style>
