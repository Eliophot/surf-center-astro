---
import { Image } from 'astro:assets';
import heroImg from '../../assets/images/hero-home.jpg';
---

<section class="lh" data-hero aria-label="Surf Center — une expérience d'exception">
  <Image
    class="lh__img"
    src={heroImg}
    alt="Les eaux turquoise du lac de Sainte-Croix vues depuis les falaises du Verdon"
    widths={[640, 1024, 1440, 1920]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
    decoding="async"
    format="webp"
    quality={85}
  />
  <div class="lh__overlay" aria-hidden="true"></div>

  <div class="lh__content">
    <div class="lh__rule" aria-hidden="true"></div>
    <p class="lh__location">Les Salles-sur-Verdon · Provence</p>
    <h1 class="lh__title">Surf Center</h1>
    <p class="lh__subtitle">L'expérience lac de Sainte-Croix</p>
    <div class="lh__rule lh__rule--bottom" aria-hidden="true"></div>

    <div class="lh__actions">
      <button type="button" class="btn btn--primary btn--lg" data-booking>
        <span class="btn-flip__inner"><span class="btn-flip__front">Réserver une expérience</span><span class="btn-flip__back">Réserver une expérience</span></span>
      </button>
    </div>
  </div>

  <div class="lh__scroll" aria-hidden="true">
    <span class="lh__scroll-text">Défiler</span>
    <span class="lh__scroll-line"></span>
  </div>
</section>

<style>
  .lh {
    position: relative;
    height: 100svh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #050505;
  }

  .lh__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    opacity: 0.55;
    animation: slow-zoom 30s var(--ease-smooth) forwards;
  }

  .lh__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg, rgb(5 5 5 / 0.4) 0%, rgb(5 5 5 / 0.2) 40%, rgb(5 5 5 / 0.6) 100%);
  }

  .lh__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding-inline: var(--s-6);
    max-width: 42rem;
  }

  .lh__rule {
    width: 40px;
    height: 1px;
    background: rgb(255 255 255 / 0.25);
    margin: 0 auto var(--s-6);
    animation: fade-up 800ms var(--ease-smooth) 200ms both;
  }
  .lh__rule--bottom { margin: var(--s-6) auto var(--s-10); animation-delay: 800ms; }

  .lh__location {
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.4);
    margin-bottom: var(--s-6);
    animation: fade-up 800ms var(--ease-smooth) 300ms both;
  }

  .lh__title {
    font-size: clamp(3rem, 10vw, 7rem);
    font-weight: 200;
    line-height: 0.95;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff !important;
    margin-bottom: var(--s-4);
    animation: fade-up 800ms var(--ease-smooth) 500ms both;
  }

  .lh__subtitle {
    font-size: clamp(0.75rem, 1.4vw, 0.95rem);
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.45);
    animation: fade-up 800ms var(--ease-smooth) 650ms both;
  }

  .lh__actions { animation: fade-up 800ms var(--ease-smooth) 1000ms both; }

  .lh__scroll {
    position: absolute;
    bottom: var(--s-8);
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-3);
    animation: fade-up 800ms var(--ease-smooth) 1400ms both;
  }

  .lh__scroll-text {
    font-size: 0.5rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.3);
  }

  .lh__scroll-line {
    display: block;
    width: 1px;
    height: 40px;
    background: linear-gradient(180deg, rgb(255 255 255 / 0.3), transparent);
    animation: bounce-subtle 2.5s ease-in-out infinite;
  }
</style>
