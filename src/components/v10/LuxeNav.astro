---
const links = [
  { title: "Nos locations", href: "/nos-locations" },
  { title: "L'esprit", href: "/esprit-surf-center" },
  { title: "Restauration", href: "/restauration" },
  { title: "Animations", href: "/animations" },
  { title: "Événements", href: "/groupes-evenements" },
  { title: "Accès & Contact", href: "/acces-contact" },
];
---

<section class="section ln section--surface" aria-labelledby="v10-nav-title">
  <div class="container ln__inner">
    <h2 id="v10-nav-title" class="ln__title reveal">Explorer</h2>
    <nav class="ln__grid reveal reveal-d1" aria-label="Pages du site">
      {links.map((l) => (
        <a href={l.href} class="ln__link">
          <span class="ln__link-text">{l.title}</span>
          <svg class="ln__arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      ))}
    </nav>
  </div>
</section>

<style>
  .ln__inner { max-width: 640px; }
  .ln__title {
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    font-weight: 200;
    text-transform: none;
    margin-bottom: var(--s-8);
  }

  .ln__grid { display: flex; flex-direction: column; }

  .ln__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--s-5) 0;
    border-bottom: 1px solid var(--c-border-light);
    text-decoration: none;
    color: var(--c-text);
    transition: color var(--t-fast);
  }
  .ln__link:first-child { border-top: 1px solid var(--c-border-light); }
  .ln__link:hover { color: var(--c-orange); }

  .ln__link-text {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .ln__arrow {
    color: var(--c-text-muted);
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity var(--t-fast), transform var(--t-fast);
  }
  .ln__link:hover .ln__arrow { opacity: 1; transform: translateX(0); color: var(--c-orange); }
</style>
