---
import Layout from '../layouts/Layout.astro';
import LocationHero from '../components/locations/LocationHero.astro';
import SectionOneImage from '../components/sections/SectionOneImage.astro';
import FormulaSwitcher from '../components/events/FormulaSwitcher.astro';
import ContactForm from '../components/events/ContactForm.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TrustBadges from '../components/v11/TrustBadges.astro';
import { proFormulas, privateFormulas } from '../data/events';

import imgHero from '../assets/images/concert-surfcenter-lac-sainte-croix.png';
import imgEvjf from '../assets/images/location-bateau-electriques-evjf-lac-sainte-croix.jpg';

const title = 'Groupes & Événements — Team building, EVJF, concerts | Surf Center Verdon';
const description = 'Organisez votre événement au lac de Sainte-Croix : team building, séminaire, EVJF, anniversaire, concert privé. Privatisation, activités nautiques, restauration — Surf Center, Gorges du Verdon.';

const siteUrl = 'https://surfcenter-verdon.fr';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Groupes & Événements — Surf Center',
    description,
    url: `${siteUrl}/groupes-evenements`,
    isPartOf: { '@type': 'WebSite', name: 'Surf Center', url: siteUrl },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'EventVenue',
    name: 'Surf Center — Espace événements',
    description: 'Lieu de réception et événements au bord du lac de Sainte-Croix. Concerts, team building, soirées privées dans les Gorges du Verdon.',
    url: `${siteUrl}/groupes-evenements`,
    image: `${siteUrl}/concert-surfcenter-lac-sainte-croix.png`,
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Plage des Salles-sur-Verdon',
      addressLocality: 'Les Salles-sur-Verdon',
      postalCode: '83630',
      addressRegion: 'Provence-Alpes-Côte d\'Azur',
      addressCountry: 'FR',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: 43.7766,
      longitude: 6.21,
    },
    maximumAttendeeCapacity: 200,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Groupes & Événements', item: `${siteUrl}/groupes-evenements` },
    ],
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <div class="gepage">
    <LocationHero
      title={['Groupes', '& Événements']}
      subtitle="Team building · EVJF/EVG · Privatisation · Concerts"
      image={imgHero}
      alt="Concert au coucher de soleil au Surf Center — lac de Sainte-Croix"
    />

    <Breadcrumbs items={[
      { label: 'Accueil', href: '/' },
      { label: 'Groupes & Événements' },
    ]} />

    <SectionOneImage
      id="intro"
      eyebrow="Organisation"
      title="Votre événement<br/>au bord du lac"
      text="Le Surf Center accueille vos événements professionnels et privés dans un cadre exceptionnel. Face au lac de Sainte-Croix, au cœur des Gorges du Verdon, nous organisons avec vous une expérience sur mesure : activités nautiques, restauration, concerts et privatisation."
      image={{ src: imgEvjf, alt: "Groupe d'amis au lac — événement privé au Surf Center" }}
      imgIcon={{ src: '/figma/resto-icon.svg', alt: '' }}
      tags={['Cadre unique', 'Sur mesure', 'Restauration sur place', 'Interlocuteur dédié']}
      style="background: linear-gradient(180deg, rgba(38, 207, 255, 0.00) 0%, rgba(38, 207, 255, 0.10) 100%);"
    />

    <FormulaSwitcher
      proFormulas={proFormulas}
      privateFormulas={privateFormulas}
      id="formulas"
    />
  <ContactForm />
  <TrustBadges />
  </div>
</Layout>

<style>
  .gepage :global(.section) {
    padding-block: clamp(2.5rem, 6vw, 5rem);
  }
</style>
