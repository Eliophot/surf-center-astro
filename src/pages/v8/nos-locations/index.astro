---
import LayoutMarketing from '../../../layouts/LayoutMarketing.astro';
import { locationDetails } from '../../../data/locations';

const badges = [
  { icon: 'shield', text: 'Paiement sécurisé' },
  { icon: 'undo', text: 'Annulation gratuite 24h' },
  { icon: 'key', text: 'Aucun permis requis' },
  { icon: 'parking', text: 'Parking gratuit' },
  { icon: 'family', text: 'Adapté aux familles' },
  { icon: 'clock', text: 'Ouvert 7j/7 en saison' },
];

const steps = [
  { num: '01', title: 'Choisissez', text: 'Sélectionnez votre activité parmi nos 5 options. Paddle, bateau, pédalo — il y en a pour tous les goûts.' },
  { num: '02', title: 'Réservez', text: 'Confirmez en quelques clics. Paiement sécurisé, annulation gratuite jusqu\'à 24h avant.' },
  { num: '03', title: 'Profitez', text: 'Présentez-vous au Surf Center, briefing express et c\'est parti pour l\'aventure !' },
];
---

<LayoutMarketing
  title="Nos activités nautiques — Surf Center · Lac de Sainte-Croix"
  description="Paddle, bateau électrique, pédalo, canoë, planche à voile — découvrez toutes nos locations nautiques au lac de Sainte-Croix. Dès 10€/h."
>
  <!-- HERO -->
  <section class="m8__lochero" aria-labelledby="m8-loc-title">
    <div class="m8__lochero-overlay" aria-hidden="true"></div>
    <div class="container m8__lochero-inner">
      <div class="m8__lochero-proof-top">
        <span class="m8__lochero-stars" aria-label="4.8 étoiles sur 5">★★★★★</span>
        <span>4.8/5 — 320+ avis vérifiés</span>
      </div>
      <span class="section__eyebrow m8__lochero-ey">Nos locations</span>
      <h1 id="m8-loc-title" class="m8__lochero-title">Nos activités<br/>nautiques</h1>
      <p class="m8__lochero-lead">
        Bateaux électriques, paddle, pédalo, canoë, planche à voile —<br/>
        trouvez l'activité parfaite pour votre journée au lac de Sainte-Croix.
      </p>
      <div class="m8__lochero-actions">
        <button type="button" class="btn btn--primary btn--lg m8__lochero-cta" data-booking>
          <span class="btn-flip__inner"><span class="btn-flip__front">Réserver maintenant</span><span class="btn-flip__back">Réserver maintenant</span></span>
        </button>
        <a href="#comparatif" class="btn btn--ghost btn--lg">Comparer les tarifs</a>
      </div>
      <p class="m8__lochero-sub">Dès 10€/h · Sans permis · Annulation gratuite</p>
    </div>
  </section>

  <!-- PRODUCT SLIDER -->
  <section class="section" aria-labelledby="m8-prod-title">
    <div class="container">
      <header class="section__header reveal">
        <span class="section__eyebrow">Explorez</span>
        <h2 id="m8-prod-title">Choisissez votre<br/>aventure</h2>
        <p class="section__lead">5 activités, un même cadre d'exception.</p>
      </header>

      <div class="m8__loc-grid">
        {locationDetails.map((loc, i) => (
          <a href={`/v8/nos-locations/${loc.slug}`} class={`m8__loc-card reveal reveal-d${Math.min(i + 1, 4)}`}>
            <div class="m8__loc-card-img">
              <img src={loc.heroImage} alt={loc.heroAlt} loading="lazy" decoding="async" width="600" height="400" />
            </div>
            <div class="m8__loc-card-price">
              <span class="m8__loc-card-from">dès</span>
              <span class="m8__loc-card-amount">{loc.price}<span class="m8__loc-card-cur">€</span></span>
              <span class="m8__loc-card-unit">/{loc.priceUnit}</span>
            </div>
            <div class="m8__loc-card-body">
              <h3 class="m8__loc-card-title">{loc.title}</h3>
              <p class="m8__loc-card-tagline">{loc.tagline}</p>
              <p class="m8__loc-card-desc">{loc.description}</p>
              <div class="m8__loc-card-highlights">
                {loc.highlights.map((h) => (
                  <span class="m8__loc-card-tag">{h}</span>
                ))}
              </div>
              <span class="m8__loc-card-link">
                Découvrir <span aria-hidden="true">→</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING TABLE -->
  <section id="comparatif" class="section section--surface" aria-labelledby="m8-compare-title">
    <div class="container">
      <header class="section__header reveal">
        <span class="section__eyebrow">Comparatif</span>
        <h2 id="m8-compare-title">Comparez nos<br/>tarifs</h2>
        <p class="section__lead">Tous les tarifs en un coup d'œil. Réductions demi-journée & journée disponibles.</p>
      </header>

      <div class="m8__table-wrap reveal">
        <table class="m8__table" role="table">
          <thead>
            <tr>
              <th scope="col">Activité</th>
              <th scope="col">Tarif / heure</th>
              <th scope="col">Capacité</th>
              <th scope="col">Niveau</th>
              <th scope="col">Durées</th>
              <th scope="col"></th>
            </tr>
          </thead>
          <tbody>
            {locationDetails.map((loc) => (
              <tr>
                <td>
                  <a href={`/v8/nos-locations/${loc.slug}`} class="m8__table-name">{loc.title}</a>
                </td>
                <td>
                  <span class="m8__table-price">{loc.price}€</span>
                </td>
                <td class="m8__table-cap">{loc.capacity}</td>
                <td class="m8__table-level">{loc.level}</td>
                <td class="m8__table-dur">{loc.duration}</td>
                <td>
                  <a href={`/v8/nos-locations/${loc.slug}`} class="m8__table-btn">Voir →</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- STEPS BOOKING -->
  <section class="section" aria-labelledby="m8-steps-title">
    <div class="container">
      <header class="section__header reveal">
        <span class="section__eyebrow">Comment ça marche</span>
        <h2 id="m8-steps-title">Réservez en<br/>3 étapes</h2>
      </header>

      <div class="m8__steps-grid">
        {steps.map((s, i) => (
          <div class={`m8__steps-item reveal reveal-d${i + 1}`}>
            <span class="m8__steps-num" aria-hidden="true">{s.num}</span>
            <h3 class="m8__steps-title">{s.title}</h3>
            <p class="m8__steps-text">{s.text}</p>
            {i < steps.length - 1 && <div class="m8__steps-connector" aria-hidden="true"></div>}
          </div>
        ))}
      </div>

      <div class="m8__steps-cta reveal">
        <button type="button" class="btn btn--primary btn--lg" data-booking>
          <span class="btn-flip__inner"><span class="btn-flip__front">Réserver maintenant</span><span class="btn-flip__back">Réserver maintenant</span></span>
        </button>
      </div>
    </div>
  </section>

  <!-- TRUST BADGES -->
  <section class="m8__loc-trust" aria-label="Engagements Surf Center">
    <div class="container">
      <div class="m8__loc-trust-grid">
        {badges.map((b) => (
          <div class="m8__loc-trust-item">
            <div class="m8__loc-trust-icon" aria-hidden="true">
              {b.icon === 'shield' && <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>}
              {b.icon === 'undo' && <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M1 4v6h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>}
              {b.icon === 'key' && <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="m21 2-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.78 7.78 5.5 5.5 0 0 1 7.78-7.78Zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>}
              {b.icon === 'parking' && <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.5"/><path d="M9 17V7h4a3 3 0 1 1 0 6H9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>}
              {b.icon === 'family' && <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/></svg>}
              {b.icon === 'clock' && <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>}
            </div>
            <span class="m8__loc-trust-text">{b.text}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
</LayoutMarketing>

<style>
  /* HERO */
  .m8__lochero {
    position: relative; min-height: 80vh; display: flex;
    align-items: center; justify-content: center;
    background: url('/location-paddle-bateaux-electriques-lac-sainte-croix-gorges-verdon.jpeg') center / cover no-repeat;
    color: #fff;
  }
  .m8__lochero-overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(180deg, rgb(0 0 0 / 0.55) 0%, rgb(0 0 0 / 0.35) 40%, rgb(0 0 0 / 0.75) 100%);
  }
  .m8__lochero-inner {
    position: relative; z-index: 2; text-align: center;
    max-width: 50rem; margin-inline: auto;
    padding-block: calc(var(--header-h) + var(--s-12)) var(--s-16);
  }
  .m8__lochero-proof-top {
    display: inline-flex; align-items: center; gap: var(--s-2);
    padding: 0.4rem 1rem; border-radius: var(--r-full);
    background: rgb(255 255 255 / 0.08); border: 1px solid rgb(255 255 255 / 0.12);
    backdrop-filter: blur(12px); font-size: 0.62rem; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: rgb(255 255 255 / 0.6); margin-bottom: var(--s-8);
    animation: fade-up 700ms var(--ease-smooth) 100ms both;
  }
  .m8__lochero-stars { font-size: 0.72rem; color: #fbbf24; letter-spacing: 2px; }
  .m8__lochero-ey { color: var(--c-orange) !important; animation: fade-up 700ms var(--ease-smooth) 200ms both; }
  .m8__lochero-title {
    font-size: clamp(2.8rem, 8vw, 5.5rem); font-weight: 800; line-height: 0.92;
    letter-spacing: -0.04em; text-transform: uppercase; color: #fff !important;
    margin-bottom: var(--s-6); text-shadow: 0 4px 40px rgb(0 0 0 / 0.5);
    animation: fade-up 700ms var(--ease-smooth) 350ms both;
  }
  .m8__lochero-lead {
    font-size: clamp(0.88rem, 1.6vw, 1.05rem); color: rgb(255 255 255 / 0.7) !important;
    line-height: 1.7; margin-bottom: var(--s-8);
    animation: fade-up 700ms var(--ease-smooth) 500ms both;
  }
  .m8__lochero-actions {
    display: flex; gap: var(--s-4); justify-content: center; flex-wrap: wrap;
    animation: fade-up 700ms var(--ease-smooth) 650ms both;
  }
  .m8__lochero-cta { box-shadow: 0 4px 30px rgb(247 123 70 / 0.4); }
  .m8__lochero-sub {
    margin-top: var(--s-5); font-size: 0.7rem; font-weight: 500;
    color: rgb(255 255 255 / 0.45); letter-spacing: 0.06em;
    animation: fade-up 700ms var(--ease-smooth) 800ms both;
  }

  /* PRODUCT GRID */
  .m8__loc-grid { display: grid; grid-template-columns: 1fr; gap: var(--s-6); }
  .m8__loc-card {
    position: relative; display: flex; flex-direction: column;
    background: var(--c-bg); border-radius: var(--r-lg);
    border: 1.5px solid var(--c-border-light); overflow: hidden;
    text-decoration: none; color: inherit;
    transition: border-color var(--t-fast), box-shadow var(--t-fast), transform var(--t-fast);
  }
  .m8__loc-card:hover { border-color: var(--c-orange); box-shadow: var(--shadow-md); transform: translateY(-3px); }
  .m8__loc-card-img { position: relative; aspect-ratio: 16 / 10; overflow: hidden; }
  .m8__loc-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s var(--ease); }
  .m8__loc-card:hover .m8__loc-card-img img { transform: scale(1.05); }
  .m8__loc-card-price {
    position: absolute; top: var(--s-4); right: var(--s-4); z-index: 2;
    display: flex; align-items: baseline; gap: 0.2rem;
    padding: 0.5rem 0.85rem; border-radius: var(--r-full);
    background: rgb(0 0 0 / 0.5); backdrop-filter: blur(16px);
  }
  .m8__loc-card-from { font-size: 0.5rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: rgb(255 255 255 / 0.5); }
  .m8__loc-card-amount { font-size: 1.15rem; font-weight: 800; letter-spacing: -0.03em; color: #fff; }
  .m8__loc-card-cur { font-size: 0.7em; font-weight: 700; opacity: 0.6; }
  .m8__loc-card-unit { font-size: 0.55rem; color: rgb(255 255 255 / 0.4); }
  .m8__loc-card-body { padding: var(--s-5); display: flex; flex-direction: column; flex: 1; }
  .m8__loc-card-title { font-size: 1.05rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 2px; }
  .m8__loc-card-tagline { font-size: 0.72rem; color: var(--c-text-muted); margin-bottom: var(--s-3); }
  .m8__loc-card-desc { font-size: 0.82rem; color: var(--c-text-secondary); line-height: 1.6; margin-bottom: var(--s-4); flex: 1; }
  .m8__loc-card-highlights { display: flex; flex-wrap: wrap; gap: var(--s-2); margin-bottom: var(--s-4); }
  .m8__loc-card-tag {
    font-size: 0.6rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--c-orange); padding: 0.2rem 0.55rem; background: rgb(247 123 70 / 0.1);
    border-radius: var(--r-full);
  }
  .m8__loc-card-link {
    font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--c-orange); display: inline-flex; align-items: center; gap: var(--s-2);
    transition: gap var(--t-fast);
  }
  .m8__loc-card:hover .m8__loc-card-link { gap: var(--s-3); }

  @media (min-width: 600px) { .m8__loc-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1000px) { .m8__loc-grid { grid-template-columns: repeat(3, 1fr); } }

  /* PRICING TABLE */
  .m8__table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .m8__table {
    width: 100%; border-collapse: collapse; min-width: 700px;
    background: var(--c-bg); border-radius: var(--r-lg); overflow: hidden;
    border: 1px solid var(--c-border-light);
  }
  .m8__table th {
    padding: var(--s-4) var(--s-5); text-align: left;
    font-size: 0.65rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--c-text-muted);
    background: var(--c-surface); border-bottom: 1px solid var(--c-border-light);
  }
  .m8__table td {
    padding: var(--s-4) var(--s-5); font-size: 0.82rem;
    color: var(--c-text-secondary); border-bottom: 1px solid var(--c-border-light);
    vertical-align: middle;
  }
  .m8__table tr:last-child td { border-bottom: none; }
  .m8__table tr:hover td { background: var(--c-surface); }
  .m8__table-name { font-weight: 700; color: var(--c-text); text-decoration: none; text-transform: uppercase; letter-spacing: 0.04em; }
  .m8__table-name:hover { color: var(--c-orange); }
  .m8__table-price { font-size: 1.1rem; font-weight: 800; color: var(--c-orange); }
  .m8__table-cap { font-size: 0.78rem; }
  .m8__table-level { font-size: 0.75rem; }
  .m8__table-dur { font-size: 0.75rem; }
  .m8__table-btn {
    font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--c-orange); text-decoration: none;
    transition: opacity var(--t-fast);
  }
  .m8__table-btn:hover { opacity: 0.7; }

  /* STEPS */
  .m8__steps-grid { display: grid; grid-template-columns: 1fr; gap: var(--s-10); max-width: var(--max-w-narrow); margin-inline: auto; }
  .m8__steps-item { position: relative; text-align: center; }
  .m8__steps-num {
    display: inline-flex; align-items: center; justify-content: center;
    width: 56px; height: 56px; border-radius: var(--r-full);
    background: var(--c-orange); color: #fff;
    font-size: 1.1rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: var(--s-5);
  }
  .m8__steps-title { font-size: 1.1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: var(--s-3); }
  .m8__steps-text { font-size: 0.88rem; color: var(--c-text-secondary); line-height: 1.7; max-width: 32ch; margin-inline: auto; }
  .m8__steps-connector { display: none; }
  .m8__steps-cta { display: flex; justify-content: center; margin-top: var(--s-12); }
  @media (min-width: 900px) {
    .m8__steps-grid { grid-template-columns: repeat(3, 1fr); gap: var(--s-8); max-width: none; }
    .m8__steps-connector {
      display: block; position: absolute; top: 28px; left: calc(50% + 40px);
      width: calc(100% - 80px + var(--s-8)); height: 1px; background: var(--c-border);
    }
  }

  /* TRUST BADGES */
  .m8__loc-trust { padding-block: var(--s-12); border-top: 1px solid var(--c-border-light); border-bottom: 1px solid var(--c-border-light); }
  .m8__loc-trust-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--s-6); }
  .m8__loc-trust-item { display: flex; align-items: center; gap: var(--s-3); }
  .m8__loc-trust-icon {
    width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;
    border-radius: var(--r-md); background: var(--c-surface); color: var(--c-orange); flex-shrink: 0;
  }
  .m8__loc-trust-text { font-size: 0.75rem; font-weight: 600; color: var(--c-text-secondary); letter-spacing: 0.02em; }
  @media (min-width: 600px) { .m8__loc-trust-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1000px) {
    .m8__loc-trust-grid { grid-template-columns: repeat(6, 1fr); }
    .m8__loc-trust-item { flex-direction: column; text-align: center; }
    .m8__loc-trust { padding-block: var(--s-16); }
  }

  @media (max-width: 600px) {
    .m8__lochero-lead br { display: none; }
  }
</style>
