---
const steps = [
  { num: '01', title: 'Choisissez', text: 'Sélectionnez votre activité et votre créneau. Bateau, paddle, pédalo — tout est disponible en quelques clics.' },
  { num: '02', title: 'Réservez', text: 'Confirmez votre réservation en ligne ou sur place. Paiement sécurisé, annulation gratuite jusqu\'à 24h.' },
  { num: '03', title: 'Profitez', text: 'Récupérez votre matériel après un bref briefing sécurité et partez explorer le lac.' },
];
---

<section class="hiw section section--surface" aria-labelledby="hiw-title">
  <div class="container">
    <!-- Header avec titre et sous-titre -->
    <header class="section__header reveal">
      <span class="section__eyebrow">Notre fonctionnement</span>
      <h2 id="hiw-title">Simple, rapide<br/>& accompagné</h2>
      <p class="section__lead">Réservez en ligne ou sur place, récupérez votre matériel au comptoir, profitez du lac.<br/>Notre équipe est là pour vous accompagner du briefing au retour.</p>
    </header>

    <!-- Frise chronologique horizontale -->
    <div class="hiw__timeline-grid" role="list" aria-label="Étapes de location">
      {steps.map((s, i) => (
        <div class={`hiw__step reveal reveal-d${i + 1}`} role="listitem">
          <span class="hiw__step-num" aria-hidden="true">{s.num}</span>
          <h3 class="hiw__step-title">{s.title}</h3>
          <p class="hiw__step-text">{s.text}</p>
          {i < steps.length - 1 && <div class="hiw__connector" aria-hidden="true"></div>}
        </div>
      ))}
    </div>

    <!-- Visuel en dernier -->
    <div class="hiw__visual reveal">
      <img src="/surfcenter-location-lac-sainte-croix.JPG" alt="Équipe Surf Center au comptoir de location — lac de Sainte-Croix" width="1200" height="500" loading="lazy" decoding="async" />
    </div>
  </div>
</section>

<style>
  /* Frise chronologique - style marketing */
  .hiw__timeline-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-10);
    max-width: var(--max-w-narrow);
    margin-inline: auto;
  }

  .hiw__step {
    position: relative;
    text-align: center;
  }

  .hiw__step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    border-radius: var(--r-full);
    background: var(--c-orange);
    color: #fff;
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: var(--s-5);
    box-shadow: 0 4px 20px rgb(247 123 70 / 0.25);
  }

  .hiw__step-title {
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: var(--s-3);
    color: var(--c-text);
  }

  .hiw__step-text {
    font-size: 0.88rem;
    color: var(--c-text-secondary);
    line-height: 1.7;
    max-width: 30ch;
    margin-inline: auto;
  }

  .hiw__connector {
    display: none;
  }

  /* Visuel panoramique */
  .hiw__visual {
    position: relative;
    border-radius: var(--r-xl);
    overflow: hidden;
    margin-top: var(--s-12);
  }

  .hiw__visual img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 21 / 9;
    object-fit: cover;
  }

  /* Desktop : frise horizontale avec connecteurs */
  @media (min-width: 900px) {
    .hiw__timeline-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--s-8);
      max-width: none;
    }
    
    .hiw__visual {
      margin-top: var(--s-16);
    }

    .hiw__step-num {
      width: 64px;
      height: 64px;
      font-size: 1.25rem;
    }

    .hiw__connector {
      display: block;
      position: absolute;
      top: 32px;
      left: calc(50% + 44px);
      width: calc(100% - 88px + var(--s-8));
      height: 2px;
      background: linear-gradient(90deg, var(--c-orange), var(--c-border));
    }

    .hiw__visual img {
      aspect-ratio: 3 / 1;
    }
  }

  /* Tablette */
  @media (min-width: 600px) and (max-width: 899px) {
    .hiw__visual img {
      aspect-ratio: 16 / 7;
    }
  }
</style>
