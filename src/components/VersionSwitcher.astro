---
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const versions = [
  { label: 'Standard', href: '/' },
  { label: 'Design', href: '/v2' },
  { label: 'Immersive', href: '/v3' },
  { label: 'Editorial', href: '/v4' },
  { label: 'Expressive', href: '/v5' },
  { label: 'Minimal', href: '/v6' },
  { label: 'Kinetic', href: '/v7' },
];
const count = versions.length;

function isActive(href: string): boolean {
  const clean = currentPath === '' ? '/' : currentPath;
  if (href === '/') return clean === '/';
  return clean.startsWith(href);
}

const activeIdx = versions.findIndex((v) => isActive(v.href));
---

<nav class="vsw" aria-label="Changer de version">
  <button class="vsw__trigger" type="button" aria-expanded="false" aria-haspopup="true">
    <svg class="vsw__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="3" width="7" height="7" rx="1.5"/>
      <rect x="14" y="3" width="7" height="7" rx="1.5"/>
      <rect x="3" y="14" width="7" height="7" rx="1.5"/>
      <rect x="14" y="14" width="7" height="7" rx="1.5"/>
    </svg>
    <span class="vsw__hint">Versions</span>
  </button>

  <div class="vsw__dropdown">
    <div class="vsw__bar" style={`--active-idx: ${activeIdx}; --count: ${count}`}>
      <span class="vsw__indicator" aria-hidden="true"></span>
      {versions.map((v) => (
        <a
          href={v.href}
          class:list={['vsw__link', { 'is-active': isActive(v.href) }]}
          aria-current={isActive(v.href) ? 'page' : undefined}
        >
          {v.label}
        </a>
      ))}
    </div>
    <span class="vsw__badge">preprod</span>
  </div>
</nav>

<script>
  const nav = document.querySelector('.vsw') as HTMLElement | null;
  const trigger = nav?.querySelector('.vsw__trigger') as HTMLButtonElement | null;
  if (!nav || !trigger) throw new Error('vsw not found');

  trigger.addEventListener('click', () => {
    const isOpen = nav.classList.toggle('is-open');
    trigger.setAttribute('aria-expanded', String(isOpen));
  });

  document.addEventListener('click', (e) => {
    if (!nav.contains(e.target as Node)) {
      nav.classList.remove('is-open');
      trigger.setAttribute('aria-expanded', 'false');
    }
  });
</script>

<style>
  .vsw {
    position: fixed;
    left: var(--s-5);
    top: 50%;
    transform: translateY(-50%);
    z-index: 900;
    animation: vsw-enter 600ms var(--ease-smooth) 800ms both;
  }

  @keyframes vsw-enter {
    from { opacity: 0; transform: translateY(-50%) translateX(-16px); }
    to { opacity: 1; transform: translateY(-50%) translateX(0); }
  }

  /* ── Trigger ── */

  .vsw__trigger {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 9px;
    background: #111;
    border: 1px solid rgb(255 255 255 / 0.08);
    border-radius: 10px;
    color: rgb(255 255 255 / 0.4);
    cursor: pointer;
    box-shadow: 0 4px 20px rgb(0 0 0 / 0.3);
    transition: color 250ms, background 250ms, border-color 250ms, gap 300ms, padding 300ms;
    -webkit-tap-highlight-color: transparent;
    overflow: hidden;
  }

  .vsw__trigger:hover {
    color: #fff;
    background: #1a1a1a;
    border-color: rgb(255 255 255 / 0.15);
    gap: 8px;
    padding: 9px 12px 9px 9px;
  }

  .vsw__icon { flex-shrink: 0; }

  .vsw__hint {
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
    max-width: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-width 300ms var(--ease), opacity 250ms;
  }

  .vsw__trigger:hover .vsw__hint {
    max-width: 80px;
    opacity: 1;
  }

  /* ── Dropdown (clic uniquement) ── */

  .vsw__dropdown {
    position: absolute;
    left: 0;
    top: calc(100% + 8px);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    pointer-events: none;
    transition: opacity 200ms, transform 200ms, visibility 0ms 200ms;
  }

  .vsw.is-open .vsw__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
    transition: opacity 200ms, transform 200ms, visibility 0ms 0ms;
  }

  .vsw__bar {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 4px;
    background: #111;
    border-radius: 14px;
    border: 1px solid rgb(255 255 255 / 0.08);
    box-shadow: 0 10px 40px rgb(0 0 0 / 0.4);
  }

  .vsw__indicator {
    position: absolute;
    left: 4px;
    right: 4px;
    height: calc(100% / var(--count) - 4px * 2 / var(--count));
    top: calc(4px + var(--active-idx) * (100% / var(--count)));
    background: rgb(255 255 255 / 0.1);
    border-radius: 10px;
    transition: top 350ms var(--ease);
    pointer-events: none;
    border: 1px solid rgb(255 255 255 / 0.05);
  }

  .vsw__link {
    position: relative;
    z-index: 1;
    display: block;
    padding: 8px 16px;
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgb(255 255 255 / 0.28);
    white-space: nowrap;
    text-align: center;
    transition: color 200ms;
    -webkit-tap-highlight-color: transparent;
  }

  .vsw__link:hover { color: rgb(255 255 255 / 0.6); }
  .vsw__link.is-active { color: #fff; }

  .vsw__badge {
    align-self: center;
    font-size: 0.42rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--c-orange);
    opacity: 0.6;
  }

  /* ── Mobile ── */

  @media (max-width: 768px) {
    .vsw {
      left: auto;
      right: var(--s-4);
      top: auto;
      bottom: var(--s-5);
      transform: none;
    }

    @keyframes vsw-enter {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .vsw__dropdown {
      left: auto;
      right: 0;
      top: auto;
      bottom: calc(100% + 8px);
      transform: translateY(6px);
    }

    .vsw.is-open .vsw__dropdown {
      transform: translateY(0);
    }

    .vsw__link {
      padding: 8px 10px;
      font-size: 0.48rem;
    }

    .vsw__badge { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .vsw { animation: none; }
    .vsw__indicator { transition: none; }
    .vsw__dropdown { transition: none; }
    .vsw__hint { transition: none; }
  }
</style>
