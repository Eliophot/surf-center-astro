---
import { Image } from 'astro:assets';
import imgPlanche from '../../assets/images/location-planche-a-voile-windsurf-lac-sainte-croix.png';
import imgBateau from '../../assets/images/location-bateau-electrique-lac-sainte-croix-surfcenter.jpeg';
import imgPedalo from '../../assets/images/location-pedalo.jpg';
import imgPaddle from '../../assets/images/location-paddle-lac-sainte-croix-surfcenter.jpeg';

const univers = [
  { n: '01', title: 'Planche à voile', href: '/nos-locations/planche-a-voile', img: imgPlanche, alt: 'Planche à voile sur le lac de Sainte-Croix' },
  { n: '02', title: 'Bateau électrique', href: '/nos-locations/bateau-electrique', img: imgBateau, alt: 'Bateau électrique sur le lac de Sainte-Croix' },
  { n: '03', title: 'Pédalo', href: '/nos-locations/pedalo', img: imgPedalo, alt: 'Pédalos sur le lac de Sainte-Croix' },
  { n: '04', title: 'Paddle board', href: '/nos-locations/paddle', img: imgPaddle, alt: 'Paddle board sur le lac de Sainte-Croix' },
];
---

<section class="ur" aria-labelledby="ur-title">
  <p id="ur-title" class="sr-only">Locations</p>
  <div class="container ur__head">
    <h3 class="ur__title">Locations</h3>
    <div class="ur__right">
      <span class="ur__kicker">Nos univers</span>
      <div class="ur__arrows">
        <button type="button" class="ur__arrow" data-ur-prev aria-label="Précédent">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M13 4l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button type="button" class="ur__arrow" data-ur-next aria-label="Suivant">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div class="ur__rail" data-ur role="region" aria-roledescription="carrousel" aria-label="Nos univers de location">
    <div class="ur__track" data-ur-track aria-live="polite">
      {univers.map((u) => (
        <a class="ur__card" href={u.href} aria-label={u.title}>
          <div class="ur__media">
            <Image class="ur__img" src={u.img} alt={u.alt} width={900} height={1120} loading="lazy" decoding="async" format="webp" quality={75} />
            <span class="ur__num" aria-hidden="true">{u.n}</span>
          </div>
          <h3 class="ur__name">{u.title}</h3>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .ur {
    padding: var(--s-section) 0;
    background: var(--c-bg);
    overflow: hidden;
  }

  .ur__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--s-6);
    margin-bottom: var(--s-10);
  }

  .ur__title {
    font-size: clamp(2.6rem, 6vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.06em;
    text-transform: uppercase;
    line-height: 1;
    margin: 0;
  }

  .ur__right {
    display: flex;
    align-items: center;
    gap: var(--s-6);
  }

  .ur__kicker {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    display: none;
  }

  .ur__arrows {
    display: flex;
    gap: var(--s-2);
  }

  .ur__arrow {
    width: 44px;
    height: 44px;
    border-radius: var(--r-full);
    border: 1px solid var(--c-border);
    background: var(--c-bg);
    color: var(--c-text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background var(--t-fast), border-color var(--t-fast), transform var(--t-fast);
  }

  .ur__arrow:hover {
    background: var(--c-surface);
    border-color: var(--c-text-muted);
    transform: translateY(-1px);
  }

  .ur__arrow:active { transform: scale(0.98); }

  .ur__rail {
    position: relative;
  }

  .ur__track {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding-inline: max(var(--s-6), env(safe-area-inset-left));
  }

  .ur__track::-webkit-scrollbar { display: none; }

  .ur__card {
    flex: 0 0 min(524px, 86vw);
    scroll-snap-align: start;
    text-decoration: none;
    color: inherit;
  }

  .ur__media {
    position: relative;
    overflow: hidden;
    border-radius: var(--r-lg);
    aspect-ratio: 524 / 655;
    background: #0a0a0a;
  }

  .ur__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s var(--ease);
  }

  .ur__card:hover .ur__img { transform: scale(1.04); }

  .ur__num {
    position: absolute;
    top: 16px;
    left: 16px;
    font-size: 4.5rem;
    font-weight: 800;
    letter-spacing: -0.06em;
    color: rgb(255 255 255 / 0.85);
    text-shadow: 0 18px 60px rgb(0 0 0 / 0.5);
    line-height: 1;
  }

  .ur__name {
    margin: 0.9rem 0 0;
    font-size: 1.05rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  @media (min-width: 900px) {
    .ur__kicker { display: inline-block; }
    .ur__track { padding-inline: 0; }
    .ur__card { flex-basis: 524px; }
  }
</style>

<script>
  document.querySelectorAll('[data-ur]').forEach((rail) => {
    const track = rail.querySelector('[data-ur-track]');
    if (!track) return;
    const prev = rail.closest('section')?.querySelector('[data-ur-prev]');
    const next = rail.closest('section')?.querySelector('[data-ur-next]');

    const scrollBy = (dir: number) => {
      const card = track.querySelector('.ur__card');
      const w = card ? card.getBoundingClientRect().width : track.clientWidth;
      track.scrollBy({ left: dir * (w + 16), behavior: 'smooth' });
    };

    prev?.addEventListener('click', () => scrollBy(-1));
    next?.addEventListener('click', () => scrollBy(1));
  });
</script>

