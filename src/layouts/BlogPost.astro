---
import Layout from './Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import BookingCTA from '../components/locations/BookingCTA.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  image: string;
  imageAlt: string;
  author: string;
  tags: string[];
  slug: string;
}

const { title, description, date, image, imageAlt, author, tags, slug } = Astro.props;

const siteUrl = 'https://surfcenter-verdon.fr';

const formattedDate = date.toLocaleDateString('fr-FR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: title,
    description,
    image: `${siteUrl}${image}`,
    datePublished: date.toISOString(),
    author: { '@type': 'Organization', name: author, url: siteUrl },
    publisher: { '@type': 'Organization', name: 'Surf Center', url: siteUrl },
    url: `${siteUrl}/blog/${slug}`,
    mainEntityOfPage: { '@type': 'WebPage', '@id': `${siteUrl}/blog/${slug}` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog` },
      { '@type': 'ListItem', position: 3, name: title, item: `${siteUrl}/blog/${slug}` },
    ],
  },
];
---

<Layout title={`${title} | Surf Center Blog`} description={description} jsonLd={jsonLd}>
  <section class="bphero" data-hero>
    <img class="bphero__bg" src={image} alt={imageAlt} width="1920" height="900" loading="eager" fetchpriority="high" decoding="async" />
    <div class="bphero__overlay" aria-hidden="true"></div>
    <div class="container bphero__content">
      <div class="bphero__tags">
        {tags.map((tag) => <span class="bphero__tag">{tag}</span>)}
      </div>
      <h1 class="bphero__title">{title}</h1>
      <div class="bphero__meta">
        <time datetime={date.toISOString().slice(0, 10)}>{formattedDate}</time>
        <span class="bphero__sep" aria-hidden="true">·</span>
        <span>{author}</span>
      </div>
    </div>
  </section>

  <Breadcrumbs items={[
    { label: 'Accueil', href: '/' },
    { label: 'Blog', href: '/blog' },
    { label: title },
  ]} />

  <article class="bpost section">
    <div class="container bpost__body">
      <slot />
    </div>
  </article>

  <BookingCTA
    title="Envie d'y être ?"
    text="Réservez votre activité nautique et venez profiter du lac de Sainte-Croix."
  />
</Layout>

<style>
  .bphero {
    position: relative;
    min-height: 50vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .bphero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .bphero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgb(0 0 0 / 0.15) 0%, rgb(0 0 0 / 0.65) 100%);
  }

  .bphero__content {
    position: relative;
    z-index: 1;
    padding-bottom: var(--s-12);
    max-width: var(--max-w-narrow);
    animation: bphero-up 700ms var(--ease-smooth) both;
  }

  @keyframes bphero-up {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .bphero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    margin-bottom: var(--s-4);
  }

  .bphero__tag {
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-orange);
    background: rgb(0 0 0 / 0.35);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 4px 12px;
    border-radius: var(--r-full);
  }

  .bphero__title {
    color: #fff !important;
    font-size: clamp(1.8rem, 5vw, 3rem);
    line-height: 1.15;
    max-width: 22ch;
    margin-bottom: var(--s-4);
  }

  .bphero__meta {
    display: flex;
    align-items: center;
    gap: var(--s-2);
    font-size: 0.72rem;
    font-weight: 500;
    color: rgb(255 255 255 / 0.6);
    letter-spacing: 0.04em;
  }

  .bphero__sep { opacity: 0.4; }

  /* Article body — prose styling */
  .bpost__body {
    max-width: var(--max-w-narrow);
  }

  .bpost__body :global(h2) {
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    margin-top: var(--s-12);
    margin-bottom: var(--s-5);
  }

  .bpost__body :global(h3) {
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    margin-top: var(--s-8);
    margin-bottom: var(--s-3);
  }

  .bpost__body :global(p) {
    font-size: 0.95rem;
    color: var(--c-text-secondary);
    line-height: 1.85;
    margin-bottom: var(--s-6);
  }

  .bpost__body :global(strong) {
    color: var(--c-text);
    font-weight: 600;
  }

  .bpost__body :global(a) {
    color: var(--c-orange);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--t-fast);
  }

  .bpost__body :global(a:hover) {
    color: var(--c-orange-dark);
  }

  .bpost__body :global(ul),
  .bpost__body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: var(--s-6);
  }

  .bpost__body :global(ul) {
    list-style: disc;
  }

  .bpost__body :global(ol) {
    list-style: decimal;
  }

  .bpost__body :global(li) {
    font-size: 0.95rem;
    color: var(--c-text-secondary);
    line-height: 1.75;
    margin-bottom: var(--s-2);
  }

  .bpost__body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: var(--s-8);
    font-size: 0.85rem;
  }

  .bpost__body :global(th) {
    text-align: left;
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    padding: var(--s-3) var(--s-4);
    border-bottom: 2px solid var(--c-border);
  }

  .bpost__body :global(td) {
    padding: var(--s-3) var(--s-4);
    color: var(--c-text-secondary);
    border-bottom: 1px solid var(--c-border-light);
  }

  .bpost__body :global(blockquote) {
    border-left: 3px solid var(--c-orange);
    padding-left: var(--s-6);
    margin-block: var(--s-8);
    font-style: italic;
  }

  .bpost__body :global(blockquote p) {
    color: var(--c-text);
  }

  .bpost__body :global(hr) {
    border: none;
    height: 1px;
    background: var(--c-border-light);
    margin-block: var(--s-10);
  }

  @media (prefers-reduced-motion: reduce) {
    .bphero__content { animation: none; }
  }
</style>
