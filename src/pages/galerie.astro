---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import LocationHero from '../components/locations/LocationHero.astro';
import BookingCTA from '../components/locations/BookingCTA.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

import imgBateauxLac from '../assets/images/lac-sainte-croix-gorges-verdon-location-bateaux-electriques.jpg';
import imgPaddleBateaux from '../assets/images/location-paddle-bateaux-electriques-lac-sainte-croix-gorges-verdon.jpeg';
import imgYoga from '../assets/images/sarah-cours-yoga-surfcenter-lac-sainte-croix.jpg';
import imgGetty from '../assets/images/GettyImages-577312024.jpg';
import imgSnack from '../assets/images/drone-snack-pedalo-lac-sainte-croix-surfcenter-salades.jpeg';
import imgBateau from '../assets/images/location-bateau-electrique-lac-sainte-croix-surfcenter.jpeg';
import imgConcertJoulik from '../assets/images/concert-joulik-lac-sainte-croix-surfcenter.jpg';
import imgPedaloPlage from '../assets/images/location-pedalo-lac-sainte-croix-plage-surfcenter.jpeg';
import imgPaddle from '../assets/images/location-paddle-lac-sainte-croix-surfcenter.jpeg';
import imgFramboise from '../assets/images/framboise-et-ceatera-lac-sainte-croix-concert-surfcenter.jpg';
import imgCanoeLac from '../assets/images/location-canoe-lac-sainte-croix-surfcenter.jpg';
import imgVoile from '../assets/images/location-planche-a-voile-windsurf-lac-sainte-croix.png';
import imgEsprit from '../assets/images/esprit.png';
import imgLac from '../assets/images/location-lac-sainte-croix-gorges-verdon.png';
import imgSunset from '../assets/images/IMG20220618204351.jpg';
import imgEvjf from '../assets/images/location-bateau-electriques-evjf-lac-sainte-croix.jpg';
import imgPedalo from '../assets/images/location-pedalo-lac-sainte-croix.jpeg';
import imgTrophee from '../assets/images/trophee-hobie-shop-lac-sainte-croix-surf-center.jpeg';

const title = 'Galerie photos — Lac de Sainte-Croix | Surf Center Verdon';
const description = 'Découvrez le Surf Center en images : lac de Sainte-Croix, Gorges du Verdon, activités nautiques, concerts, couchers de soleil. Galerie photos de notre base nautique.';

const siteUrl = 'https://surfcenter-verdon.fr';

const photos: { src: ImageMetadata; alt: string; span: string }[] = [
  { src: imgBateauxLac, alt: 'Bateaux électriques sur le lac de Sainte-Croix — Gorges du Verdon', span: 'wide' },
  { src: imgPaddleBateaux, alt: 'Paddle et bateaux au lac de Sainte-Croix', span: '' },
  { src: imgYoga, alt: 'Yoga au lever du soleil — Surf Center', span: '' },
  { src: imgGetty, alt: 'Kayak dans les Gorges du Verdon', span: 'tall' },
  { src: imgSnack, alt: 'Vue drone snack et pédalos — Surf Center', span: '' },
  { src: imgBateau, alt: 'Bateau électrique au Surf Center', span: '' },
  { src: imgConcertJoulik, alt: 'Concert Joulik au Surf Center', span: 'wide' },
  { src: imgPedaloPlage, alt: 'Pédalos sur la plage du lac de Sainte-Croix', span: '' },
  { src: imgPaddle, alt: 'Paddle sur le lac de Sainte-Croix', span: '' },
  { src: imgFramboise, alt: 'Concert Framboise & Cætera — Surf Center', span: '' },
  { src: imgCanoeLac, alt: 'Canoë sur le lac de Sainte-Croix', span: 'tall' },
  { src: imgVoile, alt: 'Planche à voile au lac de Sainte-Croix', span: '' },
  { src: imgEsprit, alt: 'Ambiance conviviale au Surf Center', span: '' },
  { src: imgLac, alt: 'Vue aérienne du lac de Sainte-Croix', span: 'wide' },
  { src: imgSunset, alt: 'Coucher de soleil au Surf Center', span: '' },
  { src: imgEvjf, alt: 'EVJF en bateau électrique', span: '' },
  { src: imgPedalo, alt: 'Pédalos colorés — lac de Sainte-Croix', span: '' },
  { src: imgTrophee, alt: 'Trophée Hobie au Surf Center', span: '' },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ImageGallery',
    name: 'Galerie photos — Surf Center',
    description,
    url: `${siteUrl}/galerie`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Galerie photos', item: `${siteUrl}/galerie` },
    ],
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <LocationHero
    title="Galerie photos"
    tagline="Lac de Sainte-Croix · Gorges du Verdon"
    image={imgBateauxLac}
    alt="Vue panoramique du lac de Sainte-Croix — Gorges du Verdon"
  />
  <Breadcrumbs items={[
    { label: 'Accueil', href: '/' },
    { label: 'Galerie photos' },
  ]} />

  <section class="section" aria-labelledby="mosaic-title">
    <div class="container">
      <header class="section__header reveal">
        <span class="section__eyebrow">Photos</span>
        <h2 id="mosaic-title">Le Surf Center en images</h2>
        <p class="section__lead">Activités nautiques, concerts, couchers de soleil — un aperçu de ce qui vous attend au lac de Sainte-Croix.</p>
      </header>

      <div class="galmosaic">
        {photos.map((p, i) => (
          <div class:list={['galmosaic__item', { 'galmosaic__item--wide': p.span === 'wide', 'galmosaic__item--tall': p.span === 'tall' }, `reveal`]} style={`--d:${Math.min(i, 6) * 50}ms`}>
            <Image src={p.src} alt={p.alt} width={800} height={600} loading={i < 4 ? 'eager' : 'lazy'} decoding="async" format="webp" quality={75} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <BookingCTA title="Envie d'y être ?" text="Réservez votre activité et venez créer vos propres souvenirs au lac de Sainte-Croix." />
</Layout>

<style>
  .galmosaic {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: 220px;
    gap: var(--s-3);
  }

  .galmosaic__item {
    overflow: hidden;
    border-radius: var(--r-md);
    position: relative;
  }

  .galmosaic__item--wide { grid-column: span 2; }
  .galmosaic__item--tall { grid-row: span 2; }

  .galmosaic__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s var(--ease);
  }

  .galmosaic__item:hover img { transform: scale(1.05); }

  @media (min-width: 768px) {
    .galmosaic {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: 260px;
    }
  }

  @media (min-width: 1100px) {
    .galmosaic { grid-auto-rows: 300px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .galmosaic__item img { transition: none; }
  }
</style>
