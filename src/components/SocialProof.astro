---
const stats = [
  { value: "10+", label: "ans d'expérience" },
  { value: "20k+", label: "visiteurs / été" },
  { value: "4.8", label: "étoiles Google" },
  { value: "N°1", label: "Sainte-Croix" },
];
---

<section class="proof" aria-label="Chiffres clés Surf Center">
  <div class="container">
    <div class="proof__grid" role="list">
      {stats.map((stat, i) => (
        <div class={`proof__item reveal ${i > 0 ? `reveal-d${i}` : ''}`} role="listitem">
          <strong class="proof__value">{stat.value}</strong>
          <span class="proof__label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .proof {
    padding-block: var(--s-16);
    border-bottom: 1px solid var(--c-border-light);
  }

  .proof__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--s-8);
  }

  .proof__item { text-align: center; }

  .proof__value {
    display: block;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--c-orange);
    margin-bottom: var(--s-2);
  }

  .proof__label {
    display: block;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--c-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (min-width: 768px) {
    .proof__grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>
