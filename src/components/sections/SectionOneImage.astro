---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import ListIcon from '../ListIcon.astro';

interface ListItem {
  text: string;
  icon?: string;
}

interface Props {
  id?: string;
  eyebrow: string;
  title: string;
  text: string;
  image: { src: string | ImageMetadata; alt: string; };
  list?: ListItem[];
  cta?: { label: string; href?: string; booking?: boolean; };
  reverse?: boolean;
  surface?: boolean;
}

const {
  id,
  eyebrow,
  title,
  text,
  image,
  list,
  cta,
  reverse = false,
  surface = false,
} = Astro.props;

const sectionId = id || eyebrow.toLowerCase().replace(/\s+/g, '-');
const titleId = `${sectionId}-title`;
---

<section
  class:list={['section', { 'section--surface': surface }]}
  aria-labelledby={titleId}
>
  <div class:list={['container s1', { 's1--reverse': reverse }]}>
    <div class="s1__content reveal">
      <span class="section__eyebrow">{eyebrow}</span>
      <h2 id={titleId} set:html={title} />
      <p class="s1__text">{text}</p>

      {list && list.length > 0 && (
        <ul class="s1__list" role="list">
          {list.map((item) => (
            <li>
              {item.icon && <ListIcon name={item.icon} />}
              <span>{item.text}</span>
            </li>
          ))}
        </ul>
      )}

      {cta && (
        cta.booking
          ? <button type="button" class="btn btn--primary" data-booking>{cta.label}</button>
          : <a href={cta.href} class="btn btn--primary">{cta.label}</a>
      )}
    </div>

    <div class="s1__visual reveal reveal-d2">
      {typeof image.src === 'string' ? (
        <img
          class="s1__img"
          src={image.src}
          alt={image.alt}
          width="640"
          height="800"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <Image
          class="s1__img"
          src={image.src}
          alt={image.alt}
          width={640}
          height={800}
          loading="lazy"
          decoding="async"
          format="webp"
          quality={75}
        />
      )}
    </div>
  </div>
</section>

<style>
  .s1 {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-12);
    align-items: center;
  }

  .s1__text {
    font-size: 1rem;
    color: var(--c-text-secondary);
    line-height: 1.75;
    max-width: 38ch;
    margin-top: var(--s-6);
  }

  .s1__list {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    margin-top: var(--s-8);
    margin-bottom: var(--s-10);
  }

  .s1__list li {
    display: flex;
    align-items: flex-start;
    gap: var(--s-3);
    font-size: 0.85rem;
    color: var(--c-text-secondary);
    line-height: 1.5;
  }

  .s1__list li > span {
    padding-top: 1px;
  }

  .s1__img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--r-lg);
  }

  @media (min-width: 900px) {
    .s1 { grid-template-columns: 1fr 1.2fr; gap: var(--s-20); }
    .s1--reverse { grid-template-columns: 1.2fr 1fr; }
    .s1--reverse .s1__visual { order: -1; }
  }
</style>
