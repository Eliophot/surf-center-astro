---
import type { ImageMetadata } from 'astro';
import Layout from '../../layouts/Layout.astro';
import LocationHero from '../../components/locations/LocationHero.astro';
import LocationDetail from '../../components/locations/LocationDetail.astro';
import ServicesGrid from '../../components/locations/ServicesGrid.astro';
import Itineraries from '../../components/locations/Itineraries.astro';
import PricingSlots from '../../components/locations/PricingSlots.astro';
import OtherLocations from '../../components/locations/OtherLocations.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { locationDetails, getLocationBySlug, getOtherLocations } from '../../data/locations';

import imgHeroBateau from '../../assets/images/lac-sainte-croix-gorges-verdon-location-bateaux-electriques.jpg';
import imgHeroPaddle from '../../assets/images/location-paddle-bateaux-electriques-lac-sainte-croix-gorges-verdon.jpeg';
import imgHeroPedalo from '../../assets/images/location-pedalo-lac-sainte-croix-plage-surfcenter.jpeg';
import imgHeroCanoe from '../../assets/images/location-canoe-lac-sainte-croix-surfcenter.jpg';
import imgHeroVoile from '../../assets/images/location-planche-a-voile-windsurf-lac-sainte-croix.png';
import imgHeroCatamaran from '../../assets/images/catamaran-lac-sainte-croix-falaises.jpg';

import imgDetailBateau from '../../assets/images/location-bateau-electrique-lac-sainte-croix-surfcenter.jpeg';
import imgDetailPaddle from '../../assets/images/location-paddle-lac-sainte-croix-surfcenter.jpeg';
import imgDetailPedalo from '../../assets/images/location-pedalo-lac-sainte-croix.jpeg';
import imgDetailCanoe from '../../assets/images/canoe.jpeg';
import imgDetailVoile from '../../assets/images/location-planche-a-voile-windsurf-lac-sainte-croix.png';
import imgDetailCatamaran from '../../assets/images/catamaran-lac-sainte-croix-falaises.jpg';

const heroImageMap: Record<string, ImageMetadata> = {
  'bateau-electrique': imgHeroBateau,
  'paddle': imgHeroPaddle,
  'pedalo': imgHeroPedalo,
  'canoe': imgHeroCanoe,
  'planche-a-voile': imgHeroVoile,
  'catamaran': imgHeroCatamaran,
};

const detailImageMap: Record<string, ImageMetadata> = {
  'bateau-electrique': imgDetailBateau,
  'paddle': imgDetailPaddle,
  'pedalo': imgDetailPedalo,
  'canoe': imgDetailCanoe,
  'planche-a-voile': imgDetailVoile,
  'catamaran': imgDetailCatamaran,
};

export function getStaticPaths() {
  return locationDetails.map((loc) => ({
    params: { slug: loc.slug },
  }));
}

const { slug } = Astro.params;
const loc = getLocationBySlug(slug as string)!;
const others = getOtherLocations(slug as string);

const title = `${loc.title} — Location au lac de Sainte-Croix | Surf Center`;
const description = loc.longDescription;

const siteUrl = 'https://surfcenter-verdon.fr';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `Location ${loc.title} — Surf Center`,
    description: loc.longDescription,
    url: `${siteUrl}/nos-locations/${loc.slug}`,
    image: `${siteUrl}${loc.heroImage}`,
    brand: { '@type': 'Brand', name: 'Surf Center' },
    offers: {
      '@type': 'Offer',
      price: String(loc.price),
      priceCurrency: 'EUR',
      availability: 'https://schema.org/InStock',
      validFrom: '2026-04-01',
      priceValidUntil: '2026-10-31',
      seller: {
        '@type': 'Organization',
        name: 'Surf Center',
        url: siteUrl,
      },
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Nos locations', item: `${siteUrl}/nos-locations` },
      { '@type': 'ListItem', position: 3, name: loc.title, item: `${siteUrl}/nos-locations/${loc.slug}` },
    ],
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <LocationHero
    title={loc.title}
    subtitle={loc.tagline}
    image={heroImageMap[loc.slug] || loc.heroImage}
    alt={loc.heroAlt}
  />
  <Breadcrumbs items={[
    { label: 'Accueil', href: '/' },
    { label: 'Nos locations', href: '/nos-locations' },
    { label: loc.title },
  ]} />
  <LocationDetail
    title={loc.shortTitle}
    description={loc.longDescription}
    image={detailImageMap[loc.slug] || loc.detailImage}
    alt={loc.detailAlt}
    price={loc.price}
    priceUnit={loc.priceUnit}
    capacity={loc.capacity}
    duration={loc.duration}
    level={loc.level}
    tag={loc.tag}
    highlights={loc.highlights}
  />
  <ServicesGrid services={loc.services} />
  <Itineraries routes={loc.itinerary} />
  <PricingSlots price={loc.price} priceUnit={loc.priceUnit} tag={loc.tag} title={loc.shortTitle.toLowerCase()} />
  <OtherLocations locations={others} />
</Layout>
