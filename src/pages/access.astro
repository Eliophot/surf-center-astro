---
const url = new URL(Astro.request.url);
const nextUrl = url.searchParams.get('next') ?? '/';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>En cours de création</title>
    <meta name="robots" content="noindex,nofollow" />
    <style>
      :root {
        color-scheme: light dark;
        --bg: #03040c;
        --card: rgba(255, 255, 255, 0.055);
        --border: rgba(255, 255, 255, 0.1);
        --text: rgba(255, 255, 255, 0.92);
        --muted: rgba(255, 255, 255, 0.64);
        --accent: #22d3ee; /* cyan */
        --accent2: #a78bfa; /* violet */
        --lime: #84cc16;
        --danger: #ff5a7a;
        --orange: #fb7185;
        --ease-ui: cubic-bezier(0.16, 1, 0.3, 1);
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(1200px 680px at 18% 8%, rgba(34, 211, 238, 0.18), transparent 58%),
          radial-gradient(900px 520px at 88% 24%, rgba(167, 139, 250, 0.14), transparent 62%),
          radial-gradient(900px 520px at 70% 92%, rgba(251, 113, 133, 0.08), transparent 62%),
          var(--bg);
        color: var(--text);
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, Cantarell, Noto Sans, sans-serif;
        overflow-x: hidden;
      }

      .stage {
        position: relative;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 2.5rem 1.25rem;
      }

      canvas#bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        opacity: 0.95;
      }

      .scrim {
        position: absolute;
        inset: 0;
        z-index: 1;
        background:
          radial-gradient(900px 520px at 50% 35%, rgba(255, 255, 255, 0.075), transparent 62%),
          linear-gradient(to bottom, rgba(3, 4, 12, 0.62), rgba(3, 4, 12, 0.9));
        pointer-events: none;
      }

      .card {
        position: relative;
        z-index: 2;
        width: min(640px, calc(100% - 2.5rem));
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: var(--card);
        backdrop-filter: blur(18px) saturate(1.35);
        -webkit-backdrop-filter: blur(18px) saturate(1.35);
        border-radius: 20px;
        padding: 1.85rem;
        box-shadow:
          0 30px 110px rgba(0, 0, 0, 0.55),
          0 0 0 1px rgba(34, 211, 238, 0.06) inset;
      }
      .card::before {
        content: '';
        position: absolute;
        inset: -2px;
        border-radius: 22px;
        background: conic-gradient(
          from 180deg,
          rgba(34, 211, 238, 0.95),
          rgba(167, 139, 250, 0.65),
          rgba(251, 113, 133, 0.55),
          rgba(34, 211, 238, 0.95)
        );
        filter: blur(14px);
        opacity: 0.26;
        z-index: -2;
        animation: spin 8.5s linear infinite;
      }
      .card::after {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 20px;
        background:
          /* holo grid */
          linear-gradient(rgba(255, 255, 255, 0.045) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.045) 1px, transparent 1px),
          radial-gradient(900px 420px at 18% 8%, rgba(34, 211, 238, 0.13), transparent 55%),
          radial-gradient(900px 420px at 85% 0%, rgba(167, 139, 250, 0.09), transparent 55%);
        background-size: 46px 46px, 46px 46px, auto, auto;
        background-position: 0 0, 0 0, 0 0, 0 0;
        pointer-events: none;
        z-index: -1;
        opacity: 0.9;
      }
      .card .scan {
        position: absolute;
        inset: 0;
        border-radius: 20px;
        pointer-events: none;
        z-index: 3;
        background: repeating-linear-gradient(
          to bottom,
          rgba(255, 255, 255, 0.06) 0px,
          rgba(255, 255, 255, 0.06) 1px,
          transparent 2px,
          transparent 6px
        );
        opacity: 0.06;
        mix-blend-mode: overlay;
        mask-image: radial-gradient(60% 70% at 50% 35%, #000 70%, transparent 100%);
      }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.4rem 0.75rem;
        border: 1px solid rgba(34, 211, 238, 0.28);
        border-radius: 9999px;
        background: rgba(255, 255, 255, 0.03);
        box-shadow:
          0 0 18px rgba(34, 211, 238, 0.12),
          inset 0 0 14px rgba(34, 211, 238, 0.05);
        margin-bottom: 0.9rem;
      }

      .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: radial-gradient(circle at 30% 30%, #fff, var(--accent) 55%, rgba(34, 211, 238, 0.2) 75%);
        box-shadow: 0 0 14px rgba(34, 211, 238, 0.6);
        animation: pulse 1.2s ease-in-out infinite;
      }

      .badge span {
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.8);
      }

      h1 {
        margin: 0 0 0.5rem 0;
        font-size: 1.7rem;
        letter-spacing: -0.03em;
        line-height: 1.15;
      }

      p {
        margin: 0 0 1.25rem 0;
        color: var(--muted);
        line-height: 1.5;
      }

      .loop {
        margin: 0.25rem 0 1.35rem;
        padding: 0.95rem 1rem;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.09);
        background:
          radial-gradient(900px 280px at 10% 0%, rgba(34, 211, 238, 0.08), transparent 58%),
          radial-gradient(900px 280px at 90% 0%, rgba(167, 139, 250, 0.06), transparent 58%),
          rgba(0, 0, 0, 0.24);
      }

      .loop .label {
        display: block;
        font-size: 0.72rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.5);
        margin-bottom: 0.45rem;
      }

      .loop .line,
      .loop .mono {
        font-size: 1.05rem;
        font-weight: 750;
        letter-spacing: -0.01em;
        line-height: 1.35;
        margin: 0;
        background: linear-gradient(135deg, rgba(38, 207, 255, 1), rgba(59, 130, 246, 1), rgba(247, 123, 70, 1));
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: shimmer 3.5s ease-in-out infinite;
      }
      .loop .mono {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        font-weight: 700;
        font-size: 0.92rem;
        letter-spacing: 0.02em;
        opacity: 0.95;
      }

      .hud {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin: 0.25rem 0 0.75rem;
      }
      .hud__left {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }
      .hud__kicker {
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.45);
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      }
      .hud__title {
        margin: 0;
        font-size: 1.02rem;
        font-weight: 820;
        letter-spacing: -0.02em;
      }
      .hud__right {
        display: flex;
        align-items: center;
        gap: 0.65rem;
      }
      .pill {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.35rem 0.6rem;
        border-radius: 9999px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(0, 0, 0, 0.14);
        color: rgba(255, 255, 255, 0.65);
        font-size: 0.75rem;
        font-weight: 650;
        letter-spacing: 0.02em;
        font-variant-numeric: tabular-nums;
      }
      .pill__dot {
        width: 8px;
        height: 8px;
        border-radius: 9999px;
        background: rgba(132, 204, 22, 0.95);
        box-shadow: 0 0 10px rgba(132, 204, 22, 0.35);
      }

      .progress {
        position: relative;
        height: 10px;
        border-radius: 9999px;
        background: rgba(255, 255, 255, 0.055);
        border: 1px solid rgba(255, 255, 255, 0.085);
        overflow: hidden;
      }
      .progress__bar {
        position: absolute;
        inset: 0;
        width: 55%;
        border-radius: 9999px;
        background: linear-gradient(90deg, rgba(34, 211, 238, 0.95), rgba(167, 139, 250, 0.92), rgba(251, 113, 133, 0.88));
        filter: saturate(1.1);
        animation: load 2.8s var(--ease, cubic-bezier(0.16, 1, 0.3, 1)) infinite;
      }
      .progress__shine {
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.16), transparent);
        transform: translateX(-100%);
        animation: shine 1.6s ease-in-out infinite;
        pointer-events: none;
      }

      .log {
        margin-top: 0.85rem;
        padding-top: 0.85rem;
        border-top: 1px dashed rgba(255, 255, 255, 0.12);
        display: grid;
        gap: 0.35rem;
      }
      .log__row {
        display: flex;
        gap: 0.65rem;
        align-items: baseline;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        font-size: 0.82rem;
        line-height: 1.4;
      }
      .log__ts {
        color: rgba(255, 255, 255, 0.45);
        font-variant-numeric: tabular-nums;
        min-width: 4.2rem;
      }
      .log__msg {
        color: rgba(255, 255, 255, 0.72);
      }
      .log__tag {
        color: rgba(34, 211, 238, 0.85);
      }

      .subline {
        margin: 0.6rem 0 0;
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.6);
      }

      .divider {
        height: 1px;
        width: 100%;
        margin: 1.25rem 0 1rem;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(38, 207, 255, 0.25),
          rgba(255, 255, 255, 0.08),
          rgba(247, 123, 70, 0.18),
          transparent
        );
      }

      form {
        display: grid;
        gap: 0.75rem;
      }

      label {
        font-size: 0.9rem;
        font-weight: 600;
      }

      input[type='password'] {
        width: 100%;
        box-sizing: border-box;
        border-radius: 12px;
        border: 1px solid var(--border);
        padding: 0.85rem 0.95rem;
        background: rgba(0, 0, 0, 0.2);
        color: var(--text);
        outline: none;
      }

      input[type='password']:focus {
        border-color: rgba(38, 207, 255, 0.6);
        box-shadow: 0 0 0 4px rgba(38, 207, 255, 0.15);
      }

      button {
        border: none;
        border-radius: 12px;
        padding: 0.9rem 1rem;
        font-weight: 800;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        cursor: pointer;
        background: linear-gradient(135deg, rgba(38, 207, 255, 1), rgba(59, 130, 246, 1));
        color: #061018;
      }

      button:hover {
        filter: brightness(1.05);
      }

      .error {
        margin-top: 0.25rem;
        color: var(--danger);
        font-weight: 650;
        font-size: 0.92rem;
      }

      .hint {
        margin-top: 0.75rem;
        font-size: 0.82rem;
        color: rgba(255, 255, 255, 0.45);
      }

      .next {
        display: inline-block;
        margin-top: 0.35rem;
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.82rem;
      }

      details {
        margin-top: 1rem;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.03);
        padding: 0.75rem 0.9rem;
      }

      summary {
        cursor: pointer;
        color: rgba(255, 255, 255, 0.75);
        font-weight: 700;
        list-style: none;
      }

      summary::-webkit-details-marker {
        display: none;
      }

      details[open] summary {
        margin-bottom: 0.75rem;
      }

      @keyframes shimmer {
        0% { filter: saturate(1) brightness(1); }
        50% { filter: saturate(1.2) brightness(1.1); }
        100% { filter: saturate(1) brightness(1); }
      }

      @keyframes pulse {
        0%, 100% { transform: scale(0.9); opacity: 0.75; }
        50% { transform: scale(1.15); opacity: 1; }
      }
      @keyframes spin { to { transform: rotate(360deg); } }
      @keyframes load {
        0% { transform: translateX(-35%); width: 35%; }
        50% { transform: translateX(20%); width: 70%; }
        100% { transform: translateX(110%); width: 35%; }
      }
      @keyframes shine {
        0% { transform: translateX(-100%); opacity: 0; }
        30% { opacity: 1; }
        100% { transform: translateX(100%); opacity: 0; }
      }

      @media (prefers-reduced-motion: reduce) {
        .dot { animation: none; }
        .loop .line { animation: none; }
        .card::before,
        .progress__bar,
        .progress__shine { animation: none; }
      }
    </style>
  </head>
  <body>
    <div class="stage">
      <canvas id="bg" aria-hidden="true"></canvas>
      <div class="scrim" aria-hidden="true"></div>

      <main class="card">
        <div class="scan" aria-hidden="true"></div>
        <div class="badge">
          <span class="dot" aria-hidden="true"></span>
          <span>Validation en cours</span>
        </div>

        <h1>En cours de création</h1>
        <p>Cette section est en train d’être finalisée. La home est accessible, le reste est temporairement protégé.</p>

        <div class="loop" aria-live="polite">
          <div class="hud">
            <div class="hud__left">
              <span class="hud__kicker">Preview gate</span>
              <p class="hud__title">Build en cours…</p>
            </div>
            <div class="hud__right">
              <span class="pill"><span class="pill__dot" aria-hidden="true"></span><span id="hudState">compilation</span></span>
              <span class="pill" id="hudPct">42%</span>
            </div>
          </div>

          <div class="progress" role="progressbar" aria-label="Chargement" aria-valuemin="0" aria-valuemax="100">
            <div class="progress__bar" aria-hidden="true"></div>
            <div class="progress__shine" aria-hidden="true"></div>
          </div>

          <div style="margin-top:0.85rem;">
            <span class="label">Petite note pendant le chargement</span>
            <p class="line" id="loopLine">En cours de création… ne soyez pas trop curieux.</p>
            <p class="subline">On peaufine les détails (et on évite de vous spoiler).</p>
          </div>

          <div class="log" aria-hidden="true">
            <div class="log__row"><span class="log__ts" id="t1">00:00</span><span class="log__msg"><span class="log__tag">[assets]</span> optimisation des images…</span></div>
            <div class="log__row"><span class="log__ts" id="t2">00:00</span><span class="log__msg"><span class="log__tag">[ui]</span> alignement des détails & micro-interactions…</span></div>
            <div class="log__row"><span class="log__ts" id="t3">00:00</span><span class="log__msg"><span class="log__tag">[seo]</span> dernières retouches avant validation…</span></div>
          </div>
        </div>

        <div class="divider" aria-hidden="true"></div>

        <details>
          <summary>J’ai le mot de passe</summary>
          <form id="accessForm" novalidate>
            <input type="hidden" name="next" value={nextUrl} />
            <div>
              <label for="password">Mot de passe</label>
              <input id="password" name="password" type="password" autocomplete="current-password" required />
              <div class="error" id="err" role="alert" style="display:none;"></div>
              <span class="next">Destination&nbsp;: {nextUrl}</span>
            </div>
            <button type="submit">Continuer</button>
          </form>
        </details>

        <div class="hint">
          Astuce : vous pouvez aussi revenir à la home via <a href="/" style="color: var(--accent)">/</a>.
        </div>
      </main>
    </div>

    <script is:inline>
      (function () {
        // Auth côté client (SSG) — UX, pas sécurité forte.
        var ACCESS_KEY = 'sc_preview_auth';
        var PASSWORD = '2026eliophotsurfcenter';
        var form = document.getElementById('accessForm');
        var err = document.getElementById('err');

        function showError(msg) {
          if (!err) return;
          err.textContent = msg;
          err.style.display = 'block';
        }

        if (form) {
          form.addEventListener('submit', function (e) {
            e.preventDefault();
            if (err) err.style.display = 'none';

            var pwdInput = form.querySelector('input[name=\"password\"]');
            var nextInput = form.querySelector('input[name=\"next\"]');
            var pwd = pwdInput && pwdInput.value ? String(pwdInput.value) : '';
            var next = nextInput && nextInput.value ? String(nextInput.value) : '/';

            if (pwd !== PASSWORD) {
              showError('Mot de passe incorrect.');
              return;
            }

            try { localStorage.setItem(ACCESS_KEY, '1'); } catch (_) {}
            location.assign(next && next.startsWith('/') ? next : '/');
          });
        }

        var phrases = [
          "En cours de création… ne soyez pas trop curieux.",
          "On assemble les pixels, un par un (promis, on va vite).",
          "Ça arrive… on peaufine la magie et les micro-détails.",
          "Version client : élégante. Version chantier : très secrète.",
          "Encore quelques réglages… et ce sera prêt à briller.",
          "Accès réservé : on évite les spoilers, merci.",
          "On finalise l’expérience — curiosité autorisée, accès limité.",
        ];

        // HUD (état + % + timestamps)
        var hudState = document.getElementById('hudState');
        var hudPct = document.getElementById('hudPct');
        var tsEls = [document.getElementById('t1'), document.getElementById('t2'), document.getElementById('t3')];
        var states = ['compilation', 'bundle', 'optimisation', 'polish UI', 'préparation', 'presque prêt'];
        var pct = 42;
        var lastHud = 0;

        function pad2(n) { return (n < 10 ? '0' : '') + n; }
        function setTS() {
          var d = new Date();
          var s = pad2(d.getHours()) + ':' + pad2(d.getMinutes());
          for (var ii = 0; ii < tsEls.length; ii++) {
            if (tsEls[ii]) tsEls[ii].textContent = s;
          }
        }
        setTS();
        setInterval(setTS, 25000);

        var line = document.getElementById('loopLine');
        var i = 0;
        var lastSwitch = 0;

        function switchLine(t) {
          if (!line) return;
          if (!lastSwitch) lastSwitch = t;
          if (t - lastSwitch < 2400) return;
          lastSwitch = t;
          i = (i + 1) % phrases.length;
          line.style.opacity = '0';
          line.style.transform = 'translateY(6px)';
          setTimeout(function () {
            line.textContent = phrases[i];
            line.style.opacity = '1';
            line.style.transform = 'translateY(0)';
          }, 220);
        }

        function tickHud(t) {
          if (!hudState && !hudPct) return;
          if (!lastHud) lastHud = t;
          if (t - lastHud < 1200) return;
          lastHud = t;
          pct = pct + 1 + Math.round(Math.random() * 2);
          if (pct > 97) pct = 42;
          if (hudPct) hudPct.textContent = pct + '%';
          if (hudState) hudState.textContent = states[Math.floor((pct / 100) * states.length) % states.length];
        }

        if (line) {
          line.style.transition = 'opacity 220ms ease, transform 220ms ease';
        }

        var canvas = document.getElementById('bg');
        if (!(canvas instanceof HTMLCanvasElement)) return;
        var ctx = canvas.getContext('2d');
        if (!ctx) return;

        var dpr = Math.min(2, window.devicePixelRatio || 1);
        var w = 0;
        var h = 0;
        var t0 = 0;

        function resize() {
          w = Math.max(1, Math.floor(window.innerWidth));
          h = Math.max(1, Math.floor(window.innerHeight));
          canvas.width = Math.floor(w * dpr);
          canvas.height = Math.floor(h * dpr);
          canvas.style.width = w + 'px';
          canvas.style.height = h + 'px';
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        }

        var palette = [
          { r: 38, g: 207, b: 255, a: 0.75 },
          { r: 59, g: 130, b: 246, a: 0.55 },
          { r: 247, g: 123, b: 70, a: 0.45 },
        ];

        var particles = Array.from({ length: 84 }, function (_, idx) {
          var p = palette[idx % palette.length];
          return {
            x: Math.random(),
            y: Math.random(),
            vx: (Math.random() - 0.5) * 0.09,
            vy: (Math.random() - 0.5) * 0.09,
            s: 0.6 + Math.random() * 1.6,
            c: p,
          };
        });

        function rgba(c, aMul) {
          return 'rgba(' + c.r + ',' + c.g + ',' + c.b + ',' + (c.a * aMul) + ')';
        }

        function draw(now) {
          if (!t0) t0 = now;
          var t = (now - t0) / 1000;

          ctx.clearRect(0, 0, w, h);

          for (var k = 0; k < 3; k++) {
            var c = palette[k];
            var cx = w * (0.2 + k * 0.3) + Math.sin(t * (0.35 + k * 0.12)) * w * 0.12;
            var cy = h * (0.25 + k * 0.18) + Math.cos(t * (0.32 + k * 0.1)) * h * 0.1;
            var r = Math.min(w, h) * (0.22 + k * 0.04);
            var g = ctx.createRadialGradient(cx, cy, 0, cx, cy, r);
            g.addColorStop(0, rgba(c, 0.22));
            g.addColorStop(1, rgba(c, 0));
            ctx.fillStyle = g;
            ctx.fillRect(0, 0, w, h);
          }

          ctx.globalCompositeOperation = 'lighter';
          for (var band = 0; band < 3; band++) {
            var c2 = palette[band];
            ctx.beginPath();
            var amp = 26 + band * 8;
            var y0 = h * (0.35 + band * 0.13);
            for (var x = -40; x <= w + 40; x += 16) {
              var y = y0 + Math.sin(t * (0.9 + band * 0.2) + x * (0.012 + band * 0.002)) * amp;
              if (x === -40) ctx.moveTo(x, y);
              else ctx.lineTo(x, y);
            }
            ctx.lineWidth = 2.2 + band * 0.6;
            ctx.strokeStyle = rgba(c2, 0.5);
            ctx.shadowColor = rgba(c2, 0.35);
            ctx.shadowBlur = 18;
            ctx.stroke();
          }
          ctx.shadowBlur = 0;

          ctx.globalCompositeOperation = 'source-over';
          for (var j = 0; j < particles.length; j++) {
            var p2 = particles[j];
            p2.x += p2.vx / 60;
            p2.y += p2.vy / 60;
            if (p2.x < -0.05) p2.x = 1.05;
            if (p2.x > 1.05) p2.x = -0.05;
            if (p2.y < -0.05) p2.y = 1.05;
            if (p2.y > 1.05) p2.y = -0.05;

            var px = p2.x * w;
            var py = p2.y * h;
            var rr = p2.s * (1.2 + 0.35 * Math.sin(t * 1.4 + j));
            ctx.beginPath();
            ctx.fillStyle = rgba(p2.c, 0.35);
            ctx.arc(px, py, rr, 0, Math.PI * 2);
            ctx.fill();
          }

          switchLine(now);
          tickHud(now);
          requestAnimationFrame(draw);
        }

        var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce) return;

        resize();
        window.addEventListener('resize', resize, { passive: true });
        requestAnimationFrame(draw);
      })();
    </script>
  </body>
</html>

