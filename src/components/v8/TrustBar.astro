---
const stats = [
  { value: "10+", label: "ans d'expérience" },
  { value: "20 000+", label: "visiteurs chaque été" },
  { value: "4.8★", label: "sur Google (320 avis)" },
  { value: "N°1", label: "base nautique Sainte-Croix" },
];
---

<section class="trust" aria-label="Chiffres clés Surf Center">
  <div class="container">
    <div class="trust__grid" role="list" aria-label="Chiffres clés">
      {stats.map((stat, i) => (
        <div class={`trust__item reveal ${i > 0 ? `reveal-d${i}` : ''}`} role="listitem">
          <strong class="trust__value">{stat.value}</strong>
          <span class="trust__label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trust {
    padding-block: var(--s-12);
    background: var(--c-surface);
    border-bottom: 1px solid var(--c-border-light);
  }

  .trust__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--s-6) var(--s-4);
  }

  .trust__item {
    text-align: center;
    padding: var(--s-4);
  }

  .trust__value {
    display: block;
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--c-orange);
    margin-bottom: var(--s-2);
  }

  .trust__label {
    display: block;
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--c-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1.4;
  }

  @media (min-width: 768px) {
    .trust { padding-block: var(--s-16); }
    .trust__grid { grid-template-columns: repeat(4, 1fr); }
    .trust__item { padding: var(--s-6); }
  }

  /* Mobile a11y — extra +1px on smallest type */
  @media (max-width: 768px) {
    .trust__label { font-size: calc(0.68rem + 1px); }
  }
</style>
