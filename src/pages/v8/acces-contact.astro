---
import LayoutMarketing from '../../layouts/LayoutMarketing.astro';
import { Image } from 'astro:assets';
import imgLac from '../../assets/images/location-lac-sainte-croix-gorges-verdon.png';
import TrustBadges from '../../components/v8/TrustBadges.astro';

const routesData = [
  { from: "Aix-en-Provence", duration: "1h30", distance: "95 km", via: "A51 puis D952" },
  { from: "Marseille", duration: "2h00", distance: "135 km", via: "A51 puis D952" },
  { from: "Nice", duration: "2h30", distance: "170 km", via: "A8 puis RN85" },
  { from: "Lyon", duration: "4h30", distance: "400 km", via: "A7 puis A51" },
  { from: "Toulouse", duration: "4h30", distance: "430 km", via: "A61 puis A54" },
  { from: "Paris", duration: "7h30", distance: "800 km", via: "A6 puis A7/A51" },
];

const faqAccess = [
  { question: "Quelle est l'adresse exacte du Surf Center ?", answer: "Surf Center, Plage des Salles-sur-Verdon, 83630 Les Salles-sur-Verdon. GPS : 43.7766, 6.2100. Suivez les panneaux « Lac / Base nautique » depuis le village." },
  { question: "Y a-t-il un parking ?", answer: "Oui, un grand parking gratuit est à disposition à 50 mètres de la plage. En pleine saison (juillet-août), nous conseillons d'arriver avant 10h pour être sûr d'avoir une place." },
  { question: "Peut-on venir en transport en commun ?", answer: "La ligne de bus LER 24 relie Aix-en-Provence à Moustiers-Sainte-Marie avec un arrêt aux Salles-sur-Verdon. En été, des navettes touristiques desservent aussi le lac." },
  { question: "Le site est-il accessible aux personnes à mobilité réduite ?", answer: "La plage est partiellement aménagée. Contactez-nous en amont pour que nous puissions organiser votre accueil au mieux." },
  { question: "Quels sont vos horaires d'ouverture ?", answer: "D'avril à octobre : 9h-19h en pleine saison (juillet-août), 10h-18h en avant/arrière-saison. Fermé de novembre à mars." },
  { question: "Quel est le meilleur moment pour venir ?", answer: "Juin et septembre offrent un beau temps avec moins de monde. En juillet-août, réservez à l'avance et venez tôt le matin pour profiter du calme." },
];

const proofSidebar = [
  { icon: "clock", text: "Réponse en moins de 24h" },
  { icon: "star", text: "98% de satisfaction client" },
  { icon: "shield", text: "Devis gratuit & sans engagement" },
  { icon: "phone", text: "Aussi joignables au 04 92 77 14 50" },
];
---

<LayoutMarketing
  title="Accès & Contact — Surf Center | Lac de Sainte-Croix"
  description="Comment venir au Surf Center, itinéraires, parking gratuit et formulaire de contact. Base nautique N°1 au lac de Sainte-Croix, Gorges du Verdon."
>
  <!-- HERO -->
  <section class="m8__hero" aria-label="Contacter Surf Center">
    <Image
      class="m8__hero-img"
      src={imgLac}
      alt="Vue aérienne du lac de Sainte-Croix et des Gorges du Verdon"
      widths={[640, 1024, 1440, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      format="webp"
      quality={80}
    />
    <div class="m8__hero-overlay" aria-hidden="true"></div>

    <div class="m8__hero-badge">
      <span class="m8__hero-badge-dot" aria-hidden="true"></span>
      Base nautique N°1 du Verdon
    </div>

    <div class="m8__hero-content">
      <div class="m8__hero-proof">
        <span class="m8__hero-stars" aria-label="4.8 étoiles sur 5">★★★★★</span>
        <span class="m8__hero-proof-text">4.8/5 — 320+ avis vérifiés</span>
      </div>
      <h1 class="m8__hero-title">Accès &<br/>Contact</h1>
      <p class="m8__hero-baseline">Venez nous retrouver au bord du lac de Sainte-Croix</p>
      <div class="m8__hero-actions">
        <a href="#contact-form" class="btn btn--primary btn--lg">
          <span class="btn-flip__inner">
            <span class="btn-flip__front">Nous contacter</span>
            <span class="btn-flip__back">Nous contacter</span>
          </span>
        </a>
        <a href="#itineraires" class="btn btn--ghost btn--lg">Voir les itinéraires</a>
      </div>
      <p class="m8__hero-sub">Réponse en 24h · Devis gratuit · 04 92 77 14 50</p>
    </div>
  </section>

  <!-- CONTACT FORM + SOCIAL PROOF SIDEBAR -->
  <section id="contact-form" class="section" aria-labelledby="m8__contact-title">
    <div class="container">
      <header class="section__header reveal">
        <span class="section__eyebrow">Contact</span>
        <h2 id="m8__contact-title">Écrivez-nous</h2>
        <p class="section__lead">Un projet, une question, un devis ? Nous revenons vers vous sous 24h.</p>
      </header>

      <div class="m8__contact-grid">
        <form class="m8__form reveal" data-contact-form>
          <div class="m8__form-row">
            <div class="m8__form-field">
              <label class="m8__form-label" for="contact-name">Nom complet *</label>
              <input class="m8__form-input" type="text" id="contact-name" name="name" required placeholder="Votre nom" autocomplete="name" />
            </div>
            <div class="m8__form-field">
              <label class="m8__form-label" for="contact-email">Email *</label>
              <input class="m8__form-input" type="email" id="contact-email" name="email" required placeholder="votre@email.fr" autocomplete="email" />
            </div>
          </div>
          <div class="m8__form-row">
            <div class="m8__form-field">
              <label class="m8__form-label" for="contact-phone">Téléphone</label>
              <input class="m8__form-input" type="tel" id="contact-phone" name="phone" placeholder="06 12 34 56 78" autocomplete="tel" />
            </div>
            <div class="m8__form-field">
              <label class="m8__form-label" for="contact-subject">Sujet *</label>
              <select class="m8__form-input" id="contact-subject" name="subject" required>
                <option value="">Choisir un sujet</option>
                <option value="reservation">Réservation</option>
                <option value="groupe">Groupe & événement</option>
                <option value="restauration">Restauration</option>
                <option value="info">Renseignement général</option>
                <option value="autre">Autre</option>
              </select>
            </div>
          </div>
          <div class="m8__form-field">
            <label class="m8__form-label" for="contact-message">Message *</label>
            <textarea class="m8__form-input m8__form-textarea" id="contact-message" name="message" required rows="5" placeholder="Décrivez votre demande…"></textarea>
          </div>
          <button type="submit" class="btn btn--primary btn--lg m8__form-submit">
            <span class="btn-flip__inner">
              <span class="btn-flip__front">Envoyer le message</span>
              <span class="btn-flip__back">Envoyer le message</span>
            </span>
          </button>
          <p class="m8__form-note">En soumettant ce formulaire, vous acceptez d'être recontacté par Surf Center.</p>
        </form>

        <aside class="m8__sidebar reveal reveal-d1">
          <h3 class="m8__sidebar-title">Pourquoi nous contacter ?</h3>
          <ul class="m8__sidebar-list">
            {proofSidebar.map((item) => (
              <li class="m8__sidebar-item">
                <div class="m8__sidebar-icon" aria-hidden="true">
                  {item.icon === 'clock' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>}
                  {item.icon === 'star' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="m12 2 3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01L12 2Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>}
                  {item.icon === 'shield' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>}
                  {item.icon === 'phone' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.11 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.81.36 1.6.68 2.35a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.75.32 1.54.55 2.35.68A2 2 0 0 1 22 16.92Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>}
                </div>
                <span class="m8__sidebar-text">{item.text}</span>
              </li>
            ))}
          </ul>

          <div class="m8__sidebar-card">
            <strong class="m8__sidebar-card-title">Coordonnées directes</strong>
            <p class="m8__sidebar-card-line">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.11 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.81.36 1.6.68 2.35a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.75.32 1.54.55 2.35.68A2 2 0 0 1 22 16.92Z" stroke="currentColor" stroke-width="1.5"/></svg>
              <a href="tel:+33492771450">04 92 77 14 50</a>
            </p>
            <p class="m8__sidebar-card-line">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <a href="mailto:contact@surfcenter-verdon.fr">contact@surfcenter-verdon.fr</a>
            </p>
            <p class="m8__sidebar-card-line">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/></svg>
              Les Salles-sur-Verdon, 83630
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ROUTES GRID -->
  <section id="itineraires" class="section section--surface" aria-labelledby="m8__routes-title">
    <div class="container">
      <header class="section__header reveal">
        <span class="section__eyebrow">Itinéraires</span>
        <h2 id="m8__routes-title">Comment venir</h2>
        <p class="section__lead">Parking gratuit sur place · GPS : 43.7766, 6.2100</p>
      </header>

      <div class="m8__routes-grid">
        {routesData.map((route, i) => (
          <div class={`m8__route-card reveal reveal-d${Math.min(i + 1, 4)}`}>
            <div class="m8__route-from">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/></svg>
              <span>{route.from}</span>
            </div>
            <div class="m8__route-details">
              <div class="m8__route-stat">
                <strong class="m8__route-value">{route.duration}</strong>
                <span class="m8__route-label">de route</span>
              </div>
              <div class="m8__route-stat">
                <strong class="m8__route-value">{route.distance}</strong>
                <span class="m8__route-label">distance</span>
              </div>
            </div>
            <p class="m8__route-via">Via {route.via}</p>
          </div>
        ))}
      </div>

      <div class="m8__map-embed reveal">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2880.5!2d6.21!3d43.7766!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDPCsDQ2JzM2LjAiTiA2wrAxMic0NS42IkU!5e0!3m2!1sfr!2sfr!4v1"
          width="100%"
          height="400"
          style="border:0; border-radius: var(--r-lg);"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Carte — Surf Center, Les Salles-sur-Verdon"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- TRUST BADGES -->
  <TrustBadges />

  <!-- FAQ ACCESS -->
  <section class="section section--surface" aria-labelledby="m8__faq-access-title">
    <div class="container m8__faq-wrap">
      <header class="section__header reveal">
        <span class="section__eyebrow">Questions fréquentes</span>
        <h2 id="m8__faq-access-title">Tout savoir pour<br/>votre venue</h2>
      </header>

      <div class="m8__faq-list reveal">
        {faqAccess.map((faq) => (
          <details class="m8__faq-item">
            <summary class="m8__faq-q">
              <span>{faq.question}</span>
              <svg class="m8__faq-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <div class="m8__faq-a"><p>{faq.answer}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CLOSING CTA -->
  <section class="section m8__closing" aria-labelledby="m8__closing-title">
    <div class="container m8__closing-inner reveal">
      <span class="section__eyebrow" style="color: var(--c-orange)">Prêt à réserver ?</span>
      <h2 id="m8__closing-title" class="m8__closing-title">Venez profiter<br/>du plus beau lac de Provence</h2>
      <p class="m8__closing-text">Réservez en ligne ou appelez-nous directement.</p>
      <div class="m8__closing-proof">
        <span class="m8__closing-dot" aria-hidden="true"></span>
        <span>320+ avis 5 étoiles · Annulation gratuite 24h</span>
      </div>
      <div class="m8__closing-actions">
        <button type="button" class="btn btn--primary btn--lg" data-booking>
          <span class="btn-flip__inner"><span class="btn-flip__front">Réserver maintenant</span><span class="btn-flip__back">Réserver maintenant</span></span>
        </button>
        <a href="tel:+33492771450" class="btn btn--ghost btn--lg">04 92 77 14 50</a>
      </div>
    </div>
  </section>
</LayoutMarketing>

<style>
  /* ── HERO ── */
  .m8__hero {
    position: relative;
    height: 85svh;
    min-height: 550px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #0a0a0a;
  }
  .m8__hero-img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; object-position: center 40%; z-index: 0;
    animation: m8-slow-zoom 25s ease forwards;
  }
  @keyframes m8-slow-zoom { from { transform: scale(1); } to { transform: scale(1.08); } }
  .m8__hero-overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(180deg, rgb(0 0 0 / 0.5) 0%, rgb(0 0 0 / 0.25) 40%, rgb(0 0 0 / 0.7) 100%);
  }
  .m8__hero-badge {
    position: absolute; top: calc(var(--header-h, 80px) + 1rem); left: 50%; transform: translateX(-50%); z-index: 3;
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.45rem 1rem; border-radius: var(--r-full);
    background: rgb(247 123 70 / 0.15); border: 1px solid rgb(247 123 70 / 0.3);
    backdrop-filter: blur(12px); font-size: 0.65rem; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--c-orange-light, #fbbf80);
    white-space: nowrap; animation: m8-fade-up 700ms ease 100ms both;
  }
  .m8__hero-badge-dot {
    width: 6px; height: 6px; border-radius: 50%; background: #4ade80;
    animation: m8-pulse 2s ease-in-out infinite;
  }
  @keyframes m8-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
  @keyframes m8-fade-up {
    from { opacity: 0; transform: translateX(-50%) translateY(16px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }
  .m8__hero-content {
    position: relative; z-index: 2; text-align: center;
    padding-inline: var(--s-6); max-width: 52rem;
    margin-top: calc(var(--header-h, 80px) * 0.4);
  }
  .m8__hero-proof {
    display: flex; align-items: center; justify-content: center;
    gap: 0.5rem; margin-bottom: var(--s-6);
    animation: m8-fade-up2 900ms ease 200ms both;
  }
  @keyframes m8-fade-up2 { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  .m8__hero-stars { font-size: 0.8rem; color: #fbbf24; letter-spacing: 2px; }
  .m8__hero-proof-text { font-size: 0.7rem; font-weight: 500; color: rgb(255 255 255 / 0.6); }
  .m8__hero-title {
    font-size: clamp(3rem, 10vw, 6.5rem); font-weight: 800; line-height: 0.9;
    letter-spacing: -0.04em; text-transform: uppercase; color: #fff !important;
    margin-bottom: var(--s-5); text-shadow: 0 4px 40px rgb(0 0 0 / 0.5);
    animation: m8-fade-up2 900ms ease 400ms both;
  }
  .m8__hero-baseline {
    font-size: clamp(0.9rem, 1.8vw, 1.15rem); font-weight: 500;
    color: rgb(255 255 255 / 0.75) !important; margin-bottom: var(--s-8);
    animation: m8-fade-up2 900ms ease 550ms both;
  }
  .m8__hero-actions {
    display: flex; gap: var(--s-4); justify-content: center; flex-wrap: wrap;
    animation: m8-fade-up2 900ms ease 700ms both;
  }
  .m8__hero-sub {
    margin-top: var(--s-4); font-size: 0.7rem; font-weight: 500;
    color: rgb(255 255 255 / 0.4); letter-spacing: 0.04em;
    animation: m8-fade-up2 900ms ease 850ms both;
  }

  /* ── CONTACT GRID ── */
  .m8__contact-grid {
    display: grid; grid-template-columns: 1fr; gap: var(--s-10);
  }
  @media (min-width: 900px) {
    .m8__contact-grid { grid-template-columns: 1.4fr 1fr; }
  }

  /* ── FORM ── */
  .m8__form { display: flex; flex-direction: column; gap: var(--s-5); }
  .m8__form-row { display: grid; grid-template-columns: 1fr; gap: var(--s-5); }
  @media (min-width: 600px) { .m8__form-row { grid-template-columns: 1fr 1fr; } }
  .m8__form-field { display: flex; flex-direction: column; gap: var(--s-2); }
  .m8__form-label {
    font-size: 0.72rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--c-text-muted);
  }
  .m8__form-input {
    padding: 0.75rem 1rem; border-radius: var(--r-md);
    border: 1px solid var(--c-border); background: var(--c-surface);
    color: var(--c-text); font-size: 0.88rem; font-family: inherit;
    transition: border-color var(--t-fast), box-shadow var(--t-fast);
  }
  .m8__form-input:focus {
    outline: none; border-color: var(--c-orange);
    box-shadow: 0 0 0 3px rgb(247 123 70 / 0.15);
  }
  .m8__form-input::placeholder { color: var(--c-text-muted); opacity: 0.6; }
  .m8__form-textarea { resize: vertical; min-height: 120px; }
  .m8__form-submit { align-self: flex-start; box-shadow: 0 4px 30px rgb(247 123 70 / 0.4); }
  .m8__form-note { font-size: 0.68rem; color: var(--c-text-muted); }

  /* ── SIDEBAR ── */
  .m8__sidebar {
    display: flex; flex-direction: column; gap: var(--s-6);
  }
  .m8__sidebar-title {
    font-size: 0.85rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .m8__sidebar-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--s-4); }
  .m8__sidebar-item { display: flex; align-items: center; gap: var(--s-3); }
  .m8__sidebar-icon {
    width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;
    border-radius: var(--r-md); background: rgb(247 123 70 / 0.1); color: var(--c-orange); flex-shrink: 0;
  }
  .m8__sidebar-text { font-size: 0.82rem; font-weight: 600; color: var(--c-text-secondary); }
  .m8__sidebar-card {
    padding: var(--s-6); background: var(--c-surface); border-radius: var(--r-lg);
    border: 1px solid var(--c-border-light); display: flex; flex-direction: column; gap: var(--s-3);
  }
  .m8__sidebar-card-title { font-size: 0.82rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: var(--s-1); }
  .m8__sidebar-card-line {
    display: flex; align-items: center; gap: var(--s-2);
    font-size: 0.8rem; color: var(--c-text-secondary);
  }
  .m8__sidebar-card-line a {
    color: var(--c-orange); text-decoration: none; font-weight: 600;
  }
  .m8__sidebar-card-line a:hover { text-decoration: underline; }
  .m8__sidebar-card-line svg { color: var(--c-text-muted); flex-shrink: 0; }

  /* ── ROUTES ── */
  .m8__routes-grid {
    display: grid; grid-template-columns: 1fr; gap: var(--s-4); margin-bottom: var(--s-10);
  }
  @media (min-width: 600px) { .m8__routes-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1000px) { .m8__routes-grid { grid-template-columns: repeat(3, 1fr); } }
  .m8__route-card {
    padding: var(--s-6); background: var(--c-bg); border-radius: var(--r-lg);
    border: 1px solid var(--c-border-light);
    transition: border-color var(--t-fast), box-shadow var(--t-fast);
  }
  .m8__route-card:hover { border-color: var(--c-orange); box-shadow: 0 0 0 1px rgb(247 123 70 / 0.1); }
  .m8__route-from {
    display: flex; align-items: center; gap: var(--s-2);
