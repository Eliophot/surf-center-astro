---
import { Image } from 'astro:assets';
import heroImg from '../assets/images/hero-home.jpg';
---

<section class="hero" data-hero aria-label="Surf Center — base nautique au lac de Sainte-Croix">
  <Image
    class="hero__img"
    src={heroImg}
    alt="Kayak sur les eaux turquoise des Gorges du Verdon, falaises et végétation méditerranéenne"
    widths={[640, 1024, 1440, 1920]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
    decoding="async"
    format="webp"
    quality={80}
  />
  <div class="hero__overlay" aria-hidden="true"></div>

  <div class="hero__content">
    <p class="hero__eyebrow">
      <span class="hero__dot" aria-hidden="true"></span>
      Lac de Sainte-Croix · Gorges du Verdon
    </p>
    <h1 class="hero__title">Surf<br/>Center</h1>
    <p class="hero__baseline">Location bateaux & activités nautiques</p>

    <div class="hero__actions">
      <button type="button" class="btn btn--primary btn--lg" data-booking>Réserver</button>
      <a href="#activites" class="btn btn--ghost btn--lg">Découvrir</a>
    </div>
  </div>

  <div class="hero__bottom">
    <div class="hero__scroll" aria-hidden="true">
      <span class="hero__scroll-line"></span>
    </div>
    <p class="hero__location">Les Salles-sur-Verdon, Provence</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100svh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #0a0a0a;
  }

  .hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    z-index: 0;
    animation: slow-zoom 25s var(--ease-smooth) forwards;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg,
        rgb(0 0 0 / 0.6) 0%,
        rgb(0 0 0 / 0.35) 30%,
        rgb(0 0 0 / 0.3) 55%,
        rgb(0 0 0 / 0.7) 100%);
  }

  .hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding-inline: var(--s-6);
    max-width: 52rem;
    margin-top: calc(var(--header-h) * -0.5);
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--s-3);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.85) !important;
    margin-bottom: var(--s-8);
    text-shadow: 0 1px 8px rgb(0 0 0 / 0.5);
    animation: fade-up 900ms var(--ease-smooth) 200ms both;
  }

  .hero__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--c-orange);
    flex-shrink: 0;
  }

  .hero__title {
    font-size: clamp(4rem, 14vw, 9rem);
    font-weight: 800;
    line-height: 0.88;
    letter-spacing: -0.045em;
    text-transform: uppercase;
    color: #ffffff !important;
    margin-bottom: var(--s-6);
    text-shadow: 0 4px 40px rgb(0 0 0 / 0.5), 0 1px 3px rgb(0 0 0 / 0.3);
    animation: fade-up 900ms var(--ease-smooth) 400ms both;
  }

  .hero__baseline {
    font-size: clamp(0.85rem, 1.6vw, 1.05rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--c-orange) !important;
    margin-bottom: var(--s-12);
    text-shadow: 0 1px 12px rgb(0 0 0 / 0.5);
    animation: fade-up 900ms var(--ease-smooth) 600ms both;
  }

  .hero__actions {
    display: flex;
    gap: var(--s-4);
    justify-content: center;
    flex-wrap: wrap;
    animation: fade-up 900ms var(--ease-smooth) 800ms both;
  }

  .hero__bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 3;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: var(--s-8) var(--s-8) var(--s-6);
    animation: fade-up 900ms var(--ease-smooth) 1200ms both;
  }

  .hero__scroll {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 40px;
    background: linear-gradient(180deg, transparent, rgb(255 255 255 / 0.5));
    animation: scroll-pulse 2s ease-in-out infinite;
  }

  @keyframes scroll-pulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.6); transform-origin: top; }
    50%      { opacity: 1; transform: scaleY(1); transform-origin: top; }
  }

  .hero__location {
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.45);
    text-shadow: 0 1px 6px rgb(0 0 0 / 0.4);
  }

  @media (max-width: 480px) {
    .hero__actions {
      flex-direction: column;
      align-items: center;
    }
    .hero__location { display: none; }
    .hero__bottom { justify-content: center; }
  }

  @media (min-width: 1400px) {
    .hero__title {
      font-size: 10rem;
    }
  }
</style>
