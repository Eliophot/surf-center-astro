---
interface Props {
  from?: string;
  to?: string;
  flip?: boolean;
  variant?: 1 | 2 | 3;
}

const {
  from = 'var(--c-bg)',
  to = 'var(--c-surface)',
  flip = false,
  variant = 1,
} = Astro.props;

const paths: Record<number, string> = {
  1: 'M0 30C120 50 240 10 360 30S600 50 720 25S960 10 1080 35S1320 50 1440 30V60H0Z',
  2: 'M0 20C180 45 360 15 540 35C720 55 900 10 1080 30C1260 50 1380 20 1440 35V60H0Z',
  3: 'M0 40C160 15 320 45 480 25C640 5 800 45 960 30C1120 15 1280 40 1440 20V60H0Z',
};
---

<div
  class="wave-sep"
  style={`background: ${from}; ${flip ? 'transform: scaleY(-1)' : ''}`}
  aria-hidden="true"
>
  <svg viewBox="0 0 1440 60" preserveAspectRatio="none" fill="none">
    <path d={paths[variant]} fill={to} />
  </svg>
</div>

<style>
  .wave-sep {
    display: block;
    width: 100%;
    line-height: 0;
    overflow: hidden;
  }

  .wave-sep svg {
    display: block;
    width: 100%;
    height: clamp(28px, 4.5vw, 55px);
  }
</style>
