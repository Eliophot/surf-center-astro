---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  subtitle?: string;
  image: string | ImageMetadata;
  alt: string;
}

const { title, subtitle, image, alt } = Astro.props;

const currentYear = new Date().getFullYear();
---

<section class="lochero" data-hero aria-label={title}>
  {typeof image === 'string' ? (
    <img class="lochero__bg" src={image} alt={alt} width="1920" height="900" loading="eager" fetchpriority="high" decoding="async" />
  ) : (
    <Image
      class="lochero__bg"
      src={image}
      alt={alt}
      widths={[640, 1024, 1440, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      format="webp"
      quality={80}
    />
  )}
  <div class="lochero__overlay" aria-hidden="true"></div>
  <div class="lochero__content">
    <div class="lochero__badge">
      <span class="lochero__badge-dot" aria-hidden="true"></span>
      <span class="lochero__badge-text">Saison {currentYear} — Réservations ouvertes</span>
    </div>
    <h1 class="lochero__title">
      {title.split(' ').map((word, i) => (
        <span class="lochero__title-line">{word}</span>
      ))}
    </h1>
    {subtitle && <p class="lochero__subtitle">{subtitle}</p>}
  </div>
</section>

<style>
  .lochero {
    position: relative;
    height: 70vh;
    min-height: 500px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .lochero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .lochero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.48) 0%,
      rgba(0, 0, 0, 0.28) 30%,
      rgba(0, 0, 0, 0.24) 55%,
      rgba(0, 0, 0, 0.56) 100%
    );
  }

  .lochero__content {
    position: relative;
    z-index: 1;
    padding-left: max(1.5rem, calc((100vw - 1200px) / 2 + 1.5rem));
    padding-top: 6rem;
    animation: lochero-up 800ms var(--ease-smooth) both;
  }

  @keyframes lochero-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .lochero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    background: rgba(247, 123, 70, 0.15);
    border: 1px solid rgba(247, 123, 70, 0.3);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    padding: 0.5rem 1rem;
    border-radius: var(--r-full);
    margin-bottom: 1.5rem;
  }

  .lochero__badge-dot {
    width: 6px;
    height: 6px;
    background: #4ade80;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .lochero__badge-text {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-orange-light);
  }

  .lochero__title {
    display: flex;
    flex-direction: column;
    color: #fff;
    font-family: var(--font-sans);
    font-size: clamp(3.5rem, 10vw, 8.6875rem); /* 139px @ desktop */
    font-style: normal;
    font-weight: 800;
    line-height: clamp(3rem, 8.6vw, 7.5rem); /* 120px @ desktop */
    letter-spacing: -0.052em; /* -7.2px @ 139px */
    text-transform: uppercase;
    text-shadow:
      0 4px 40px rgba(0, 0, 0, 0.50),
      0 1px 3px rgba(0, 0, 0, 0.30);
    margin: 0;
  }

  .lochero__title-line {
    display: block;
  }

  .lochero__subtitle {
    margin-top: 2rem;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    text-shadow: 0px 1px 6px rgba(0, 0, 0, 0.4);
  }

  @media (prefers-reduced-motion: reduce) {
    .lochero__content { animation: none; }
  }

  @media (max-width: 768px) {
    .lochero {
      height: 60vh;
      min-height: 420px;
    }

    .lochero__content {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
      padding-top: 4rem;
    }

    .lochero__badge-text {
      font-size: calc(0.65rem + 1px);
    }

    .lochero__subtitle {
      font-size: calc(0.62rem + 1px);
    }
  }
</style>
