---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import LocationHero from '../components/locations/LocationHero.astro';
import SectionOneImage from '../components/sections/SectionOneImage.astro';
import Maillage from '../components/Maillage.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

import imgSnack from '../assets/images/drone-snack-pedalo-lac-sainte-croix-surfcenter-salades.jpeg';
import imgEsprit from '../assets/images/esprit.png';
import imgBar from '../assets/images/IMG20220610131419.jpg';

const title = 'Restauration — Snack-pizzeria face au lac | Surf Center Verdon';
const description = 'Pizzas artisanales au feu de bois, salades fraîches, glaces et boissons avec terrasse face au lac de Sainte-Croix. Snack-pizzeria Surf Center, Les Salles-sur-Verdon, Gorges du Verdon.';

const siteUrl = 'https://surfcenter-verdon.fr';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'FoodEstablishment',
    name: 'Snack-Pizzeria Surf Center',
    description: 'Pizzas au feu de bois, salades, glaces et boissons avec vue directe sur le lac de Sainte-Croix.',
    url: `${siteUrl}/restauration`,
    image: `${siteUrl}/drone-snack-pedalo-lac-sainte-croix-surfcenter-salades.jpeg`,
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Plage des Salles-sur-Verdon',
      addressLocality: 'Les Salles-sur-Verdon',
      postalCode: '83630',
      addressCountry: 'FR',
    },
    geo: { '@type': 'GeoCoordinates', latitude: 43.7766, longitude: 6.21 },
    servesCuisine: ['Pizza', 'Snack', 'Salades', 'Glaces'],
    priceRange: '€',
    openingHoursSpecification: [{
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
      opens: '11:00', closes: '18:30',
      validFrom: '2026-04-01', validThrough: '2026-10-31',
    }],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Restauration', item: `${siteUrl}/restauration` },
    ],
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <div class="rpage">
  <LocationHero
    title="Restauration"
    image={imgSnack}
    alt="Vue aérienne du snack-pizzeria Surf Center au lac de Sainte-Croix"
  />
  <Breadcrumbs items={[
    { label: 'Accueil', href: '/' },
    { label: 'Restauration' },
  ]} />

  <!-- Le Snack -->
  <SectionOneImage
    id="snack"
    eyebrow="Le snack"
    title="Pause gourmande<br/>face au lac"
    text="Notre snack-pizzeria vous accueille tout au long de la journée, directement sur la plage du lac de Sainte-Croix. Commandez au comptoir, installez-vous en terrasse les pieds dans le sable et profitez de la vue."
    image={{ src: imgSnack, alt: 'Terrasse du snack Surf Center face au lac de Sainte-Croix' }}
    imgIcon={{ src: '/figma/resto-icon.svg', alt: '' }}
    tags={['Service 11h–18h30', 'Terrasse vue lac', 'Commande au comptoir', 'À emporter']}
  />

  <!-- Les Pizzas -->
  <section id="pizzas" class="rp section" aria-labelledby="rp-title">
    <div class="container">
      <article class="rp__row">
        <div class="rp__media reveal">
          <Image
            src={imgEsprit}
            alt="Pizzas artisanales au feu de bois — Surf Center"
            width={1200}
            height={760}
            loading="lazy"
            decoding="async"
            format="webp"
            quality={75}
          />
        </div>

        <div class="rp__copy reveal reveal-d1">
          <h2 class="rp__eyebrow home-h2">Les pizzas</h2>
          <h3 id="rp-title" class="home-h3 rp__title">Au feu de bois,<br/>comme en Italie</h3>
          <p class="rp__desc">Nos pizzas sont préparées chaque jour avec des ingrédients frais et cuites au feu de bois. Pâte faite maison, mozzarella di bufala, légumes de saison — le goût de l'Italie face au lac de Sainte-Croix.</p>

          <div class="rp__tags">
            <span>Feu de bois</span>
            <span>Pâte maison</span>
            <span>Ingrédients frais</span>
            <span>Formules midi</span>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- Le bar -->
  <SectionOneImage
    id="bar"
    eyebrow="Le bar"
    title="Boissons fraîches<br/>& glaces"
    text="Jus de fruits pressés, smoothies, bières artisanales, rosé de Provence et glaces artisanales — tout ce qu'il faut pour se rafraîchir entre deux sessions nautiques."
    image={{ src: imgBar, alt: 'Boissons et glaces au bar Surf Center' }}
    ellipse={{ src: '/figma/events-ellipse.svg', alt: '', position: 'left', width: 84, height: 101 }}
    tags={['Jus frais & smoothies', 'Bières artisanales & rosé', 'Glaces artisanales', 'Café & thé']}
    fill
    vCenterContent
    style="background: linear-gradient(0deg, rgba(38, 207, 255, 0.10) 0%, rgba(38, 207, 255, 0.00) 100%);"
  />

  <!-- Horaires & infos -->
  <section class="infocard section" aria-labelledby="horaires-title">
    <div class="container">
      <header class="section__header reveal">
        <span class="section__eyebrow">Infos pratiques</span>
        <h2 id="horaires-title">Horaires & accès</h2>
        <p class="infocard__intro">Ouvert tous les jours en saison, sans réservation — venez quand vous voulez.</p>
      </header>

      <div class="infocard__grid" role="list">
        <div class="infocard__item reveal reveal-d1" role="listitem" data-info-card>
          <span class="infocard__shimmer" aria-hidden="true"></span>
          <div class="infocard__icon-wrap" aria-hidden="true">
            <div class="infocard__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
          </div>
          <span class="infocard__label">Horaires</span>
          <span class="infocard__value">11h — 18h30</span>
          <span class="infocard__sub">Tous les jours, avril à octobre</span>
        </div>

        <div class="infocard__item reveal reveal-d2" role="listitem" data-info-card>
          <span class="infocard__shimmer" aria-hidden="true"></span>
          <div class="infocard__icon-wrap" aria-hidden="true">
            <div class="infocard__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
            </div>
          </div>
          <span class="infocard__label">Service continu</span>
          <span class="infocard__value">Non-stop</span>
          <span class="infocard__sub">Pas de coupure midi</span>
        </div>

        <div class="infocard__item reveal reveal-d3" role="listitem" data-info-card>
          <span class="infocard__shimmer" aria-hidden="true"></span>
          <div class="infocard__icon-wrap" aria-hidden="true">
            <div class="infocard__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            </div>
          </div>
          <span class="infocard__label">Paiement</span>
          <span class="infocard__value">CB & espèces</span>
          <span class="infocard__sub">Sans minimum</span>
        </div>

        <div class="infocard__item reveal reveal-d4" role="listitem" data-info-card>
          <span class="infocard__shimmer" aria-hidden="true"></span>
          <div class="infocard__icon-wrap" aria-hidden="true">
            <div class="infocard__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
          </div>
          <span class="infocard__label">Accès</span>
          <span class="infocard__value">Plage directe</span>
          <span class="infocard__sub">Parking gratuit à 50m</span>
        </div>
      </div>
    </div>
  </section>

  <Maillage />
  </div>
</Layout>

<style>
  /* ── Padding réduit sur toute la page ────────────── */
  .rpage :global(.section) {
    padding-block: clamp(2.5rem, 6vw, 5rem);
  }

  /* ── Pizzas (layout bloc pro) ────────────────────── */
  .rp {
    overflow: hidden;
  }

  .rp__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-10);
    align-items: stretch;
  }

  .rp__media {
    overflow: hidden;
    border-radius: 20px;
    box-shadow: var(--shadow-md);
    background: #0a0a0a;
  }

  .rp__media :global(img) {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 4 / 3;
  }

  .rp__copy {
    max-width: 380px;
  }

  .rp__eyebrow {
    display: block;
    text-align: left;
    margin: 0 0 var(--s-5);
  }

  .rp__title {
    text-align: left;
    margin-top: 0;
  }

  .rp__desc {
    margin-top: var(--s-6);
    color: #4A4A4A;
    font-family: Montserrat, var(--font-sans);
    font-size: 14.4px;
    line-height: 25.2px;
    max-width: 42ch;
  }

  :global([data-theme='dark']) .rp__desc { color: var(--c-text-secondary); }

  .rp__list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: var(--s-7);
  }

  .rp__list li {
    display: flex;
    gap: var(--s-3);
    color: #4A4A4A;
    font-family: Montserrat, var(--font-sans);
    font-size: 13.1px;
    line-height: 19.68px;
  }

  :global([data-theme='dark']) .rp__list li { color: var(--c-text-secondary); }

  .rp__dash {
    color: var(--c-orange);
    flex-shrink: 0;
  }

  .rp__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    margin-top: var(--s-8);
  }

  .rp__tags span {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    background: var(--c-bg);
    padding: 5px 14px;
    border-radius: var(--r-full);
    border: 1px solid var(--c-border-light);
  }

  :global([data-theme='dark']) .rp__tags span {
    background: var(--c-surface);
    border-color: var(--c-border);
  }

  @media (min-width: 900px) {
    .rp__row {
      grid-template-columns: minmax(0, 1fr) minmax(0, 380px);
      gap: clamp(3rem, 6vw, 5rem);
      align-items: stretch;
    }

    .rp__media {
      height: 100%;
      min-height: 100%;
    }

    .rp__media :global(img) {
      height: 100%;
      min-height: 100%;
    }

    .rp__copy {
      padding-top: var(--s-2);
    }
  }

  /* ── Section ─────────────────────────────────────── */
  .infocard {
    background: linear-gradient(180deg, rgba(38, 207, 255, 0.10) 0%, rgba(38, 207, 255, 0.00) 100%);
  }

  .infocard .section__header { text-align: center; }

  .infocard__intro {
    font-size: 1rem;
    color: var(--c-text-secondary);
    line-height: 1.7;
    max-width: 42ch;
    margin-inline: auto;
    margin-top: var(--s-4);
  }

  /* ── Grid tokens ─────────────────────────────────── */
  .infocard__grid {
    --ic-border:       rgb(237 103 118 / 0.28);
    --ic-border-hover: rgb(237 103 118 / 0.55);
    --ic-glow:         0 0 0 rgb(0 0 0 / 0);
    --ic-glow-hover:
      0 12px 30px rgb(237 103 118 / 0.12),
      0 0 0 1px rgb(237 103 118 / 0.06);
    --ic-shimmer-c1:   rgb(237 103 118 / 0.28);
    --ic-shimmer-c2:   rgb(250 128 61 / 0.20);
    --ic-shimmer-blend: multiply;

    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--s-5);
    max-width: 900px;
    margin-inline: auto;
    margin-top: var(--s-12);
  }

  [data-theme='dark'] .infocard__grid {
    --ic-border:       rgb(237 103 118 / 0.22);
    --ic-border-hover: rgb(237 103 118 / 0.55);
    --ic-glow:         inset 0 0 0 1px rgb(255 255 255 / 0.02);
    --ic-glow-hover:
      0 0 24px rgb(237 103 118 / 0.18),
      0 0 60px rgb(250 128 61 / 0.10),
      inset 0 0 24px rgb(237 103 118 / 0.06);
    --ic-shimmer-c1:   rgb(237 103 118 / 0.34);
    --ic-shimmer-c2:   rgb(250 128 61 / 0.26);
    --ic-shimmer-blend: screen;
  }

  /* ── Card ────────────────────────────────────────── */
  .infocard__item {
    --holo-x: 50%;
    --holo-y: 50%;
    --holo-angle: 180deg;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--s-3);
    padding: var(--s-8) var(--s-5);
    background: var(--c-bg);
    border-radius: var(--r-xl);
    border: 1px solid var(--ic-border);
    overflow: hidden;
    box-shadow: var(--ic-glow);
    transition:
      border-color 0.4s var(--ease),
      box-shadow   0.4s var(--ease),
      transform    0.4s var(--ease);
  }

  .infocard__item:hover {
    border-color: var(--ic-border-hover);
    box-shadow: var(--ic-glow-hover);
    transform: translateY(-3px);
  }

  [data-theme='dark'] .infocard__item { background: var(--c-surface); }

  /* ── Shimmer ─────────────────────────────────────── */
  .infocard__shimmer {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s var(--ease);
    background:
      radial-gradient(
        circle at var(--holo-x) var(--holo-y),
        var(--ic-shimmer-c1) 0%,
        transparent 55%
      ),
      conic-gradient(
        from var(--holo-angle) at var(--holo-x) var(--holo-y),
        var(--ic-shimmer-c1),
        var(--ic-shimmer-c2),
        var(--ic-shimmer-c1)
      );
    mix-blend-mode: var(--ic-shimmer-blend);
  }

  .infocard__item:hover .infocard__shimmer { opacity: 1; }

  /* ── Icon ────────────────────────────────────────── */
  .infocard__icon-wrap { position: relative; z-index: 2; }

  .infocard__icon {
    position: relative;
    z-index: 1;
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--r-full);
    background: linear-gradient(180deg, #ED6776 0%, #F47456 71.742%, #F77B46 100%);
    color: #fff;
    margin-bottom: var(--s-2);
  }

  /* ── Typography ──────────────────────────────────── */
  .infocard__label {
    position: relative; z-index: 2;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--c-text-muted);
  }

  .infocard__value {
    position: relative; z-index: 2;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--c-text);
    line-height: 1.2;
  }

  .infocard__sub {
    position: relative; z-index: 2;
    font-size: 0.78rem;
    color: var(--c-text-muted);
    line-height: 1.4;
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (min-width: 600px) {
    .infocard__grid { grid-template-columns: repeat(4, 1fr); gap: var(--s-6); }
    .infocard__item { padding: var(--s-10) var(--s-5); }
    .infocard__icon { width: 80px; height: 80px; }
    .infocard__icon svg { width: 32px; height: 32px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .infocard__item,
    .infocard__shimmer { transition: none; }
    .infocard__item:hover { transform: none; }
  }
</style>

<script>
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduced) {
    document.querySelectorAll<HTMLElement>('[data-info-card]').forEach((card) => {
      let raf = 0;
      const onMove = (e: MouseEvent) => {
        if (raf) return;
        raf = requestAnimationFrame(() => {
          raf = 0;
          const r = card.getBoundingClientRect();
          const x = ((e.clientX - r.left) / r.width) * 100;
          const y = ((e.clientY - r.top) / r.height) * 100;
          card.style.setProperty('--holo-x', `${x}%`);
          card.style.setProperty('--holo-y', `${y}%`);
          card.style.setProperty('--holo-angle', `${Math.round(x * 3.6)}deg`);
        });
      };
      const onLeave = () => {
        if (raf) { cancelAnimationFrame(raf); raf = 0; }
        card.style.setProperty('--holo-x', '50%');
        card.style.setProperty('--holo-y', '50%');
      };
      card.addEventListener('mousemove', onMove, { passive: true });
      card.addEventListener('mouseleave', onLeave);
    });
  }
</script>
