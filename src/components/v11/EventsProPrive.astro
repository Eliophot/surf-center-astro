---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Block {
  eyebrow: string;
  title: string;
  text: string;
  list: string[];
  cta: { label: string; href: string };
  image: { src: ImageMetadata; alt: string };
  secondaryImage?: { src: ImageMetadata; alt: string };
}

interface Props {
  privateBlock: Block;
  proBlock: Block;
}

const { privateBlock, proBlock } = Astro.props;
---

<section class="epp" aria-labelledby="epp-title">
  <p id="epp-title" class="sr-only">Événements privés et professionnels</p>

  <div class="container">
    <article class="epp__row epp__row--private">
      <div class="epp__media reveal">
        <Image
          src={privateBlock.image.src}
          alt={privateBlock.image.alt}
          width={900}
          height={1400}
          loading="lazy"
          decoding="async"
          format="webp"
          quality={75}
        />
      </div>

      <div class="epp__copy reveal reveal-d1">
        <h2 class="epp__eyebrow home-h2">{privateBlock.eyebrow}</h2>
        <h3 class="home-h3 epp__title">{privateBlock.title}</h3>
        <p class="epp__desc">{privateBlock.text}</p>

        <ul class="epp__list" role="list">
          {privateBlock.list.map((t) => (
            <li><span class="epp__dash" aria-hidden="true">—</span><span>{t}</span></li>
          ))}
        </ul>

        <a href={privateBlock.cta.href} class="btn btn--primary epp__cta">
          <span class="btn-flip__inner">
            <span class="btn-flip__front">{privateBlock.cta.label}</span>
            <span class="btn-flip__back">{privateBlock.cta.label}</span>
          </span>
        </a>

        {privateBlock.secondaryImage && (
          <div class="epp__secondary-wrap">
            <div class="epp__secondary reveal reveal-d2">
              <Image
                src={privateBlock.secondaryImage.src}
                alt={privateBlock.secondaryImage.alt}
                width={900}
                height={600}
                loading="lazy"
                decoding="async"
                format="webp"
                quality={75}
              />
            </div>
            <span class="epp__ellipse" aria-hidden="true">
              <img src="/figma/events-ellipse.svg" alt="" width="84" height="101" loading="lazy" decoding="async" />
            </span>
          </div>
        )}
      </div>
    </article>

    <article class="epp__row epp__row--pro">
      <div class="epp__copy reveal">
        <h2 class="epp__eyebrow home-h2">{proBlock.eyebrow}</h2>
        <h3 class="home-h3 epp__title">{proBlock.title}</h3>
        <p class="epp__desc">{proBlock.text}</p>

        <ul class="epp__list" role="list">
          {proBlock.list.map((t) => (
            <li><span class="epp__dash" aria-hidden="true">—</span><span>{t}</span></li>
          ))}
        </ul>

        <a href={proBlock.cta.href} class="btn btn--primary epp__cta">
          <span class="btn-flip__inner">
            <span class="btn-flip__front">{proBlock.cta.label}</span>
            <span class="btn-flip__back">{proBlock.cta.label}</span>
          </span>
        </a>
      </div>

      <div class="epp__media reveal reveal-d1">
        <Image
          src={proBlock.image.src}
          alt={proBlock.image.alt}
          width={1200}
          height={760}
          loading="lazy"
          decoding="async"
          format="webp"
          quality={75}
        />
      </div>
    </article>
  </div>
</section>

<style>
  .epp {
    padding: var(--s-section) 0;
    background: linear-gradient(
      180deg,
      rgba(39, 207, 255, 0.10) 0%,
      rgba(147, 231, 255, 0.10) 23.077%,
      rgba(255, 255, 255, 0.10) 61.058%
    );
    overflow: hidden;
  }

  .epp__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-10);
    align-items: start;
  }

  .epp__row + .epp__row {
    margin-top: clamp(3.5rem, 9vw, 7rem);
  }

  .epp__media {
    overflow: hidden;
    border-radius: 20px;
    box-shadow: var(--shadow-md);
    background: #0a0a0a;
  }

  .epp__media :global(img) {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .epp__row--private .epp__media :global(img) {
    aspect-ratio: 564 / 958;
  }

  .epp__row--pro .epp__media :global(img) {
    aspect-ratio: 1137 / 619;
  }

  .epp__copy {
    max-width: 380px;
  }

  .epp__eyebrow {
    display: block;
    text-align: left;
    margin: 0 0 var(--s-5);
  }

  .epp__title {
    text-align: left;
    margin-top: 0;
  }

  .epp__desc {
    margin-top: var(--s-6);
    color: #4A4A4A;
    font-family: Montserrat, var(--font-sans);
    font-size: 14.4px;
    line-height: 25.2px;
    max-width: 42ch;
  }

  .epp__list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: var(--s-7);
  }

  .epp__list li {
    display: flex;
    gap: var(--s-3);
    color: #4A4A4A;
    font-family: Montserrat, var(--font-sans);
    font-size: 13.1px;
    line-height: 19.68px;
  }

  .epp__dash {
    color: var(--c-orange);
    flex-shrink: 0;
  }

  .epp__cta {
    margin-top: var(--s-8);
  }

  .epp__secondary-wrap {
    position: relative;
    margin-top: var(--s-10);
  }

  .epp__secondary {
    overflow: hidden;
    border-radius: 20px;
    box-shadow: var(--shadow-md);
    position: relative;
    z-index: 1;
  }

  .epp__secondary :global(img) {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 564 / 376;
    object-fit: cover;
  }

  .epp__ellipse {
    position: absolute;
    width: 84px;
    height: 101px;
    top: -50px;
    right: -64px;
    z-index: 0;
    display: none;
    pointer-events: none;
    user-select: none;
  }

  .epp__ellipse img {
    width: 100%;
    height: 100%;
    display: block;
  }

  @media (min-width: 900px) {
    .epp__ellipse { display: block; }

    .epp__row--private {
      grid-template-columns: 1fr 1fr;
      gap: clamp(3rem, 6vw, 5rem);
      align-items: stretch;
    }

    .epp__row--private .epp__copy {
      padding-top: var(--s-2);
      max-width: none;
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .epp__row--pro {
      grid-template-columns: minmax(0, 380px) minmax(0, 1fr);
      gap: clamp(3rem, 6vw, 5rem);
      align-items: stretch;
    }

    .epp__row--pro .epp__copy {
      padding-top: var(--s-2);
    }

    .epp__row--pro .epp__media {
      height: 100%;
      min-height: 100%;
    }

    .epp__row--pro .epp__media :global(img) {
      aspect-ratio: auto;
      height: 100%;
      min-height: 100%;
    }
  }
</style>

