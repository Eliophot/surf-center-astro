---
import '../styles/global.css';
import HeaderHyper from '../components/v11/HeaderHyper.astro';
import FooterHyper from '../components/v11/FooterHyper.astro';
import WaterCanvas from '../components/v11/WaterCanvas.astro';
import UniversalModal from '../components/UniversalModal.astro';
import VersionSwitcher from '../components/VersionSwitcher.astro';
import StickyActions from '../components/StickyActions.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = '/og-default.jpg',
  jsonLd,
} = Astro.props;

const siteUrl = 'https://surfcenter-verdon.fr';
---

<!doctype html>
<html lang="fr" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#050510" id="meta-theme-color" />

    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = stored || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.classList.toggle('dark', theme === 'dark');
        var meta = document.getElementById('meta-theme-color');
        if (meta) meta.setAttribute('content', theme === 'dark' ? '#050510' : '#ffffff');
      })();
    </script>

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:site_name" content="Surf Center" />
    <meta property="og:locale" content="fr_FR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <meta name="geo.region" content="FR-83" />
    <meta name="geo.placename" content="Les Salles-sur-Verdon" />
    <meta name="geo.position" content="43.7766;6.2100" />
    <meta name="ICBM" content="43.7766, 6.2100" />

    {jsonLd && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])}
      />
    )}

    <style is:inline>
      body.hyper-body {
        background: #050510;
        color: #f0f0eb;
      }
      .lh11-cursor {
        position: fixed;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(38, 207, 255, 0.6) 0%, transparent 70%);
        box-shadow: 0 0 12px rgba(38, 207, 255, 0.4), 0 0 24px rgba(38, 207, 255, 0.15);
        pointer-events: none;
        z-index: 9999;
        transform: translate(-50%, -50%);
        transition: opacity 0.3s ease;
        opacity: 0;
        mix-blend-mode: screen;
      }
      .lh11-cursor.is-visible {
        opacity: 1;
      }
    </style>
  </head>
  <body class="hyper-body">
    <WaterCanvas opacity={0.25} speed={0.8} />
    <HeaderHyper />
    <main id="main-content">
      <slot />
    </main>
    <FooterHyper />
    <UniversalModal />
    <VersionSwitcher />
    <StickyActions />

    <div class="lh11-cursor" id="cursorTrail" aria-hidden="true"></div>

    <button class="spct11" id="scrollPct11" type="button" aria-label="Retour en haut">
      <span class="spct11__left">
        <span class="spct11__pct">
          <span class="spct11__num" id="scrollValue11">0</span><span class="spct11__sign">%</span>
        </span>
        <span class="spct11__arrow">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M8 13V3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M4 6.5L8 3l4 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </span>
      <span class="spct11__sep" aria-hidden="true"></span>
      <span class="spct11__right">
        <span class="spct11__label-scroll">SCROLL</span>
        <span class="spct11__label-top">TOP</span>
      </span>
    </button>

    <style>
      .spct11 {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        z-index: 90;
        display: flex;
        align-items: center;
        gap: 0;
        height: 46px;
        padding: 0;
        border: 1px solid rgba(38, 207, 255, 0.15);
        border-radius: var(--r-full, 9999px);
        background: rgba(5, 5, 16, 0.6);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3), 0 0 12px rgba(38, 207, 255, 0.05);
        cursor: pointer;
        opacity: 0;
        transform: translateY(16px);
        transition:
          opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1),
          transform 0.45s cubic-bezier(0.16, 1, 0.3, 1),
          box-shadow 0.3s ease,
          border-color 0.3s ease;
        pointer-events: none;
        user-select: none;
        font-family: var(--font-sans);
        outline: none;
        color: rgba(255, 255, 255, 0.7);
      }

      .spct11.is-active {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }

      .spct11:hover {
        border-color: rgba(38, 207, 255, 0.4);
        box-shadow: 0 6px 28px rgba(0, 0, 0, 0.4), 0 0 16px rgba(38, 207, 255, 0.1);
      }

      .spct11:active { transform: scale(0.96); }

      .spct11__left {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 54px;
        height: 100%;
      }

      .spct11__pct {
        display: flex;
        align-items: baseline;
        gap: 1px;
        transition: opacity 0.25s ease, transform 0.25s ease;
      }

      .spct11__arrow {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #26cfff;
        opacity: 0;
        transform: translateY(4px);
        transition: opacity 0.25s ease, transform 0.25s ease;
      }

      .spct11:hover .spct11__pct {
        opacity: 0;
        transform: translateY(-4px);
      }

      .spct11:hover .spct11__arrow {
        opacity: 1;
        transform: translateY(0);
      }

      .spct11__num {
        font-size: 0.92rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1;
        color: #26cfff;
        font-variant-numeric: tabular-nums;
        text-shadow: 0 0 8px rgba(38, 207, 255, 0.3);
      }

      .spct11__sign {
        font-size: 0.52rem;
        font-weight: 600;
        color: rgba(38, 207, 255, 0.5);
        line-height: 1;
        margin-left: 1px;
      }

      .spct11__sep {
        width: 1px;
        height: 18px;
        background: rgba(38, 207, 255, 0.12);
        flex-shrink: 0;
      }

      .spct11__right {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 1rem;
        height: 100%;
      }

      .spct11__label-scroll,
      .spct11__label-top {
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        line-height: 1;
        transition: opacity 0.25s ease, transform 0.25s ease;
      }

      .spct11__label-scroll {
        color: rgba(255, 255, 255, 0.35);
      }

      .spct11__label-top {
        position: absolute;
        color: #26cfff;
        opacity: 0;
        transform: translateY(4px);
      }

      .spct11:hover .spct11__label-scroll {
        opacity: 0;
        transform: translateY(-4px);
      }

      .spct11:hover .spct11__label-top {
        opacity: 1;
        transform: translateY(0);
      }

      @media (max-width: 768px) {
        .spct11 { display: none; }
      }

      @media (prefers-reduced-motion: reduce) {
        .spct11,
        .spct11__pct,
        .spct11__arrow,
        .spct11__label-scroll,
        .spct11__label-top { transition: none; }
      }
    </style>

    <!-- Reveal observer -->
    <script is:inline>
      document.documentElement.classList.remove('no-js');
      if ('IntersectionObserver' in window) {
        var ro = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              ro.unobserve(e.target);
            }
          });
        }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll('.reveal').forEach(function (el) { ro.observe(el); });
      } else {
        document.querySelectorAll('.reveal').forEach(function (el) { el.classList.add('is-visible'); });
      }
    </script>

    <!-- Scroll percent button -->
    <script is:inline>
      (function () {
        var el = document.getElementById('scrollPct11');
        var val = document.getElementById('scrollValue11');
        if (!el || !val) return;

        var ticking = false;
        var shown = false;
        var last = -1;

        function update() {
          ticking = false;
          var h = document.documentElement.scrollHeight - window.innerHeight;
          if (h <= 0) return;
          var pct = Math.round((window.scrollY / h) * 100);
          if (pct === last) return;
          last = pct;
          if (!shown && pct > 0) { shown = true; el.classList.add('is-active'); }
          if (shown && pct === 0) { shown = false; el.classList.remove('is-active'); }
          val.textContent = pct;
        }

        window.addEventListener('scroll', function () {
          if (!ticking) { ticking = true; requestAnimationFrame(update); }
        }, { passive: true });

        el.addEventListener('click', function () {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      })();
    </script>

    <!-- Cursor trail effect -->
    <script is:inline>
      (function () {
        var dot = document.getElementById('cursorTrail');
        if (!dot || window.matchMedia('(pointer: coarse)').matches) return;

        var cx = -100, cy = -100;
        var dx = -100, dy = -100;
        var visible = false;

        document.addEventListener('mousemove', function (e) {
          cx = e.clientX;
          cy = e.clientY;
          if (!visible) {
            visible = true;
            dot.classList.add('is-visible');
          }
        }, { passive: true });

        document.addEventListener('mouseleave', function () {
          visible = false;
          dot.classList.remove('is-visible');
        });

        function animate() {
          dx += (cx - dx) * 0.15;
          dy += (cy - dy) * 0.15;
          dot.style.left = dx + 'px';
          dot.style.top = dy + 'px';
          requestAnimationFrame(animate);
        }
        requestAnimationFrame(animate);
      })();
    </script>
  </body>
</html>
