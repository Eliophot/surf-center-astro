---
const items = [
  {
    label: 'Paiement 100% sécurisé',
    icon: 'shield',
  },
  {
    label: 'Satisfaction garantie',
    icon: 'check',
  },
  {
    label: 'Annulation gratuite 24h',
    icon: 'refresh',
  },
  {
    label: 'Données protégées',
    icon: 'lock',
  },
];
---

<section class="trust" aria-label="Engagements de confiance">
  <ul class="container trust__list" role="list">
    {items.map((it) => (
      <li class="trust__item">
        <span class="trust__icon" aria-hidden="true">
          {it.icon === 'shield' && (
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path
                d="M10 2.5 4 4.5v4.7c0 3.4 2.4 6.6 6 8.3 3.6-1.7 6-4.9 6-8.3V4.5l-6-2Z"
                stroke="currentColor"
                stroke-width="1.4"
                stroke-linejoin="round"
              />
            </svg>
          )}
          {it.icon === 'check' && (
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.4" />
              <path
                d="m6.8 10.3 2.2 2.2 4.2-4.5"
                stroke="currentColor"
                stroke-width="1.4"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          )}
          {it.icon === 'refresh' && (
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path
                d="M16.5 4.5v4h-4M3.5 15.5v-4h4"
                stroke="currentColor"
                stroke-width="1.4"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
              <path
                d="M5.5 8.5A5 5 0 0 1 14.4 7M14.5 11.5A5 5 0 0 1 5.6 13"
                stroke="currentColor"
                stroke-width="1.4"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          )}
          {it.icon === 'lock' && (
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <rect
                x="4"
                y="9"
                width="12"
                height="8"
                rx="1.5"
                stroke="currentColor"
                stroke-width="1.4"
              />
              <path
                d="M6.5 9V7a3.5 3.5 0 1 1 7 0v2"
                stroke="currentColor"
                stroke-width="1.4"
                stroke-linecap="round"
              />
            </svg>
          )}
        </span>
        <span class="trust__label">{it.label}</span>
      </li>
    ))}
  </ul>
</section>

<style>
  .trust {
    background: #111;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    padding: clamp(2rem, 4vw, 3rem) 0;
  }

  .trust__list {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(2rem, 5vw, 4.5rem);
    flex-wrap: wrap;
    margin-block: 0;
    margin-inline: auto;
    padding-inline: var(--s-6);
  }

  .trust__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    min-width: 0;
  }

  .trust__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.06);
    color: #27CFFF;
    flex-shrink: 0;
  }

  .trust__icon svg {
    width: 20px;
    height: 20px;
  }

  .trust__label {
    color: rgba(255, 255, 255, 0.7);
    text-align: center;
    font-family: Montserrat, var(--font-sans);
    font-size: 11.5px;
    font-style: normal;
    font-weight: 600;
    line-height: 14.98px; /* 130.317% */
    letter-spacing: 0.23px;
  }

  @media (max-width: 599px) {
    .trust__list {
      gap: var(--s-6) var(--s-4);
    }

    .trust__item {
      flex: 0 0 calc(50% - var(--s-2));
      gap: 10px;
    }
  }
</style>
