---
interface ServiceItem {
  icon: string;
  label: string;
}

interface Props {
  services: ServiceItem[];
  title?: string;
}

const { services, title = 'Services inclus' } = Astro.props;
---

<div class="svcgrid section" aria-labelledby="svc-title">
  <div class="container">
    <header class="section__header reveal">
      <span class="section__eyebrow">Nos engagements</span>
      <h2 id="svc-title">{title}</h2>
    </header>

    <div class="svcgrid__grid" role="list">
      {services.map((svc, i) => (
        <div class={`svcgrid__item reveal reveal-d${i + 1}`} role="listitem" data-svc-card>
          <span class="svcgrid__shimmer" aria-hidden="true"></span>
          <div class="svcgrid__icon-wrap" aria-hidden="true">
            <div class="svcgrid__icon">
              {svc.icon === 'pet' && (
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <ellipse cx="8.5" cy="8" rx="2" ry="2.5"/>
                  <ellipse cx="15.5" cy="8" rx="2" ry="2.5"/>
                  <ellipse cx="5" cy="13" rx="1.5" ry="2"/>
                  <ellipse cx="19" cy="13" rx="1.5" ry="2"/>
                  <path d="M12 18c-4 0-6-2-6-4s2-3 6-3 6 1 6 3-2 4-6 4z"/>
                </svg>
              )}
              {svc.icon === 'nopermit' && (
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M2 20L22 4"/>
                  <rect x="3" y="11" width="18" height="8" rx="2"/>
                  <path d="M7 11V9a5 5 0 0110 0v2"/>
                  <circle cx="12" cy="15" r="1.5"/>
                </svg>
              )}
              {svc.icon === 'calendar' && (
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="18" rx="2"/>
                  <path d="M16 2v4M8 2v4M3 10h18"/>
                  <path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01"/>
                </svg>
              )}
            </div>
          </div>
          <span class="svcgrid__label">{svc.label}</span>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  /* ── Theme tokens ────────────────────────────────── */
  .svcgrid__grid {
    --svc-card-bg: var(--c-bg);
    --svc-card-border: rgb(250 128 61 / 0.18);
    --svc-card-border-hover: rgb(237 102 122 / 0.45);
    --svc-card-glow: 0 0 0 rgb(0 0 0 / 0);
    --svc-card-glow-hover:
      0 12px 30px rgb(250 128 61 / 0.10),
      0 0 0 1px rgb(237 102 122 / 0.06);
    --svc-shimmer-c1: rgb(250 128 61 / 0.22);
    --svc-shimmer-c2: rgb(237 102 122 / 0.18);
    --svc-shimmer-blend: multiply;

    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-6);
    max-width: 900px;
    margin-inline: auto;
  }

  [data-theme='dark'] .svcgrid__grid {
    --svc-card-bg: var(--c-surface);
    --svc-card-border: rgb(250 128 61 / 0.18);
    --svc-card-border-hover: rgb(237 102 122 / 0.50);
    --svc-card-glow: inset 0 0 0 1px rgb(255 255 255 / 0.02);
    --svc-card-glow-hover:
      0 0 24px rgb(250 128 61 / 0.16),
      0 0 60px rgb(237 102 122 / 0.10),
      inset 0 0 24px rgb(250 128 61 / 0.05);
    --svc-shimmer-c1: rgb(250 128 61 / 0.30);
    --svc-shimmer-c2: rgb(237 102 122 / 0.24);
    --svc-shimmer-blend: screen;
  }

  /* ── Card ────────────────────────────────────────── */
  .svcgrid__item {
    --holo-x: 50%;
    --holo-y: 50%;
    --holo-angle: 180deg;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--s-5);
    padding: var(--s-8) var(--s-6);
    background: var(--svc-card-bg);
    border-radius: var(--r-xl);
    border: 1px solid var(--svc-card-border);
    overflow: hidden;
    box-shadow: var(--svc-card-glow);
    transition:
      border-color 0.4s var(--ease),
      box-shadow 0.4s var(--ease),
      transform 0.4s var(--ease);
  }

  .svcgrid__item:hover {
    border-color: var(--svc-card-border-hover);
    box-shadow: var(--svc-card-glow-hover);
    transform: translateY(-2px);
  }

  /* ── Shimmer overlay ─────────────────────────────── */
  .svcgrid__shimmer {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s var(--ease);
    background:
      radial-gradient(
        circle at var(--holo-x) var(--holo-y),
        var(--svc-shimmer-c1) 0%,
        transparent 55%
      ),
      conic-gradient(
        from var(--holo-angle) at var(--holo-x) var(--holo-y),
        var(--svc-shimmer-c1),
        var(--svc-shimmer-c2),
        var(--svc-shimmer-c1)
      );
    mix-blend-mode: var(--svc-shimmer-blend);
  }

  .svcgrid__item:hover .svcgrid__shimmer { opacity: 1; }

  /* ── Icon ────────────────────────────────────────── */
  .svcgrid__icon-wrap {
    position: relative;
    z-index: 2;
  }

  .svcgrid__icon-wrap::before {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: var(--r-full);
    background: linear-gradient(135deg, rgb(247 123 70 / 0.15), rgb(247 123 70 / 0.05));
    z-index: 0;
  }

  .svcgrid__icon {
    position: relative;
    z-index: 1;
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--r-full);
    background: linear-gradient(145deg, var(--c-orange), #e05a2d);
    color: #fff;
    box-shadow: 
      0 4px 16px rgb(247 123 70 / 0.35),
      inset 0 1px 0 rgb(255 255 255 / 0.2);
  }

  .svcgrid__icon svg {
    filter: drop-shadow(0 1px 2px rgb(0 0 0 / 0.15));
  }

  .svcgrid__label {
    position: relative;
    z-index: 2;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--c-text);
    line-height: 1.3;
  }

  @media (min-width: 600px) {
    .svcgrid__grid { 
      grid-template-columns: repeat(3, 1fr); 
      gap: var(--s-8);
    }

    .svcgrid__item {
      padding: var(--s-10) var(--s-6);
    }

    .svcgrid__icon {
      width: 80px;
      height: 80px;
    }

    .svcgrid__icon svg {
      width: 40px;
      height: 40px;
    }

    .svcgrid__label {
      font-size: 1.05rem;
    }
  }

  @media (min-width: 900px) {
    .svcgrid__icon {
      width: 88px;
      height: 88px;
    }

    .svcgrid__icon svg {
      width: 44px;
      height: 44px;
    }

    .svcgrid__icon-wrap::before {
      inset: -8px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .svcgrid__item,
    .svcgrid__shimmer { transition: none; }
    .svcgrid__item:hover { transform: none; }
  }
</style>

<script>
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reducedMotion) {
    document.querySelectorAll<HTMLElement>('[data-svc-card]').forEach((card) => {
      let pending = 0;
      const onMove = (e: MouseEvent) => {
        if (pending) return;
        pending = requestAnimationFrame(() => {
          pending = 0;
          const rect = card.getBoundingClientRect();
          const x = ((e.clientX - rect.left) / rect.width) * 100;
          const y = ((e.clientY - rect.top) / rect.height) * 100;
          card.style.setProperty('--holo-x', `${x}%`);
          card.style.setProperty('--holo-y', `${y}%`);
          card.style.setProperty('--holo-angle', `${Math.round(x * 3.6)}deg`);
        });
      };
      const onLeave = () => {
        if (pending) { cancelAnimationFrame(pending); pending = 0; }
        card.style.setProperty('--holo-x', '50%');
        card.style.setProperty('--holo-y', '50%');
      };
      card.addEventListener('mousemove', onMove, { passive: true });
      card.addEventListener('mouseleave', onLeave);
    });
  }
</script>
