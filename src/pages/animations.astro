---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import LocationHero from '../components/locations/LocationHero.astro';
import SectionOneImage from '../components/sections/SectionOneImage.astro';
import Maillage from '../components/Maillage.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

import imgYoga from '../assets/images/sarah-cours-yoga-surfcenter-lac-sainte-croix.jpg';
import imgPaddle from '../assets/images/location-paddle-lac-sainte-croix-surfcenter.jpeg';
import imgConcertJoulik from '../assets/images/concert-joulik-lac-sainte-croix-surfcenter.jpg';
import imgFramboise from '../assets/images/framboise-et-ceatera-lac-sainte-croix-concert-surfcenter.jpg';
import imgWindsurf from '../assets/images/location-planche-a-voile-windsurf-lac-sainte-croix.png';
import imgSunset from '../assets/images/IMG20220618204351.jpg';

const title = 'Animations — Yoga, cours nautiques, concerts | Surf Center Verdon';
const description = 'Yoga face au lac, cours de paddle et windsurf, concerts live et soirées coucher de soleil. Toutes les animations et événements du Surf Center au lac de Sainte-Croix, Gorges du Verdon.';

const siteUrl = 'https://surfcenter-verdon.fr';

const upcomingEvents = [
  { date: '12 Juil.', title: 'Concert Joulik — acoustique', type: 'Concert' },
  { date: '19 Juil.', title: 'Sunset DJ Set', type: 'Soirée' },
  { date: '26 Juil.', title: 'Framboise & Cætera — live', type: 'Concert' },
  { date: '2 Août', title: 'Nuit du lac — soirée spéciale', type: 'Soirée' },
  { date: '9 Août', title: 'Yoga & Brunch sunrise', type: 'Atelier' },
  { date: '16 Août', title: 'Régate des familles', type: 'Sport' },
];

const currentYear = new Date().getFullYear();
const monthMap: Record<string, string> = {
  'Janv.': '01',
  'Févr.': '02',
  'Mars': '03',
  'Avr.': '04',
  'Mai': '05',
  'Juin': '06',
  'Juil.': '07',
  'Août': '08',
  'Sept.': '09',
  'Oct.': '10',
  'Nov.': '11',
  'Déc.': '12',
};

const toIsoDate = (d: string) => {
  // Formats attendus: "12 Juil." / "2 Août"
  const m = d.trim().match(/^(\d{1,2})\s+([^\s]+)$/);
  if (!m) return undefined;
  const day = m[1].padStart(2, '0');
  const month = monthMap[m[2]];
  if (!month) return undefined;
  return `${currentYear}-${month}-${day}`;
};

const eventLocation = {
  '@type': 'Place',
  name: 'Surf Center',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Plage des Salles-sur-Verdon',
    addressLocality: 'Les Salles-sur-Verdon',
    postalCode: '83630',
    addressCountry: 'FR',
  },
  geo: { '@type': 'GeoCoordinates', latitude: 43.7766, longitude: 6.21 },
};

const galleryImages: { src: ImageMetadata; alt: string }[] = [
  { src: imgYoga, alt: 'Yoga au lever du soleil — Surf Center' },
  { src: imgConcertJoulik, alt: 'Concert Joulik — Surf Center' },
  { src: imgPaddle, alt: 'Cours de paddle — lac de Sainte-Croix' },
  { src: imgFramboise, alt: 'Concert Framboise & Cætera — Surf Center' },
  { src: imgWindsurf, alt: 'Windsurf au lac de Sainte-Croix' },
  { src: imgSunset, alt: 'Coucher de soleil au Surf Center' },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Animations — Surf Center',
    description,
    url: `${siteUrl}/animations`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'EventSeries',
    name: 'Animations & événements — Surf Center',
    description,
    url: `${siteUrl}/animations`,
    location: eventLocation,
    organizer: { '@type': 'Organization', name: 'Surf Center', url: siteUrl },
    eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
    isAccessibleForFree: true,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Prochains événements',
    itemListOrder: 'https://schema.org/ItemListOrderAscending',
    numberOfItems: upcomingEvents.length,
    itemListElement: upcomingEvents.map((evt, idx) => ({
      '@type': 'ListItem',
      position: idx + 1,
      item: {
        '@type': 'Event',
        name: evt.title,
        startDate: toIsoDate(evt.date),
        eventStatus: 'https://schema.org/EventScheduled',
        eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
        location: eventLocation,
        organizer: { '@type': 'Organization', name: 'Surf Center', url: siteUrl },
        isAccessibleForFree: true,
      },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Animations', item: `${siteUrl}/animations` },
    ],
  },
];
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <div class="anipage">
    <LocationHero
      title="Animations"
      subtitle="Yoga · Cours · Concerts · Soirées"
      image={imgYoga}
      alt="Cours de yoga au lever du soleil au bord du lac de Sainte-Croix — Surf Center"
    />
    <Breadcrumbs items={[
      { label: 'Accueil', href: '/' },
      { label: 'Animations' },
    ]} />

    <!-- Présentation types d'animations -->
    <SectionOneImage
      id="types"
      eyebrow="Activités"
      title="Bien plus qu'une<br/>base nautique"
      text="Au Surf Center, chaque journée propose son lot d'expériences : cours encadrés, ateliers bien-être, animations sportives et soirées musicales. Le tout face au lac de Sainte-Croix, dans un cadre exceptionnel."
      image={{ src: imgPaddle, alt: 'Activités nautiques encadrées au Surf Center' }}
      imgIcon={{ src: '/figma/resto-icon.svg', alt: '' }}
      tags={['Cours encadrés', 'Bien-être sunrise', 'Sensations', 'Concerts & soirées']}
      cta={{ label: 'Réserver', booking: true }}
    />

    <!-- Yoga -->
    <SectionOneImage
      id="yoga"
      eyebrow="Bien-être"
      title="Yoga face au lac"
      text="Chaque matin d'été, notre professeure Sarah vous accueille pour une session de yoga face au lac de Sainte-Croix. Au lever du soleil, dans le calme absolu, reconnectez-vous à la nature."
      image={{ src: imgYoga, alt: 'Sarah — cours de yoga au Surf Center, lac de Sainte-Croix' }}
      ellipse={{ src: '/figma/events-ellipse.svg', alt: '', position: 'right', width: 84, height: 101 }}
      tags={['Sunrise 7h30 — 8h30', 'Tous niveaux', 'Tapis fournis', 'Sur réservation']}
      reverse
    />

    <!-- Concerts -->
    <SectionOneImage
      id="concerts"
      eyebrow="Concerts"
      title="Live au<br/>coucher du soleil"
      text="Le Surf Center accueille des artistes tout l'été pour des concerts acoustiques, DJ sets et soirées thématiques les pieds dans le sable, face au coucher de soleil sur le lac."
      image={{ src: imgConcertJoulik, alt: 'Concert live Joulik au Surf Center — lac de Sainte-Croix' }}
      tags={['Concerts live', 'DJ sets', 'Soirées à thème', 'Entrée libre']}
      cta={{ label: 'Voir les événements', href: '/groupes-evenements' }}
      style="background: linear-gradient(0deg, rgba(38, 207, 255, 0.10) 0%, rgba(38, 207, 255, 0.00) 100%);"
    />

  <!-- Prochains événements -->
  <section
    class="section"
    aria-labelledby="upcoming-title"
    style="background: linear-gradient(180deg, rgba(38, 207, 255, 0.10) 0%, rgba(38, 207, 255, 0.00) 65%);"
  >
    <div class="container">
      <header class="section__header reveal">
        <span class="section__eyebrow">Agenda</span>
        <h2 id="upcoming-title">Prochains événements</h2>
      </header>

      <div class="anievt__list">
        {upcomingEvents.map((evt, i) => (
          <div class={`anievt__row reveal reveal-d${Math.min(i + 1, 4)}`}>
            <span class="anievt__date">{evt.date}</span>
            <span class="anievt__name">{evt.title}</span>
            <span class="anievt__type">{evt.type}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Galerie photos -->
  <section class="section gal" aria-labelledby="gallery-title">
    <div class="container">
      <header class="section__header reveal">
        <span class="section__eyebrow">Galerie</span>
        <h2 id="gallery-title">En images</h2>
      </header>

      <div class="gal__slider-wrap reveal">
        <button type="button" class="gal__arrow gal__arrow--prev" data-gal-prev aria-label="Précédent">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M13 4l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div class="gal__track" data-gal-track>
          {galleryImages.map((img) => (
            <div class="gal__slide">
              <Image
                src={img.src}
                alt={img.alt}
                width={600}
                height={400}
                loading="lazy"
                decoding="async"
                format="webp"
                quality={75}
              />
            </div>
          ))}
        </div>

        <button type="button" class="gal__arrow gal__arrow--next" data-gal-next aria-label="Suivant">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
  </section>

  <Maillage />
  </div>
</Layout>

<style>
  /* ── Padding réduit sur toute la page ────────────── */
  .anipage :global(.section) {
    padding-block: clamp(2.5rem, 6vw, 5rem);
  }

  .anievt__list {
    display: flex;
    flex-direction: column;
  }

  .anievt__row {
    display: grid;
    grid-template-columns: 5rem 1fr auto;
    gap: var(--s-4);
    align-items: center;
    padding: var(--s-5) 0;
    border-bottom: 1px solid var(--c-border-light);
    transition: padding var(--t-fast);
  }

  .anievt__row:first-child { border-top: 1px solid var(--c-border-light); }
  .anievt__row:hover { padding-left: var(--s-3); }

  .anievt__date {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--c-orange);
    white-space: nowrap;
  }

  .anievt__name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--c-text);
  }

  .anievt__type {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    background: var(--c-bg);
    padding: 4px 12px;
    border-radius: var(--r-full);
    border: 1px solid var(--c-border-light);
    white-space: nowrap;
  }

  /* ── Galerie Slider moderne ────────────────────────── */
  .gal {
    background: transparent;
  }

  .gal__slider-wrap {
    position: relative;
  }

  .gal__track {
    display: flex;
    gap: var(--s-4);
    overflow-x: auto;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding: var(--s-2) 0;
  }

  .gal__track::-webkit-scrollbar { display: none; }

  .gal__slide {
    flex: 0 0 80%;
    scroll-snap-align: center;
    border-radius: var(--r-xl);
    overflow: hidden;
    position: relative;
  }

  .gal__slide :global(img) {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }

  .gal__arrow {
    position: absolute;
    top: 50%;
    z-index: 10;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    border-radius: var(--r-full);
    border: 1px solid var(--c-border);
    background: var(--c-bg);
    color: var(--c-text);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-md);
    transition: all var(--t-fast) var(--ease);
  }

  .gal__arrow:hover {
    background: var(--c-orange);
    border-color: var(--c-orange);
    color: #fff;
    box-shadow: var(--shadow-glow);
  }

  .gal__arrow:disabled {
    opacity: 0.3;
    pointer-events: none;
  }

  .gal__arrow--prev { left: var(--s-3); }
  .gal__arrow--next { right: var(--s-3); }

  @media (min-width: 600px) {
    .gal__slide { flex: 0 0 45%; }
    .gal__arrow--prev { left: calc(-1 * var(--s-6)); }
    .gal__arrow--next { right: calc(-1 * var(--s-6)); }
  }

  @media (min-width: 900px) {
    .gal__slide { flex: 0 0 35%; }
  }

  @media (min-width: 1200px) {
    .gal__slide { flex: 0 0 30%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .gal__track { scroll-behavior: auto; }
    .gal__slide,
    .gal__slide :global(img) { transition: none; }
  }
</style>

<script>
  document.querySelectorAll('.gal__slider-wrap').forEach((wrap) => {
    const track = wrap.querySelector<HTMLElement>('[data-gal-track]');
    const prevBtn = wrap.querySelector<HTMLButtonElement>('[data-gal-prev]');
    const nextBtn = wrap.querySelector<HTMLButtonElement>('[data-gal-next]');
    if (!track) return;

    const getScrollAmount = () => {
      const slide = track.querySelector('.gal__slide') as HTMLElement | null;
      return slide ? slide.offsetWidth + 16 : 300;
    };

    const updateArrows = () => {
      if (prevBtn) prevBtn.disabled = track.scrollLeft <= 2;
      if (nextBtn) nextBtn.disabled = track.scrollLeft + track.clientWidth >= track.scrollWidth - 2;
    };

    updateArrows();
    track.addEventListener('scroll', updateArrows, { passive: true });
    prevBtn?.addEventListener('click', () => track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' }));
    nextBtn?.addEventListener('click', () => track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' }));
  });
</script>
