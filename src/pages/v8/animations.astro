<script>
  document.querySelectorAll('[data-m8a-slider]').forEach((slider) => {
    const track = slider.querySelector('[data-m8a-track]') as HTMLElement | null;
    const wrap = slider.closest('.m8__a-slider-wrap');
    const prevBtn = wrap?.querySelector('[data-m8a-prev]') as HTMLButtonElement | null;
    const nextBtn = wrap?.querySelector('[data-m8a-next]') as HTMLButtonElement | null;
    if (!track) return;

    const getScrollAmount = () => {
      const card = track.querySelector('.m8__a-card') as HTMLElement | null;
      return card ? card.offsetWidth + 20 : 300;
    };

    const updateArrows = () => {
      if (prevBtn) prevBtn.disabled = track.scrollLeft <= 2;
      if (nextBtn) nextBtn.disabled = track.scrollLeft + track.clientWidth >= track.scrollWidth - 2;
    };

    updateArrows();
    track.addEventListener('scroll', updateArrows, { passive: true });
    prevBtn?.addEventListener('click', () => track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' }));
    nextBtn?.addEventListener('click', () => track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' }));
  });
</script>
