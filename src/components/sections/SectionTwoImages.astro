---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import ListIcon from '../ListIcon.astro';

interface ListItem {
  text: string;
  icon?: string;
}

interface ImageDef {
  src: string | ImageMetadata;
  alt: string;
}

interface Props {
  id?: string;
  eyebrow: string;
  title: string;
  text: string;
  images: [ImageDef, ImageDef];
  list?: ListItem[];
  cta?: { label: string; href?: string; booking?: boolean; };
  reverse?: boolean;
  surface?: boolean;
}

const {
  id,
  eyebrow,
  title,
  text,
  images,
  list,
  cta,
  reverse = false,
  surface = false,
} = Astro.props;

const sectionId = id || eyebrow.toLowerCase().replace(/\s+/g, '-');
const titleId = `${sectionId}-title`;
---

<section
  class:list={['section', { 'section--surface': surface }]}
  aria-labelledby={titleId}
>
  <div class="container">
    <div class:list={['twimg', { 'twimg--reverse': reverse }]}>
      <div class="twimg__col-left">
        <div class="twimg__copy reveal">
          <span class="section__eyebrow">{eyebrow}</span>
          <h2 id={titleId} set:html={title} />
          <p class="twimg__desc">{text}</p>

          {list && list.length > 0 && (
            <ul class="twimg__list" role="list">
              {list.map((item) => (
                <li>
                  {item.icon && <ListIcon name={item.icon} />}
                  <span>{item.text}</span>
                </li>
              ))}
            </ul>
          )}

          {cta && (
            cta.booking
              ? <button type="button" class="btn btn--primary" data-booking><span class="btn-flip__inner"><span class="btn-flip__front">{cta.label}</span><span class="btn-flip__back">{cta.label}</span></span></button>
              : <a href={cta.href} class="btn btn--primary">{cta.label}</a>
          )}
        </div>

        <div class="twimg__photo-left reveal reveal-d1">
          {typeof images[0].src === 'string' ? (
            <img src={images[0].src} alt={images[0].alt} width="560" height="380" loading="lazy" decoding="async" />
          ) : (
            <Image src={images[0].src} alt={images[0].alt} width={560} height={380} loading="lazy" decoding="async" format="webp" quality={75} />
          )}
        </div>
      </div>

      <div class="twimg__col-right reveal reveal-d1">
        {typeof images[1].src === 'string' ? (
          <img src={images[1].src} alt={images[1].alt} width="560" height="720" loading="lazy" decoding="async" />
        ) : (
          <Image src={images[1].src} alt={images[1].alt} width={560} height={720} loading="lazy" decoding="async" format="webp" quality={75} />
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .twimg {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-8);
  }

  .twimg__col-left {
    display: flex;
    flex-direction: column;
    gap: var(--s-8);
  }

  .twimg__copy {
    max-width: 460px;
  }

  .twimg__desc {
    font-size: 0.9rem;
    color: var(--c-text-secondary);
    line-height: 1.75;
    max-width: 38ch;
    margin-top: var(--s-5);
  }

  .twimg__list {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    margin-top: var(--s-8);
  }

  .twimg__list li {
    display: flex;
    align-items: flex-start;
    gap: var(--s-3);
    font-size: 0.82rem;
    color: var(--c-text-secondary);
    line-height: 1.5;
  }

  .twimg__list li > span {
    padding-top: 1px;
  }

  .twimg__photo-left {
    overflow: hidden;
    border-radius: var(--r-lg);
  }

  .twimg__photo-left img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }

  .twimg__photo-left:hover img { transform: scale(1.03); }

  .twimg__col-right {
    overflow: hidden;
    border-radius: var(--r-lg);
  }

  .twimg__col-right img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }

  .twimg__col-right:hover img { transform: scale(1.03); }

  @media (min-width: 900px) {
    .twimg {
      grid-template-columns: 1fr 1fr;
      gap: var(--s-6);
    }

    .twimg--reverse {
      direction: rtl;
    }

    .twimg--reverse > * {
      direction: ltr;
    }

    .twimg__col-left {
      justify-content: space-between;
    }

    .twimg__col-right img {
      aspect-ratio: auto;
      height: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .twimg__photo-left img,
    .twimg__col-right img { transition: none; }
  }
</style>
