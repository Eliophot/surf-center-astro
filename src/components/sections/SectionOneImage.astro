---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
interface ListItem {
  text: string;
  icon?: string;
}

interface Props {
  id?: string;
  eyebrow: string;
  title: string;
  text: string;
  image: { src: string | ImageMetadata; alt: string; };
  imgIcon?: { src: string; alt?: string; width?: number; height?: number };
  ellipse?: { src: string; alt?: string; width?: number; height?: number; position?: 'left' | 'right' };
  list?: ListItem[];
  tags?: string[];
  cta?: { label: string; href?: string; booking?: boolean; };
  reverse?: boolean;
  surface?: boolean;
  fill?: boolean;
  vCenterContent?: boolean;
  className?: string;
  style?: string;
}

const {
  id,
  eyebrow,
  title,
  text,
  image,
  imgIcon,
  ellipse,
  list,
  tags,
  cta,
  reverse = false,
  surface = false,
  fill = false,
  vCenterContent = false,
  className,
  style,
} = Astro.props;

const sectionId = id || eyebrow.toLowerCase().replace(/\s+/g, '-');
const titleId = `${sectionId}-title`;
---

<section
  class:list={['section', className, { 'section--surface': surface }]}
  aria-labelledby={titleId}
  style={style}
>
  <div class:list={['container s1', { 's1--reverse': reverse, 's1--fill': fill, 's1--vcenter': vCenterContent }]}>
    <div class="s1__content reveal">
      <span class="section__eyebrow">{eyebrow}</span>
      <h2 id={titleId} set:html={title} />
      <p class="s1__text">{text}</p>

      {list && list.length > 0 && (
        <ul class="s1__list" role="list">
          {list.map((item) => (
            <li>
              <span class="s1__dash" aria-hidden="true">—</span>
              <span>{item.text}</span>
            </li>
          ))}
        </ul>
      )}

      {tags && tags.length > 0 && (
        <div class="s1__tags">
          {tags.map((tag) => <span>{tag}</span>)}
        </div>
      )}

      {cta && (
        <div class="s1__cta">
          {cta.booking
            ? (
              <button type="button" class="btn btn--primary" data-booking>
                <span class="btn-flip__inner">
                  <span class="btn-flip__front">{cta.label}</span>
                  <span class="btn-flip__back">{cta.label}</span>
                </span>
              </button>
            )
            : (
              <a href={cta.href} class="btn btn--primary">{cta.label}</a>
            )
          }
        </div>
      )}
    </div>

    <div class="s1__visual reveal reveal-d2">
      <div class="s1__visual-inner">
        {typeof image.src === 'string' ? (
          <img
            class="s1__img"
            src={image.src}
            alt={image.alt}
            width="640"
            height="800"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <Image
            class="s1__img"
            src={image.src}
            alt={image.alt}
            width={640}
            height={800}
            loading="lazy"
            decoding="async"
            format="webp"
            quality={75}
          />
        )}
      </div>
      {imgIcon?.src && (
        <div class="ovlap__img-icon" aria-hidden="true">
          <img
            src={imgIcon.src}
            alt={imgIcon.alt ?? ''}
            width={imgIcon.width ?? 91}
            height={imgIcon.height ?? 91}
            loading="lazy"
            decoding="async"
          />
        </div>
      )}
      {ellipse?.src && (
        <span class:list={['epp__ellipse', { 'epp__ellipse--left': ellipse.position === 'left' }]} aria-hidden="true">
          <img
            src={ellipse.src}
            alt={ellipse.alt ?? ''}
            width={ellipse.width ?? 84}
            height={ellipse.height ?? 101}
            loading="lazy"
            decoding="async"
          />
        </span>
      )}
    </div>
  </div>
</section>

<style>
  .s1 {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-12);
    align-items: center;
  }

  .s1__text {
    font-size: 1rem;
    color: var(--c-text-secondary);
    line-height: 1.75;
    max-width: 38ch;
    margin-top: var(--s-6);
  }

  .s1__list {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    margin-top: var(--s-8);
    margin-bottom: var(--s-10);
  }

  .s1__list li {
    display: flex;
    align-items: flex-start;
    gap: var(--s-3);
    font-size: 0.85rem;
    color: var(--c-text-secondary);
    line-height: 1.5;
  }

  .s1__dash {
    color: var(--c-orange);
    flex-shrink: 0;
  }

  .s1__list li > span:last-child {
    padding-top: 1px;
  }

  .s1__img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--r-lg);
  }

  .s1__visual {
    position: relative;
  }

  .s1__visual-inner {
    position: relative;
    overflow: hidden;
    border-radius: var(--r-lg);
    z-index: 1;
  }

  .ovlap__img-icon {
    position: absolute;
    top: 0;
    right: 0;
    transform: translate(42%, -70%);
    width: 91px;
    height: 91px;
    z-index: 3;
    pointer-events: none;
    user-select: none;
    display: none;
  }

  .ovlap__img-icon img {
    width: 100%;
    height: 100%;
    display: block;
  }

  .epp__ellipse {
    position: absolute;
    width: 84px;
    height: 101px;
    max-width: 84px;
    max-height: 101px;
    top: -50px;
    right: -64px;
    z-index: 3;
    display: none;
    pointer-events: none;
    user-select: none;
  }

  .epp__ellipse--left {
    right: auto;
    left: -40px;
  }

  .epp__ellipse img {
    width: 100%;
    height: 100%;
    display: block;
  }

  .s1__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    margin-top: var(--s-8);
  }

  .s1__cta {
    padding-top: var(--s-8);
    align-self: flex-start;
  }

  .s1__tags span {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    background: var(--c-bg);
    padding: 5px 14px;
    border-radius: var(--r-full);
    border: 1px solid var(--c-border-light);
  }

  :global([data-theme='dark']) .s1__tags span {
    background: var(--c-surface);
    border-color: var(--c-border);
  }

  @media (min-width: 900px) {
    .s1 { grid-template-columns: 1fr 1.2fr; gap: var(--s-20); }
    .s1--reverse { grid-template-columns: 1.2fr 1fr; }
    .s1--reverse .s1__visual { order: -1; }

    .s1--vcenter .s1__content {
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    /* Image qui épouse la hauteur du contenu (comme le bloc pro de la home) */
    .s1--fill { align-items: stretch; }
    .s1--fill .s1__visual-inner {
      box-shadow: var(--shadow-md);
      height: 100%;
      min-height: 100%;
    }
    .s1--fill .s1__img {
      aspect-ratio: auto;
      height: 100%;
      min-height: 100%;
      border-radius: 0;
    }

    .ovlap__img-icon { display: inline-flex; }
    .epp__ellipse { display: block; }
  }
</style>
