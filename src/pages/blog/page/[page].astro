---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import LocationHero from '../../../components/locations/LocationHero.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import TrustBadges from '../../../components/v11/TrustBadges.astro';

import imgHeroBlog from '../../../assets/images/lac-sainte-croix-gorges-verdon-location-bateaux-electriques.jpg';

const title = 'Blog — Actualités & guides | Surf Center Verdon';
const description = 'Guides pratiques, bons plans et actualités du Surf Center : activités nautiques, événements, criques secrètes et conseils pour profiter du lac de Sainte-Croix.';

const siteUrl = 'https://surfcenter-verdon.fr';
const POSTS_PER_PAGE = 5;

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const totalPages = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));

export async function getStaticPaths() {
  const POSTS_PER_PAGE = 5;
  const all = (await getCollection('blog'))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  const pages = Math.max(1, Math.ceil(all.length / POSTS_PER_PAGE));
  return Array.from({ length: pages }, (_, i) => ({
    params: { page: String(i + 1) },
  }));
}

const page = Math.max(1, Number.parseInt(Astro.params.page ?? '1', 10) || 1);
const safePage = Math.min(page, totalPages);
const start = (safePage - 1) * POSTS_PER_PAGE;
const pagePosts = posts.slice(start, start + POSTS_PER_PAGE);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Blog',
    name: 'Blog Surf Center',
    description,
    url: `${siteUrl}/blog`,
    publisher: { '@type': 'Organization', name: 'Surf Center', url: siteUrl },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog` },
      { '@type': 'ListItem', position: 3, name: `Page ${safePage}`, item: `${siteUrl}/blog/page/${safePage}` },
    ],
  },
];

function formatDate(date: Date): string {
  return date.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <div class="blogpage">
    <LocationHero
      title="Blog"
      subtitle="Guides · Actualités · Bons plans"
      image={imgHeroBlog}
      alt="Vue panoramique du lac de Sainte-Croix — Gorges du Verdon"
    />
    <Breadcrumbs items={[
      { label: 'Accueil', href: '/' },
      { label: 'Blog', href: '/blog' },
      { label: `Page ${safePage}` },
    ]} />

    <section class="section" aria-label="Listing du blog">
      <div class="container">
        <header class="section__header reveal">
          <span class="section__eyebrow">Actualités</span>
          <h2>Page {safePage}</h2>
          <p class="section__lead">Guides pratiques, événements et bons plans pour profiter du lac de Sainte-Croix.</p>
        </header>

        <div class="blg-grid">
          {pagePosts.map((post) => (
            <a href={`/blog/${post.id}`} class="blg-card reveal" aria-label={`Lire : ${post.data.title}`}>
              <div class="blg-card__visual">
                <img
                  src={post.data.image}
                  alt={post.data.imageAlt}
                  width="900"
                  height="560"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="blg-card__body">
                <div class="blg-card__tags">
                  {post.data.tags.slice(0, 2).map((tag) => (
                    <span class="blg-tag">{tag}</span>
                  ))}
                </div>
                <h3 class="blg-card__title">{post.data.title}</h3>
                <p class="blg-card__excerpt">{post.data.description}</p>
                <div class="blg-card__footer">
                  <time datetime={post.data.date.toISOString().slice(0, 10)}>{formatDate(post.data.date)}</time>
                  <span class="blg-card__read">Lire <span aria-hidden="true">→</span></span>
                </div>
              </div>
            </a>
          ))}
        </div>

        <nav class="blg-pagi" aria-label="Pagination du blog">
          {safePage > 1 ? (
            <a class="blg-pagi__btn" href={safePage === 2 ? '/blog' : `/blog/page/${safePage - 1}`}>← Page précédente</a>
          ) : <span />}
          <span class="blg-pagi__info">{safePage} / {totalPages}</span>
          {safePage < totalPages ? (
            <a class="blg-pagi__btn" href={`/blog/page/${safePage + 1}`}>Page suivante →</a>
          ) : <span />}
        </nav>
      </div>
    </section>

    <TrustBadges />
  </div>
</Layout>

<style>
  .blogpage :global(.section) {
    padding-block: clamp(2.5rem, 6vw, 5rem);
  }

  .blg-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-8);
    min-width: 0;
  }

  .blg-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--r-lg);
    overflow: hidden;
    background: var(--c-bg);
    border: 1px solid var(--c-border-light);
    text-decoration: none;
    color: inherit;
  }

  :global([data-theme='dark']) .blg-card {
    background: var(--c-surface);
    border-color: var(--c-border);
  }

  .blg-card__visual {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .blg-card__visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .blg-card__body {
    padding: var(--s-6);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .blg-card__tags {
    display: flex;
    gap: var(--s-2);
    flex-wrap: wrap;
    margin-bottom: var(--s-3);
  }

  .blg-tag {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-orange);
    background: rgb(247 123 70 / 0.08);
    padding: 3px 10px;
    border-radius: var(--r-full);
  }

  .blg-card__title {
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 700;
    line-height: 1.35;
    color: var(--c-text);
    margin-bottom: var(--s-3);
  }

  .blg-card__excerpt {
    font-size: 0.82rem;
    color: var(--c-text-muted);
    line-height: 1.65;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blg-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--s-5);
    padding-top: var(--s-4);
    border-top: 1px solid var(--c-border-light);
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--c-text-muted);
    letter-spacing: 0.04em;
  }

  .blg-card__read {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-text-secondary);
  }

  .blg-pagi {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    margin-top: var(--s-10);
  }

  .blg-pagi__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    text-decoration: none;
    color: var(--c-text);
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.7rem;
    padding: 0.9rem 1.4rem;
    border-radius: var(--r-full);
    border: 1px solid var(--c-border-light);
    background: var(--c-bg);
  }

  :global([data-theme='dark']) .blg-pagi__btn {
    border-color: var(--c-border);
    background: var(--c-surface);
  }

  .blg-pagi__info {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--c-text-muted);
    letter-spacing: 0.04em;
  }

  @media (min-width: 700px) {
    .blg-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1100px) {
    .blg-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>

