---
interface Props {
  count?: number;
  speed?: number;
}

const { count = 200, speed = 0.5 } = Astro.props;
---

<canvas
  class="pf11"
  id="particleField"
  data-count={count}
  data-speed={speed}
  aria-hidden="true"
></canvas>

<script is:inline>
(function () {
  var canvas = document.getElementById('particleField');
  if (!canvas) return;

  var count = parseInt(canvas.dataset.count, 10) || 200;
  var baseSpeed = parseFloat(canvas.dataset.speed) || 0.5;
  var ctx = canvas.getContext('2d');
  if (!ctx) return;

  var particles = [];
  var w, h, dpr;
  var scrollSpeed = 0;
  var lastScroll = window.scrollY;

  function resize() {
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    w = window.innerWidth;
    h = window.innerHeight;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    canvas.style.width = w + 'px';
    canvas.style.height = h + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  var colors = [
    'rgba(38, 207, 255, ',
    'rgba(255, 255, 255, ',
    'rgba(147, 197, 253, ',
    'rgba(59, 130, 246, ',
    'rgba(107, 33, 168, '
  ];

  function createParticle() {
    return {
      x: Math.random() * w,
      y: Math.random() * h,
      size: Math.random() * 3 + 0.5,
      speedY: -(Math.random() * 0.5 + 0.2) * baseSpeed,
      speedX: (Math.random() - 0.5) * 0.3 * baseSpeed,
      opacity: Math.random() * 0.6 + 0.1,
      color: colors[Math.floor(Math.random() * colors.length)],
      wobblePhase: Math.random() * Math.PI * 2,
      wobbleSpeed: Math.random() * 0.02 + 0.005,
      wobbleAmp: Math.random() * 0.5 + 0.2
    };
  }

  function init() {
    resize();
    particles = [];
    for (var i = 0; i < count; i++) {
      particles.push(createParticle());
    }
  }

  init();
  window.addEventListener('resize', resize);

  window.addEventListener('scroll', function () {
    var cur = window.scrollY;
    scrollSpeed = Math.abs(cur - lastScroll) * 0.1;
    lastScroll = cur;
  }, { passive: true });

  var raf;
  function render() {
    ctx.clearRect(0, 0, w, h);

    scrollSpeed *= 0.95;

    for (var i = 0; i < particles.length; i++) {
      var p = particles[i];
      p.wobblePhase += p.wobbleSpeed;
      p.x += p.speedX + Math.sin(p.wobblePhase) * p.wobbleAmp;
      p.y += p.speedY - scrollSpeed * 0.5;

      if (p.y < -10) {
        p.y = h + 10;
        p.x = Math.random() * w;
      }
      if (p.x < -10) p.x = w + 10;
      if (p.x > w + 10) p.x = -10;

      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx.fillStyle = p.color + p.opacity + ')';
      ctx.fill();

      if (p.size > 1.5) {
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size * 2.5, 0, Math.PI * 2);
        ctx.fillStyle = p.color + (p.opacity * 0.15) + ')';
        ctx.fill();
      }
    }

    raf = requestAnimationFrame(render);
  }
  raf = requestAnimationFrame(render);

  window.addEventListener('beforeunload', function () {
    cancelAnimationFrame(raf);
  });
})();
</script>

<style>
  .pf11 {
    position: fixed;
    inset: 0;
    z-index: 1;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
  }
</style>
