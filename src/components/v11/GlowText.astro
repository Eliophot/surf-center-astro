---
interface Props {
  color?: string;
  intensity?: 'low' | 'medium' | 'high';
  tag?: string;
  class?: string;
}

const {
  color = '#26cfff',
  intensity = 'medium',
  tag = 'span',
  class: extraClass = '',
} = Astro.props;

const Tag = tag as any;

const glowMap: Record<string, string> = {
  low: '4px',
  medium: '12px',
  high: '24px',
};
const blurSize = glowMap[intensity] || glowMap.medium;
---

<Tag
  class={`gt11 gt11--${intensity} ${extraClass}`.trim()}
  style={`--gt-color: ${color}; --gt-blur: ${blurSize};`}
>
  <slot />
</Tag>

<style>
  .gt11 {
    color: var(--gt-color);
    text-shadow:
      0 0 var(--gt-blur) var(--gt-color),
      0 0 calc(var(--gt-blur) * 2) color-mix(in srgb, var(--gt-color) 40%, transparent);
  }

  .gt11--low {
    text-shadow:
      0 0 4px var(--gt-color),
      0 0 8px color-mix(in srgb, var(--gt-color) 30%, transparent);
  }

  .gt11--medium {
    text-shadow:
      0 0 8px var(--gt-color),
      0 0 16px color-mix(in srgb, var(--gt-color) 40%, transparent),
      0 0 32px color-mix(in srgb, var(--gt-color) 15%, transparent);
    animation: gt11-pulse 3s ease-in-out infinite;
  }

  .gt11--high {
    text-shadow:
      0 0 10px var(--gt-color),
      0 0 20px var(--gt-color),
      0 0 40px color-mix(in srgb, var(--gt-color) 50%, transparent),
      0 0 80px color-mix(in srgb, var(--gt-color) 20%, transparent);
    animation: gt11-pulse 2.5s ease-in-out infinite;
  }

  @keyframes gt11-pulse {
    0%, 100% { filter: brightness(1); }
    50% { filter: brightness(1.3); }
  }

  @media (prefers-reduced-motion: reduce) {
    .gt11--medium,
    .gt11--high {
      animation: none;
    }
  }
</style>
