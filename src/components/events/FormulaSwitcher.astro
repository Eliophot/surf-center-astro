---
import type { EventFormula } from '../../data/events';

interface Props {
  proFormulas: EventFormula[];
  privateFormulas: EventFormula[];
  id?: string;
}

const { proFormulas, privateFormulas, id = 'formulas' } = Astro.props;
---

<section class="fsw section" id={id} aria-labelledby={`${id}-title`}>
  <div class="container">
    <header class="section__header reveal">
      <span class="section__eyebrow">Nos formules</span>
      <h2 id={`${id}-title`}>Choisissez votre événement</h2>
    </header>

    <!-- Switch Toggle -->
    <div class="fsw__toggle reveal">
      <button
        type="button"
        class="fsw__btn fsw__btn--active"
        data-tab="pro"
        aria-pressed="true"
      >
        <svg class="fsw__btn-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
          <path d="M3 21h18"/>
          <path d="M3 7h4v14"/>
          <path d="M17 7h4v14"/>
          <rect x="10" y="9" width="4" height="5" rx="1"/>
        </svg>
        <span class="fsw__btn-label">Entreprises</span>
      </button>
      <button
        type="button"
        class="fsw__btn"
        data-tab="private"
        aria-pressed="false"
      >
        <svg class="fsw__btn-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <span class="fsw__btn-label">Privés</span>
      </button>
      <span class="fsw__slider" aria-hidden="true"></span>
    </div>

    <!-- Tab Panels -->
    <div class="fsw__panels">
      <div class="fsw__panel fsw__panel--active" data-panel="pro" role="tabpanel">
        <div class="fsw__grid">
          {proFormulas.map((f, i) => (
            <article class={`fsw__card reveal reveal-d${Math.min(i + 1, 3)}`}>
              <div class="fsw__img-wrap">
                <img
                  src={f.image}
                  alt={f.alt}
                  width="600"
                  height="400"
                  loading="lazy"
                  decoding="async"
                />
                <span class="fsw__capacity">{f.capacity}</span>
              </div>
              <div class="fsw__body">
                <h3 class="fsw__name">{f.title}</h3>
                <p class="fsw__desc">{f.description}</p>
                <ul class="fsw__features" role="list">
                  {f.features.map((feat) => <li>{feat}</li>)}
                </ul>
                <a href="/groupes-evenements#contact" class="btn btn--primary fsw__cta">
                  <span class="btn-flip__inner">
                    <span class="btn-flip__front">Demander un devis</span>
                    <span class="btn-flip__back">Demander un devis</span>
                  </span>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="fsw__panel" data-panel="private" role="tabpanel" hidden>
        <div class="fsw__grid">
          {privateFormulas.map((f, i) => (
            <article class={`fsw__card reveal reveal-d${Math.min(i + 1, 3)}`}>
              <div class="fsw__img-wrap">
                <img
                  src={f.image}
                  alt={f.alt}
                  width="600"
                  height="400"
                  loading="lazy"
                  decoding="async"
                />
                <span class="fsw__capacity">{f.capacity}</span>
              </div>
              <div class="fsw__body">
                <h3 class="fsw__name">{f.title}</h3>
                <p class="fsw__desc">{f.description}</p>
                <ul class="fsw__features" role="list">
                  {f.features.map((feat) => <li>{feat}</li>)}
                </ul>
                <a href="/groupes-evenements#contact" class="btn btn--primary fsw__cta">
                  <span class="btn-flip__inner">
                    <span class="btn-flip__front">Demander un devis</span>
                    <span class="btn-flip__back">Demander un devis</span>
                  </span>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initFormulaSwitcher() {
    const toggles = document.querySelectorAll<HTMLButtonElement>('.fsw__btn');
    const panels = document.querySelectorAll<HTMLDivElement>('.fsw__panel');
    const slider = document.querySelector<HTMLSpanElement>('.fsw__slider');

    if (!toggles.length || !panels.length || !slider) return;

    toggles.forEach((btn) => {
      btn.addEventListener('click', () => {
        const tabId = btn.dataset.tab;

        toggles.forEach((b) => {
          b.classList.remove('fsw__btn--active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('fsw__btn--active');
        btn.setAttribute('aria-pressed', 'true');

        if (tabId === 'private') {
          slider.style.transform = 'translateX(100%)';
        } else {
          slider.style.transform = 'translateX(0)';
        }

        panels.forEach((panel) => {
          const isPanelActive = panel.dataset.panel === tabId;
          panel.classList.toggle('fsw__panel--active', isPanelActive);
          panel.hidden = !isPanelActive;

          if (isPanelActive) {
            const cards = panel.querySelectorAll('.fsw__card');
            cards.forEach((card, i) => {
              (card as HTMLElement).style.animationDelay = `${i * 0.1}s`;
              card.classList.remove('fsw__card--animate');
              void (card as HTMLElement).offsetWidth;
              card.classList.add('fsw__card--animate');
            });
          }
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initFormulaSwitcher);
  initFormulaSwitcher();
</script>

<style>
  .fsw {
    background: linear-gradient(180deg, rgba(38, 207, 255, 0.10) 0%, rgba(38, 207, 255, 0.00) 100%);
  }

  .fsw__toggle {
    display: flex;
    justify-content: center;
    margin-bottom: var(--s-10);
    position: relative;
    background: var(--c-bg);
    border-radius: 999px;
    padding: 6px;
    max-width: 360px;
    margin-inline: auto;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    border: 1px solid var(--c-border-light);
  }

  .fsw__slider {
    position: absolute;
    top: 6px;
    left: 6px;
    width: calc(50% - 6px);
    height: calc(100% - 12px);
    background: linear-gradient(135deg, var(--c-orange) 0%, #ff8a5c 100%);
    border-radius: 999px;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: 0;
  }

  .fsw__btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--s-2);
    padding: var(--s-3) var(--s-5);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--c-text-secondary);
    background: transparent;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    position: relative;
    z-index: 1;
    transition: color 0.3s ease;
  }

  .fsw__btn--active {
    color: white;
  }

  .fsw__btn:hover:not(.fsw__btn--active) {
    color: var(--c-orange);
  }

  .fsw__btn-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    overflow: visible;
  }

  .fsw__btn-label {
    display: none;
  }

  @media (min-width: 480px) {
    .fsw__btn-label {
      display: inline;
    }
  }

  .fsw__panels {
    position: relative;
  }

  .fsw__panel {
    display: none;
  }

  .fsw__panel--active {
    display: block;
  }

  .fsw__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-6);
  }

  @media (min-width: 640px) {
    .fsw__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .fsw__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .fsw__card {
    background: var(--c-bg);
    border-radius: var(--r-lg);
    overflow: hidden;
    border: 1px solid var(--c-border-light);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    display: flex;
    flex-direction: column;
  }

  .fsw__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
  }

  .fsw__card--animate {
    animation: cardFadeIn 0.5s ease forwards;
  }

  @keyframes cardFadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fsw__img-wrap {
    position: relative;
    overflow: hidden;
  }

  .fsw__img-wrap img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }

  .fsw__card:hover .fsw__img-wrap img {
    transform: scale(1.06);
  }

  .fsw__capacity {
    position: absolute;
    bottom: var(--s-3);
    right: var(--s-3);
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    color: white;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: var(--s-1) var(--s-3);
    border-radius: 999px;
  }

  .fsw__body {
    padding: var(--s-5);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .fsw__name {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: var(--s-2);
    color: var(--c-text);
  }

  .fsw__desc {
    font-size: 0.85rem;
    color: var(--c-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--s-4);
    flex: 1;
  }

  .fsw__features {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
  }

  .fsw__features li {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--c-text-muted);
    background: var(--c-surface);
    padding: var(--s-1) var(--s-2);
    border-radius: var(--r-sm);
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .fsw__features li::before {
    content: '✓';
    color: var(--c-orange);
    font-weight: 700;
    font-size: 0.65rem;
  }

  .fsw__cta {
    margin-top: var(--s-5);
    align-self: flex-start;
  }

  @media (prefers-color-scheme: dark) {
    .fsw {
      background: linear-gradient(180deg, rgba(38, 207, 255, 0.08) 0%, rgba(38, 207, 255, 0.00) 100%);
    }

    .fsw__toggle {
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
    }

    .fsw__card:hover {
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    }

    .fsw__features li {
      background: rgba(255, 255, 255, 0.06);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fsw__slider,
    .fsw__btn,
    .fsw__card,
    .fsw__img-wrap img {
      transition: none;
    }

    .fsw__card--animate {
      animation: none;
    }
  }
</style>
