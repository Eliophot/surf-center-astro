---
import LayoutKinetic from '../../../layouts/LayoutKinetic.astro';

const posts = [
  {
    slug: 'top-5-activites-lac-sainte-croix',
    title: 'Top 5 des activités nautiques au lac de Sainte-Croix',
    excerpt: 'Paddle, bateau électrique, canoë… découvrez les incontournables pour une journée parfaite sur le plus beau lac du Verdon.',
    image: '/location-paddle-bateaux-electriques-lac-sainte-croix-gorges-verdon.jpeg',
    alt: 'Activités nautiques sur le lac de Sainte-Croix',
    date: '2026-04-15',
    category: 'Activités',
  },
  {
    slug: 'gorges-du-verdon-guide-complet',
    title: 'Gorges du Verdon : le guide complet pour votre séjour',
    excerpt: 'Randonnées, baignades, villages perchés — tout ce qu\'il faut savoir pour planifier votre escapade dans le Grand Canyon d\'Europe.',
    image: '/lac-sainte-croix-gorges-verdon-location-bateaux-electriques.jpg',
    alt: 'Vue des Gorges du Verdon depuis le lac de Sainte-Croix',
    date: '2026-03-28',
    category: 'Guide',
  },
  {
    slug: 'paddle-debutant-conseils',
    title: 'Débuter en paddle : nos 7 conseils pour réussir',
    excerpt: 'Première fois sur un paddle ? Nos moniteurs partagent leurs astuces pour se lever, pagayer et profiter dès la première session.',
    image: '/location-paddle-lac-sainte-croix-surfcenter.jpeg',
    alt: 'Paddle board au lac de Sainte-Croix — conseils débutant',
    date: '2026-03-10',
    category: 'Conseils',
  },
  {
    slug: 'concerts-evenements-ete-2026',
    title: 'Concerts & événements : le programme de l\'été 2026',
    excerpt: 'Musique live, soirées coucher de soleil, yoga matinal — découvrez toutes les animations prévues cet été au Surf Center.',
    image: '/concert-surfcenter-lac-sainte-croix.png',
    alt: 'Concert au Surf Center — lac de Sainte-Croix',
    date: '2026-02-20',
    category: 'Événements',
  },
];

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<LayoutKinetic
  title="Blog | Surf Center — Lac de Sainte-Croix"
  description="Actualités, conseils et guides sur les activités nautiques au lac de Sainte-Croix et dans les Gorges du Verdon."
>
  <!-- KINETIC HERO -->
  <section class="k7bl__hero" aria-label="Blog Surf Center">
    <div class="k7bl__hero-bg" aria-hidden="true">
      <div class="k7bl__hero-stripes"></div>
    </div>
    <div class="container k7bl__hero-inner">
      <span class="k7bl__hero-tag">Actualités · Conseils · Guides</span>
      <h1 class="k7bl__hero-title">
        <span class="k7bl__hero-t1">Blog</span>
      </h1>
      <p class="k7bl__hero-sub">Inspirations, conseils pratiques et coulisses de la vie au Surf Center.</p>
    </div>
  </section>

  <!-- RACE GRID LISTING -->
  <section class="k7bl__listing" aria-labelledby="k7bl-list-title">
    <div class="container">
      <div class="k7bl__list-head reveal">
        <div class="k7bl__list-stripe" aria-hidden="true"></div>
        <h2 id="k7bl-list-title" class="k7bl__list-title">Articles récents</h2>
      </div>

      <div class="k7bl__grid">
        {posts.map((post, i) => (
          <a href={`/v7/blog/${post.slug}`} class:list={['k7bl__card', i === 0 && 'k7bl__card--featured', 'reveal']} style={`--d:${i * 100}ms`}>
            <div class="k7bl__card-img">
              <img src={post.image} alt={post.alt} width="800" height="500" loading={i < 2 ? 'eager' : 'lazy'} decoding="async" />
              <div class="k7bl__card-slant" aria-hidden="true"></div>
            </div>
            <div class="k7bl__card-body">
              <div class="k7bl__card-meta">
                <span class="k7bl__card-cat">{post.category}</span>
                <time datetime={post.date}>{formatDate(post.date)}</time>
              </div>
              <h3 class="k7bl__card-title">{post.title}</h3>
              <p class="k7bl__card-excerpt">{post.excerpt}</p>
              <span class="k7bl__card-read">Lire l'article →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</LayoutKinetic>

<style>
  /* ═══════════════ HERO ═══════════════ */
  .k7bl__hero {
    position: relative;
    min-height: 60svh;
    display: flex;
    align-items: flex-end;
    background: var(--c-dark);
    overflow: hidden;
  }

  .k7bl__hero-bg { position: absolute; inset: 0; }

  .k7bl__hero-stripes {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 40px,
      rgb(255 255 255 / 0.02) 40px,
      rgb(255 255 255 / 0.02) 42px
    );
  }

  .k7bl__hero-inner {
    position: relative;
    z-index: 1;
    padding: calc(var(--header-h) + var(--s-16)) 0 var(--s-16);
    animation: k7bl-up 800ms var(--ease-smooth) both;
  }

  @keyframes k7bl-up {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .k7bl__hero-tag {
    display: inline-block;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--c-orange);
    background: rgb(247 123 70 / 0.1);
    padding: 5px 16px;
    border-radius: var(--r-full);
    margin-bottom: var(--s-6);
  }

  .k7bl__hero-title { margin-bottom: var(--s-5); }

  .k7bl__hero-t1 {
    font-size: clamp(4rem, 14vw, 9rem);
    font-weight: bold;
    letter-spacing: -0.06em;
    line-height: 0.85;
    color: #fff;
    text-transform: uppercase;
  }

  .k7bl__hero-sub {
    font-size: 0.88rem;
    color: rgb(255 255 255 / 0.45);
    line-height: 1.7;
    max-width: 40ch;
  }

  /* ═══════════════ RACE GRID ═══════════════ */
  .k7bl__listing {
    padding: var(--s-section) 0;
    background: var(--c-bg);
  }

  .k7bl__list-head {
    display: flex;
    align-items: center;
    gap: var(--s-5);
    margin-bottom: var(--s-10);
  }

  .k7bl__list-stripe {
    width: 40px;
    height: 4px;
    background: var(--c-orange);
    flex-shrink: 0;
  }

  .k7bl__list-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: bold;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    line-height: 1;
  }

  .k7bl__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-6);
  }

  .k7bl__card {
    display: grid;
    grid-template-columns: 1fr;
    background: var(--c-surface);
    border-radius: var(--r-sm);
    overflow: hidden;
    border: 1px solid var(--c-border-light);
    transition: transform 0.4s var(--ease), box-shadow 0.4s var(--ease);
  }

  .k7bl__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgb(0 0 0 / 0.1);
  }

  .k7bl__card-img {
    position: relative;
    overflow: hidden;
  }

  .k7bl__card-img img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    display: block;
    transition: transform 0.6s var(--ease);
  }

  .k7bl__card:hover .k7bl__card-img img { transform: scale(1.05); }

  .k7bl__card-slant {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 30px;
    background: var(--c-surface);
    clip-path: polygon(0 100%, 100% 0, 100% 100%);
  }

  .k7bl__card-body { padding: var(--s-5) var(--s-6) var(--s-6); }

  .k7bl__card-meta {
    display: flex;
    align-items: center;
    gap: var(--s-4);
    margin-bottom: var(--s-3);
  }

  .k7bl__card-cat {
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--c-orange);
  }

  .k7bl__card-meta time {
    font-size: 0.62rem;
    color: var(--c-text-muted);
  }

  .k7bl__card-title {
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 1.3;
    margin-bottom: var(--s-3);
    transition: color var(--t-fast);
  }

  .k7bl__card:hover .k7bl__card-title { color: var(--c-orange); }

  .k7bl__card-excerpt {
    font-size: 0.8rem;
    color: var(--c-text-secondary);
    line-height: 1.65;
    margin-bottom: var(--s-4);
  }

  .k7bl__card-read {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-orange);
  }

  @media (min-width: 768px) {
    .k7bl__grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .k7bl__card--featured {
      grid-column: 1 / -1;
      grid-template-columns: 1.4fr 1fr;
    }
    .k7bl__card--featured .k7bl__card-img img { aspect-ratio: auto; height: 100%; }
    .k7bl__card--featured .k7bl__card-slant { display: none; }
    .k7bl__card--featured .k7bl__card-body {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: var(--s-8);
    }
    .k7bl__card--featured .k7bl__card-title { font-size: 1.4rem; }
  }

  /* ═══════════════ MOTION ═══════════════ */
  @media (prefers-reduced-motion: reduce) {
    .k7bl__hero-inner { animation: none; }
    .k7bl__card { transition: none; }
    .k7bl__card-img img { transition: none; }
  }
</style>
