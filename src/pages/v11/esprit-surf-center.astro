---
import LayoutHyper from '../../layouts/LayoutHyper.astro';
import { Image } from 'astro:assets';
import MeshGradient from '../../components/v11/MeshGradient.astro';
import GlowText from '../../components/v11/GlowText.astro';
import HolographicCard from '../../components/v11/HolographicCard.astro';
import WaveDivider from '../../components/v11/WaveDivider.astro';
import imgEsprit from '../../assets/images/esprit.png';
import imgHero from '../../assets/images/hero-home.jpg';
import imgLac from '../../assets/images/lac-sainte-croix-gorges-verdon-location-bateaux-electriques.jpg';
import { locationDetails } from '../../data/locations';

const keyNumbers = [
  { value: "10+", label: "ans d'expérience", color: "#26cfff" },
  { value: "50 000+", label: "clients satisfaits", color: "#6b21a8" },
  { value: "4.8★", label: "note Google", color: "#f77b46" },
  { value: "N°1", label: "base nautique du lac", color: "#3b82f6" },
];

const timeline = [
  { year: "2005", title: "Les débuts", text: "Ouverture d'un petit stand de location de pédalos sur la plage des Salles-sur-Verdon. L'aventure Surf Center commence." },
  { year: "2010", title: "Expansion nautique", text: "Ajout du paddle, des canoës et de la planche à voile. L'équipe s'agrandit avec des moniteurs diplômés." },
  { year: "2015", title: "Le snack-pizzeria", text: "Construction du restaurant face au lac. Pizzas au feu de bois, salades fraîches et terrasse panoramique." },
  { year: "2018", title: "Bateaux électriques", text: "Lancement de la flotte de bateaux électriques sans permis. Navigation silencieuse et écologique." },
  { year: "2022", title: "Scène musicale", text: "Création de la scène de concerts au bord de l'eau. Soirées musicales tout l'été sous les étoiles." },
  { year: "2026", title: "Aujourd'hui", text: "Base nautique N°1 du lac de Sainte-Croix : 5 activités, restaurant, animations et événements." },
];

const cadreCards = [
  {
    title: "Le lac de Sainte-Croix",
    text: "Joyau de Provence aux eaux turquoise, niché au pied des Gorges du Verdon. Un décor naturel spectaculaire et préservé.",
    color: "#26cfff",
  },
  {
    title: "Matériel premium",
    text: "Flotte renouvelée régulièrement : bateaux électriques silencieux, paddles rigides, canoës stables. Sécurité et confort garantis.",
    color: "#6b21a8",
  },
  {
    title: "Équipe passionnée",
    text: "Des moniteurs diplômés, des conseillers qui connaissent le lac par cœur. Accompagnement personnalisé à chaque étape.",
    color: "#f77b46",
  },
];

const values = [
  { title: "Accessibilité", text: "Pas de permis requis, parking gratuit, activités dès 3 ans.", icon: "key", color: "#26cfff" },
  { title: "Éco-responsable", text: "Moteurs 100% électriques, tri sélectif, produits locaux.", icon: "leaf", color: "#22c55e" },
  { title: "Tout sur place", text: "Location, restauration, animations : une journée complète.", icon: "sun", color: "#f77b46" },
  { title: "Convivialité", text: "Ambiance familiale et chaleureuse depuis plus de 10 ans.", icon: "heart", color: "#6b21a8" },
];
---

<LayoutHyper
  title="L'esprit Surf Center — Notre histoire | Lac de Sainte-Croix"
  description="Découvrez l'esprit Surf Center : notre histoire, nos valeurs, notre équipe passionnée au bord du lac de Sainte-Croix, Gorges du Verdon."
>
  <!-- HERO -->
  <section class="hyes__hero" aria-label="L'esprit Surf Center">
    <MeshGradient class="hyes__hero-mesh" />
    <Image
      class="hyes__hero-img"
      src={imgHero}
      alt="Vue panoramique du Surf Center au bord du lac de Sainte-Croix"
      widths={[640, 1024, 1440]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      format="webp"
      quality={75}
    />
    <div class="hyes__hero-overlay" aria-hidden="true"></div>
    <div class="hyes__hero-content reveal">
      <GlowText tag="h1" color="#26cfff" intensity="high" class="hyes__hero-title">
        L'esprit Surf Center
      </GlowText>
      <p class="hyes__hero-sub">Depuis 2005, la passion du lac de Sainte-Croix</p>
    </div>
  </section>

  <WaveDivider color="#26cfff" />

  <!-- KEY NUMBERS -->
  <section class="hyes__numbers" aria-label="Chiffres clés">
    <div class="hyes__numbers-grid">
      {keyNumbers.map((n) => (
        <div class="hyes__numbers-item reveal">
          <GlowText tag="span" color={n.color} intensity="high" class="hyes__numbers-val">{n.value}</GlowText>
          <span class="hyes__numbers-label">{n.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- TIMELINE -->
  <section class="hyes__timeline" aria-label="Notre histoire">
    <GlowText tag="h2" color="#26cfff" intensity="medium" class="hyes__section-title">Notre histoire</GlowText>
    <p class="hyes__section-sub">De la plage au leader du lac, année après année</p>

    <div class="hyes__tl-track">
      {timeline.map((t, i) => (
        <div class={`hyes__tl-item reveal ${i % 2 === 0 ? 'hyes__tl-item--left' : 'hyes__tl-item--right'}`}>
          <div class="hyes__tl-dot" aria-hidden="true">
            <span class="hyes__tl-dot-core"></span>
          </div>
          <HolographicCard class="hyes__tl-card">
            <div class="hyes__tl-inner">
              <GlowText tag="span" color="#f77b46" intensity="high" class="hyes__tl-year">{t.year}</GlowText>
              <h3 class="hyes__tl-name">{t.title}</h3>
              <p class="hyes__tl-text">{t.text}</p>
            </div>
          </HolographicCard>
        </div>
      ))}
      <div class="hyes__tl-line" aria-hidden="true"></div>
    </div>
  </section>

  <WaveDivider color="#6b21a8" flip />

  <!-- LE CADRE -->
  <section class="hyes__cadre" aria-label="Le cadre">
    <GlowText tag="h2" color="#26cfff" intensity="medium" class="hyes__section-title">Le cadre</GlowText>
    <p class="hyes__section-sub">Un environnement unique en Provence</p>

    <div class="hyes__cadre-grid">
      {cadreCards.map((c) => (
        <HolographicCard class="hyes__cadre-card">
          <div class="hyes__cadre-inner">
            <div class="hyes__cadre-bar" style={`background: ${c.color};`} aria-hidden="true"></div>
            <GlowText tag="h3" color={c.color} intensity="low" class="hyes__cadre-title">{c.title}</GlowText>
            <p class="hyes__cadre-text">{c.text}</p>
          </div>
        </HolographicCard>
      ))}
    </div>

    <div class="hyes__cadre-img-wrap reveal">
      <Image
        class="hyes__cadre-img"
        src={imgLac}
        alt="Bateaux électriques sur le lac de Sainte-Croix"
        widths={[640, 1024, 1440]}
        sizes="(max-width: 768px) 100vw, 80vw"
        format="webp"
        quality={75}
      />
      <div class="hyes__cadre-img-overlay" aria-hidden="true"></div>
    </div>
  </section>

  <WaveDivider color="#3b82f6" />

  <!-- VALUES -->
  <section class="hyes__values" aria-label="Nos valeurs">
    <GlowText tag="h2" color="#26cfff" intensity="medium" class="hyes__section-title">Nos valeurs</GlowText>
    <div class="hyes__values-grid">
      {values.map((v) => (
        <HolographicCard class="hyes__values-card">
          <div class="hyes__values-inner">
            <div class="hyes__values-icon" style={`color: ${v.color};`} aria-hidden="true">
              {v.icon === 'key' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
              )}
              {v.icon === 'leaf' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 17 3.5s2.5 2.1 2.5 7.5c0 5.4-4.5 9-8.5 9z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
              )}
              {v.icon === 'sun' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
              )}
              {v.icon === 'heart' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              )}
            </div>
            <GlowText tag="h3" color={v.color} intensity="low" class="hyes__values-title">{v.title}</GlowText>
            <p class="hyes__values-text">{v.text}</p>
          </div>
        </HolographicCard>
      ))}
    </div>
  </section>

  <WaveDivider color="#f77b46" flip />

  <!-- ACTIVITIES GRID -->
  <section class="hyes__activities" aria-label="Nos activités">
    <GlowText tag="h2" color="#26cfff" intensity="medium" class="hyes__section-title">Nos activités</GlowText>
    <p class="hyes__section-sub">5 façons de vivre le lac de Sainte-Croix</p>

    <div class="hyes__act-grid">
      {locationDetails.map((loc) => (
        <a href={`/v11/nos-locations/${loc.slug}`} class="hyes__act-link">
          <HolographicCard class="hyes__act-card">
            <div class="hyes__act-inner">
              <GlowText tag="h3" color="#26cfff" intensity="low" class="hyes__act-name">{loc.title}</GlowText>
              <p class="hyes__act-tagline">{loc.tagline}</p>
              <div class="hyes__act-footer">
                <span class="hyes__act-price">
                  <GlowText tag="span" color="#f77b46" intensity="low">{loc.price}€</GlowText>
                  <span class="hyes__act-unit">/{loc.priceUnit}</span>
                </span>
                <span class="hyes__act-arrow" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#26cfff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
              </div>
            </div>
          </HolographicCard>
        </a>
      ))}
    </div>
  </section>

  <!-- ESPRIT CTA -->
  <section class="hyes__cta reveal" aria-label="Découvrir Surf Center">
    <div class="hyes__cta-wrap">
      <MeshGradient class="hyes__cta-mesh" />
      <div class="hyes__cta-content">
        <Image
          class="hyes__cta-img"
          src={imgEsprit}
          alt="L'esprit Surf Center"
          widths={[200, 300]}
          sizes="150px"
          format="webp"
          quality={75}
        />
        <GlowText tag="h2" color="#26cfff" intensity="high" class="hyes__cta-title">Venez vivre l'expérience</GlowText>
        <p class="hyes__cta-desc">Activités nautiques, restauration et animations — tout au bord du lac.</p>
        <a href="/v11/acces-contact" class="hyes__cta-btn">
          <span>Planifier ma visite</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>
</LayoutHyper>

<style>
  /* HERO */
  .hyes__hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .hyes__hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.25;
    z-index: 0;
  }
  .hyes__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(5,5,16,0.5) 0%, rgba(5,5,16,0.95) 100%);
    z-index: 1;
  }
  .hyes__hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 6rem 1.5rem 4rem;
  }
  .hyes__hero-title {
    font-size: clamp(2.2rem, 6vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 1rem;
  }
  .hyes__hero-sub {
    font-size: 1.1rem;
    color: rgba(240,240,235,0.6);
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  /* SECTION COMMON */
  .hyes__section-title {
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    text-align: center;
    margin: 0 0 0.5rem;
  }
  .hyes__section-sub {
    text-align: center;
    color: rgba(240,240,235,0.5);
    font-size: 1rem;
    margin: 0 0 3rem;
  }

  /* KEY NUMBERS */
  .hyes__numbers {
    padding: 4rem 1.5rem;
    max-width: 1000px;
    margin: 0 auto;
  }
  .hyes__numbers-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }
  .hyes__numbers-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .hyes__numbers-val {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: bold;
    letter-spacing: -0.03em;
  }
  .hyes__numbers-label {
    font-size: 0.82rem;
    color: rgba(240,240,235,0.5);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* TIMELINE */
  .hyes__timeline {
    padding: 5rem 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .hyes__tl-track {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-top: 1rem;
  }
  .hyes__tl-line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 2px;
    background: linear-gradient(180deg, rgba(38,207,255,0.4) 0%, rgba(107,33,168,0.3) 50%, rgba(247,123,70,0.3) 100%);
    transform: translateX(-50%);
    z-index: 0;
  }
  .hyes__tl-item {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: start;
    gap: 1.5rem;
    z-index: 1;
  }
  .hyes__tl-item--left :global(.hyes__tl-card) {
    grid-column: 1;
  }
  .hyes__tl-item--left .hyes__tl-dot {
    grid-column: 2;
  }
  .hyes__tl-item--right :global(.hyes__tl-card) {
    grid-column: 3;
  }
  .hyes__tl-item--right .hyes__tl-dot {
    grid-column: 2;
  }
  .hyes__tl-dot {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(5,5,16,0.8);
    border: 2px solid rgba(38,207,255,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1.5rem;
    flex-shrink: 0;
  }
  .hyes__tl-dot-core {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #26cfff;
    box-shadow: 0 0 8px rgba(38,207,255,0.6);
  }
  .hyes__tl-inner {
    padding: 1.5rem;
  }
  .hyes__tl-year {
    font-size: 1.6rem;
    font-weight: bold;
    display: block;
    margin-bottom: 0.5rem;
  }
  .hyes__tl-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: #f0f0eb;
    margin: 0 0 0.5rem;
  }
  .hyes__tl-text {
    font-size: 0.88rem;
    color: rgba(240,240,235,0.6);
    line-height: 1.6;
    margin: 0;
  }

  /* CADRE */
  .hyes__cadre {
    padding: 5rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .hyes__cadre-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  .hyes__cadre-inner {
    padding: 2rem 1.5rem;
  }
  .hyes__cadre-bar {
    width: 40px;
    height: 3px;
    border-radius: 2px;
    margin-bottom: 1.25rem;
    opacity: 0.8;
    box-shadow: 0 0 12px currentColor;
  }
  .hyes__cadre-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
  }
  .hyes__cadre-text {
    color: rgba(240,240,235,0.6);
    font-size: 0.9rem;
    line-height: 1.65;
    margin: 0;
  }
  .hyes__cadre-img-wrap {
    position: relative;
    border-radius: 1.25rem;
    overflow: hidden;
    max-height: 400px;
  }
  .hyes__cadre-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .hyes__cadre-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(5,5,16,0.7) 100%);
    pointer-events: none;
  }

  /* VALUES */
  .hyes__values {
    padding: 5rem 1.5rem;
    max-width: 1000px;
    margin: 0 auto;
  }
  .hyes__values-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .hyes__values-inner {
    padding: 2rem 1.5rem;
  }
  .hyes__values-icon {
    margin-bottom: 1rem;
  }
  .hyes__values-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }
  .hyes__values-text {
    color: rgba(240,240,235,0.6);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
  }

  /* ACTIVITIES */
  .hyes__activities {
    padding: 5rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .hyes__act-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
  }
  .hyes__act-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .hyes__act-inner {
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-height: 180px;
  }
  .hyes__act-name {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0;
  }
  .hyes__act-tagline {
    font-size: 0.82rem;
    color: rgba(240,240,235,0.5);
    margin: 0;
    flex: 1;
  }
  .hyes__act-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .hyes__act-price {
    display: flex;
    align-items: baseline;
    gap: 0.15rem;
    font-size: 1.2rem;
    font-weight: 800;
  }
  .hyes__act-unit {
    font-size: 0.72rem;
    color: rgba(240,240,235,0.4);
    font-weight: 500;
  }
  .hyes__act-arrow {
    opacity: 0.4;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .hyes__act-link:hover .hyes__act-arrow {
    opacity: 1;
    transform: translateX(4px);
  }

  /* CTA */
  .hyes__cta {
    padding: 4rem 1.5rem 6rem;
    max-width: 800px;
    margin: 0 auto;
  }
  .hyes__cta-wrap {
    position: relative;
    border-radius: 1.5rem;
    overflow: hidden;
    border: 1px solid rgba(38,207,255,0.12);
    background: rgba(255,255,255,0.02);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  .hyes__cta-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 3.5rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .hyes__cta-img {
    width: 120px;
    height: auto;
    opacity: 0.7;
    margin-bottom: 0.5rem;
  }
  .hyes__cta-title {
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    font-weight: 700;
    margin: 0;
  }
  .hyes__cta-desc {
    color: rgba(240,240,235,0.6);
    font-size: 1rem;
    margin: 0;
  }
  .hyes__cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.9rem 2.2rem;
    border: 1px solid rgba(38,207,255,0.3);
    border-radius: 9999px;
    background: linear-gradient(135deg, rgba(38,207,255,0.12) 0%, rgba(107,33,168,0.1) 100%);
    color: #26cfff;
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s ease;
    letter-spacing: 0.02em;
    margin-top: 0.5rem;
  }
  .hyes__cta-btn:hover {
    border-color: rgba(38,207,255,0.6);
