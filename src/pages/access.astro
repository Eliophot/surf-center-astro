---
const url = new URL(Astro.request.url);
const nextUrl = url.searchParams.get('next') ?? '/';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>En cours de création</title>
    <meta name="robots" content="noindex,nofollow" />
    <style>
      :root {
        color-scheme: light dark;
        --bg: #050510;
        --card: rgba(255, 255, 255, 0.06);
        --border: rgba(255, 255, 255, 0.12);
        --text: rgba(255, 255, 255, 0.92);
        --muted: rgba(255, 255, 255, 0.65);
        --accent: #26cfff;
        --danger: #ff5a7a;
        --orange: #f77b46;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(1200px 600px at 10% 10%, rgba(38, 207, 255, 0.25), transparent 55%),
          radial-gradient(1000px 500px at 90% 30%, rgba(247, 123, 70, 0.18), transparent 60%),
          var(--bg);
        color: var(--text);
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, Cantarell, Noto Sans, sans-serif;
        overflow-x: hidden;
      }

      .stage {
        position: relative;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 2.5rem 1.25rem;
      }

      canvas#bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        opacity: 0.95;
      }

      .scrim {
        position: absolute;
        inset: 0;
        z-index: 1;
        background:
          radial-gradient(800px 420px at 50% 40%, rgba(255, 255, 255, 0.08), transparent 62%),
          linear-gradient(to bottom, rgba(5, 5, 16, 0.72), rgba(5, 5, 16, 0.88));
        pointer-events: none;
      }

      .card {
        position: relative;
        z-index: 2;
        width: min(600px, calc(100% - 2.5rem));
        border: 1px solid var(--border);
        background: var(--card);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border-radius: 18px;
        padding: 1.75rem;
        box-shadow: 0 20px 80px rgba(0, 0, 0, 0.45);
      }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.4rem 0.75rem;
        border: 1px solid rgba(38, 207, 255, 0.25);
        border-radius: 9999px;
        background: rgba(255, 255, 255, 0.04);
        box-shadow:
          0 0 18px rgba(38, 207, 255, 0.12),
          inset 0 0 14px rgba(38, 207, 255, 0.05);
        margin-bottom: 0.9rem;
      }

      .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: radial-gradient(circle at 30% 30%, #fff, var(--accent) 55%, rgba(38, 207, 255, 0.2) 75%);
        box-shadow: 0 0 14px rgba(38, 207, 255, 0.55);
        animation: pulse 1.2s ease-in-out infinite;
      }

      .badge span {
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.8);
      }

      h1 {
        margin: 0 0 0.5rem 0;
        font-size: 1.55rem;
        letter-spacing: -0.02em;
      }

      p {
        margin: 0 0 1.25rem 0;
        color: var(--muted);
        line-height: 1.5;
      }

      .loop {
        margin: 0.25rem 0 1.35rem;
        padding: 0.95rem 1rem;
        border-radius: 14px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(0, 0, 0, 0.18);
      }

      .loop .label {
        display: block;
        font-size: 0.72rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.5);
        margin-bottom: 0.45rem;
      }

      .loop .line {
        font-size: 1.05rem;
        font-weight: 750;
        letter-spacing: -0.01em;
        line-height: 1.35;
        margin: 0;
        background: linear-gradient(135deg, rgba(38, 207, 255, 1), rgba(59, 130, 246, 1), rgba(247, 123, 70, 1));
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: shimmer 3.5s ease-in-out infinite;
      }

      .subline {
        margin: 0.6rem 0 0;
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.6);
      }

      .divider {
        height: 1px;
        width: 100%;
        margin: 1.25rem 0 1rem;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(38, 207, 255, 0.25),
          rgba(255, 255, 255, 0.08),
          rgba(247, 123, 70, 0.18),
          transparent
        );
      }

      form {
        display: grid;
        gap: 0.75rem;
      }

      label {
        font-size: 0.9rem;
        font-weight: 600;
      }

      input[type='password'] {
        width: 100%;
        box-sizing: border-box;
        border-radius: 12px;
        border: 1px solid var(--border);
        padding: 0.85rem 0.95rem;
        background: rgba(0, 0, 0, 0.2);
        color: var(--text);
        outline: none;
      }

      input[type='password']:focus {
        border-color: rgba(38, 207, 255, 0.6);
        box-shadow: 0 0 0 4px rgba(38, 207, 255, 0.15);
      }

      button {
        border: none;
        border-radius: 12px;
        padding: 0.9rem 1rem;
        font-weight: 800;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        cursor: pointer;
        background: linear-gradient(135deg, rgba(38, 207, 255, 1), rgba(59, 130, 246, 1));
        color: #061018;
      }

      button:hover {
        filter: brightness(1.05);
      }

      .error {
        margin-top: 0.25rem;
        color: var(--danger);
        font-weight: 650;
        font-size: 0.92rem;
      }

      .hint {
        margin-top: 0.75rem;
        font-size: 0.82rem;
        color: rgba(255, 255, 255, 0.45);
      }

      .next {
        display: inline-block;
        margin-top: 0.35rem;
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.82rem;
      }

      details {
        margin-top: 1rem;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.03);
        padding: 0.75rem 0.9rem;
      }

      summary {
        cursor: pointer;
        color: rgba(255, 255, 255, 0.75);
        font-weight: 700;
        list-style: none;
      }

      summary::-webkit-details-marker {
        display: none;
      }

      details[open] summary {
        margin-bottom: 0.75rem;
      }

      @keyframes shimmer {
        0% { filter: saturate(1) brightness(1); }
        50% { filter: saturate(1.2) brightness(1.1); }
        100% { filter: saturate(1) brightness(1); }
      }

      @keyframes pulse {
        0%, 100% { transform: scale(0.9); opacity: 0.75; }
        50% { transform: scale(1.15); opacity: 1; }
      }

      @media (prefers-reduced-motion: reduce) {
        .dot { animation: none; }
        .loop .line { animation: none; }
      }
    </style>
  </head>
  <body>
    <div class="stage">
      <canvas id="bg" aria-hidden="true"></canvas>
      <div class="scrim" aria-hidden="true"></div>

      <main class="card">
        <div class="badge">
          <span class="dot" aria-hidden="true"></span>
          <span>Validation en cours</span>
        </div>

        <h1>En cours de création</h1>
        <p>Cette section est en train d’être finalisée. La home est accessible, le reste est temporairement protégé.</p>

        <div class="loop" aria-live="polite">
          <span class="label">Petite note pendant le chargement</span>
          <p class="line" id="loopLine">En cours de création… ne soyez pas trop curieux.</p>
          <p class="subline">On peaufine les détails (et on évite de vous spoiler).</p>
        </div>

        <div class="divider" aria-hidden="true"></div>

        <details>
          <summary>J’ai le mot de passe</summary>
          <form id="accessForm" novalidate>
            <input type="hidden" name="next" value={nextUrl} />
            <div>
              <label for="password">Mot de passe</label>
              <input id="password" name="password" type="password" autocomplete="current-password" required />
              <div class="error" id="err" role="alert" style="display:none;"></div>
              <span class="next">Destination&nbsp;: {nextUrl}</span>
            </div>
            <button type="submit">Continuer</button>
          </form>
        </details>

        <div class="hint">
          Astuce : vous pouvez aussi revenir à la home via <a href="/" style="color: var(--accent)">/</a>.
        </div>
      </main>
    </div>

    <script is:inline>
      (function () {
        // Auth côté client (SSG) — UX, pas sécurité forte.
        var ACCESS_KEY = 'sc_preview_auth';
        var PASSWORD = '2026eliophotsurfcenter';
        var form = document.getElementById('accessForm');
        var err = document.getElementById('err');

        function showError(msg) {
          if (!err) return;
          err.textContent = msg;
          err.style.display = 'block';
        }

        if (form) {
          form.addEventListener('submit', function (e) {
            e.preventDefault();
            if (err) err.style.display = 'none';

            var pwdInput = form.querySelector('input[name=\"password\"]');
            var nextInput = form.querySelector('input[name=\"next\"]');
            var pwd = pwdInput && pwdInput.value ? String(pwdInput.value) : '';
            var next = nextInput && nextInput.value ? String(nextInput.value) : '/';

            if (pwd !== PASSWORD) {
              showError('Mot de passe incorrect.');
              return;
            }

            try { localStorage.setItem(ACCESS_KEY, '1'); } catch (_) {}
            location.assign(next && next.startsWith('/') ? next : '/');
          });
        }

        var phrases = [
          "En cours de création… ne soyez pas trop curieux.",
          "On assemble les pixels, un par un (promis, on va vite).",
          "Ça arrive… on peaufine la magie et les micro-détails.",
          "Version client : élégante. Version chantier : très secrète.",
          "Encore quelques réglages… et ce sera prêt à briller.",
          "Accès réservé : on évite les spoilers, merci.",
          "On finalise l’expérience — curiosité autorisée, accès limité.",
        ];

        var line = document.getElementById('loopLine');
        var i = 0;
        var lastSwitch = 0;

        function switchLine(t) {
          if (!line) return;
          if (!lastSwitch) lastSwitch = t;
          if (t - lastSwitch < 2400) return;
          lastSwitch = t;
          i = (i + 1) % phrases.length;
          line.style.opacity = '0';
          line.style.transform = 'translateY(6px)';
          setTimeout(function () {
            line.textContent = phrases[i];
            line.style.opacity = '1';
            line.style.transform = 'translateY(0)';
          }, 220);
        }

        if (line) {
          line.style.transition = 'opacity 220ms ease, transform 220ms ease';
        }

        var canvas = document.getElementById('bg');
        if (!(canvas instanceof HTMLCanvasElement)) return;
        var ctx = canvas.getContext('2d');
        if (!ctx) return;

        var dpr = Math.min(2, window.devicePixelRatio || 1);
        var w = 0;
        var h = 0;
        var t0 = 0;

        function resize() {
          w = Math.max(1, Math.floor(window.innerWidth));
          h = Math.max(1, Math.floor(window.innerHeight));
          canvas.width = Math.floor(w * dpr);
          canvas.height = Math.floor(h * dpr);
          canvas.style.width = w + 'px';
          canvas.style.height = h + 'px';
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        }

        var palette = [
          { r: 38, g: 207, b: 255, a: 0.75 },
          { r: 59, g: 130, b: 246, a: 0.55 },
          { r: 247, g: 123, b: 70, a: 0.45 },
        ];

        var particles = Array.from({ length: 84 }, function (_, idx) {
          var p = palette[idx % palette.length];
          return {
            x: Math.random(),
            y: Math.random(),
            vx: (Math.random() - 0.5) * 0.09,
            vy: (Math.random() - 0.5) * 0.09,
            s: 0.6 + Math.random() * 1.6,
            c: p,
          };
        });

        function rgba(c, aMul) {
          return 'rgba(' + c.r + ',' + c.g + ',' + c.b + ',' + (c.a * aMul) + ')';
        }

        function draw(now) {
          if (!t0) t0 = now;
          var t = (now - t0) / 1000;

          ctx.clearRect(0, 0, w, h);

          for (var k = 0; k < 3; k++) {
            var c = palette[k];
            var cx = w * (0.2 + k * 0.3) + Math.sin(t * (0.35 + k * 0.12)) * w * 0.12;
            var cy = h * (0.25 + k * 0.18) + Math.cos(t * (0.32 + k * 0.1)) * h * 0.1;
            var r = Math.min(w, h) * (0.22 + k * 0.04);
            var g = ctx.createRadialGradient(cx, cy, 0, cx, cy, r);
            g.addColorStop(0, rgba(c, 0.22));
            g.addColorStop(1, rgba(c, 0));
            ctx.fillStyle = g;
            ctx.fillRect(0, 0, w, h);
          }

          ctx.globalCompositeOperation = 'lighter';
          for (var band = 0; band < 3; band++) {
            var c2 = palette[band];
            ctx.beginPath();
            var amp = 26 + band * 8;
            var y0 = h * (0.35 + band * 0.13);
            for (var x = -40; x <= w + 40; x += 16) {
              var y = y0 + Math.sin(t * (0.9 + band * 0.2) + x * (0.012 + band * 0.002)) * amp;
              if (x === -40) ctx.moveTo(x, y);
              else ctx.lineTo(x, y);
            }
            ctx.lineWidth = 2.2 + band * 0.6;
            ctx.strokeStyle = rgba(c2, 0.5);
            ctx.shadowColor = rgba(c2, 0.35);
            ctx.shadowBlur = 18;
            ctx.stroke();
          }
          ctx.shadowBlur = 0;

          ctx.globalCompositeOperation = 'source-over';
          for (var j = 0; j < particles.length; j++) {
            var p2 = particles[j];
            p2.x += p2.vx / 60;
            p2.y += p2.vy / 60;
            if (p2.x < -0.05) p2.x = 1.05;
            if (p2.x > 1.05) p2.x = -0.05;
            if (p2.y < -0.05) p2.y = 1.05;
            if (p2.y > 1.05) p2.y = -0.05;

            var px = p2.x * w;
            var py = p2.y * h;
            var rr = p2.s * (1.2 + 0.35 * Math.sin(t * 1.4 + j));
            ctx.beginPath();
            ctx.fillStyle = rgba(p2.c, 0.35);
            ctx.arc(px, py, rr, 0, Math.PI * 2);
            ctx.fill();
          }

          switchLine(now);
          requestAnimationFrame(draw);
        }

        var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce) return;

        resize();
        window.addEventListener('resize', resize, { passive: true });
        requestAnimationFrame(draw);
      })();
    </script>
  </body>
</html>

