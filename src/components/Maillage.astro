---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

import imgBateau from '../assets/images/location-bateau-electrique-lac-sainte-croix-surfcenter.jpeg';
import imgEsprit from '../assets/images/esprit.png';
import imgSnack from '../assets/images/drone-snack-pedalo-lac-sainte-croix-surfcenter-salades.jpeg';
import imgYoga from '../assets/images/sarah-cours-yoga-surfcenter-lac-sainte-croix.jpg';
import imgConcert from '../assets/images/concert-surfcenter-lac-sainte-croix.png';

const links: { title: string; description: string; href: string; image: ImageMetadata; alt: string }[] = [
  {
    title: "Nos locations",
    description: "Bateaux, paddle, pédalo, canoë",
    href: "/nos-locations",
    image: imgBateau,
    alt: "Location de bateaux — Surf Center",
  },
  {
    title: "L'esprit Surf Center",
    description: "Notre histoire & nos valeurs",
    href: "/esprit-surf-center",
    image: imgEsprit,
    alt: "L'esprit Surf Center — lac de Sainte-Croix",
  },
  {
    title: "Restauration",
    description: "Snack-pizzeria face au lac",
    href: "/restauration",
    image: imgSnack,
    alt: "Restaurant Surf Center",
  },
  {
    title: "Animations",
    description: "Yoga, cours & activités",
    href: "/animations",
    image: imgYoga,
    alt: "Yoga au Surf Center",
  },
  {
    title: "Groupes & Événements",
    description: "Concerts, soirées & privatisation",
    href: "/groupes-evenements",
    image: imgConcert,
    alt: "Concert au Surf Center",
  },
];
---

<section class="mesh" aria-labelledby="maillage-title">
  <div class="container">
    <header class="mesh__header reveal">
      <span class="mesh__eyebrow">Explorer</span>
      <h2 id="maillage-title" class="mesh__title">Tout Surf Center</h2>
    </header>

    <div class="mesh-grid">
      {links.map((link, i) => (
        <a href={link.href} class={`mesh-card reveal reveal-d${Math.min(i + 1, 4)}`}>
          <Image
            class="mesh-card__img"
            src={link.image}
            alt={link.alt}
            width={320}
            height={200}
            loading="lazy"
            decoding="async"
            format="webp"
            quality={75}
          />
          <div class="mesh-card__overlay"></div>
          <div class="mesh-card__content">
            <h3 class="mesh-card__title">{link.title}</h3>
            <p class="mesh-card__desc">{link.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .mesh {
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }

  .mesh__header {
    text-align: center;
    margin-bottom: var(--s-8);
  }

  .mesh__eyebrow {
    display: inline-block;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--c-orange);
    margin-bottom: var(--s-3);
  }

  .mesh__title {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--c-text);
    margin: 0;
  }

  .mesh-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-3);
  }

  .mesh-card {
    position: relative;
    display: block;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: var(--r-md);
    text-decoration: none;
    color: #fff;
  }

  .mesh-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }

  .mesh-card:hover .mesh-card__img { transform: scale(1.05); }

  .mesh-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg,
      rgb(0 0 0 / 0.7) 0%,
      rgb(0 0 0 / 0.1) 65%,
      rgb(0 0 0 / 0.15) 100%);
    transition: background var(--t-normal);
  }

  .mesh-card:hover .mesh-card__overlay {
    background: linear-gradient(0deg,
      rgb(0 0 0 / 0.78) 0%,
      rgb(0 0 0 / 0.15) 65%,
      rgb(0 0 0 / 0.22) 100%);
  }

  .mesh-card__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--s-3) var(--s-4);
    z-index: 1;
  }

  .mesh-card__title {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #fff;
    margin: 0 0 1px;
    line-height: 1.2;
  }

  .mesh-card__desc {
    font-size: 0.62rem;
    color: rgb(255 255 255 / 0.65);
    letter-spacing: 0.02em;
    margin: 0;
    line-height: 1.3;
  }

  @media (min-width: 600px) {
    .mesh-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (min-width: 1000px) {
    .mesh-grid { grid-template-columns: repeat(5, 1fr); }
  }
</style>
