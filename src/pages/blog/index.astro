---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import LocationHero from '../../components/locations/LocationHero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BookingCTA from '../../components/locations/BookingCTA.astro';

import imgHeroBlog from '../../assets/images/lac-sainte-croix-gorges-verdon-location-bateaux-electriques.jpg';

const title = 'Blog — Actualités & guides | Surf Center Verdon';
const description = 'Guides pratiques, bons plans et actualités du Surf Center : activités nautiques, événements, criques secrètes et conseils pour profiter du lac de Sainte-Croix.';

const siteUrl = 'https://surfcenter-verdon.fr';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Blog',
    name: 'Blog Surf Center',
    description,
    url: `${siteUrl}/blog`,
    publisher: { '@type': 'Organization', name: 'Surf Center', url: siteUrl },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog` },
    ],
  },
];

function formatDate(date: Date): string {
  return date.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <LocationHero
    title="Blog"
    tagline="Guides · Actualités · Bons plans"
    image={imgHeroBlog}
    alt="Vue panoramique du lac de Sainte-Croix — Gorges du Verdon"
  />
  <Breadcrumbs items={[
    { label: 'Accueil', href: '/' },
    { label: 'Blog' },
  ]} />

  <section class="section" aria-labelledby="blog-listing-title">
    <div class="container">
      <header class="section__header reveal">
        <span class="section__eyebrow">Actualités</span>
        <h2 id="blog-listing-title">Derniers articles</h2>
        <p class="section__lead">Guides pratiques, événements et bons plans pour profiter du lac de Sainte-Croix.</p>
      </header>

      {posts.length === 0 && (
        <p class="blg-empty">Aucun article pour le moment. Revenez bientôt !</p>
      )}

      <div class="blg-grid">
        {posts.map((post, i) => (
          <a href={`/blog/${post.id}`} class={`blg-card reveal`} style={`--d:${i * 80}ms`}>
            <div class="blg-card__visual">
              <img
                src={post.data.image}
                alt={post.data.imageAlt}
                width="800"
                height="500"
                loading={i < 3 ? 'eager' : 'lazy'}
                decoding="async"
              />
            </div>
            <div class="blg-card__body">
              <div class="blg-card__tags">
                {post.data.tags.slice(0, 2).map((tag) => (
                  <span class="blg-card__tag">{tag}</span>
                ))}
              </div>
              <h3 class="blg-card__title">{post.data.title}</h3>
              <p class="blg-card__excerpt">{post.data.description}</p>
              <div class="blg-card__footer">
                <time datetime={post.data.date.toISOString().slice(0, 10)}>{formatDate(post.data.date)}</time>
                <span class="blg-card__read">Lire <span aria-hidden="true">→</span></span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <BookingCTA
    title="Envie de lac ?"
    text="Réservez votre activité nautique et venez profiter du lac de Sainte-Croix."
  />
</Layout>

<style>
  .blg-empty {
    text-align: center;
    color: var(--c-text-muted);
    font-size: 0.95rem;
    padding: var(--s-16) 0;
  }

  .blg-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-8);
  }

  .blg-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--r-lg);
    overflow: hidden;
    background: var(--c-surface);
    border: 1px solid var(--c-border-light);
    text-decoration: none;
    color: inherit;
    transition: transform var(--t-normal) var(--ease), box-shadow var(--t-normal) var(--ease);
  }

  .blg-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .blg-card__visual {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .blg-card__visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease);
  }

  .blg-card:hover .blg-card__visual img {
    transform: scale(1.05);
  }

  .blg-card__body {
    padding: var(--s-6);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .blg-card__tags {
    display: flex;
    gap: var(--s-2);
    flex-wrap: wrap;
    margin-bottom: var(--s-3);
  }

  .blg-card__tag {
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-orange);
    background: rgb(247 123 70 / 0.08);
    padding: 3px 10px;
    border-radius: var(--r-full);
  }

  [data-theme='dark'] .blg-card__tag {
    background: rgb(247 123 70 / 0.15);
  }

  .blg-card__title {
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 700;
    line-height: 1.35;
    color: var(--c-text);
    margin-bottom: var(--s-3);
  }

  .blg-card__excerpt {
    font-size: 0.82rem;
    color: var(--c-text-muted);
    line-height: 1.65;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blg-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--s-5);
    padding-top: var(--s-4);
    border-top: 1px solid var(--c-border-light);
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--c-text-muted);
    letter-spacing: 0.04em;
  }

  .blg-card__read {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-text-secondary);
    transition: color var(--t-fast);
  }

  .blg-card:hover .blg-card__read {
    color: var(--c-orange);
  }

  @media (min-width: 700px) {
    .blg-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1100px) {
    .blg-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (prefers-reduced-motion: reduce) {
    .blg-card { transition: none; }
    .blg-card__visual img { transition: none; }
  }
</style>
