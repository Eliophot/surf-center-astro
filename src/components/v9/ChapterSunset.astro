---
import { Image } from 'astro:assets';
import imgConcert from '../../assets/images/concert-surfcenter-lac-sainte-croix.png';
import imgEsprit from '../../assets/images/esprit.png';
---

<section class="section chs" aria-labelledby="v9-sunset-title">
  <div class="container">
    <div class="chs__header reveal">
      <span class="chs__chapter">Chapitre 05</span>
      <span class="chs__clock">18h — 23h</span>
    </div>

    <div class="chs__grid">
      <div class="chs__copy reveal">
        <h2 id="v9-sunset-title" class="chs__title">Et quand le soleil<br/>se couche…</h2>
        <p class="chs__text">
          Le lac prend des couleurs dorées. La musique s'installe. Les soirées au Surf Center sont ces moments où tout le monde se retrouve — concerts acoustiques, DJ sets, couchers de soleil partagés.
        </p>
        <p class="chs__text">
          C'est pour ça qu'on revient. Pas seulement pour le lac, mais pour l'atmosphère.
        </p>
        <a href="/groupes-evenements" class="btn btn--primary">Nos événements</a>
      </div>

      <div class="chs__visuals">
        <div class="chs__img-wrap chs__img-wrap--main reveal reveal-d1">
          <Image class="chs__img" src={imgConcert} alt="Concert au coucher du soleil au Surf Center" width={640} height={800} loading="lazy" decoding="async" format="webp" quality={75} />
        </div>
        <div class="chs__img-wrap chs__img-wrap--small reveal reveal-d2">
          <Image class="chs__img" src={imgEsprit} alt="Ambiance Surf Center au bord du lac" width={400} height={400} loading="lazy" decoding="async" format="webp" quality={75} />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .chs__header {
    display: flex;
    align-items: center;
    gap: var(--s-4);
    margin-bottom: var(--s-10);
  }
  .chs__chapter { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.3em; text-transform: uppercase; color: var(--c-orange); }
  .chs__clock { font-size: 0.6rem; font-weight: 500; letter-spacing: 0.1em; color: var(--c-text-muted); padding: 0.2rem 0.6rem; border: 1px solid var(--c-border-light); border-radius: var(--r-full); }

  .chs__grid { display: grid; grid-template-columns: 1fr; gap: var(--s-10); }

  .chs__title {
    font-size: clamp(1.8rem, 4.5vw, 3rem);
    font-weight: 300;
    text-transform: none;
    line-height: 1.15;
    margin-bottom: var(--s-6);
  }
  .chs__text { font-size: 0.95rem; color: var(--c-text-secondary); line-height: 1.8; max-width: 40ch; margin-bottom: var(--s-4); }

  .chs__visuals {
    display: grid;
    grid-template-columns: 1.4fr 0.6fr;
    gap: var(--s-4);
  }

  .chs__img-wrap { overflow: hidden; border-radius: var(--r-lg); }
  .chs__img-wrap--main { aspect-ratio: 4 / 5; }
  .chs__img-wrap--small { aspect-ratio: 1 / 1; align-self: end; }

  .chs__img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s var(--ease); }
  .chs__img-wrap:hover .chs__img { transform: scale(1.04); }

  @media (min-width: 900px) {
    .chs__grid { grid-template-columns: 1fr 1.2fr; align-items: center; gap: var(--s-16); }
  }
</style>
