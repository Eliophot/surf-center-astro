---
import LayoutMarketing from '../../../layouts/LayoutMarketing.astro';

const posts = [
  {
    slug: 'top-5-activites-lac-sainte-croix',
    title: 'Top 5 des activités nautiques au lac de Sainte-Croix',
    excerpt: 'Paddle, bateau électrique, pédalo… Découvrez notre sélection des meilleures activités pour profiter du lac cet été.',
    image: '/location-paddle-bateaux-electriques-lac-sainte-croix-gorges-verdon.jpeg',
    date: '15 avril 2026',
    readTime: '5 min',
    category: 'Guide',
  },
  {
    slug: 'preparer-journee-gorges-verdon',
    title: 'Comment préparer sa journée dans les Gorges du Verdon',
    excerpt: 'Tout ce qu\'il faut savoir avant de venir : horaires, équipement, astuces pour éviter la foule et profiter au maximum.',
    image: '/lac-sainte-croix-gorges-verdon-location-bateaux-electriques.jpg',
    date: '8 avril 2026',
    readTime: '7 min',
    category: 'Conseils',
  },
  {
    slug: 'bateau-electrique-guide-debutant',
    title: 'Bateau électrique : le guide complet pour débutants',
    excerpt: 'Pas besoin de permis ! On vous explique tout sur la navigation en bateau électrique sur le lac.',
    image: '/location-bateau-electrique-lac-sainte-croix-surfcenter.jpeg',
    date: '1er avril 2026',
    readTime: '6 min',
    category: 'Tutoriel',
  },
  {
    slug: 'paddle-coucher-soleil-verdon',
    title: 'Paddle au coucher du soleil : une expérience magique',
    excerpt: 'Le lac se transforme à la golden hour. Récit d\'une session paddle inoubliable face aux falaises du Verdon.',
    image: '/location-paddle-lac-sainte-croix-surfcenter.jpeg',
    date: '25 mars 2026',
    readTime: '4 min',
    category: 'Récit',
  },
];
---

<LayoutMarketing
  title="Blog — Conseils & guides nautiques · Surf Center"
  description="Conseils, guides et récits pour profiter du lac de Sainte-Croix et des Gorges du Verdon. Activités nautiques, astuces et bons plans."
>
  <!-- HERO -->
  <section class="m8__bloghero" aria-labelledby="m8-blog-title">
    <div class="m8__bloghero-overlay" aria-hidden="true"></div>
    <div class="container m8__bloghero-inner">
      <span class="section__eyebrow m8__bloghero-ey">Blog & conseils</span>
      <h1 id="m8-blog-title" class="m8__bloghero-title">Nos conseils pour<br/>profiter du lac</h1>
      <p class="m8__bloghero-lead">
        Guides pratiques, astuces locales et récits d'aventures —<br/>
        tout pour préparer votre journée parfaite au Verdon.
      </p>
      <div class="m8__bloghero-actions">
        <a href="#articles" class="btn btn--primary btn--lg">
          <span class="btn-flip__inner"><span class="btn-flip__front">Lire nos articles</span><span class="btn-flip__back">Lire nos articles</span></span>
        </a>
        <button type="button" class="btn btn--ghost btn--lg" data-booking>Réserver une activité</button>
      </div>
    </div>
  </section>

  <!-- ARTICLES -->
  <section id="articles" class="section" aria-labelledby="m8-articles-title">
    <div class="container">
      <header class="section__header reveal">
        <span class="section__eyebrow">Derniers articles</span>
        <h2 id="m8-articles-title">À lire avant<br/>votre visite</h2>
      </header>

      <div class="m8__blog-grid">
        {posts.map((post, i) => (
          <a href={`/v8/blog/${post.slug}`} class={`m8__blog-card reveal reveal-d${Math.min(i + 1, 4)}`}>
            <div class="m8__blog-card-img">
              <img src={post.image} alt={post.title} loading="lazy" decoding="async" width="600" height="400" />
              <span class="m8__blog-card-cat">{post.category}</span>
            </div>
            <div class="m8__blog-card-body">
              <div class="m8__blog-card-meta">
                <span>{post.date}</span>
                <span class="m8__blog-card-sep">·</span>
                <span>{post.readTime} de lecture</span>
              </div>
              <h3 class="m8__blog-card-title">{post.title}</h3>
              <p class="m8__blog-card-excerpt">{post.excerpt}</p>
              <span class="m8__blog-card-link">Lire l'article →</span>
            </div>
          </a>
        ))}

        {/* CTA card interspersed */}
        <div class="m8__blog-cta-card reveal reveal-d2">
          <div class="m8__blog-cta-card-inner">
            <span class="m8__blog-cta-card-ey">Envie d'essayer ?</span>
            <h3 class="m8__blog-cta-card-title">Réservez votre<br/>activité nautique</h3>
            <p class="m8__blog-cta-card-text">Dès 10€/h · Sans permis · Annulation gratuite</p>
            <button type="button" class="btn btn--primary" data-booking>
              <span class="btn-flip__inner"><span class="btn-flip__front">Réserver maintenant</span><span class="btn-flip__back">Réserver maintenant</span></span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="m8__blog-newsletter" aria-labelledby="m8-newsletter-title">
    <div class="m8__blog-newsletter-overlay" aria-hidden="true"></div>
    <div class="container m8__blog-newsletter-inner reveal">
      <span class="section__eyebrow" style="color: var(--c-orange);">Newsletter</span>
      <h2 id="m8-newsletter-title" class="m8__blog-newsletter-title">Ne ratez rien<br/>de la saison</h2>
      <p class="m8__blog-newsletter-text">
        Recevez nos meilleurs conseils, offres exclusives et actualités du lac.<br/>
        1 email par mois, désabonnement en 1 clic.
      </p>
      <form class="m8__blog-newsletter-form" onsubmit="event.preventDefault();">
        <div class="m8__blog-newsletter-field">
          <input
            type="email"
            placeholder="votre@email.com"
            required
            aria-label="Adresse email"
            class="m8__blog-newsletter-input"
          />
          <button type="submit" class="btn btn--primary m8__blog-newsletter-btn">
            <span class="btn-flip__inner"><span class="btn-flip__front">S'inscrire</span><span class="btn-flip__back">S'inscrire</span></span>
          </button>
        </div>
        <p class="m8__blog-newsletter-note">Pas de spam. Données jamais partagées.</p>
      </form>

      <div class="m8__blog-newsletter-proof">
        <span class="m8__blog-newsletter-proof-dot" aria-hidden="true"></span>
        2 500+ abonnés · Offres exclusives
      </div>
    </div>
  </section>
</LayoutMarketing>

<style>
  /* HERO */
  .m8__bloghero {
    position: relative; min-height: 70vh; display: flex;
    align-items: center; justify-content: center;
    background: url('/lac-sainte-croix-gorges-verdon-location-bateaux-electriques.jpg') center / cover no-repeat;
    color: #fff;
  }
  .m8__bloghero-overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(180deg, rgb(0 0 0 / 0.6) 0%, rgb(0 0 0 / 0.4) 40%, rgb(0 0 0 / 0.75) 100%);
  }
  .m8__bloghero-inner {
    position: relative; z-index: 2; text-align: center;
    max-width: 48rem; margin-inline: auto;
    padding-block: calc(var(--header-h) + var(--s-12)) var(--s-16);
  }
  .m8__bloghero-ey { color: var(--c-orange) !important; animation: fade-up 700ms var(--ease-smooth) 100ms both; }
  .m8__bloghero-title {
    font-size: clamp(2.5rem, 7vw, 5rem); font-weight: 800; line-height: 0.92;
    letter-spacing: -0.04em; text-transform: uppercase; color: #fff !important;
    margin-bottom: var(--s-6); text-shadow: 0 4px 40px rgb(0 0 0 / 0.5);
    animation: fade-up 700ms var(--ease-smooth) 250ms both;
  }
  .m8__bloghero-lead {
    font-size: clamp(0.88rem, 1.6vw, 1.05rem); color: rgb(255 255 255 / 0.7) !important;
    line-height: 1.7; margin-bottom: var(--s-8);
    animation: fade-up 700ms var(--ease-smooth) 400ms both;
  }
  .m8__bloghero-actions {
    display: flex; gap: var(--s-4); justify-content: center; flex-wrap: wrap;
    animation: fade-up 700ms var(--ease-smooth) 550ms both;
  }

  /* BLOG GRID */
  .m8__blog-grid { display: grid; grid-template-columns: 1fr; gap: var(--s-6); }
  .m8__blog-card {
    display: flex; flex-direction: column; background: var(--c-bg);
    border-radius: var(--r-lg); border: 1.5px solid var(--c-border-light);
    overflow: hidden; text-decoration: none; color: inherit;
    transition: border-color var(--t-fast), box-shadow var(--t-fast), transform var(--t-fast);
  }
  .m8__blog-card:hover { border-color: var(--c-border); box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .m8__blog-card-img { position: relative; aspect-ratio: 16 / 10; overflow: hidden; }
  .m8__blog-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s var(--ease); }
  .m8__blog-card:hover .m8__blog-card-img img { transform: scale(1.04); }
  .m8__blog-card-cat {
    position: absolute; top: var(--s-3); left: var(--s-3); z-index: 2;
    padding: 0.25rem 0.65rem; border-radius: var(--r-full);
    background: var(--c-orange); color: #fff; font-size: 0.58rem;
    font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
  }
  .m8__blog-card-body { padding: var(--s-5); display: flex; flex-direction: column; flex: 1; }
  .m8__blog-card-meta {
    display: flex; align-items: center; gap: var(--s-2);
    font-size: 0.65rem; color: var(--c-text-muted); margin-bottom: var(--s-3);
  }
  .m8__blog-card-sep { opacity: 0.4; }
  .m8__blog-card-title { font-size: 1rem; font-weight: 700; line-height: 1.35; margin-bottom: var(--s-3); }
  .m8__blog-card-excerpt { font-size: 0.82rem; color: var(--c-text-secondary); line-height: 1.6; margin-bottom: var(--s-4); flex: 1; }
  .m8__blog-card-link {
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--c-orange);
    transition: opacity var(--t-fast);
  }
  .m8__blog-card:hover .m8__blog-card-link { opacity: 0.8; }

  /* CTA CARD */
  .m8__blog-cta-card {
    background: linear-gradient(135deg, var(--c-orange), #e5623a);
    border-radius: var(--r-lg); overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    min-height: 280px;
  }
  .m8__blog-cta-card-inner { text-align: center; padding: var(--s-8); color: #fff; }
  .m8__blog-cta-card-ey {
    font-size: 0.62rem; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: rgb(255 255 255 / 0.7);
    display: block; margin-bottom: var(--s-3);
  }
  .m8__blog-cta-card-title { font-size: 1.3rem; font-weight: 800; margin-bottom: var(--s-3); line-height: 1.2; }
  .m8__blog-cta-card-text { font-size: 0.72rem; color: rgb(255 255 255 / 0.7); margin-bottom: var(--s-5); }
  .m8__blog-cta-card .btn--primary {
    background: #fff; color: var(--c-orange); border-color: #fff;
  }
  .m8__blog-cta-card .btn--primary:hover { background: rgb(255 255 255 / 0.9); }

  @media (min-width: 600px) { .m8__blog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1000px) { .m8__blog-grid { grid-template-columns: repeat(3, 1fr); } }

  /* NEWSLETTER */
  .m8__blog-newsletter {
    position: relative; overflow: hidden; color: #fff;
    background: url('/concert-surfcenter-lac-sainte-croix.png') center / cover no-repeat;
  }
  .m8__blog-newsletter-overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(180deg, rgb(10 10 10 / 0.75) 0%, rgb(10 10 10 / 0.9) 100%);
  }
  .m8__blog-newsletter-inner {
    position: relative; z-index: 2; text-align: center;
    max-width: 36rem; margin-inline: auto; padding-block: var(--s-20);
  }
  .m8__blog-newsletter-title {
    font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 800;
    letter-spacing: -0.03em; color: #fff; margin-bottom: var(--s-5);
  }
  .m8__blog-newsletter-text {
    font-size: 0.92rem; color: rgb(255 255 255 / 0.6); line-height: 1.7;
    margin-bottom: var(--s-8);
  }
  .m8__blog-newsletter-form { margin-bottom: var(--s-6); }
  .m8__blog-newsletter-field {
    display: flex; gap: var(--s-3); max-width: 28rem; margin-inline: auto;
  }
  .m8__blog-newsletter-input {
    flex: 1; padding: 0.75rem 1rem; border-radius: var(--r-md);
    border: 1.5px solid rgb(255 255 255 / 0.15);
    background: rgb(255 255 255 / 0.06); color: #fff;
    font-size: 0.85rem; font-family: inherit; outline: none;
    transition: border-color var(--t-fast);
  }
  .m8__blog-newsletter-input::placeholder { color: rgb(255 255 255 / 0.3); }
  .m8__blog-newsletter-input:focus { border-color: var(--c-orange); }
  .m8__blog-newsletter-btn { flex-shrink: 0; }
  .m8__blog-newsletter-note {
    font-size: 0.62rem; color: rgb(255 255 255 / 0.3);
    margin-top: var(--s-3);
  }
  .m8__blog-newsletter-proof {
    display: inline-flex; align-items: center; gap: var(--s-2);
    padding: 0.35rem 0.9rem; border-radius: var(--r-full);
    background: rgb(255 255 255 / 0.06); border: 1px solid rgb(255 255 255 / 0.08);
    font-size: 0.6rem; font-weight: 600; letter-spacing: 0.06em;
    text-transform: uppercase; color: rgb(255 255 255 / 0.4);
  }
  .m8__blog-newsletter-proof-dot {
    width: 6px; height: 6px; border-radius: 50%; background: #4ade80;
    animation: m8-nlpulse 2s ease-in-out infinite;
  }
  @keyframes m8-nlpulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

  @media (max-width: 480px) {
    .m8__blog-newsletter-field { flex-direction: column; }
    .m8__bloghero-lead br { display: none; }
    .m8__blog-newsletter-text br { display: none; }
  }
</style>
