---
import { Image } from 'astro:assets';
import imgPlanche from '../../assets/images/location-planche-a-voile.png';
import imgBateau from '../../assets/images/location-bateau-electrique.jpeg';
import imgPedalo from '../../assets/images/location-pedalo.jpg';
import imgPaddle from '../../assets/images/location-paddle.jpeg';
import imgCanoe from '../../assets/images/location-canoe.jpeg';

const products = [
  {
    title: "Canoë",
    subtitle: "Exploration · Face aux falaises",
    price: 10,
    unit: "h",
    features: ["Solo ou duo", "Idéal pour les criques", "Accessible à tous"],
    image: imgCanoe,
    alt: "Canoë sur le lac de Sainte-Croix",
    tag: "e57bf5a3-2296-4226-94a8-06295b1415d8",
    popular: false,
  },
  {
    title: "Paddle board",
    subtitle: "Accessible à tous · Vue garantie",
    price: 15,
    unit: "h",
    features: ["Rigide haute qualité", "Briefing inclus", "Vue imprenable"],
    image: imgPaddle,
    alt: "Paddle board sur le lac de Sainte-Croix",
    tag: "52bf76b6-6f0a-43ff-b0a2-4c1332d5ede5",
    popular: false,
  },
  {
    title: "Bateau électrique",
    subtitle: "Sans permis · Jusqu'à 7 pers.",
    price: 55,
    unit: "h",
    features: ["Sans permis", "Jusqu'à 7 personnes", "Silencieux & écologique"],
    image: imgBateau,
    alt: "Bateau électrique sur le lac de Sainte-Croix",
    tag: "62329049-d954-482c-82a1-faa16321e3bf",
    popular: true,
  },
  {
    title: "Pédalo",
    subtitle: "En famille · Criques secrètes",
    price: 15,
    unit: "h",
    features: ["2 à 5 personnes", "Parfait en famille", "Toboggan intégré"],
    image: imgPedalo,
    alt: "Pédalos sur le lac de Sainte-Croix",
    tag: "03a55e88-44ac-4161-ad03-aa857b1d0dc0",
    popular: false,
  },
  {
    title: "Planche à voile",
    subtitle: "Adrénaline · Vent du Verdon",
    price: 20,
    unit: "h",
    features: ["Sensations garanties", "Vent régulier", "Tous niveaux"],
    image: imgPlanche,
    alt: "Planche à voile sur le lac de Sainte-Croix",
    tag: "7a524907-97b7-42bd-bfdc-deb401767b21",
    popular: false,
  },
];
---

<section id="tarifs" class="section section--surface" aria-labelledby="v8-pricing-title">
  <div class="container">
    <header class="section__header reveal">
      <span class="section__eyebrow">Tarifs</span>
      <h2 id="v8-pricing-title">Des tarifs<br/>pour tous</h2>
      <p class="section__lead">Choisissez votre activité et réservez en quelques clics. Tarifs à partir de 10€/h.</p>
    </header>

    <div class="pc__grid" role="list" aria-label="Nos tarifs de location">
      {products.map((p, i) => (
        <button
          type="button"
          class={`pc__card reveal reveal-d${Math.min(i + 1, 4)} ${p.popular ? 'pc__card--pop' : ''}`}
          data-product-book
          data-tag={p.tag}
          role="listitem"
          aria-label={`Réserver ${p.title} — dès ${p.price}€/${p.unit}`}
        >
          {p.popular && <span class="pc__badge">Le + populaire</span>}
          <div class="pc__img-wrap">
            <Image
              class="pc__img"
              src={p.image}
              alt={p.alt}
              width={400}
              height={300}
              loading="lazy"
              decoding="async"
              format="webp"
              quality={75}
            />
          </div>
          <div class="pc__body">
            <h3 class="pc__title">{p.title}</h3>
            <p class="pc__subtitle">{p.subtitle}</p>
            <div class="pc__amount">
              <span class="pc__from">dès</span>
              <span class="pc__num">{p.price}<span class="pc__cur">€</span></span>
              <span class="pc__unit">/ {p.unit}</span>
            </div>
            <ul class="pc__features" role="list">
              {p.features.map((f) => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M3.5 7l2.5 2.5 4.5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
            <span class="pc__cta">Réserver <span aria-hidden="true">→</span></span>
          </div>
        </button>
      ))}
    </div>

    <div class="pc__footer reveal">
      <p class="pc__note">Réductions disponibles pour les demi-journées et journées complètes. <a href="/nos-locations" class="link-anim">Voir toutes nos locations</a></p>
    </div>
  </div>
</section>

<style>
  .pc__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-5);
  }

  .pc__card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--c-bg);
    border-radius: var(--r-lg);
    border: 1.5px solid var(--c-border-light);
    overflow: hidden;
    text-align: left;
    cursor: pointer;
    font-family: inherit;
    color: inherit;
    padding: 0;
    transition: border-color var(--t-fast), box-shadow var(--t-fast), transform var(--t-fast);
    -webkit-tap-highlight-color: transparent;
  }
  .pc__card:hover { border-color: var(--c-border); box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .pc__card--pop { border-color: var(--c-orange); box-shadow: 0 0 0 1px rgb(247 123 70 / 0.15), var(--shadow-md); }
  .pc__card--pop:hover { border-color: var(--c-orange); box-shadow: 0 0 0 1px rgb(247 123 70 / 0.2), var(--shadow-lg); }

  .pc__badge {
    position: absolute;
    top: var(--s-3);
    right: var(--s-3);
    z-index: 2;
    padding: 0.3rem 0.7rem;
    border-radius: var(--r-full);
    background: var(--c-orange);
    color: #fff;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .pc__img-wrap { position: relative; aspect-ratio: 16 / 10; overflow: hidden; }
  .pc__img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s var(--ease); }
  .pc__card:hover .pc__img { transform: scale(1.04); }

  .pc__body {
    padding: var(--s-5) var(--s-5) var(--s-6);
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .pc__title { font-size: 1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 2px; }
  .pc__subtitle { font-size: 0.72rem; color: var(--c-text-muted); margin-bottom: var(--s-4); }
  .pc__amount { display: flex; align-items: baseline; gap: 0.3rem; margin-bottom: var(--s-4); }
  .pc__from { font-size: 0.6rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--c-text-muted); }
  .pc__num { font-size: 1.8rem; font-weight: 800; letter-spacing: -0.03em; line-height: 1; color: var(--c-text); }
  .pc__cur { font-size: 0.6em; font-weight: 700; opacity: 0.5; }
  .pc__unit { font-size: 0.72rem; color: var(--c-text-muted); font-weight: 500; }

  .pc__features { display: flex; flex-direction: column; gap: var(--s-2); margin-bottom: var(--s-5); flex: 1; }
  .pc__features li { display: flex; align-items: center; gap: var(--s-2); font-size: 0.78rem; color: var(--c-text-secondary); }
  .pc__features svg { color: var(--c-orange); flex-shrink: 0; }

  .pc__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-orange);
    transition: gap var(--t-fast);
  }
  .pc__card:hover .pc__cta { gap: var(--s-3); }

  .pc__footer { text-align: center; margin-top: var(--s-10); }
  .pc__note { font-size: 0.85rem; color: var(--c-text-muted); }
  .pc__note a { color: var(--c-orange); font-weight: 600; }

  @media (min-width: 600px) { .pc__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .pc__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1100px) {
    .pc__grid { grid-template-columns: repeat(5, 1fr); }
    .pc__img-wrap { aspect-ratio: 4 / 3; }
  }
</style>
