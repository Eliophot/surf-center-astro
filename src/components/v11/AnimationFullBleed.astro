---
import { Image } from 'astro:assets';
import imgBg from '../../assets/images/894ec088a4e63c24885d09144825a95cf0883dab.png';
---

<section class="afb" aria-labelledby="afb-title">
  <div class="afb__bg" aria-hidden="true">
    <Image
      class="afb__img"
      src={imgBg}
      alt=""
      widths={[960, 1440, 1920]}
      sizes="100vw"
      loading="lazy"
      decoding="async"
      format="webp"
      quality={75}
    />
    <div class="afb__grad"></div>
  </div>

  <div class="container afb__inner">
    <div class="afb__panel reveal">
      <h2 id="afb-title" class="afb__eyebrow home-h2">Animations</h2>
      <h3 class="home-h3 afb__title">DES <br/>MOMENTS À <br/>PARTAGER</h3>
      <p class="afb__text">
        Yoga au lever du soleil, cours de paddle,
initiations au windsurf — chaque journée
au Surf Center est une invitation à
bouger, respirer, s'amuser. <br/><br/>Lorem ipsum dolor sit amet consectetur. Nibh phasellus scelerisque diam at dolor convallis purus tortor metus.
      </p>
      <a href="/animations" class="btn btn--primary afb__cta">
        <span class="btn-flip__inner">
          <span class="btn-flip__front">En savoir plus</span>
          <span class="btn-flip__back">En savoir plus</span>
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  .afb {
    position: relative;
    min-height: 720px;
    height: 960px;
    background: #0a0a0a;
    overflow: hidden;
  }

  .afb__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .afb__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .afb__grad {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(1000px 700px at 80% 40%, rgb(0 0 0 / 0.15), transparent 70%),
      linear-gradient(90deg, rgb(0 0 0 / 0.25), rgb(0 0 0 / 0.65));
  }

  .afb__inner {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding-block: var(--s-12);
  }

  .afb__panel {
    width: min(440px, 100%);
    background: #ffffff;
    border-radius: 14px;
    padding: 3rem 2.5rem;
    color: #1a1a1a;
    box-shadow: 0 30px 80px rgb(0 0 0 / 0.18);
  }

  .afb__eyebrow {
    display: inline-block;
    margin-bottom: var(--s-5);
    text-align: left;
  }

  .afb__title {
    text-align: left;
    margin-bottom: var(--s-6);
  }

  .afb__text {
    font-size: 0.9rem;
    line-height: 1.75;
    color: #4a4a4a;
    margin: 0 0 var(--s-8);
  }

  @media (max-width: 700px) {
    .afb {
      height: auto;
      min-height: 720px;
    }
    .afb__inner {
      justify-content: center;
    }
    .afb__panel {
      padding: 2.25rem 1.6rem;
    }
  }
</style>

